---
// Plays a pre-generated narration MP3 (see scripts/generate-audio-narration.mjs)
// through a real <audio> element. Native playback means accurate duration,
// sample-accurate scrubbing, and consistent voice quality for every visitor —
// unlike the browser-speech-synthesis approach this replaced.
interface Props {
	src: string;
}

const { src } = Astro.props;
const id = `audio-narr-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="audio-narration" id={id}>
	<audio id={`${id}-audio`} src={src} preload="metadata"></audio>
	<button type="button" class="narr-play" id={`${id}-play`} aria-label="Play narration">
		<svg class="icon-play" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
			<path d="M8 5v14l11-7z" />
		</svg>
		<svg class="icon-pause is-hidden" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
			<rect x="6" y="5" width="4" height="14" />
			<rect x="14" y="5" width="4" height="14" />
		</svg>
	</button>
	<div class="narr-body">
		<p class="narr-label">Listen to this article</p>
		<div
			class="narr-bar-track"
			id={`${id}-track`}
			role="slider"
			tabindex="0"
			aria-label="Seek narration"
			aria-valuemin="0"
			aria-valuenow="0"
		>
			<div class="narr-bar-fill" id={`${id}-fill`}></div>
			<div class="narr-bar-thumb" id={`${id}-thumb`}></div>
		</div>
	</div>
	<span class="narr-time" id={`${id}-time`}>0:00 / --:--</span>
</div>

<style>
	.audio-narration {
		display: flex;
		align-items: center;
		gap: var(--space-sm);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: var(--color-bg-panel);
		padding: var(--space-sm) var(--space-md);
		margin: 0 0 var(--space-lg);
	}

	.narr-play {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: var(--radius-full);
		cursor: pointer;
		flex-shrink: 0;
		padding: 0;
		width: 2.5rem;
		height: 2.5rem;
		border: none;
		background: var(--color-text-heading);
		color: var(--color-bg);
	}

	.narr-body {
		flex: 1;
		min-width: 0;
	}

	.narr-label {
		font-size: var(--text-small);
		color: var(--color-text-secondary);
		margin: 0 0 0.375rem;
	}

	.narr-bar-track {
		position: relative;
		display: flex;
		align-items: center;
		height: 1rem;
		cursor: pointer;
		touch-action: none;
	}

	.narr-bar-track::before {
		content: '';
		position: absolute;
		left: 0;
		right: 0;
		height: 4px;
		border-radius: var(--radius-full);
		background: var(--color-border);
	}

	.narr-bar-fill {
		position: absolute;
		left: 0;
		height: 4px;
		width: 0%;
		border-radius: var(--radius-full);
		background: var(--color-text-heading);
	}

	.narr-bar-thumb {
		position: absolute;
		left: 0%;
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background: var(--color-text-heading);
		transform: translateX(-50%);
		box-shadow: 0 0 0 3px var(--color-bg-panel);
	}

	.narr-time {
		font-size: var(--text-xs);
		color: var(--color-text-muted);
		white-space: nowrap;
		flex-shrink: 0;
	}

	/* SVG elements don't get the UA [hidden] { display: none } rule
	   HTML elements get, so toggle visibility with a class instead. */
	.is-hidden {
		display: none;
	}
</style>

<script is:inline define:vars={{ id }}>
	function initAudioNarration() {
		var root = document.getElementById(id);
		if (!root) return;

		var audio = document.getElementById(id + '-audio');
		var playBtn = document.getElementById(id + '-play');
		var track = document.getElementById(id + '-track');
		var fillEl = document.getElementById(id + '-fill');
		var thumbEl = document.getElementById(id + '-thumb');
		var timeEl = document.getElementById(id + '-time');
		var iconPlay = playBtn.querySelector('.icon-play');
		var iconPause = playBtn.querySelector('.icon-pause');

		var scrubbing = false;
		var duration = 0;

		function formatTime(sec) {
			sec = Math.max(0, Math.round(sec));
			var m = Math.floor(sec / 60);
			var s = sec % 60;
			return m + ':' + (s < 10 ? '0' : '') + s;
		}

		function updateDisplay(currentTime) {
			var pct = duration > 0 ? Math.min((currentTime / duration) * 100, 100) : 0;
			fillEl.style.width = pct + '%';
			thumbEl.style.left = pct + '%';
			timeEl.textContent = formatTime(currentTime) + ' / ' + (duration ? formatTime(duration) : '--:--');
			track.setAttribute('aria-valuemax', String(Math.round(duration)));
			track.setAttribute('aria-valuenow', String(Math.round(currentTime)));
			track.setAttribute('aria-valuetext', formatTime(currentTime) + ' of ' + formatTime(duration));
		}

		function setPlayingUI(playing) {
			iconPlay.classList.toggle('is-hidden', playing);
			iconPause.classList.toggle('is-hidden', !playing);
			playBtn.setAttribute('aria-label', playing ? 'Pause narration' : 'Play narration');
		}

		audio.addEventListener('loadedmetadata', function () {
			duration = audio.duration;
			updateDisplay(audio.currentTime);
		});

		audio.addEventListener('timeupdate', function () {
			if (!scrubbing) updateDisplay(audio.currentTime);
		});

		audio.addEventListener('play', function () { setPlayingUI(true); });
		audio.addEventListener('pause', function () { setPlayingUI(false); });
		audio.addEventListener('ended', function () { setPlayingUI(false); });

		// The browser starts loading audio metadata as soon as it parses the
		// <audio> tag, independent of script timing — on a fast (local/cached)
		// load, 'loadedmetadata' can fire before this listener attaches.
		if (audio.readyState >= 1) {
			duration = audio.duration;
			updateDisplay(audio.currentTime);
		}

		playBtn.addEventListener('click', function () {
			if (audio.paused) {
				audio.play();
			} else {
				audio.pause();
			}
		});

		function fractionFromEvent(e) {
			var rect = track.getBoundingClientRect();
			var x = (e.clientX - rect.left) / rect.width;
			return Math.min(Math.max(x, 0), 1);
		}

		track.addEventListener('pointerdown', function (e) {
			scrubbing = true;
			track.setPointerCapture(e.pointerId);
			updateDisplay(fractionFromEvent(e) * duration);
		});

		track.addEventListener('pointermove', function (e) {
			if (!scrubbing) return;
			updateDisplay(fractionFromEvent(e) * duration);
		});

		track.addEventListener('pointerup', function (e) {
			if (!scrubbing) return;
			scrubbing = false;
			audio.currentTime = fractionFromEvent(e) * duration;
		});

		track.addEventListener('keydown', function (e) {
			var step = 5;
			if (e.key === 'ArrowRight' || e.key === 'ArrowUp') {
				audio.currentTime = Math.min(audio.currentTime + step, duration);
			} else if (e.key === 'ArrowLeft' || e.key === 'ArrowDown') {
				audio.currentTime = Math.max(audio.currentTime - step, 0);
			} else if (e.key === 'Home') {
				audio.currentTime = 0;
			} else if (e.key === 'End') {
				audio.currentTime = duration;
			} else {
				return;
			}
			e.preventDefault();
		});
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initAudioNarration);
	} else {
		initAudioNarration();
	}
</script>
