---
// Free, browser-only narration: reads the surrounding article's prose aloud
// using the Web Speech API (SpeechSynthesis). No audio files, no API cost —
// but voice quality/availability depends on the visitor's browser and OS.
const id = `audio-narr-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="audio-narration" id={id}>
	<button type="button" class="narr-play" id={`${id}-play`} aria-label="Play narration">
		<svg class="icon-play" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
			<path d="M8 5v14l11-7z" />
		</svg>
		<svg class="icon-pause is-hidden" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
			<rect x="6" y="5" width="4" height="14" />
			<rect x="14" y="5" width="4" height="14" />
		</svg>
	</button>
	<div class="narr-body">
		<p class="narr-label">Listen to this article</p>
		<div
			class="narr-bar-track"
			id={`${id}-track`}
			role="slider"
			tabindex="0"
			aria-label="Seek narration"
			aria-valuemin="0"
			aria-valuenow="0"
		>
			<div class="narr-bar-fill" id={`${id}-fill`}></div>
			<div class="narr-bar-thumb" id={`${id}-thumb`}></div>
		</div>
	</div>
	<span class="narr-time" id={`${id}-time`}>0:00 / --:--</span>
</div>

<style>
	.audio-narration {
		display: flex;
		align-items: center;
		gap: var(--space-sm);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: var(--color-bg-panel);
		padding: var(--space-sm) var(--space-md);
		margin: 0 0 var(--space-lg);
	}

	.narr-play {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: var(--radius-full);
		cursor: pointer;
		flex-shrink: 0;
		padding: 0;
		width: 2.5rem;
		height: 2.5rem;
		border: none;
		background: var(--color-text-heading);
		color: var(--color-bg);
	}

	.narr-body {
		flex: 1;
		min-width: 0;
	}

	.narr-label {
		font-size: var(--text-small);
		color: var(--color-text-secondary);
		margin: 0 0 0.375rem;
	}

	.narr-bar-track {
		position: relative;
		display: flex;
		align-items: center;
		height: 1rem;
		cursor: pointer;
		touch-action: none;
	}

	.narr-bar-track::before {
		content: '';
		position: absolute;
		left: 0;
		right: 0;
		height: 4px;
		border-radius: var(--radius-full);
		background: var(--color-border);
	}

	.narr-bar-fill {
		position: absolute;
		left: 0;
		height: 4px;
		width: 0%;
		border-radius: var(--radius-full);
		background: var(--color-text-heading);
	}

	.narr-bar-thumb {
		position: absolute;
		left: 0%;
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background: var(--color-text-heading);
		transform: translateX(-50%);
		box-shadow: 0 0 0 3px var(--color-bg-panel);
	}

	.narr-time {
		font-size: var(--text-xs);
		color: var(--color-text-muted);
		white-space: nowrap;
		flex-shrink: 0;
	}

	/* SVG elements don't get the UA [hidden] { display: none } rule
	   HTML elements get, so toggle visibility with a class instead. */
	.is-hidden {
		display: none;
	}
</style>

<script is:inline define:vars={{ id }}>
	function initAudioNarration() {
		var root = document.getElementById(id);
		if (!root) return;

		if (!('speechSynthesis' in window) || typeof SpeechSynthesisUtterance === 'undefined') {
			root.remove();
			return;
		}

		var playBtn = document.getElementById(id + '-play');
		var track = document.getElementById(id + '-track');
		var fillEl = document.getElementById(id + '-fill');
		var thumbEl = document.getElementById(id + '-thumb');
		var timeEl = document.getElementById(id + '-time');
		var iconPlay = playBtn.querySelector('.icon-play');
		var iconPause = playBtn.querySelector('.icon-pause');

		var prose = root.closest('.prose') || root.parentElement;
		var SKIP_SELECTOR = '.audio-narration, .calc, .poll, .article-promo, .product-cards';

		var chunks = Array.prototype.slice
			.call(prose.querySelectorAll('h2, h3, p, li, blockquote'))
			.filter(function (el) { return !el.closest(SKIP_SELECTOR); })
			.map(function (el) { return el.textContent.trim(); })
			.filter(function (t) { return t.length > 0; });

		if (chunks.length === 0) {
			root.remove();
			return;
		}

		var WORDS_PER_SECOND = 2.5;
		var chunkStartTimes = [];
		var acc = 0;
		chunks.forEach(function (text) {
			chunkStartTimes.push(acc);
			var wc = text.split(/\s+/).filter(Boolean).length;
			acc += wc / WORDS_PER_SECOND;
		});
		var estimatedTotal = Math.max(Math.round(acc), 1);

		var index = 0;
		var elapsed = 0;
		var isPlaying = false;
		var started = false;
		var pendingSeek = false;
		var scrubbing = false;
		var timerId = null;

		function formatTime(sec) {
			sec = Math.max(0, Math.round(sec));
			var m = Math.floor(sec / 60);
			var s = sec % 60;
			return m + ':' + (s < 10 ? '0' : '') + s;
		}

		function updateTime() {
			timeEl.textContent = formatTime(elapsed) + ' / ' + formatTime(estimatedTotal);
			var pct = Math.min((elapsed / estimatedTotal) * 100, 100);
			fillEl.style.width = pct + '%';
			thumbEl.style.left = pct + '%';
			track.setAttribute('aria-valuemax', String(estimatedTotal));
			track.setAttribute('aria-valuenow', String(Math.round(elapsed)));
			track.setAttribute('aria-valuetext', formatTime(elapsed) + ' of ' + formatTime(estimatedTotal));
		}
		updateTime();

		function startTimer() {
			stopTimer();
			timerId = window.setInterval(function () {
				elapsed += 0.25;
				updateTime();
			}, 250);
		}

		function stopTimer() {
			if (timerId) {
				clearInterval(timerId);
				timerId = null;
			}
		}

		function setPlayingUI(playing) {
			isPlaying = playing;
			iconPlay.classList.toggle('is-hidden', playing);
			iconPause.classList.toggle('is-hidden', !playing);
			playBtn.setAttribute('aria-label', playing ? 'Pause narration' : 'Play narration');
		}

		function findChunkIndexForTime(t) {
			for (var i = chunkStartTimes.length - 1; i >= 0; i--) {
				if (t >= chunkStartTimes[i]) return i;
			}
			return 0;
		}

		function speakFrom(startIndex) {
			window.speechSynthesis.cancel();
			index = startIndex;
			speakChunk();
		}

		function speakChunk() {
			if (index >= chunks.length) {
				finish();
				return;
			}
			var utter = new SpeechSynthesisUtterance(chunks[index]);
			utter.rate = 1;
			utter.onend = function () {
				index += 1;
				if (index < chunks.length) {
					speakChunk();
				} else {
					finish();
				}
			};
			utter.onerror = function () {
				finish();
			};
			window.speechSynthesis.speak(utter);
		}

		function finish() {
			stopTimer();
			setPlayingUI(false);
			started = false;
			pendingSeek = false;
			index = 0;
			elapsed = estimatedTotal;
			updateTime();
		}

		function play() {
			if (!started || pendingSeek) {
				started = true;
				pendingSeek = false;
				speakFrom(index);
			} else {
				window.speechSynthesis.resume();
			}
			setPlayingUI(true);
			startTimer();
		}

		function pause() {
			window.speechSynthesis.pause();
			setPlayingUI(false);
			stopTimer();
		}

		function seekToFraction(fraction) {
			fraction = Math.min(Math.max(fraction, 0), 1);
			var targetTime = fraction * estimatedTotal;
			var wasPlaying = isPlaying;

			window.speechSynthesis.cancel();
			stopTimer();
			index = findChunkIndexForTime(targetTime);
			elapsed = targetTime;
			started = true;
			pendingSeek = true;
			updateTime();

			if (wasPlaying) {
				play();
			} else {
				setPlayingUI(false);
			}
		}

		function fractionFromEvent(e) {
			var rect = track.getBoundingClientRect();
			var x = (e.clientX - rect.left) / rect.width;
			return Math.min(Math.max(x, 0), 1);
		}

		playBtn.addEventListener('click', function () {
			if (isPlaying) {
				pause();
			} else {
				play();
			}
		});

		track.addEventListener('pointerdown', function (e) {
			scrubbing = true;
			track.setPointerCapture(e.pointerId);
			elapsed = fractionFromEvent(e) * estimatedTotal;
			updateTime();
		});

		track.addEventListener('pointermove', function (e) {
			if (!scrubbing) return;
			elapsed = fractionFromEvent(e) * estimatedTotal;
			updateTime();
		});

		track.addEventListener('pointerup', function (e) {
			if (!scrubbing) return;
			scrubbing = false;
			seekToFraction(fractionFromEvent(e));
		});

		track.addEventListener('keydown', function (e) {
			var step = 5;
			if (e.key === 'ArrowRight' || e.key === 'ArrowUp') {
				seekToFraction((elapsed + step) / estimatedTotal);
			} else if (e.key === 'ArrowLeft' || e.key === 'ArrowDown') {
				seekToFraction((elapsed - step) / estimatedTotal);
			} else if (e.key === 'Home') {
				seekToFraction(0);
			} else if (e.key === 'End') {
				seekToFraction(1);
			} else {
				return;
			}
			e.preventDefault();
		});

		window.addEventListener('pagehide', function () {
			window.speechSynthesis.cancel();
		});
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initAudioNarration);
	} else {
		initAudioNarration();
	}
</script>
