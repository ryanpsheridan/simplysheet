---
interface Props {
  mode?: 'full' | 'assessment' | 'calculator';
}
const { mode = 'full' } = Astro.props;
const showAssessment = mode !== 'calculator';
const showCalculator = mode !== 'assessment';
const id = `sfc-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="sfc" id={id} data-mode={mode}>

  <!-- Phase 1: Assessment -->
  {showAssessment && (
    <div class="sfc-assess" id={`${id}-assess`}>
      <div class="sfc-progress">
        <span class="sfc-progress-text" id={`${id}-ptext`}>Question 1 of 5</span>
        <div class="sfc-progress-bar">
          <div class="sfc-progress-fill" id={`${id}-pfill`} style="width:20%"></div>
        </div>
      </div>
      <h2 class="sfc-q-text" id={`${id}-qtext`}></h2>
      <p class="sfc-q-hint" id={`${id}-qhint`}></p>
      <div class="sfc-opts" id={`${id}-opts`}></div>
    </div>
  )}

  <!-- Phase 2: Recommendation + Calculator -->
  <div class="sfc-phase2" id={`${id}-phase2`} hidden={showAssessment}>

    {showAssessment && (
      <>
        <div class="sfc-rec" id={`${id}-rec`}>
          <div class="sfc-rec-icon" id={`${id}-rec-icon`}></div>
          <p class="sfc-rec-eyebrow">Assessment result</p>
          <h2 class="sfc-rec-title" id={`${id}-rec-title`}></h2>
          <p class="sfc-rec-body" id={`${id}-rec-body`}></p>
          <p class="sfc-rec-links" id={`${id}-rec-links`}></p>
        </div>
        <div class="sfc-divider"></div>
      </>
    )}

    {showCalculator && (
      <>
        <h2 class="sfc-calc-heading">Calculate your monthly savings</h2>

        <div class="sfc-input-grid">
          <div class="sfc-field">
            <label class="sfc-label" for={`${id}-amount`}>Target amount</label>
            <div class="sfc-money-field">
              <span class="sfc-prefix">$</span>
              <input type="text" id={`${id}-amount`} class="sfc-money-input" inputmode="decimal" placeholder="0" autocomplete="off" />
            </div>
          </div>
          <div class="sfc-field">
            <label class="sfc-label" for={`${id}-date`}>Target month</label>
            <input type="month" id={`${id}-date`} class="sfc-month-input" required />
          </div>
        </div>

        <div class="sfc-results" id={`${id}-results`}>
          <div class="sfc-stats">
            <div class="sfc-stat">
              <span class="sfc-stat-label sfc-stat-label--primary">Save each month</span>
              <span class="sfc-stat-value sfc-stat-value--primary" id={`${id}-monthly`}>—</span>
            </div>
            <div class="sfc-stat">
              <span class="sfc-stat-label">Months remaining</span>
              <span class="sfc-stat-value" id={`${id}-mcount`}>—</span>
            </div>
            <div class="sfc-stat">
              <span class="sfc-stat-label">Weekly equivalent</span>
              <span class="sfc-stat-value" id={`${id}-weekly`}>—</span>
            </div>
            <div class="sfc-stat">
              <span class="sfc-stat-label">Every two weeks</span>
              <span class="sfc-stat-value" id={`${id}-biweekly`}>—</span>
            </div>
          </div>

          <p class="sfc-tip" id={`${id}-tip`}></p>
        </div>

        <p class="sfc-hint" id={`${id}-hint`}>Updates automatically as you fill in both fields above.</p>
        <p class="sfc-error" id={`${id}-error`} hidden>Enter a target amount and a future target month to see your savings plan.</p>
      </>
    )}

    {mode === 'assessment' && (
      <a href="/tools/sinking-fund-calculator/" class="btn btn-primary sfc-cta" id={`${id}-calc-cta`}>
        Calculate your monthly savings <span class="arrow">&rarr;</span>
      </a>
    )}

    {showAssessment && (
      <button class="sfc-retake" id={`${id}-retake`}>&larr; Start over</button>
    )}
  </div>
</div>
<div class="sfc-cta-divider"></div>
<a href="/spreadsheets/savings-goals-tracker/" class="sfc-product-link">
  Track your savings progress <span class="arrow">&rarr;</span>
</a>

<style>
  /* ——— Container ——— */
  /* No card, border, or fill — the tool sits directly in the page column.
     A hairline rule + generous top padding opens the section instead. */

  .sfc {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-lg);
    margin: var(--space-lg) 0;
  }

  /* ——— Progress ——— */

  .sfc-progress {
    margin-bottom: var(--space-md);
  }
  .sfc-progress-text {
    display: block;
    font-size: var(--text-small);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-xs);
  }
  .sfc-progress-bar {
    height: 4px;
    background: var(--color-bg-panel);
    border-radius: 2px;
    overflow: hidden;
  }
  .sfc-progress-fill {
    height: 100%;
    background: var(--color-text-heading);
    border-radius: 2px;
    transition: width 0.3s ease;
  }

  /* ——— Question ——— */

  .sfc-q-text {
    font-size: var(--text-h2);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    margin-bottom: var(--space-xs);
  }
  .sfc-q-hint {
    font-size: var(--text-small);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-md);
    min-height: 1em;
  }
  .sfc-opts {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  /* Category pill grid (Q1) */
  .sfc-opts.sfc-opts--grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xs);
  }

  /* Option buttons */
  :global(.sfc-opt) {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: var(--weight-normal);
    color: var(--color-text-secondary);
    background: var(--color-bg-surface);
    border: 1.5px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 1rem 1.25rem;
    cursor: pointer;
    text-align: left;
    transition: color 0.15s, border-color 0.15s, background 0.15s, transform 0.1s ease;
    line-height: var(--leading-snug);
    width: 100%;
    display: block;
    box-sizing: border-box;
  }
  :global(.sfc-opts--grid .sfc-opt) {
    padding: 0.75rem 0.875rem;
    font-size: var(--text-small);
    text-align: center;
  }
  @media (hover: hover) {
    :global(.sfc-opt:hover) {
      color: var(--color-text);
      border-color: var(--color-text-muted);
      background: var(--color-bg-emphasis);
    }
  }
  :global(.sfc-opt:active),
  :global(.sfc-opt.selected) {
    background: var(--color-bg-inverse);
    color: var(--color-bg);
    border-color: var(--color-bg-inverse);
    transform: scale(0.98);
  }
  :global(.sfc-opt:disabled) {
    cursor: default;
  }

  /* ——— Recommendation ——— */

  .sfc-rec {
    margin-bottom: var(--space-md);
  }
  .sfc-rec-icon {
    width: 3rem;
    height: 3rem;
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-sm);
    font-size: 1.5rem;
  }
  .sfc-rec-eyebrow {
    font-size: var(--text-small);
    font-weight: var(--weight-medium);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-2xs);
  }
  .sfc-rec-title {
    font-size: var(--text-h2);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    margin-bottom: var(--space-xs);
  }
  .sfc-rec-body {
    font-size: var(--text-body);
    line-height: var(--leading-normal);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-xs);
    max-width: 36rem;
  }
  .sfc-rec-links {
    font-size: var(--text-body);
    line-height: var(--leading-normal);
    color: var(--color-text-secondary);
    max-width: 36rem;
    margin: 0;
  }
  :global(.sfc-rec-links a) {
    font-weight: var(--weight-normal);
  }

  /* ——— Divider ——— */

  .sfc-divider {
    height: 1px;
    background: var(--color-border);
    margin: var(--space-md) 0;
  }

  /* ——— Calculator ——— */

  .sfc-calc-heading {
    font-size: var(--text-h3);
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }
  .sfc-input-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }
  .sfc-field {
    min-width: 0;
  }
  .sfc-label {
    display: block;
    font-size: var(--text-small);
    font-weight: var(--weight-normal);
    color: var(--color-text);
    margin-bottom: var(--space-xs);
  }
  .sfc-money-field {
    display: flex;
    align-items: center;
    height: 2.75rem;
    box-sizing: border-box;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: var(--color-bg-surface);
    transition: border-color 0.15s;
  }
  .sfc-money-field:focus-within {
    border-color: var(--color-link);
  }
  .sfc-prefix {
    padding: 0.625rem 0 0.625rem 0.75rem;
    font-size: var(--text-body);
    color: var(--color-text-muted);
    user-select: none;
  }
  .sfc-money-input {
    flex: 1;
    border: none;
    outline: none;
    font-family: var(--font-sans);
    font-size: var(--text-body);
    padding: 0.625rem 0.75rem 0.625rem 0.25rem;
    color: var(--color-text);
    background: transparent;
  }
  .sfc-money-input::placeholder {
    color: var(--color-text-muted);
  }
  .sfc-month-input {
    width: 100%;
    max-width: 100%;
    min-width: 0;
    height: 2.75rem;
    /* iOS renders type=month with a native min width that ignores width:100% and
       overflows its grid cell; normalizing appearance makes it respect the box. */
    -webkit-appearance: none;
    appearance: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-family: var(--font-sans);
    font-size: var(--text-body);
    padding: 0.625rem 0.75rem;
    color: var(--color-text);
    background: var(--color-bg-surface);
    box-sizing: border-box;
    transition: border-color 0.15s;
    outline: none;
  }
  .sfc-month-input:focus {
    border-color: var(--color-link);
  }
  .sfc-month-input:invalid {
    color: var(--color-text-muted);
  }

  /* ——— Results: flush rows, with "Save each month" as the emphasized first row ——— */

  .sfc-stats {
    display: flex;
    flex-direction: column;
  }
  .sfc-stat {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-md);
    padding: var(--space-sm) 0;
    border-bottom: 1px solid var(--color-border);
  }
  .sfc-stat:first-child {
    padding-top: 0;
  }
  .sfc-stat:last-child {
    padding-bottom: 0;
    border-bottom: none;
  }
  .sfc-stat-label {
    font-size: var(--text-xs);
    font-weight: var(--weight-normal);
    color: var(--color-text-secondary);
  }
  .sfc-stat-label--primary {
    color: var(--color-text);
    font-weight: 600;
  }
  .sfc-stat-value {
    font-size: var(--text-h3);
    font-weight: var(--weight-normal);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    white-space: nowrap;
  }
  .sfc-stat-value--primary {
    font-weight: 600;
  }
  .sfc-tip {
    font-size: var(--text-small);
    line-height: var(--leading-normal);
    color: var(--color-text-secondary);
    margin: var(--space-sm) 0 0;
    padding-top: var(--space-sm);
    border-top: 1px solid var(--color-border);
  }
  .sfc-tip:empty {
    display: none;
  }
  .sfc-hint,
  .sfc-error {
    font-size: var(--text-small);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-sm);
  }

  /* ——— CTA + retake ——— */

  .sfc-cta {
    width: 100%;
    margin-bottom: var(--space-sm);
  }
  .sfc-cta[hidden] {
    display: none;
  }
  .sfc-cta-divider {
    height: 1px;
    background: var(--color-border);
    margin-top: var(--space-lg);
  }
  .sfc-product-link {
    display: block;
    width: fit-content;
    color: var(--color-accent-info);
    margin-top: var(--space-md);
    margin-bottom: var(--space-lg);
    font-size: 0.875rem;
    text-decoration: none;
  }
  .sfc-product-link:hover {
    text-decoration: underline;
  }
  .sfc-product-link .arrow {
    display: inline-block;
    transition: transform 0.15s ease;
  }
  .sfc-product-link:hover .arrow {
    transform: translateX(2px);
  }
  .sfc-product-link[hidden] {
    display: none;
  }
  .sfc-retake {
    font-family: var(--font-sans);
    font-size: var(--text-small);
    color: var(--color-text-secondary);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: color 0.15s;
  }
  .sfc-retake:hover {
    color: var(--color-text);
  }

  /* ——— Responsive ——— */

  @media (max-width: 767px) {
    .sfc {
      padding-top: var(--space-md);
    }
    .sfc-opts.sfc-opts--grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .sfc-input-grid {
      grid-template-columns: 1fr;
      gap: var(--space-sm);
    }
    .sfc-rec-title {
      font-size: var(--text-h3);
    }
    .sfc-highlight-value {
      font-size: var(--text-h2);
    }
  }
</style>

<script is:inline define:vars={{ id, mode }}>
(function () {
  var root = document.getElementById(id);
  if (!root) return;

  var showAssessment = mode !== 'calculator';
  var showCalculator = mode !== 'assessment';

  var assessEl = document.getElementById(id + '-assess');
  var phase2El = document.getElementById(id + '-phase2');
  var ptextEl = document.getElementById(id + '-ptext');
  var pfillEl = document.getElementById(id + '-pfill');
  var qtextEl = document.getElementById(id + '-qtext');
  var qhintEl = document.getElementById(id + '-qhint');
  var optsEl  = document.getElementById(id + '-opts');
  var recIconEl  = document.getElementById(id + '-rec-icon');
  var recTitleEl = document.getElementById(id + '-rec-title');
  var recBodyEl  = document.getElementById(id + '-rec-body');
  var recLinksEl = document.getElementById(id + '-rec-links');
  var calcCtaEl  = document.getElementById(id + '-calc-cta');
  var amountEl   = document.getElementById(id + '-amount');
  var dateEl     = document.getElementById(id + '-date');
  var monthlyEl  = document.getElementById(id + '-monthly');
  var mcountEl   = document.getElementById(id + '-mcount');
  var weeklyEl   = document.getElementById(id + '-weekly');
  var biweeklyEl = document.getElementById(id + '-biweekly');
  var tipEl      = document.getElementById(id + '-tip');
  var hintEl     = document.getElementById(id + '-hint');
  var errorEl    = document.getElementById(id + '-error');
  var ctaEl      = document.getElementById(id + '-cta');
  var retakeBtn  = document.getElementById(id + '-retake');

  var currentQ = 0;
  var answers = [];   // string answers per question
  var selectedCategory = '';
  var preset = null;  // { name, amount, dateStr }

  var today = new Date();
  var todayYear  = today.getFullYear();
  var todayMonth = today.getMonth(); // 0-indexed

  /* ——— Pre-fill presets ——— */

  function monthValue(y, m) { // m is 0-indexed
    return y + '-' + String(m + 1).padStart(2, '0');
  }
  function addMonths(m) {
    var d = new Date(todayYear, todayMonth + m, 1);
    return monthValue(d.getFullYear(), d.getMonth());
  }
  function nextOccurrence(targetMonth) { // targetMonth 0-indexed
    var y = todayYear;
    // If this month is past (or equal to) target, jump to next year
    if (todayMonth >= targetMonth - 1) y++;
    return monthValue(y, targetMonth);
  }

  var PRESETS = {
    'Christmas':        { amount: 600,  dateStr: nextOccurrence(11) },
    'Vacation':         { amount: 2000, dateStr: nextOccurrence(6)  },
    'Annual Insurance': { amount: 1200, dateStr: addMonths(6)       },
    'Car Maintenance':  { amount: 1500, dateStr: addMonths(12)      },
    'Home Repairs':     { amount: 1000, dateStr: addMonths(12)      },
    'Property Taxes':   { amount: 2400, dateStr: nextOccurrence(11) },
    'Gifts':            { amount: 300,  dateStr: nextOccurrence(11) },
    'School Expenses':  { amount: 500,  dateStr: nextOccurrence(7)  },
    'Pet Care':         { amount: 800,  dateStr: addMonths(12)      }
  };

  /* ——— Questions ——— */

  var CATEGORIES = [
    'Christmas', 'Vacation', 'Annual Insurance', 'Car Maintenance',
    'Home Repairs', 'Property Taxes', 'Gifts', 'School Expenses',
    'Pet Care', 'Other'
  ];

  var questions = [
    {
      text: 'What are you saving for?',
      hint: '',
      type: 'grid',
      opts: CATEGORIES.map(function (c) { return { text: c }; })
    },
    {
      text: 'Do you know roughly when you\'ll need the money?',
      hint: '',
      type: 'yn',
      opts: [
        { text: 'Yes — I have a date or timeframe in mind' },
        { text: 'No — it\'s open-ended' }
      ]
    },
    {
      text: 'Is this something you expected, rather than a surprise?',
      hint: '',
      type: 'yn',
      opts: [
        { text: 'Yes — I knew this expense was coming' },
        { text: 'No — it came up unexpectedly' }
      ]
    },
    {
      text: 'Would paying for this all at once put stress on your monthly budget?',
      hint: '',
      type: 'yn',
      opts: [
        { text: 'Yes — it would be a stretch' },
        { text: 'No — I could handle it in one month' }
      ]
    },
    {
      text: 'Does this happen occasionally rather than every month?',
      hint: 'Examples that qualify: Christmas, annual insurance, vacation, new tires.\nExamples that don\'t: rent, groceries, utilities.',
      type: 'yn',
      opts: [
        { text: 'Yes — it\'s infrequent or annual' },
        { text: 'No — it\'s a regular monthly cost' }
      ]
    }
  ];

  /* ——— Recommendations ——— */

  var RECS = {
    great: {
      icon: '✓',
      iconBg: 'var(--color-accent-positive-bg)',
      iconColor: 'var(--color-accent-positive)',
      title: 'Great candidate for a sinking fund',
      body: 'This is a predictable expense that doesn\'t happen every month and would be easier to handle by saving gradually. A sinking fund is exactly the right tool for this.',
      links: ''
    },
    maybe: {
      icon: '~',
      iconBg: 'var(--color-accent-caution-bg)',
      iconColor: 'var(--color-accent-caution-strong)',
      title: 'Could work as a sinking fund',
      body: 'This expense has some of the hallmarks of a sinking fund candidate. Depending on your situation, you might handle it through your regular monthly budget or by setting aside a dedicated amount each month.',
      links: ''
    },
    emergency: {
      icon: '!',
      iconBg: 'var(--color-accent-critical-bg)',
      iconColor: 'var(--color-accent-critical)',
      title: 'This sounds more like an emergency fund expense',
      body: 'Sinking funds work best for expenses you can anticipate. This one sounds like it came up unexpectedly — which is exactly what an emergency fund is designed for.',
      links: 'Learn more about how much to keep in an <a href="/articles/emergency-fund-sizing/">emergency fund</a>.'
    },
    monthly: {
      icon: '↻',
      iconBg: 'var(--color-accent-info-bg)',
      iconColor: 'var(--color-accent-info)',
      title: 'This sounds like a regular monthly expense',
      body: 'Sinking funds work best for occasional, non-monthly costs. If this expense happens every month, it belongs in your regular monthly budget rather than a sinking fund.',
      links: 'Need help building a budget that sticks? See <a href="/articles/why-most-budgets-fail/">why most budgets fail</a> and what tends to work instead.'
    }
  };

  /* ——— Tips ——— */

  var CATEGORY_TIPS = {
    'Christmas': 'This type of annual expense is exactly what sinking funds are designed for — a small monthly amount means December never feels like a financial sprint.',
    'Vacation': 'Starting early gives you maximum flexibility. If plans change, you can easily redirect these savings toward another goal.',
    'Annual Insurance': 'Some insurers offer a discount for paying annually. A sinking fund makes that the easy choice.',
    'Car Maintenance': 'Spreading vehicle costs across many months means a repair bill never has to blow up a monthly budget.',
    'Property Taxes': 'Treating property taxes as a monthly sinking fund contribution is one of the smoothest ways to handle a large annual bill.',
  };

  function getTip(category, months, monthly) {
    if (CATEGORY_TIPS[category]) return CATEGORY_TIPS[category];
    if (months < 3) return 'With a short timeline, saving consistently now is key. Consider whether the target date can flex if the monthly amount feels high.';
    if (monthly > 500) return 'If this monthly amount feels high, extending the target date by a few months can make it much more manageable.';
    if (months > 12) return 'Starting this early gives you real flexibility. Even if circumstances change, you\'ll have a comfortable cushion built up.';
    return 'Setting up a recurring transfer right after payday makes this feel automatic — you save before you have a chance to spend.';
  }

  /* ——— Recommendation logic ——— */

  function classify() {
    // answers[2] = Q3 (expected?) 'yes'|'no'
    // answers[4] = Q5 (occasional?) 'yes'|'no'
    // answers[1] = Q2 (timing?) 'yes'|'no'
    // answers[3] = Q4 (stresses budget?) 'yes'|'no'
    var expected   = answers[2];
    var occasional = answers[4];
    var timing     = answers[1];
    var stresses   = answers[3];

    if (expected === 'no')   return 'emergency';
    if (occasional === 'no') return 'monthly';
    if (timing === 'yes' && stresses === 'yes') return 'great';
    return 'maybe';
  }

  /* ——— Formatting ——— */

  function fmt(n, decimals) {
    return '$' + n.toLocaleString('en-US', {
      minimumFractionDigits: decimals,
      maximumFractionDigits: decimals
    });
  }

  function fmtInput(val) {
    var num = val.replace(/[^0-9.]/g, '');
    var parts = num.split('.');
    if (parts[0]) parts[0] = parseInt(parts[0], 10).toLocaleString('en-US');
    return parts.join('.');
  }

  /* ——— Render question ——— */

  function renderQuestion() {
    var q = questions[currentQ];
    var total = questions.length;
    ptextEl.textContent = 'Question ' + (currentQ + 1) + ' of ' + total;
    pfillEl.style.width = ((currentQ + 1) / total * 100) + '%';
    qtextEl.textContent = q.text;
    qhintEl.textContent = q.hint || '';
    qhintEl.style.display = q.hint ? '' : 'none';

    optsEl.innerHTML = '';
    if (q.type === 'grid') {
      optsEl.classList.add('sfc-opts--grid');
    } else {
      optsEl.classList.remove('sfc-opts--grid');
    }

    q.opts.forEach(function (opt, i) {
      var btn = document.createElement('button');
      btn.className = 'sfc-opt';
      btn.textContent = opt.text;
      btn.addEventListener('click', function () {
        btn.classList.add('selected');
        optsEl.querySelectorAll('.sfc-opt').forEach(function (b) { b.disabled = true; });

        // Handle Q1 category selection
        if (currentQ === 0) {
          selectedCategory = opt.text;
          preset = PRESETS[opt.text] || null;
        }

        // Store answer as 'yes'/'no' for Q2-Q5, or category text for Q1
        if (q.type === 'grid') {
          answers[currentQ] = opt.text;
        } else {
          answers[currentQ] = i === 0 ? 'yes' : 'no';
        }

        setTimeout(function () {
          if (currentQ < questions.length - 1) {
            currentQ++;
            renderQuestion();
          } else {
            showResult();
          }
        }, 220);
      });
      optsEl.appendChild(btn);
    });
  }

  /* ——— Show result + calculator ——— */

  function showResult() {
    var key = classify();
    var rec = RECS[key];

    recIconEl.textContent = rec.icon;
    recIconEl.style.background = rec.iconBg;
    recIconEl.style.color = rec.iconColor;
    recTitleEl.textContent = rec.title;
    recBodyEl.textContent = rec.body;
    if (rec.links) {
      recLinksEl.innerHTML = rec.links;
      recLinksEl.style.display = '';
    } else {
      recLinksEl.style.display = 'none';
    }

    // Pre-fill calculator from preset
    if (showCalculator) {
      if (preset) {
        amountEl.value = preset.amount.toLocaleString('en-US');
        dateEl.value   = preset.dateStr;
      } else {
        // Other: clear fields
        amountEl.value = '';
        dateEl.value   = '';
      }
    }

    // Assessment mode: point the CTA at the calculator, carrying the preset along
    if (calcCtaEl) {
      var params = new URLSearchParams();
      if (preset) {
        params.set('amount', String(preset.amount));
        params.set('month', preset.dateStr);
      }
      var qs = params.toString();
      calcCtaEl.href = '/tools/sinking-fund-calculator/' + (qs ? '?' + qs : '');
    }

    assessEl.hidden = true;
    phase2El.hidden = false;

    // Trigger calculation if preset filled in
    if (showCalculator && preset) calculate();
  }

  /* ——— Calculate ——— */

  // The results card stays visible at all times (with — placeholders) so it
  // reads as a live preview that fills in, rather than a form to submit.
  function resetResults() {
    if (!monthlyEl) return;
    monthlyEl.textContent  = '—';
    mcountEl.textContent   = '—';
    weeklyEl.textContent   = '—';
    biweeklyEl.textContent = '—';
    tipEl.textContent      = '';
  }

  function calculate() {
    var rawAmount = amountEl.value.replace(/[^0-9.]/g, '');
    var amount = parseFloat(rawAmount) || 0;
    var dateVal = dateEl.value; // "YYYY-MM"

    if (!amount || !dateVal) {
      resetResults();
      errorEl.hidden = true;
      if (hintEl) hintEl.hidden = false;
      if (ctaEl) ctaEl.hidden = true;
      return;
    }

    var parts = dateVal.split('-');
    var targetYear  = parseInt(parts[0], 10);
    var targetMonth = parseInt(parts[1], 10) - 1; // 0-indexed
    var months = (targetYear - todayYear) * 12 + (targetMonth - todayMonth);

    if (months <= 0) {
      resetResults();
      if (hintEl) hintEl.hidden = true;
      errorEl.hidden = false;
      errorEl.textContent = 'Target month must be in the future.';
      if (ctaEl) ctaEl.hidden = true;
      return;
    }

    if (hintEl) hintEl.hidden = true;
    errorEl.hidden = true;

    var monthly  = amount / months;
    var weekly   = monthly * 12 / 52;
    var biweekly = monthly * 12 / 26;

    monthlyEl.textContent  = fmt(monthly, 0);
    mcountEl.textContent   = months + (months === 1 ? ' month' : ' months');
    weeklyEl.textContent   = fmt(weekly, 2);
    biweeklyEl.textContent = fmt(biweekly, 2);
    tipEl.textContent      = getTip(selectedCategory, months, monthly);

    if (ctaEl) ctaEl.hidden = false;
  }

  /* ——— Input listeners ——— */

  if (showCalculator) {
    dateEl.min = addMonths(1);

    amountEl.addEventListener('input', function () {
      var pos    = amountEl.selectionStart;
      var before = amountEl.value.length;
      amountEl.value = fmtInput(amountEl.value);
      var after = amountEl.value.length;
      amountEl.setSelectionRange(pos + (after - before), pos + (after - before));
      calculate();
    });

    dateEl.addEventListener('change', calculate);
  }

  /* ——— Retake ——— */

  if (retakeBtn) {
    retakeBtn.addEventListener('click', function () {
      currentQ = 0;
      answers  = [];
      selectedCategory = '';
      preset   = null;
      resetResults();
      if (errorEl) errorEl.hidden = true;
      if (hintEl) hintEl.hidden = false;
      if (ctaEl) ctaEl.hidden = true;
      phase2El.hidden  = true;
      assessEl.hidden  = false;
      renderQuestion();
    });
  }

  /* ——— Init ——— */

  if (showAssessment) {
    renderQuestion();
  } else {
    // Calculator-only mode: prefill from query params (e.g. handed off from the assessment)
    var qp = new URLSearchParams(window.location.search);
    var qAmount = qp.get('amount');
    var qMonth  = qp.get('month');
    if (qAmount) amountEl.value = fmtInput(qAmount);
    if (qMonth)  dateEl.value = qMonth;
    calculate();
  }
})();
</script>
