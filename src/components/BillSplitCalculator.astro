---
const id = `bscalc-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="calc" id={id}>
	<div class="calc-form-grid">
		<div class="calc-input-group">
			<label class="calc-label" for={`${id}-a`}>Your monthly take-home</label>
			<div class="calc-field">
				<span class="calc-prefix">$</span>
				<input type="text" id={`${id}-a`} class="calc-input" data-role="income-a" inputmode="decimal" placeholder="0" autocomplete="off" />
			</div>
		</div>
		<div class="calc-input-group">
			<label class="calc-label" for={`${id}-b`}>Partner's monthly take-home</label>
			<div class="calc-field">
				<span class="calc-prefix">$</span>
				<input type="text" id={`${id}-b`} class="calc-input" data-role="income-b" inputmode="decimal" placeholder="0" autocomplete="off" />
			</div>
		</div>
	</div>

	<div class="calc-input-group calc-bills">
		<label class="calc-label" for={`${id}-bills`}>Total shared monthly bills</label>
		<div class="calc-field">
			<span class="calc-prefix">$</span>
			<input type="text" id={`${id}-bills`} class="calc-input" data-role="bills" inputmode="decimal" placeholder="0" autocomplete="off" />
		</div>
		<p class="calc-input-hint">Rent, utilities, groceries, and anything else you cover together. Leave out personal spending.</p>
	</div>

	<table class="calc-table">
		<colgroup>
			<col class="calc-col-person" />
			<col class="calc-col-amount" />
			<col class="calc-col-amount" />
		</colgroup>
		<thead>
			<tr>
				<th scope="col">Each person</th>
				<th scope="col">50/50</th>
				<th scope="col">By income</th>
			</tr>
		</thead>
		<tbody>
			<tr>
				<td>
					<span class="bs-name"><i class="bs-dot bs-dot-you"></i>You</span>
					<span class="bs-sub" data-role="a-sub"></span>
				</td>
				<td class="calc-table-amount" data-role="a-even">$0</td>
				<td class="calc-table-amount" data-role="a-prop">$0</td>
			</tr>
			<tr>
				<td>
					<span class="bs-name"><i class="bs-dot bs-dot-partner"></i>Partner</span>
					<span class="bs-sub" data-role="b-sub"></span>
				</td>
				<td class="calc-table-amount" data-role="b-even">$0</td>
				<td class="calc-table-amount" data-role="b-prop">$0</td>
			</tr>
		</tbody>
	</table>

	<p class="bs-note">"By income" splits the same bills in proportion to what each person earns, so both cover the same share of their own paycheck.</p>
</div>
<div class="calc-cta-divider"></div>
<a href="/spreadsheets/couples-budget-spreadsheet/" class="calc-product-link">Track it in a couples budget spreadsheet <span class="arrow">&rarr;</span></a>

<style>
	/* No card, border, or fill — the calculator sits directly in the page column.
	   A hairline rule + generous top padding is the only signal that a new,
	   interactive section is starting. */
	.calc {
		border-top: 1px solid var(--color-border);
		padding-top: var(--space-lg);
		margin: var(--space-lg) 0;
	}

	.calc-form-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-md);
	}
	.calc-bills {
		margin-top: var(--space-md);
	}

	/* ——— Inputs ——— */

	.calc-label {
		display: block;
		font-size: var(--text-small);
		font-weight: var(--weight-normal);
		color: var(--color-text);
		margin-bottom: var(--space-xs);
	}
	.calc-field {
		display: flex;
		align-items: center;
		height: 2.75rem;
		box-sizing: border-box;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		overflow: hidden;
		background: var(--color-bg-surface);
		transition: border-color 0.15s;
	}
	.calc-field:focus-within {
		border-color: var(--color-link);
	}
	.calc-prefix {
		padding: 0.625rem 0 0.625rem 0.75rem;
		font-size: var(--text-body);
		color: var(--color-text-muted);
		user-select: none;
	}
	.calc-input {
		flex: 1;
		min-width: 0;
		border: none;
		outline: none;
		font-family: var(--font-sans);
		font-size: var(--text-body);
		padding: 0.625rem 0.75rem 0.625rem 0.25rem;
		color: var(--color-text);
		background: transparent;
	}
	.calc-input::placeholder {
		color: var(--color-text-muted);
	}
	.calc-input-hint {
		font-size: 0.75rem;
		color: var(--color-text-secondary);
		margin: var(--space-xs) 0 0;
	}

	/* ——— Comparison table: flush with the page, no wrapping card ——— */

	.calc-table {
		/* Explicit display:table so the calculator keeps its fixed table layout
		   when embedded in an article: the global `.prose table` mobile rule
		   switches tables to display:block/overflow-x:auto, which would let these
		   cells shrink-wrap and stop the row dividers short of full width. This
		   scoped selector outranks `.prose table`, so the layout stays put. */
		display: table;
		width: 100%;
		table-layout: fixed;
		border-collapse: collapse;
		margin-top: var(--space-lg);
	}
	.calc-col-person {
		width: 48%;
	}
	.calc-col-amount {
		width: 26%;
	}
	.calc-table th {
		font-size: var(--text-xs);
		font-weight: var(--weight-medium);
		color: var(--color-text-secondary);
		padding: 0 var(--space-sm) var(--space-xs);
		text-align: right;
		white-space: nowrap;
	}
	.calc-table th:first-child {
		text-align: left;
		padding-left: 0;
	}
	.calc-table th:last-child {
		padding-right: 0;
	}
	.calc-table td {
		font-size: var(--text-small);
		color: var(--color-text);
		padding: var(--space-sm);
		border-top: 1px solid var(--color-border);
		vertical-align: top;
	}
	.calc-table td:first-child {
		padding-left: 0;
	}
	.calc-table-amount {
		text-align: right;
		white-space: nowrap;
		font-variant-numeric: tabular-nums;
	}
	.calc-table td:last-child {
		padding-right: 0;
	}

	.bs-name {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--color-text);
		white-space: nowrap;
	}
	.bs-sub {
		display: block;
		font-size: var(--text-xs);
		color: var(--color-text-muted);
		margin-top: 2px;
		white-space: nowrap;
	}
	.bs-dot {
		width: 8px;
		height: 8px;
		border-radius: var(--radius-full);
		flex-shrink: 0;
	}
	.bs-dot-you {
		background: var(--color-split-you);
	}
	.bs-dot-partner {
		background: var(--color-split-partner);
	}

	.bs-note {
		font-size: var(--text-xs);
		color: var(--color-text-secondary);
		line-height: var(--leading-snug);
		margin: var(--space-md) 0 0;
	}

	/* ——— Product link ——— */

	.calc-cta-divider {
		height: 1px;
		background: var(--color-border);
		margin-top: var(--space-lg);
	}
	.calc-product-link {
		display: block;
		width: fit-content;
		color: var(--color-accent-info);
		margin-top: var(--space-md);
		margin-bottom: var(--space-lg);
		font-size: 0.875rem;
		text-decoration: none;
	}
	.calc-product-link:hover {
		text-decoration: underline;
	}
	.calc-product-link .arrow {
		display: inline-block;
		transition: transform 0.15s ease;
	}
	.calc-product-link:hover .arrow {
		transform: translateX(2px);
	}

	/* ——— Responsive ——— */

	@media (max-width: 767px) {
		.calc {
			padding-top: var(--space-md);
		}
		.calc-form-grid {
			grid-template-columns: 1fr;
			gap: var(--space-sm);
		}
		.calc-table {
			margin-top: calc(var(--space-md) * 0.75);
		}
		/* Give the amount columns more room so "By income" and the dollar
		   figures never clip against the page edge on narrow phones. */
		.calc-col-person {
			width: 40%;
		}
		.calc-col-amount {
			width: 30%;
		}
	}
</style>

<script is:inline define:vars={{ id }}>
(function () {
	var root = document.getElementById(id);
	if (!root) return;

	var incomeA = root.querySelector('[data-role="income-a"]');
	var incomeB = root.querySelector('[data-role="income-b"]');
	var billsEl = root.querySelector('[data-role="bills"]');

	var aSubEl = root.querySelector('[data-role="a-sub"]');
	var bSubEl = root.querySelector('[data-role="b-sub"]');
	var aEvenEl = root.querySelector('[data-role="a-even"]');
	var bEvenEl = root.querySelector('[data-role="b-even"]');
	var aPropEl = root.querySelector('[data-role="a-prop"]');
	var bPropEl = root.querySelector('[data-role="b-prop"]');

	function formatCurrency(n) {
		return '$' + Math.round(n).toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
	}

	function formatInput(val) {
		var num = val.replace(/[^0-9.]/g, '');
		var parts = num.split('.');
		if (parts[0]) parts[0] = parseInt(parts[0], 10).toLocaleString('en-US');
		return parts.join('.');
	}

	function num(el) {
		return parseFloat(el.value.replace(/[^0-9.]/g, '')) || 0;
	}

	function calculate() {
		var a = num(incomeA);
		var b = num(incomeB);
		var bills = num(billsEl);
		var totalIncome = a + b;

		var even = bills / 2;
		aEvenEl.textContent = formatCurrency(even);
		bEvenEl.textContent = formatCurrency(even);

		if (totalIncome > 0) {
			var shareA = a / totalIncome;
			var pctA = Math.round(shareA * 100);
			var pctB = 100 - pctA;
			var propA = bills * shareA;
			var propB = bills - propA;

			aSubEl.textContent = pctA + '% of income';
			bSubEl.textContent = pctB + '% of income';
			aPropEl.textContent = formatCurrency(propA);
			bPropEl.textContent = formatCurrency(propB);
		} else {
			aSubEl.textContent = '';
			bSubEl.textContent = '';
			aPropEl.textContent = '—';
			bPropEl.textContent = '—';
		}
	}

	[incomeA, incomeB, billsEl].forEach(function (input) {
		input.addEventListener('input', function () {
			var pos = input.selectionStart;
			var before = input.value.length;
			input.value = formatInput(input.value);
			var after = input.value.length;
			input.setSelectionRange(pos + (after - before), pos + (after - before));
			calculate();
		});
	});

	calculate();
})();
</script>
