---
const id = `bscalc-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="calc" id={id}>
	<div class="bs-incomes">
		<div class="calc-input-group">
			<label class="calc-label" for={`${id}-a`}>Your monthly take-home</label>
			<div class="calc-field">
				<span class="calc-prefix">$</span>
				<input type="text" id={`${id}-a`} class="calc-input" data-role="income-a" inputmode="decimal" placeholder="0" autocomplete="off" />
			</div>
		</div>
		<div class="calc-input-group">
			<label class="calc-label" for={`${id}-b`}>Partner's monthly take-home</label>
			<div class="calc-field">
				<span class="calc-prefix">$</span>
				<input type="text" id={`${id}-b`} class="calc-input" data-role="income-b" inputmode="decimal" placeholder="0" autocomplete="off" />
			</div>
		</div>
	</div>

	<div class="calc-input-group">
		<label class="calc-label" for={`${id}-bills`}>Total shared monthly bills</label>
		<div class="calc-field">
			<span class="calc-prefix">$</span>
			<input type="text" id={`${id}-bills`} class="calc-input" data-role="bills" inputmode="decimal" placeholder="0" autocomplete="off" />
		</div>
		<p class="calc-input-hint">Rent, utilities, groceries, and anything else you cover together. Leave out personal spending.</p>
	</div>

	<div class="bs-table" role="table" aria-label="Bill split comparison">
		<div class="bs-row bs-head" role="row">
			<span role="columnheader">Each person</span>
			<span role="columnheader">50/50</span>
			<span role="columnheader">By income</span>
		</div>
		<div class="bs-row" role="row">
			<span class="bs-who" role="rowheader">
				<span class="bs-name"><i class="bs-dot bs-dot-you"></i>You</span>
				<small data-role="a-sub"></small>
			</span>
			<span class="bs-amt" role="cell" data-role="a-even">$0</span>
			<span class="bs-amt" role="cell" data-role="a-prop">$0</span>
		</div>
		<div class="bs-row" role="row">
			<span class="bs-who" role="rowheader">
				<span class="bs-name"><i class="bs-dot bs-dot-partner"></i>Partner</span>
				<small data-role="b-sub"></small>
			</span>
			<span class="bs-amt" role="cell" data-role="b-even">$0</span>
			<span class="bs-amt" role="cell" data-role="b-prop">$0</span>
		</div>
	</div>

	<p class="bs-note">"By income" splits the same bills in proportion to what each person earns, so both cover the same share of their own paycheck.</p>
</div>
<a href="/spreadsheets/couples-budget-spreadsheet/" class="calc-product-link">Track it in a couples budget spreadsheet <span class="arrow">&rarr;</span></a>

<style>
	.calc {
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		padding: var(--space-md);
		margin: var(--space-lg) 0;
		background: var(--color-bg-panel);
	}

	/* ——— Inputs ——— */

	.bs-incomes {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-sm);
	}
	.calc-input-group + .calc-input-group {
		margin-top: 0;
	}
	.bs-incomes + .calc-input-group {
		margin-top: var(--space-md);
	}

	.calc-label {
		display: block;
		font-size: var(--text-small);
		font-weight: var(--weight-normal);
		color: var(--color-text);
		margin-bottom: var(--space-xs);
	}
	.calc-field {
		display: flex;
		align-items: center;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		overflow: hidden;
		background: var(--color-bg-surface);
		transition: border-color 0.15s;
	}
	.calc-field:focus-within {
		border-color: var(--color-link);
	}
	.calc-prefix {
		padding: 0.625rem 0 0.625rem 0.75rem;
		font-size: var(--text-body);
		color: var(--color-text-muted);
		user-select: none;
	}
	.calc-input {
		flex: 1;
		min-width: 0;
		border: none;
		outline: none;
		font-family: var(--font-sans);
		font-size: var(--text-body);
		padding: 0.625rem 0.75rem 0.625rem 0.25rem;
		color: var(--color-text);
		background: transparent;
	}
	.calc-input::placeholder {
		color: var(--color-text-muted);
	}
	.calc-input-hint {
		font-size: var(--text-xs);
		color: var(--color-text-muted);
		margin: var(--space-xs) 0 0;
	}

	/* ——— Comparison table (a clean white card on the panel, styled to match
	   the article's markdown tables: quiet header, hairline row dividers) ——— */

	.bs-table {
		margin-top: var(--space-md);
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		overflow: hidden;
	}
	.bs-row {
		display: grid;
		grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr) minmax(0, 1fr);
		align-items: center;
		gap: var(--space-md);
		padding: var(--space-sm) var(--space-md);
	}
	.bs-row + .bs-row {
		border-top: 1px solid var(--color-border);
	}
	.bs-head {
		border-bottom: 1px solid var(--color-border);
	}
	.bs-head span {
		font-size: var(--text-xs);
		color: var(--color-text-muted);
		text-align: right;
		line-height: var(--leading-snug);
		white-space: nowrap;
	}
	.bs-head span:first-child {
		text-align: left;
	}
	.bs-who {
		display: flex;
		flex-direction: column;
		gap: 2px;
		min-width: 0;
	}
	.bs-name {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: var(--text-body);
		color: var(--color-text);
		white-space: nowrap;
	}
	.bs-who small {
		font-size: var(--text-xs);
		color: var(--color-text-muted);
		white-space: nowrap;
	}
	.bs-dot {
		width: 8px;
		height: 8px;
		border-radius: var(--radius-full);
		flex-shrink: 0;
	}
	.bs-dot-you {
		background: var(--color-split-you);
	}
	.bs-dot-partner {
		background: var(--color-split-partner);
	}
	.bs-amt {
		text-align: right;
		font-size: var(--text-body);
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		font-variant-numeric: tabular-nums;
	}

	.bs-note {
		font-size: var(--text-xs);
		color: var(--color-text-muted);
		line-height: var(--leading-snug);
		margin: var(--space-sm) 0 0;
	}

	/* ——— Product link ——— */

	.calc-product-link {
		display: block;
		width: fit-content;
		color: var(--color-accent-info);
		margin-top: calc(var(--space-md) - var(--space-lg));
		margin-bottom: var(--space-lg);
		font-size: 0.875rem;
		text-decoration: none;
	}
	.calc-product-link:hover {
		text-decoration: underline;
	}
	.calc-product-link .arrow {
		display: inline-block;
		transition: transform 0.15s ease;
	}
	.calc-product-link:hover .arrow {
		transform: translateX(2px);
	}

	/* ——— Responsive ——— */

	@media (max-width: 480px) {
		.bs-incomes {
			grid-template-columns: 1fr;
			gap: var(--space-sm);
		}
		.bs-incomes .calc-input-group + .calc-input-group {
			margin-top: 0;
		}
		.bs-row {
			gap: var(--space-xs);
			padding: var(--space-sm);
			grid-template-columns: minmax(0, 1.8fr) minmax(0, 1fr) minmax(0, 1fr);
		}
		.bs-amt {
			font-size: var(--text-small);
		}
	}
</style>

<script is:inline define:vars={{ id }}>
(function () {
	var root = document.getElementById(id);
	if (!root) return;

	var incomeA = root.querySelector('[data-role="income-a"]');
	var incomeB = root.querySelector('[data-role="income-b"]');
	var billsEl = root.querySelector('[data-role="bills"]');

	var aSubEl = root.querySelector('[data-role="a-sub"]');
	var bSubEl = root.querySelector('[data-role="b-sub"]');
	var aEvenEl = root.querySelector('[data-role="a-even"]');
	var bEvenEl = root.querySelector('[data-role="b-even"]');
	var aPropEl = root.querySelector('[data-role="a-prop"]');
	var bPropEl = root.querySelector('[data-role="b-prop"]');

	function formatCurrency(n) {
		return '$' + Math.round(n).toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
	}

	function formatInput(val) {
		var num = val.replace(/[^0-9.]/g, '');
		var parts = num.split('.');
		if (parts[0]) parts[0] = parseInt(parts[0], 10).toLocaleString('en-US');
		return parts.join('.');
	}

	function num(el) {
		return parseFloat(el.value.replace(/[^0-9.]/g, '')) || 0;
	}

	function calculate() {
		var a = num(incomeA);
		var b = num(incomeB);
		var bills = num(billsEl);
		var totalIncome = a + b;

		var even = bills / 2;
		aEvenEl.textContent = formatCurrency(even);
		bEvenEl.textContent = formatCurrency(even);

		if (totalIncome > 0) {
			var shareA = a / totalIncome;
			var pctA = Math.round(shareA * 100);
			var pctB = 100 - pctA;
			var propA = bills * shareA;
			var propB = bills - propA;

			aSubEl.textContent = pctA + '% of income';
			bSubEl.textContent = pctB + '% of income';
			aPropEl.textContent = formatCurrency(propA);
			bPropEl.textContent = formatCurrency(propB);
		} else {
			aSubEl.textContent = '';
			bSubEl.textContent = '';
			aPropEl.textContent = '—';
			bPropEl.textContent = '—';
		}
	}

	[incomeA, incomeB, billsEl].forEach(function (input) {
		input.addEventListener('input', function () {
			var pos = input.selectionStart;
			var before = input.value.length;
			input.value = formatInput(input.value);
			var after = input.value.length;
			input.setSelectionRange(pos + (after - before), pos + (after - before));
			calculate();
		});
	});

	calculate();
})();
</script>
