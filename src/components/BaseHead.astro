---
import '../styles/global.css';
import { SITE_TITLE } from '../consts';
import SpeedInsights from '@vercel/speed-insights/astro';

interface Props {
	title: string;
	description: string;
	image?: string;
	noindex?: boolean;
	type?: 'website' | 'article';
	pubDate?: Date;
	updatedDate?: Date;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const { title, description, image = '/images/og-default.svg', noindex, type = 'website', pubDate, updatedDate } = Astro.props;
// Social crawlers (Facebook, iMessage, Slack, etc.) don't render SVG for
// preview images, so swap in the rasterized PNG generated at build time
// by scripts/generate-og-images.mjs.
const ogImage = new URL(image.replace(/\.svg$/i, '.png'), Astro.site).toString();
---

<meta charset="utf-8" />

<SpeedInsights />

<script is:inline>
	// Owner-device opt-out. Visit any page once with ?ga=off on a device to
	// permanently stop Google Analytics collecting from that browser
	// (?ga=on re-enables). Persists in localStorage, so it survives IP
	// changes and works on cellular — unlike GA's IP-based internal traffic
	// filter. Must run before the gtag scripts below: window['ga-disable-<ID>']
	// only takes effect if set before GA initializes. Also silences GA during
	// local development.
	(function () {
		var KEY = 'ss-ga-off';
		try {
			var ga = new URLSearchParams(window.location.search).get('ga');
			if (ga === 'off') localStorage.setItem(KEY, '1');
			if (ga === 'on') localStorage.removeItem(KEY);
			var isLocal = /^(localhost|127\.0\.0\.1|0\.0\.0\.0|\[::1\])$/.test(window.location.hostname);
			if (isLocal || localStorage.getItem(KEY) === '1') {
				window['ga-disable-G-3CSDE2XWTG'] = true;
				console.info('[SimplySheet] Google Analytics is disabled on this device. Visit any page with ?ga=on to re-enable.');
			}
		} catch (e) {
			// localStorage unavailable (private mode, blocked storage) — let GA run.
		}
	})();
</script>
<script async src="https://www.googletagmanager.com/gtag/js?id=G-3CSDE2XWTG"></script>
<script is:inline>
	window.dataLayer = window.dataLayer || [];
	function gtag(){dataLayer.push(arguments);}
	gtag('js', new Date());
	gtag('config', 'G-3CSDE2XWTG');
</script>
<script is:inline>
	// Fires a GA4 event whenever a link to Etsy is clicked, without touching
	// the link's href — Etsy's own tracking params stay untouched.
	document.addEventListener('click', function (e) {
		var link = e.target.closest('a[href]');
		if (!link) return;

		var url;
		try {
			url = new URL(link.href, window.location.href);
		} catch (err) {
			return;
		}
		if (!/(^|\.)etsy\.com$/i.test(url.hostname)) return;

		gtag('event', 'etsy_outbound_click', {
			link_url: link.href,
			link_domain: url.hostname,
			link_label: link.dataset.cta || link.textContent.trim().slice(0, 100),
			page_path: window.location.pathname,
		});
	}, true);
</script>

<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" href="/favicon.ico" sizes="32x32" />
<link rel="icon" type="image/png" sizes="48x48" href="/images/logo-favicon.png" />
<link rel="icon" type="image/svg+xml" href="/images/logo-svg.svg" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />
<meta name="msvalidate.01" content="381616FE7F40C68FCB63685CE836A381" />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

<link rel="canonical" href={canonicalURL} />

<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<meta property="og:type" content={type} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
{type === 'article' && pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
{type === 'article' && updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}

<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={ogImage} />
