---
import '../styles/global.css';
import { SITE_TITLE } from '../consts';

interface Props {
	title: string;
	description: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const { title, description } = Astro.props;
---

<script async src="https://www.googletagmanager.com/gtag/js?id=G-3CSDE2XWTG"></script>
<script is:inline>
	window.dataLayer = window.dataLayer || [];
	function gtag(){dataLayer.push(arguments);}
	gtag('js', new Date());
	gtag('config', 'G-3CSDE2XWTG');

	document.addEventListener('click', function(e) {
		var link = e.target.closest('a[href*="etsy.com"]');
		if (!link) return;

		var path = location.pathname.replace(/\/+$/, '') || '/';
		var seg = path.split('/').filter(Boolean);

		var pageType = 'page';
		var pageSlug = 'homepage';

		if (seg.length === 0) {
			pageType = 'homepage';
		} else if (seg[0] === 'articles' && seg[1]) {
			pageType = 'article';
			pageSlug = seg[1];
		} else if (seg[0] === 'articles') {
			pageType = 'article';
			pageSlug = 'articles';
		} else if (seg[0] === 'tools' || seg[0] === 'calculators') {
			pageType = 'tool';
			pageSlug = seg[1] || 'tools';
		} else if (seg[0] === 'quiz') {
			pageType = 'tool';
			pageSlug = seg[1] || 'quiz';
		} else {
			pageSlug = seg[seg.length - 1];
		}

		var href = link.href;
		var m = href.match(/listing\/\d+\/([^?#]+)/);
		var product = m ? m[1] : (href.match(/listing\/(\d+)/) ? 'listing-' + href.match(/listing\/(\d+)/)[1] : 'store');

		gtag('event', 'etsy_click', {
			link_url: href,
			page_slug: pageSlug,
			page_type: pageType,
			product: product,
			transport_type: 'beacon'
		});
	});
</script>

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/images/logo-svg.svg" />
<link rel="icon" type="image/jpeg" href="/images/logo-favicon.jpg" />
<link rel="apple-touch-icon" href="/images/logo-256px.jpg" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Urbanist:wght@500;600&display=swap" rel="stylesheet" />

<link rel="canonical" href={canonicalURL} />

<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />

<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
