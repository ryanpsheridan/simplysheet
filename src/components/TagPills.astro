---
interface Props {
	tags?: string[];
	tagMap: Record<string, string>;
}

const { tags = [], tagMap } = Astro.props;
const visible = tags.slice(0, 2);
---

{visible.length > 0 && (
	<div class="tag-pills">
		{visible.map((slug) => (
			<span class="tag-pill">{tagMap[slug] ?? slug}</span>
		))}
	</div>
)}

<style>
	.tag-pills {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-bottom: var(--space-sm);
	}

	.tag-pill {
		display: inline-block;
		background: var(--color-bg-panel);
		color: var(--color-text-secondary);
		font-size: 0.8125rem;
		font-weight: var(--weight-medium);
		line-height: 1;
		padding: 0.4375rem 0.875rem;
		border-radius: var(--radius-full);
		white-space: nowrap;
	}
</style>
