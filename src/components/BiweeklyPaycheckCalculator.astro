---
interface Props {
	showFrequencyToggle?: boolean;
}

const { showFrequencyToggle = false } = Astro.props;
const id = `bwcalc-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="calc" id={id} data-freq="biweekly">
	{showFrequencyToggle && (
		<div class="calc-freq-group">
			<span class="calc-label">Pay frequency</span>
			<div class="calc-freq-toggle">
				<button class="calc-freq-btn active" data-freq="biweekly">Biweekly</button>
				<button class="calc-freq-btn" data-freq="weekly">Weekly</button>
				<button class="calc-freq-btn" data-freq="semimonthly">Semi-monthly</button>
			</div>
			<p class="calc-freq-hint">Paid monthly? Use the <a href="/tools/50-30-20-budget-calculator/">50/30/20 calculator</a> instead.</p>
		</div>
	)}

	<div class="calc-input-group">
		<label class="calc-label" for={`${id}-paycheck`}>Take-home pay per paycheck</label>
		<div class="calc-field">
			<span class="calc-prefix">$</span>
			<input
				type="text"
				id={`${id}-paycheck`}
				class="calc-input"
				inputmode="decimal"
				placeholder="0"
				autocomplete="off"
			/>
		</div>
		<p class="calc-input-hint">Use your average paycheck if your income varies.</p>
	</div>

	<div class="calc-highlight">
		<span class="calc-highlight-label">Average Monthly Income</span>
		<span class="calc-highlight-value" data-role="average">$0</span>
		<p class="calc-highlight-desc">Use this number when creating a monthly budget.</p>
	</div>

	<div class="calc-stats-row">
		<div class="calc-stat">
			<span class="calc-stat-label">Typical Month <small data-role="typical-note">(2 paychecks)</small></span>
			<span class="calc-stat-value" data-role="typical">$0</span>
		</div>
		<div class="calc-stat calc-stat-extra">
			<span class="calc-stat-label"><span data-role="extra-label">3-Paycheck Month</span> <small data-role="extra-note">(~2x a year)</small></span>
			<span class="calc-stat-value" data-role="extra">$0</span>
		</div>
	</div>

	<div class="calc-insight" data-role="insight">
		<span class="calc-insight-label">Monthly Buffer Needed</span>
		<span class="calc-insight-value" data-role="buffer">$0</span>
		<p class="calc-insight-desc">If you want your budget to stay consistent year-round, set aside this amount during months with an extra paycheck.</p>
	</div>
</div>
<a href="/spreadsheets/budget-spreadsheet/" class="calc-product-link">Track it in a budget spreadsheet <span class="arrow">&rarr;</span></a>

<style>
	.calc {
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		padding: var(--space-md);
		margin: var(--space-lg) 0;
		background: var(--color-bg-panel);
	}

	/* ——— Pay frequency toggle ——— */

	.calc-freq-group {
		margin-bottom: var(--space-md);
		padding-bottom: var(--space-md);
		border-bottom: 1px solid var(--color-border);
	}
	.calc-freq-toggle {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-xs);
	}
	.calc-freq-btn {
		font-family: var(--font-sans);
		font-size: var(--text-small);
		font-weight: var(--weight-normal);
		color: var(--color-text-secondary);
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-full);
		padding: 0.375rem 0.875rem;
		cursor: pointer;
		transition: color 0.15s, border-color 0.15s, background 0.15s;
	}
	.calc-freq-btn:hover {
		color: var(--color-text);
		border-color: var(--color-text-muted);
	}
	.calc-freq-btn.active {
		color: var(--color-bg);
		background: var(--color-bg-inverse);
		border-color: var(--color-bg-inverse);
	}
	.calc-freq-hint {
		font-size: var(--text-xs);
		color: var(--color-text-muted);
		margin: var(--space-sm) 0 0;
	}

	/* ——— Input ——— */

	.calc-label {
		display: block;
		font-size: var(--text-small);
		font-weight: var(--weight-normal);
		color: var(--color-text);
		margin-bottom: var(--space-xs);
	}
	.calc-field {
		display: flex;
		align-items: center;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		overflow: hidden;
		background: var(--color-bg-surface);
		transition: border-color 0.15s;
	}
	.calc-field:focus-within {
		border-color: var(--color-link);
	}
	.calc-prefix {
		padding: 0.625rem 0 0.625rem 0.75rem;
		font-size: var(--text-body);
		color: var(--color-text-muted);
		user-select: none;
	}
	.calc-input {
		flex: 1;
		border: none;
		outline: none;
		font-family: var(--font-sans);
		font-size: var(--text-body);
		padding: 0.625rem 0.75rem 0.625rem 0.25rem;
		color: var(--color-text);
		background: transparent;
	}
	.calc-input::placeholder {
		color: var(--color-text-muted);
	}
	.calc-input-hint {
		font-size: var(--text-xs);
		color: var(--color-text-muted);
		margin: var(--space-xs) 0 0;
	}

	/* ——— Highlight card: the hero result ——— */

	.calc-highlight {
		display: flex;
		flex-direction: column;
		margin-top: var(--space-md);
		padding: var(--space-md);
		background: var(--color-bg-surface);
		border-radius: var(--radius-md);
	}
	.calc-highlight-label {
		display: block;
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		color: var(--color-text);
		margin-bottom: var(--space-2xs);
	}
	.calc-highlight-value {
		display: block;
		font-size: var(--text-h1);
		font-weight: var(--weight-normal);
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		margin-bottom: var(--space-2xs);
	}
	.calc-highlight-desc {
		font-size: var(--text-small);
		line-height: var(--leading-snug);
		color: var(--color-text-secondary);
		margin: 0;
	}

	/* ——— Reference stats (compact supporting numbers) ——— */

	.calc-stats-row {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--space-sm);
		margin-top: var(--space-md);
	}
	.calc-stats-row.single {
		grid-template-columns: 1fr;
	}
	.calc-stat {
		display: flex;
		flex-direction: column;
		gap: var(--space-2xs);
	}
	.calc-stat-label {
		font-size: var(--text-xs);
		color: var(--color-text-muted);
		line-height: var(--leading-snug);
	}
	.calc-stat-label small {
		display: block;
		font-size: 0.95em;
	}
	.calc-stat-value {
		font-size: var(--text-h3);
		font-weight: var(--weight-normal);
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
	}

	/* ——— Insight: secondary, optional budgeting tip ——— */

	.calc-insight {
		margin-top: var(--space-md);
		padding-top: var(--space-md);
		border-top: 1px solid var(--color-border);
	}
	.calc-insight[hidden] {
		display: none;
	}
	.calc-insight-label {
		display: block;
		font-size: var(--text-xs);
		font-weight: var(--weight-normal);
		color: var(--color-text-muted);
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
		margin-bottom: var(--space-2xs);
	}
	.calc-insight-value {
		display: block;
		font-size: var(--text-h3);
		font-weight: var(--weight-normal);
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		margin-bottom: var(--space-2xs);
	}
	.calc-insight-desc {
		font-size: var(--text-xs);
		line-height: var(--leading-snug);
		color: var(--color-text-muted);
		margin: 0;
		max-width: 34rem;
	}

	/* ——— Product link ——— */

	.calc-product-link {
		display: block;
		width: fit-content;
		color: var(--color-accent-info);
		/* Collapses against the container's space-lg bottom margin to net space-md (24px) below the box */
		margin-top: calc(var(--space-md) - var(--space-lg));
		margin-bottom: var(--space-lg);
		font-size: 0.875rem;
		text-decoration: none;
	}
	.calc-product-link:hover {
		text-decoration: underline;
	}
	.calc-product-link .arrow {
		display: inline-block;
		transition: transform 0.15s ease;
	}
	.calc-product-link:hover .arrow {
		transform: translateX(2px);
	}

	/* ——— Responsive ——— */

	@media (max-width: 767px) {
		.calc-freq-group {
			margin-bottom: calc(var(--space-md) * 0.75);
			padding-bottom: calc(var(--space-md) * 0.75);
		}
		.calc-highlight {
			margin-top: calc(var(--space-md) * 0.75);
		}
		.calc-highlight-value {
			font-size: var(--text-h2);
		}
		.calc-stats-row {
			gap: calc(var(--space-sm) * 0.75);
			margin-top: calc(var(--space-md) * 0.75);
		}
		.calc-insight {
			margin-top: calc(var(--space-md) * 0.75);
			padding-top: calc(var(--space-md) * 0.75);
		}
	}
</style>

<script is:inline define:vars={{ id }}>
(function () {
	var root = document.getElementById(id);
	if (!root) return;

	var FREQUENCIES = {
		biweekly: {
			paychecksPerYear: 26,
			typicalPerMonth: 2,
			extraPerMonth: 3,
			extraTimesAYear: 2,
			hasExtra: true,
		},
		weekly: {
			paychecksPerYear: 52,
			typicalPerMonth: 4,
			extraPerMonth: 5,
			extraTimesAYear: 4,
			hasExtra: true,
		},
		semimonthly: {
			paychecksPerYear: 24,
			typicalPerMonth: 2,
			hasExtra: false,
		},
	};

	var freq = 'biweekly';

	var input = root.querySelector('.calc-input');
	var freqBtns = root.querySelectorAll('.calc-freq-btn');
	var statsRowEl = root.querySelector('.calc-stats-row');
	var extraStatEl = root.querySelector('.calc-stat-extra');
	var typicalEl = root.querySelector('[data-role="typical"]');
	var typicalNoteEl = root.querySelector('[data-role="typical-note"]');
	var extraEl = root.querySelector('[data-role="extra"]');
	var extraLabelEl = root.querySelector('[data-role="extra-label"]');
	var extraNoteEl = root.querySelector('[data-role="extra-note"]');
	var averageEl = root.querySelector('[data-role="average"]');
	var insightEl = root.querySelector('[data-role="insight"]');
	var bufferEl = root.querySelector('[data-role="buffer"]');

	function formatCurrency(n) {
		return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
	}

	function formatInput(val) {
		var num = val.replace(/[^0-9.]/g, '');
		var parts = num.split('.');
		if (parts[0]) parts[0] = parseInt(parts[0], 10).toLocaleString('en-US');
		return parts.join('.');
	}

	function calculate() {
		var config = FREQUENCIES[freq];
		var raw = input.value.replace(/[^0-9.]/g, '');
		var paycheck = parseFloat(raw) || 0;

		var typical = paycheck * config.typicalPerMonth;
		var annual = paycheck * config.paychecksPerYear;
		var average = annual / 12;
		var buffer = Math.max(0, average - typical);

		typicalNoteEl.textContent = '(' + config.typicalPerMonth + ' paychecks)';
		typicalEl.textContent = formatCurrency(typical);
		averageEl.textContent = formatCurrency(average);

		if (config.hasExtra) {
			var extra = paycheck * config.extraPerMonth;
			extraStatEl.style.display = '';
			statsRowEl.classList.remove('single');
			extraLabelEl.textContent = config.extraPerMonth + '-Paycheck Month';
			extraNoteEl.textContent = '(~' + config.extraTimesAYear + 'x a year)';
			extraEl.textContent = formatCurrency(extra);
			insightEl.hidden = false;
			bufferEl.textContent = formatCurrency(buffer);
		} else {
			extraStatEl.style.display = 'none';
			statsRowEl.classList.add('single');
			insightEl.hidden = true;
		}
	}

	input.addEventListener('input', function () {
		var pos = input.selectionStart;
		var before = input.value.length;
		input.value = formatInput(input.value);
		var after = input.value.length;
		input.setSelectionRange(pos + (after - before), pos + (after - before));
		calculate();
	});

	freqBtns.forEach(function (btn) {
		btn.addEventListener('click', function () {
			freqBtns.forEach(function (b) { b.classList.remove('active'); });
			btn.classList.add('active');
			freq = btn.dataset.freq;
			calculate();
		});
	});

	calculate();
})();
</script>
