---
interface Props {
	showFrequencyToggle?: boolean;
}

const { showFrequencyToggle = false } = Astro.props;
const id = `bwcalc-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="calc" id={id} data-freq="biweekly">
	{showFrequencyToggle && (
		<div class="calc-freq-group">
			<span class="calc-label">Pay frequency</span>
			<div class="calc-freq-toggle">
				<button class="calc-freq-btn active" data-freq="biweekly">Biweekly</button>
				<button class="calc-freq-btn" data-freq="weekly">Weekly</button>
				<button class="calc-freq-btn" data-freq="semimonthly">Semi-monthly</button>
			</div>
			<p class="calc-freq-hint">Paid monthly? Your income already matches the calendar — skip the buffer math and use the <a href="/tools/50-30-20-budget-calculator/">50/30/20 calculator</a> instead.</p>
		</div>
	)}

	<div class="calc-input-group">
		<label class="calc-label" for={`${id}-paycheck`}>Take-home pay per paycheck</label>
		<div class="calc-field">
			<span class="calc-prefix">$</span>
			<input
				type="text"
				id={`${id}-paycheck`}
				class="calc-input"
				inputmode="decimal"
				placeholder="0"
				autocomplete="off"
			/>
		</div>
		<p class="calc-input-hint">If your paycheck amount changes, use your average from the last few months instead of a single one.</p>
	</div>

	<div class="calc-stats-row">
		<div class="calc-stat">
			<span class="calc-stat-label">Typical month <small data-role="typical-note">(2 paychecks)</small></span>
			<span class="calc-stat-value" data-role="typical">$0</span>
		</div>
		<div class="calc-stat calc-stat-extra">
			<span class="calc-stat-label"><span data-role="extra-label">3-paycheck month</span> <small data-role="extra-note">(~2x a year)</small></span>
			<span class="calc-stat-value" data-role="extra">$0</span>
		</div>
		<div class="calc-stat">
			<span class="calc-stat-label">Steady average <small>(one number all year)</small></span>
			<span class="calc-stat-value" data-role="average">$0</span>
			<span class="calc-stat-math" data-role="average-math"></span>
		</div>
	</div>

	<div class="calc-highlight">
		<span class="calc-highlight-label" data-role="buffer-label">Cushion needed for a 2-paycheck month</span>
		<span class="calc-highlight-value" data-role="buffer">$0</span>
		<span class="calc-highlight-math" data-role="buffer-math"></span>

		<a href="/spreadsheets/budget-spreadsheet/" class="btn btn-primary calc-cta">
			Track it in a budget spreadsheet
			<span class="arrow">&rarr;</span>
		</a>
	</div>
</div>

<style>
	.calc {
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		padding: var(--space-md);
		margin: var(--space-lg) 0;
		background: var(--color-bg-panel);
	}

	/* ——— Pay frequency toggle ——— */

	.calc-freq-group {
		margin-bottom: var(--space-md);
		padding-bottom: var(--space-md);
		border-bottom: 1px solid var(--color-border);
	}
	.calc-freq-toggle {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-xs);
	}
	.calc-freq-btn {
		font-family: var(--font-sans);
		font-size: var(--text-small);
		font-weight: var(--weight-normal);
		color: var(--color-text-secondary);
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-full);
		padding: 0.375rem 0.875rem;
		cursor: pointer;
		transition: color 0.15s, border-color 0.15s, background 0.15s;
	}
	.calc-freq-btn:hover {
		color: var(--color-text);
		border-color: var(--color-text-muted);
	}
	.calc-freq-btn.active {
		color: var(--color-bg);
		background: var(--color-bg-inverse);
		border-color: var(--color-bg-inverse);
	}
	.calc-freq-hint {
		font-size: var(--text-xs);
		color: var(--color-text-muted);
		margin: var(--space-sm) 0 0;
	}

	/* ——— Input ——— */

	.calc-label {
		display: block;
		font-size: var(--text-small);
		font-weight: var(--weight-normal);
		color: var(--color-text);
		margin-bottom: var(--space-xs);
	}
	.calc-field {
		display: flex;
		align-items: center;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		overflow: hidden;
		background: var(--color-bg-surface);
		transition: border-color 0.15s;
	}
	.calc-field:focus-within {
		border-color: var(--color-link);
	}
	.calc-prefix {
		padding: 0.625rem 0 0.625rem 0.75rem;
		font-size: var(--text-body);
		color: var(--color-text-muted);
		user-select: none;
	}
	.calc-input {
		flex: 1;
		border: none;
		outline: none;
		font-family: var(--font-sans);
		font-size: var(--text-body);
		padding: 0.625rem 0.75rem 0.625rem 0.25rem;
		color: var(--color-text);
		background: transparent;
	}
	.calc-input::placeholder {
		color: var(--color-text-muted);
	}
	.calc-input-hint {
		font-size: var(--text-xs);
		color: var(--color-text-muted);
		margin: var(--space-xs) 0 0;
	}

	/* ——— Reference stats (de-emphasized, compact) ——— */

	.calc-stats-row {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--space-sm);
		margin-top: var(--space-md);
	}
	.calc-stats-row.two-col {
		grid-template-columns: repeat(2, 1fr);
	}
	.calc-stat {
		display: flex;
		flex-direction: column;
		gap: var(--space-2xs);
	}
	.calc-stat-label {
		font-size: var(--text-xs);
		color: var(--color-text-muted);
		line-height: var(--leading-snug);
	}
	.calc-stat-label small {
		display: block;
		font-size: 0.95em;
	}
	.calc-stat-value {
		font-size: var(--text-h3);
		font-weight: var(--weight-normal);
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
	}
	.calc-stat-math {
		font-size: var(--text-xs);
		color: var(--color-text-muted);
	}

	/* ——— Highlight card: the actionable takeaway + CTA ——— */

	.calc-highlight {
		display: flex;
		flex-direction: column;
		margin-top: var(--space-md);
		padding: var(--space-md);
		background: var(--color-bg-surface);
		border-radius: var(--radius-md);
	}
	.calc-highlight-label {
		display: block;
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		color: var(--color-text);
		margin-bottom: var(--space-2xs);
	}
	.calc-highlight-value {
		display: block;
		font-size: var(--text-h2);
		font-weight: var(--weight-normal);
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		margin-bottom: var(--space-2xs);
	}
	.calc-highlight-math {
		display: block;
		font-size: var(--text-small);
		color: var(--color-text-muted);
		min-height: 1.4em;
	}

	/* ——— CTA ——— */

	.calc-cta {
		width: 100%;
		margin-top: var(--space-sm);
	}

	/* ——— Responsive ——— */

	@media (max-width: 480px) {
		.calc-stats-row {
			grid-template-columns: 1fr;
			gap: var(--space-sm);
		}
	}
</style>

<script is:inline define:vars={{ id }}>
(function () {
	var root = document.getElementById(id);
	if (!root) return;

	var FREQUENCIES = {
		biweekly: {
			paychecksPerYear: 26,
			typicalPerMonth: 2,
			extraPerMonth: 3,
			extraTimesAYear: 2,
			hasExtra: true,
		},
		weekly: {
			paychecksPerYear: 52,
			typicalPerMonth: 4,
			extraPerMonth: 5,
			extraTimesAYear: 4,
			hasExtra: true,
		},
		semimonthly: {
			paychecksPerYear: 24,
			typicalPerMonth: 2,
			hasExtra: false,
		},
	};

	var freq = 'biweekly';

	var input = root.querySelector('.calc-input');
	var freqBtns = root.querySelectorAll('.calc-freq-btn');
	var statsRowEl = root.querySelector('.calc-stats-row');
	var extraStatEl = root.querySelector('.calc-stat-extra');
	var typicalEl = root.querySelector('[data-role="typical"]');
	var typicalNoteEl = root.querySelector('[data-role="typical-note"]');
	var extraEl = root.querySelector('[data-role="extra"]');
	var extraLabelEl = root.querySelector('[data-role="extra-label"]');
	var extraNoteEl = root.querySelector('[data-role="extra-note"]');
	var averageEl = root.querySelector('[data-role="average"]');
	var averageMathEl = root.querySelector('[data-role="average-math"]');
	var bufferLabelEl = root.querySelector('[data-role="buffer-label"]');
	var bufferEl = root.querySelector('[data-role="buffer"]');
	var bufferMathEl = root.querySelector('[data-role="buffer-math"]');

	function formatCurrency(n) {
		return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
	}

	function formatInput(val) {
		var num = val.replace(/[^0-9.]/g, '');
		var parts = num.split('.');
		if (parts[0]) parts[0] = parseInt(parts[0], 10).toLocaleString('en-US');
		return parts.join('.');
	}

	function calculate() {
		var config = FREQUENCIES[freq];
		var raw = input.value.replace(/[^0-9.]/g, '');
		var paycheck = parseFloat(raw) || 0;

		var typical = paycheck * config.typicalPerMonth;
		var annual = paycheck * config.paychecksPerYear;
		var average = annual / 12;
		var buffer = Math.max(0, average - typical);

		typicalNoteEl.textContent = '(' + config.typicalPerMonth + ' paychecks)';
		typicalEl.textContent = formatCurrency(typical);
		averageEl.textContent = formatCurrency(average);
		bufferEl.textContent = formatCurrency(buffer);

		if (config.hasExtra) {
			var extra = paycheck * config.extraPerMonth;
			extraStatEl.style.display = '';
			statsRowEl.classList.remove('two-col');
			extraLabelEl.textContent = config.extraPerMonth + '-paycheck month';
			extraNoteEl.textContent = '(~' + config.extraTimesAYear + 'x a year)';
			extraEl.textContent = formatCurrency(extra);
			bufferLabelEl.textContent = 'Cushion needed for a ' + config.typicalPerMonth + '-paycheck month';
		} else {
			extraStatEl.style.display = 'none';
			statsRowEl.classList.add('two-col');
			bufferLabelEl.textContent = 'Cushion needed';
		}

		if (paycheck > 0) {
			averageMathEl.textContent = formatCurrency(paycheck) + ' × ' + config.paychecksPerYear + ' ÷ 12';
			bufferMathEl.textContent = config.hasExtra
				? formatCurrency(average) + ' average − ' + formatCurrency(typical) + ' in a ' + config.typicalPerMonth + '-paycheck month'
				: 'Semi-monthly pay always lines up evenly with the calendar — no buffer needed. You\'re all set.';
		} else {
			averageMathEl.textContent = '';
			bufferMathEl.textContent = '';
		}
	}

	input.addEventListener('input', function () {
		var pos = input.selectionStart;
		var before = input.value.length;
		input.value = formatInput(input.value);
		var after = input.value.length;
		input.setSelectionRange(pos + (after - before), pos + (after - before));
		calculate();
	});

	freqBtns.forEach(function (btn) {
		btn.addEventListener('click', function () {
			freqBtns.forEach(function (b) { b.classList.remove('active'); });
			btn.classList.add('active');
			freq = btn.dataset.freq;
			calculate();
		});
	});

	calculate();
})();
</script>
