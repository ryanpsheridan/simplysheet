---
const id = `bwcalc-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="calc" id={id}>
	<div class="calc-input-group">
		<label class="calc-label" for={`${id}-paycheck`}>Take-home pay per paycheck</label>
		<div class="calc-field">
			<span class="calc-prefix">$</span>
			<input
				type="text"
				id={`${id}-paycheck`}
				class="calc-input"
				inputmode="decimal"
				placeholder="0"
				autocomplete="off"
			/>
		</div>
		<p class="calc-input-hint">If your paycheck amount changes, use your average from the last few months instead of a single one.</p>
	</div>

	<div class="calc-results">
		<div class="calc-result">
			<span class="calc-result-label">Typical month (2 paychecks)</span>
			<span class="calc-result-value" data-role="two">$0</span>
		</div>
		<div class="calc-result">
			<span class="calc-result-label">Three-paycheck month (about twice a year)</span>
			<span class="calc-result-value" data-role="three">$0</span>
		</div>
		<div class="calc-result">
			<span class="calc-result-label">Steady average (if you'd rather budget one number all year)</span>
			<span class="calc-result-value" data-role="average">$0</span>
			<span class="calc-result-math" data-role="average-math"></span>
		</div>
		<div class="calc-result">
			<span class="calc-result-label">Buffer to keep on hand for a 2-paycheck month</span>
			<span class="calc-result-value" data-role="buffer">$0</span>
			<span class="calc-result-math" data-role="buffer-math"></span>
		</div>
	</div>

	<a href="/templates/budget-spreadsheet/" class="btn btn-primary calc-cta">
		Track it in a budget spreadsheet
		<span class="arrow">&rarr;</span>
	</a>
</div>

<style>
	.calc {
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		padding: var(--space-md);
		margin: var(--space-lg) 0;
		background: var(--color-bg-surface);
	}

	/* ——— Input ——— */

	.calc-label {
		display: block;
		font-size: var(--text-small);
		font-weight: var(--weight-normal);
		color: var(--color-text);
		margin-bottom: var(--space-xs);
	}
	.calc-field {
		display: flex;
		align-items: center;
		border: 1px solid var(--color-divider);
		border-radius: var(--radius-sm);
		overflow: hidden;
		transition: border-color 0.15s;
	}
	.calc-field:focus-within {
		border-color: var(--color-link);
	}
	.calc-prefix {
		padding: 0.625rem 0 0.625rem 0.75rem;
		font-size: var(--text-body);
		color: var(--color-text-muted);
		user-select: none;
	}
	.calc-input {
		flex: 1;
		border: none;
		outline: none;
		font-family: var(--font-sans);
		font-size: var(--text-body);
		padding: 0.625rem 0.75rem 0.625rem 0.25rem;
		color: var(--color-text);
		background: transparent;
	}
	.calc-input::placeholder {
		color: var(--color-text-muted);
	}
	.calc-input-hint {
		font-size: var(--text-xs);
		color: var(--color-text-muted);
		margin: var(--space-xs) 0 0;
	}

	/* ——— Results ——— */

	.calc-results {
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
		margin-top: var(--space-md);
	}
	.calc-result-label {
		display: block;
		font-size: var(--text-small);
		font-weight: var(--weight-normal);
		color: var(--color-text);
		margin-bottom: var(--space-2xs);
	}
	.calc-result-value {
		display: block;
		font-size: var(--text-h2);
		font-weight: var(--weight-normal);
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		margin-bottom: var(--space-2xs);
	}
	.calc-result-math {
		display: block;
		font-size: var(--text-small);
		color: var(--color-text-muted);
		min-height: 1.4em;
	}

	/* ——— CTA ——— */

	.calc-cta {
		width: 100%;
		margin-top: var(--space-sm);
	}
</style>

<script is:inline define:vars={{ id }}>
(function () {
	var root = document.getElementById(id);
	if (!root) return;

	var input = root.querySelector('.calc-input');
	var twoEl = root.querySelector('[data-role="two"]');
	var threeEl = root.querySelector('[data-role="three"]');
	var averageEl = root.querySelector('[data-role="average"]');
	var averageMathEl = root.querySelector('[data-role="average-math"]');
	var bufferEl = root.querySelector('[data-role="buffer"]');
	var bufferMathEl = root.querySelector('[data-role="buffer-math"]');

	function formatCurrency(n) {
		return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
	}

	function formatInput(val) {
		var num = val.replace(/[^0-9.]/g, '');
		var parts = num.split('.');
		if (parts[0]) parts[0] = parseInt(parts[0], 10).toLocaleString('en-US');
		return parts.join('.');
	}

	function calculate() {
		var raw = input.value.replace(/[^0-9.]/g, '');
		var paycheck = parseFloat(raw) || 0;

		var two = paycheck * 2;
		var three = paycheck * 3;
		var annual = paycheck * 26;
		var average = annual / 12;
		var buffer = Math.max(0, average - two);

		twoEl.textContent = formatCurrency(two);
		threeEl.textContent = formatCurrency(three);
		averageEl.textContent = formatCurrency(average);
		bufferEl.textContent = formatCurrency(buffer);

		if (paycheck > 0) {
			averageMathEl.textContent = formatCurrency(paycheck) + ' × 26 ÷ 12';
			bufferMathEl.textContent = formatCurrency(average) + ' average − ' + formatCurrency(two) + ' in a 2-paycheck month';
		} else {
			averageMathEl.textContent = '';
			bufferMathEl.textContent = '';
		}
	}

	input.addEventListener('input', function () {
		var pos = input.selectionStart;
		var before = input.value.length;
		input.value = formatInput(input.value);
		var after = input.value.length;
		input.setSelectionRange(pos + (after - before), pos + (after - before));
		calculate();
	});

	calculate();
})();
</script>
