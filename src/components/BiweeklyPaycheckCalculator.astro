---
interface Props {
	showFrequencyToggle?: boolean;
}

const { showFrequencyToggle = false } = Astro.props;
const id = `bwcalc-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="calc" id={id} data-freq="biweekly">
	<div class="calc-form-grid">
		{showFrequencyToggle && (
			<div class="calc-freq-group">
				<label class="calc-label" for={`${id}-freq`}>Pay frequency</label>
				<select id={`${id}-freq`} class="calc-select" data-role="freq-select">
					<option value="biweekly">Biweekly</option>
					<option value="weekly">Weekly</option>
					<option value="semimonthly">Semi-monthly</option>
				</select>
			</div>
		)}

		<div class="calc-input-group">
			<label class="calc-label" for={`${id}-paycheck`}>Take-home pay per paycheck</label>
			<div class="calc-field">
				<span class="calc-prefix">$</span>
				<input
					type="text"
					id={`${id}-paycheck`}
					class="calc-input"
					inputmode="decimal"
					placeholder="0"
					autocomplete="off"
				/>
			</div>
			<p class="calc-input-hint">Use your average paycheck if your income varies.</p>
		</div>
	</div>

	<div class="calc-highlight">
		<span class="calc-highlight-label">Average Monthly Income</span>
		<span class="calc-highlight-value" data-role="average">$0</span>
		<p class="calc-highlight-desc">Use this number when creating a monthly budget.</p>
	</div>

	<table class="calc-table">
		<colgroup>
			<col class="calc-table-col-period" />
			<col class="calc-table-col-count" />
			<col class="calc-table-col-amount" />
		</colgroup>
		<thead>
			<tr>
				<th scope="col">Period</th>
				<th scope="col">Count</th>
				<th scope="col">Amount</th>
			</tr>
		</thead>
		<tbody>
			<tr>
				<td>Typical Month</td>
				<td data-role="typical-count">2</td>
				<td class="calc-table-amount" data-role="typical">$0</td>
			</tr>
			<tr data-role="extra-row">
				<td data-role="extra-label">3-Paycheck Month</td>
				<td data-role="extra-count">3</td>
				<td class="calc-table-amount" data-role="extra">$0</td>
			</tr>
			<tr data-role="buffer-row">
				<td>
					Monthly Buffer Needed
					<span class="calc-tooltip-wrap">
						<button
							type="button"
							class="calc-tooltip-trigger"
							data-role="buffer-tooltip-trigger"
							aria-expanded="false"
							aria-controls={`${id}-buffer-tooltip`}
							aria-label="Why you might need this"
						>?</button>
						<span class="calc-tooltip-bubble" id={`${id}-buffer-tooltip`} data-role="buffer-tooltip-bubble" role="note" hidden>If you want your budget to stay consistent year-round, set aside this amount during months with an extra paycheck.</span>
					</span>
				</td>
				<td>—</td>
				<td class="calc-table-amount" data-role="buffer">$0</td>
			</tr>
		</tbody>
	</table>
</div>
<a href="/spreadsheets/budget-spreadsheet/" class="calc-product-link">Track it in a budget spreadsheet <span class="arrow">&rarr;</span></a>

<style>
	/* No card, border, or fill — the calculator sits directly in the page column.
	   A hairline rule + generous top padding is the only signal that a new,
	   interactive section is starting. */
	.calc {
		border-top: 1px solid var(--color-border);
		padding-top: var(--space-lg);
		margin: var(--space-lg) 0;
	}

	.calc-form-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-md);
	}
	.calc-form-grid > *:only-child {
		grid-column: 1 / -1;
	}

	/* ——— Pay frequency ——— */

	.calc-select {
		width: 100%;
		height: 2.75rem;
		box-sizing: border-box;
		font-family: var(--font-sans);
		font-size: var(--text-body);
		padding: 0 0.75rem;
		color: var(--color-text);
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		outline: none;
		cursor: pointer;
		transition: border-color 0.15s;
	}
	.calc-select:focus {
		border-color: var(--color-link);
	}

	/* ——— Input ——— */

	.calc-label {
		display: block;
		font-size: var(--text-small);
		font-weight: var(--weight-normal);
		color: var(--color-text);
		margin-bottom: var(--space-xs);
	}
	.calc-field {
		display: flex;
		align-items: center;
		height: 2.75rem;
		box-sizing: border-box;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		overflow: hidden;
		background: var(--color-bg-surface);
		transition: border-color 0.15s;
	}
	.calc-field:focus-within {
		border-color: var(--color-link);
	}
	.calc-prefix {
		padding: 0.625rem 0 0.625rem 0.75rem;
		font-size: var(--text-body);
		color: var(--color-text-muted);
		user-select: none;
	}
	.calc-input {
		flex: 1;
		border: none;
		outline: none;
		font-family: var(--font-sans);
		font-size: var(--text-body);
		padding: 0.625rem 0.75rem 0.625rem 0.25rem;
		color: var(--color-text);
		background: transparent;
	}
	.calc-input::placeholder {
		color: var(--color-text-muted);
	}
	.calc-input-hint {
		font-size: 0.75rem;
		color: var(--color-text-secondary);
		margin: var(--space-xs) 0 0;
	}

	/* ——— Highlight card: the one deliberate card in the layout, reserved for the hero result ——— */

	.calc-highlight {
		display: flex;
		flex-direction: column;
		margin-top: var(--space-lg);
		padding: var(--space-md);
		background: var(--color-bg-panel);
		border-radius: var(--radius-md);
	}
	.calc-highlight-label {
		display: block;
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		color: var(--color-text);
		margin-bottom: var(--space-2xs);
	}
	.calc-highlight-value {
		display: block;
		font-size: var(--text-h1);
		font-weight: var(--weight-normal);
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		margin-bottom: var(--space-2xs);
	}
	.calc-highlight-desc {
		font-size: var(--text-small);
		line-height: var(--leading-snug);
		color: var(--color-text-secondary);
		margin: 0;
	}

	/* ——— Breakdown table: flush with the page, no wrapping card ——— */

	.calc-table {
		width: 100%;
		table-layout: fixed;
		border-collapse: collapse;
		margin-top: var(--space-lg);
	}
	.calc-table-col-period {
		width: 46%;
	}
	.calc-table-col-count {
		width: 16%;
	}
	.calc-table-col-amount {
		width: 38%;
	}
	.calc-table th {
		text-align: left;
		font-size: var(--text-xs);
		font-weight: var(--weight-medium);
		color: var(--color-text-secondary);
		padding: 0 var(--space-sm) var(--space-xs);
	}
	.calc-table th:first-child,
	.calc-table td:first-child {
		padding-left: 0;
	}
	.calc-table th:last-child,
	.calc-table td:last-child {
		padding-right: 0;
		text-align: right;
	}
	.calc-table td {
		/* Smaller than the hero value on purpose — these are supporting numbers, not the answer */
		font-size: var(--text-small);
		color: var(--color-text);
		padding: var(--space-sm);
		border-top: 1px solid var(--color-border);
	}
	/* Paychecks count and dollar amounts stay on one line; only the period label may wrap */
	.calc-table td:nth-child(2),
	.calc-table-amount {
		white-space: nowrap;
		font-variant-numeric: tabular-nums;
	}
	/* ——— Buffer row tooltip ——— */

	.calc-tooltip-wrap {
		position: relative;
		display: inline-block;
	}
	.calc-tooltip-trigger {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.125rem;
		height: 1.125rem;
		margin-left: var(--space-2xs);
		padding: 0;
		font-family: var(--font-sans);
		font-size: 0.6875rem;
		line-height: 1;
		color: var(--color-text-secondary);
		background: var(--color-bg-panel);
		border: none;
		border-radius: 50%;
		cursor: pointer;
		vertical-align: middle;
	}
	.calc-tooltip-trigger:hover,
	.calc-tooltip-trigger:focus-visible {
		color: var(--color-bg);
		background: var(--color-bg-inverse);
	}
	.calc-tooltip-bubble {
		position: absolute;
		left: 0;
		top: calc(100% + var(--space-xs));
		z-index: 5;
		width: max-content;
		max-width: min(14rem, 80vw);
		padding: var(--space-xs) var(--space-sm);
		background: var(--color-bg-inverse);
		color: var(--color-bg);
		font-size: var(--text-xs);
		font-weight: var(--weight-normal);
		line-height: var(--leading-snug);
		text-align: left;
		white-space: normal;
		border-radius: var(--radius-sm);
	}
	.calc-tooltip-bubble[hidden] {
		display: none;
	}

	/* ——— Product link ——— */

	.calc-product-link {
		display: block;
		width: fit-content;
		color: var(--color-accent-info);
		margin-top: var(--space-md);
		margin-bottom: var(--space-lg);
		font-size: 0.875rem;
		text-decoration: none;
	}
	.calc-product-link:hover {
		text-decoration: underline;
	}
	.calc-product-link .arrow {
		display: inline-block;
		transition: transform 0.15s ease;
	}
	.calc-product-link:hover .arrow {
		transform: translateX(2px);
	}

	/* ——— Responsive ——— */

	@media (max-width: 767px) {
		.calc {
			padding-top: var(--space-md);
		}
		.calc-form-grid {
			grid-template-columns: 1fr;
			gap: var(--space-sm);
		}
		.calc-highlight {
			margin-top: calc(var(--space-md) * 0.75);
		}
		.calc-highlight-value {
			font-size: var(--text-h2);
		}
		.calc-table {
			margin-top: calc(var(--space-md) * 0.75);
		}
	}
</style>

<script is:inline define:vars={{ id }}>
(function () {
	var root = document.getElementById(id);
	if (!root) return;

	var FREQUENCIES = {
		biweekly: {
			paychecksPerYear: 26,
			typicalPerMonth: 2,
			extraPerMonth: 3,
			hasExtra: true,
		},
		weekly: {
			paychecksPerYear: 52,
			typicalPerMonth: 4,
			extraPerMonth: 5,
			hasExtra: true,
		},
		semimonthly: {
			paychecksPerYear: 24,
			typicalPerMonth: 2,
			hasExtra: false,
		},
	};

	var freq = 'biweekly';

	var input = root.querySelector('.calc-input');
	var freqSelect = root.querySelector('[data-role="freq-select"]');
	var extraRowEl = root.querySelector('[data-role="extra-row"]');
	var bufferRowEl = root.querySelector('[data-role="buffer-row"]');
	var bufferTooltipTrigger = root.querySelector('[data-role="buffer-tooltip-trigger"]');
	var bufferTooltipBubble = root.querySelector('[data-role="buffer-tooltip-bubble"]');
	var typicalEl = root.querySelector('[data-role="typical"]');
	var typicalCountEl = root.querySelector('[data-role="typical-count"]');
	var extraEl = root.querySelector('[data-role="extra"]');
	var extraCountEl = root.querySelector('[data-role="extra-count"]');
	var extraLabelEl = root.querySelector('[data-role="extra-label"]');
	var averageEl = root.querySelector('[data-role="average"]');
	var bufferEl = root.querySelector('[data-role="buffer"]');

	function formatCurrency(n) {
		return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
	}

	function formatInput(val) {
		var num = val.replace(/[^0-9.]/g, '');
		var parts = num.split('.');
		if (parts[0]) parts[0] = parseInt(parts[0], 10).toLocaleString('en-US');
		return parts.join('.');
	}

	function calculate() {
		var config = FREQUENCIES[freq];
		var raw = input.value.replace(/[^0-9.]/g, '');
		var paycheck = parseFloat(raw) || 0;

		var typical = paycheck * config.typicalPerMonth;
		var annual = paycheck * config.paychecksPerYear;
		var average = annual / 12;
		var buffer = Math.max(0, average - typical);

		typicalCountEl.textContent = config.typicalPerMonth;
		typicalEl.textContent = formatCurrency(typical);
		averageEl.textContent = formatCurrency(average);

		if (config.hasExtra) {
			var extra = paycheck * config.extraPerMonth;
			extraRowEl.style.display = '';
			bufferRowEl.style.display = '';
			extraCountEl.textContent = config.extraPerMonth;
			extraLabelEl.textContent = config.extraPerMonth + '-Paycheck Month';
			extraEl.textContent = formatCurrency(extra);
			bufferEl.textContent = formatCurrency(buffer);
		} else {
			extraRowEl.style.display = 'none';
			bufferRowEl.style.display = 'none';
		}
	}

	input.addEventListener('input', function () {
		var pos = input.selectionStart;
		var before = input.value.length;
		input.value = formatInput(input.value);
		var after = input.value.length;
		input.setSelectionRange(pos + (after - before), pos + (after - before));
		calculate();
	});

	if (freqSelect) {
		freqSelect.addEventListener('change', function () {
			freq = freqSelect.value;
			calculate();
		});
	}

	if (bufferTooltipTrigger && bufferTooltipBubble) {
		bufferTooltipTrigger.addEventListener('click', function (e) {
			e.stopPropagation();
			var willOpen = bufferTooltipBubble.hidden;
			bufferTooltipBubble.hidden = !willOpen;
			bufferTooltipTrigger.setAttribute('aria-expanded', String(willOpen));
		});
		document.addEventListener('click', function () {
			bufferTooltipBubble.hidden = true;
			bufferTooltipTrigger.setAttribute('aria-expanded', 'false');
		});
		document.addEventListener('keydown', function (e) {
			if (e.key === 'Escape') {
				bufferTooltipBubble.hidden = true;
				bufferTooltipTrigger.setAttribute('aria-expanded', 'false');
			}
		});
	}

	calculate();
})();
</script>
