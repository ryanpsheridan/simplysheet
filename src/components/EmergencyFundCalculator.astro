---
const id = `efcalc-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="calc" id={id}>
	<div class="calc-form-grid">
		<div class="calc-input-group">
			<label class="calc-label" for={`${id}-expenses`}>Essential monthly expenses</label>
			<div class="calc-field">
				<span class="calc-prefix">$</span>
				<input
					type="text"
					id={`${id}-expenses`}
					class="calc-input"
					inputmode="decimal"
					placeholder="0"
					autocomplete="off"
				/>
			</div>
		</div>

		<div class="calc-months-group">
			<label class="calc-label" for={`${id}-months`}>Months of coverage</label>
			<select id={`${id}-months`} class="calc-select" data-role="months-select">
				<option value="3">3 months</option>
				<option value="6" selected>6 months</option>
				<option value="9">9 months</option>
				<option value="12">12 months</option>
			</select>
		</div>
	</div>

	<div class="calc-highlight">
		<span class="calc-highlight-label">Target emergency fund</span>
		<span class="calc-highlight-value">$0</span>
		<span class="calc-highlight-math"></span>
	</div>

</div>
<div class="calc-cta-divider"></div>
<a href="/spreadsheets/savings-goals-tracker/" class="calc-product-link">Track your savings goal <span class="arrow">&rarr;</span></a>

<style>
	/* No card, border, or fill — the calculator sits directly in the page column. */
	.calc {
		border-top: 1px solid var(--color-border);
		padding-top: var(--space-lg);
		margin: var(--space-lg) 0;
	}

	.calc-form-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-md);
	}

	/* ——— Input ——— */

	.calc-label {
		display: block;
		font-size: var(--text-small);
		font-weight: var(--weight-normal);
		color: var(--color-text);
		margin-bottom: var(--space-xs);
	}
	.calc-field {
		display: flex;
		align-items: center;
		height: 2.75rem;
		box-sizing: border-box;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		overflow: hidden;
		background: var(--color-bg-surface);
		transition: border-color 0.15s;
	}
	.calc-field:focus-within {
		border-color: var(--color-link);
	}
	.calc-prefix {
		padding: 0.625rem 0 0.625rem 0.75rem;
		font-size: var(--text-body);
		color: var(--color-text-muted);
		user-select: none;
	}
	.calc-input {
		flex: 1;
		border: none;
		outline: none;
		font-family: var(--font-sans);
		font-size: var(--text-body);
		padding: 0.625rem 0.75rem 0.625rem 0.25rem;
		color: var(--color-text);
		background: transparent;
	}
	.calc-input::placeholder {
		color: var(--color-text-muted);
	}

	/* ——— Months dropdown ——— */

	.calc-select {
		width: 100%;
		height: 2.75rem;
		box-sizing: border-box;
		font-family: var(--font-sans);
		font-size: var(--text-body);
		padding: 0 0.75rem;
		color: var(--color-text);
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		outline: none;
		cursor: pointer;
		transition: border-color 0.15s;
	}
	.calc-select:focus {
		border-color: var(--color-link);
	}

	/* ——— Results: the one card in the layout, reserved for the hero result ——— */

	.calc-highlight {
		display: flex;
		flex-direction: column;
		margin-top: var(--space-lg);
		padding: var(--space-md);
		background: var(--color-bg-panel);
		border-radius: var(--radius-md);
	}
	.calc-highlight-label {
		display: block;
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		color: var(--color-text);
		margin-bottom: var(--space-2xs);
	}
	.calc-highlight-value {
		display: block;
		font-size: var(--text-h1);
		font-weight: var(--weight-normal);
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		margin-bottom: var(--space-2xs);
	}
	.calc-highlight-math {
		display: block;
		font-size: var(--text-small);
		color: var(--color-text-secondary);
	}
	.calc-highlight-math:empty {
		display: none;
	}

	/* ——— Product link ——— */

	.calc-cta-divider {
		height: 1px;
		background: var(--color-border);
		margin-top: var(--space-lg);
	}
	.calc-product-link {
		display: block;
		width: fit-content;
		color: var(--color-accent-info);
		margin-top: var(--space-md);
		margin-bottom: var(--space-lg);
		font-size: 0.875rem;
		text-decoration: none;
	}
	.calc-product-link:hover {
		text-decoration: underline;
	}
	.calc-product-link .arrow {
		display: inline-block;
		transition: transform 0.15s ease;
	}
	.calc-product-link:hover .arrow {
		transform: translateX(2px);
	}

	/* ——— Responsive ——— */

	@media (max-width: 767px) {
		.calc {
			padding-top: var(--space-md);
		}
		.calc-form-grid {
			grid-template-columns: 1fr;
			gap: var(--space-sm);
		}
		.calc-highlight {
			margin-top: calc(var(--space-md) * 0.75);
		}
		.calc-highlight-value {
			font-size: var(--text-h2);
		}
	}
</style>

<script is:inline define:vars={{ id }}>
(function () {
	var root = document.getElementById(id);
	if (!root) return;

	var input = root.querySelector('.calc-input');
	var resultValue = root.querySelector('.calc-highlight-value');
	var resultMath = root.querySelector('.calc-highlight-math');
	var monthsSelect = root.querySelector('[data-role="months-select"]');
	var months = 6;

	function formatCurrency(n) {
		return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
	}

	function formatInput(val) {
		var num = val.replace(/[^0-9.]/g, '');
		var parts = num.split('.');
		if (parts[0]) parts[0] = parseInt(parts[0], 10).toLocaleString('en-US');
		return parts.join('.');
	}

	function calculate() {
		var raw = input.value.replace(/[^0-9.]/g, '');
		var expenses = parseFloat(raw) || 0;
		var target = expenses * months;

		resultValue.textContent = formatCurrency(target);

		if (expenses > 0) {
			resultMath.textContent = formatCurrency(expenses) + ' × ' + months + ' months = ' + formatCurrency(target);
		} else {
			resultMath.textContent = '';
		}
	}

	input.addEventListener('input', function () {
		var pos = input.selectionStart;
		var before = input.value.length;
		input.value = formatInput(input.value);
		var after = input.value.length;
		input.setSelectionRange(pos + (after - before), pos + (after - before));
		calculate();
	});

	monthsSelect.addEventListener('change', function () {
		months = parseInt(monthsSelect.value, 10);
		calculate();
	});

	calculate();
})();
</script>
