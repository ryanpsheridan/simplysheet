---
const id = `efcalc-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="calc" id={id}>
	<div class="calc-input-group">
		<label class="calc-label" for={`${id}-expenses`}>Essential monthly expenses</label>
		<div class="calc-field">
			<span class="calc-prefix">$</span>
			<input
				type="text"
				id={`${id}-expenses`}
				class="calc-input"
				inputmode="decimal"
				placeholder="0"
				autocomplete="off"
			/>
		</div>
	</div>

	<div class="calc-months-group">
		<span class="calc-label">Months of coverage</span>
		<div class="calc-months-toggle">
			<button class="calc-months-btn" data-months="3">3 months</button>
			<button class="calc-months-btn active" data-months="6">6 months</button>
			<button class="calc-months-btn" data-months="9">9 months</button>
			<button class="calc-months-btn" data-months="12">12 months</button>
		</div>
	</div>

	<div class="calc-results">
		<div class="calc-result">
			<span class="calc-result-label">Target emergency fund</span>
			<span class="calc-result-value">$0</span>
			<span class="calc-result-math"></span>
		</div>
	</div>

	<a href="/spreadsheets/savings-goals-tracker/" class="btn btn-primary calc-cta">
		Track your savings goal
		<span class="arrow">&rarr;</span>
	</a>
</div>

<style>
	.calc {
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		padding: var(--space-md);
		margin: var(--space-lg) 0;
		background: var(--color-bg-surface);
	}

	/* ——— Input ——— */

	.calc-label {
		display: block;
		font-size: var(--text-small);
		font-weight: var(--weight-normal);
		color: var(--color-text);
		margin-bottom: var(--space-xs);
	}
	.calc-field {
		display: flex;
		align-items: center;
		border: 1px solid var(--color-divider);
		border-radius: var(--radius-sm);
		overflow: hidden;
		transition: border-color 0.15s;
	}
	.calc-field:focus-within {
		border-color: var(--color-link);
	}
	.calc-prefix {
		padding: 0.625rem 0 0.625rem 0.75rem;
		font-size: var(--text-body);
		color: var(--color-text-muted);
		user-select: none;
	}
	.calc-input {
		flex: 1;
		border: none;
		outline: none;
		font-family: var(--font-sans);
		font-size: var(--text-body);
		padding: 0.625rem 0.75rem 0.625rem 0.25rem;
		color: var(--color-text);
		background: transparent;
	}
	.calc-input::placeholder {
		color: var(--color-text-muted);
	}

	/* ——— Months toggle ——— */

	.calc-months-group {
		margin-top: var(--space-md);
	}
	.calc-months-toggle {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-xs);
	}
	.calc-months-btn {
		font-family: var(--font-sans);
		font-size: var(--text-small);
		font-weight: var(--weight-normal);
		color: var(--color-text-secondary);
		background: none;
		border: 1px solid var(--color-divider);
		border-radius: var(--radius-full);
		padding: 0.375rem 0.875rem;
		cursor: pointer;
		transition: color 0.15s, border-color 0.15s, background 0.15s;
	}
	.calc-months-btn:hover {
		color: var(--color-text);
		border-color: var(--color-text-muted);
	}
	.calc-months-btn.active {
		color: var(--color-bg);
		background: var(--color-bg-inverse);
		border-color: var(--color-bg-inverse);
	}

	/* ——— Results ——— */

	.calc-results {
		margin-top: var(--space-md);
	}
	.calc-result-label {
		display: block;
		font-size: var(--text-small);
		font-weight: var(--weight-normal);
		color: var(--color-text);
		margin-bottom: var(--space-2xs);
	}
	.calc-result-value {
		display: block;
		font-size: var(--text-h2);
		font-weight: var(--weight-normal);
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		margin-bottom: var(--space-2xs);
	}
	.calc-result-math {
		display: block;
		font-size: var(--text-small);
		color: var(--color-text-muted);
		min-height: 1.4em;
	}

	/* ——— CTA ——— */

	.calc-cta {
		width: 100%;
	}
</style>

<script is:inline define:vars={{ id }}>
(function () {
	var root = document.getElementById(id);
	if (!root) return;

	var input = root.querySelector('.calc-input');
	var resultValue = root.querySelector('.calc-result-value');
	var resultMath = root.querySelector('.calc-result-math');
	var monthsBtns = root.querySelectorAll('.calc-months-btn');
	var months = 6;

	function formatCurrency(n) {
		return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
	}

	function formatInput(val) {
		var num = val.replace(/[^0-9.]/g, '');
		var parts = num.split('.');
		if (parts[0]) parts[0] = parseInt(parts[0], 10).toLocaleString('en-US');
		return parts.join('.');
	}

	function calculate() {
		var raw = input.value.replace(/[^0-9.]/g, '');
		var expenses = parseFloat(raw) || 0;
		var target = expenses * months;

		resultValue.textContent = formatCurrency(target);

		if (expenses > 0) {
			resultMath.textContent = formatCurrency(expenses) + ' × ' + months + ' months = ' + formatCurrency(target);
		} else {
			resultMath.textContent = '';
		}
	}

	input.addEventListener('input', function () {
		var pos = input.selectionStart;
		var before = input.value.length;
		input.value = formatInput(input.value);
		var after = input.value.length;
		input.setSelectionRange(pos + (after - before), pos + (after - before));
		calculate();
	});

	monthsBtns.forEach(function (btn) {
		btn.addEventListener('click', function () {
			monthsBtns.forEach(function (b) { b.classList.remove('active'); });
			btn.classList.add('active');
			months = parseInt(btn.dataset.months, 10);
			calculate();
		});
	});

	calculate();
})();
</script>
