---
const id = `quiz-${Math.random().toString(36).slice(2, 8)}`;
---

<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,0,0&display=swap" rel="stylesheet" />

<div class="quiz" id={id}>
	<div class="quiz-questions" id={`${id}-questions`}>
		<div class="quiz-progress">
			<span class="quiz-progress-text" id={`${id}-progress`}>Question 1 of 7</span>
			<div class="quiz-progress-bar"><div class="quiz-progress-fill" id={`${id}-fill`}></div></div>
		</div>
		<div class="quiz-question" id={`${id}-q`}>
			<h2 class="quiz-question-text" id={`${id}-qtext`}></h2>
			<div class="quiz-options" id={`${id}-opts`}></div>
		</div>
	</div>

	<div class="quiz-result" id={`${id}-result`} hidden>
		<div class="quiz-result-icon" id={`${id}-icon`}></div>
		<span class="quiz-result-label">Your budgeting style</span>
		<h2 class="quiz-result-title" id={`${id}-style`}></h2>
		<p class="quiz-result-desc" id={`${id}-desc`}></p>
		<h3 class="quiz-tip-label">Your Pro-Tip for Growth 💡</h3>
		<div class="quiz-result-tip" id={`${id}-tip`}></div>
		<p class="quiz-result-rec" id={`${id}-rec`}></p>
		<div class="quiz-result-actions">
			<button class="btn btn-primary quiz-retake" id={`${id}-retake`}>Retake quiz</button>
			<a class="btn btn-secondary quiz-result-cta" id={`${id}-cta`} href="#" target="_blank" rel="noopener noreferrer" data-cta="budgeting_quiz_result_cta">Browse budget templates</a>
		</div>
	</div>
</div>
<a href="/spreadsheets/budget-spreadsheet/" class="calc-product-link">Track it in a budget spreadsheet <span class="arrow">&rarr;</span></a>

<style>
	.quiz {
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		padding: 2rem;
		margin: var(--space-lg) 0;
		background: var(--color-bg-panel);
	}

	/* ——— Progress ——— */

	.quiz-progress {
		margin-bottom: var(--space-md);
	}
	.quiz-progress-text {
		display: block;
		font-size: var(--text-small);
		color: var(--color-text-muted);
		margin-bottom: var(--space-xs);
	}
	.quiz-progress-bar {
		height: 4px;
		background: var(--color-bg-surface);
		border-radius: 2px;
		overflow: hidden;
	}
	.quiz-progress-fill {
		height: 100%;
		background: var(--color-text-heading);
		border-radius: 2px;
		width: 14.28%;
		transition: width 0.3s ease;
	}

	/* ——— Question ——— */

	.quiz-question-text {
		font-size: var(--text-h2);
		line-height: var(--leading-snug);
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		margin-bottom: var(--space-lg);
	}
	.quiz-options {
		display: flex;
		flex-direction: column;
		gap: 0.625rem;
	}
	:global(.quiz-option) {
		font-family: var(--font-sans);
		font-size: 1.0625rem;
		font-weight: var(--weight-normal);
		color: var(--color-text-secondary);
		background: var(--color-bg-surface);
		border: 1.5px solid var(--color-border);
		border-radius: var(--radius-md);
		padding: 1rem 1.25rem;
		min-height: 3.25rem;
		cursor: pointer;
		text-align: left;
		transition: color 0.15s, border-color 0.15s, background 0.15s, transform 0.1s ease;
		line-height: var(--leading-snug);
		width: 100%;
		display: block;
		box-sizing: border-box;
	}
	@media (hover: hover) {
		:global(.quiz-option:hover) {
			color: var(--color-text);
			border-color: var(--color-text-muted);
			background: var(--color-bg-emphasis);
		}
	}
	:global(.quiz-option:active),
	:global(.quiz-option.selected) {
		background: var(--color-bg-inverse);
		color: var(--color-bg);
		border-color: var(--color-bg-inverse);
		transform: scale(0.98);
	}

	/* ——— Result ——— */

	.quiz-result {
		display: flex;
		flex-direction: column;
	}
	.quiz-result[hidden] {
		display: none;
	}
	.quiz-result-icon {
		width: 3.5rem;
		height: 3.5rem;
		border-radius: 0.75rem;
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: var(--space-md);
		background: var(--color-bg-surface);
	}
	:global(.quiz-result-icon .material-symbols-rounded) {
		font-family: 'Material Symbols Rounded';
		font-weight: normal;
		font-style: normal;
		font-size: 28px;
		line-height: 1;
		color: var(--color-text-heading);
	}
	.quiz-result-label {
		font-size: var(--text-small);
		font-weight: var(--weight-normal);
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
		color: var(--color-text-muted);
		margin-bottom: var(--space-2xs);
	}
	.quiz-result-title {
		font-size: var(--text-h2);
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		margin-bottom: var(--space-sm);
	}
	.quiz-result-desc {
		font-size: var(--text-body);
		line-height: var(--leading-normal);
		color: var(--color-text-secondary);
		margin: 0 0 var(--space-md);
		max-width: 36rem;
	}
	.quiz-tip-label {
		font-size: var(--text-body);
		font-weight: var(--weight-normal);
		color: var(--color-text);
		margin: 0 0 var(--space-xs);
	}
	.quiz-result-tip {
		font-size: var(--text-body);
		line-height: var(--leading-normal);
		color: var(--color-text);
		background: var(--color-bg-surface);
		border-radius: var(--radius-md);
		padding: var(--space-md);
		margin-bottom: var(--space-md);
		max-width: 36rem;
	}
	.quiz-result-rec {
		font-size: var(--text-body);
		line-height: var(--leading-normal);
		color: var(--color-text-secondary);
		margin: 0 0 var(--space-md);
		max-width: 36rem;
	}
	.quiz-result-actions {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
		max-width: 36rem;
	}
	.quiz-result-actions .btn {
		text-align: center;
		justify-content: center;
	}

	@media (max-width: 480px) {
		.quiz {
			padding: var(--space-md);
		}
		.quiz-result-title {
			font-size: var(--text-h3);
		}
	}

	/* ——— Product link ——— */

	.calc-product-link {
		display: block;
		width: fit-content;
		/* Collapses against the container's space-lg bottom margin to net space-md (24px) below the box */
		margin-top: calc(var(--space-md) - var(--space-lg));
		margin-bottom: var(--space-lg);
		font-size: 0.875rem;
		text-decoration: none;
	}
	.calc-product-link:hover {
		text-decoration: underline;
	}
	.calc-product-link .arrow {
		display: inline-block;
		transition: transform 0.15s ease;
	}
	.calc-product-link:hover .arrow {
		transform: translateX(2px);
	}
</style>

<script is:inline define:vars={{ id }}>
(function () {
	var root = document.getElementById(id);
	if (!root) return;

	var questions = [
		{
			q: "What is the first thing you do after getting paid?",
			opts: [
				{ text: "Move money into savings and bills right away", style: "planner" },
				{ text: "Check my deposit, then move on", style: "saver" },
				{ text: "Think about what I want to buy", style: "spender" },
				{ text: "Try not to think about it", style: "avoider" }
			]
		},
		{
			q: "How do you feel when you check your bank balance?",
			opts: [
				{ text: "Confident — I know what it should be", style: "planner" },
				{ text: "Good — I like watching it grow", style: "saver" },
				{ text: "A little nervous, but I check anyway", style: "spender" },
				{ text: "I avoid checking unless I have to", style: "avoider" }
			]
		},
		{
			q: "An unexpected $500 expense comes up. What do you do?",
			opts: [
				{ text: "Pull from my emergency fund", style: "planner" },
				{ text: "Use savings, but it bothers me", style: "saver" },
				{ text: "Put it on a credit card", style: "spender" },
				{ text: "Feel overwhelmed and put it off", style: "avoider" }
			]
		},
		{
			q: "How would you describe your approach to budgeting?",
			opts: [
				{ text: "I track every dollar regularly", style: "planner" },
				{ text: "Keep it simple — spend less than I earn", style: "saver" },
				{ text: "I have tried budgets but they never stick", style: "spender" },
				{ text: "I do not really have a budget", style: "avoider" }
			]
		},
		{
			q: "A friend invites you on a last-minute trip. How do you decide?",
			opts: [
				{ text: "Check if my budget can handle it", style: "planner" },
				{ text: "Say no unless it is really cheap", style: "saver" },
				{ text: "Say yes, worry about cost later", style: "spender" },
				{ text: "Say I will think about it, then never reply", style: "avoider" }
			]
		},
		{
			q: "What is your relationship with financial goals?",
			opts: [
				{ text: "Clear goals with timelines and amounts", style: "planner" },
				{ text: "My main goal is always to save more", style: "saver" },
				{ text: "I set goals but get sidetracked", style: "spender" },
				{ text: "I know I should set goals but have not yet", style: "avoider" }
			]
		},
		{
			q: "You see a sale on something you want but do not need. You usually...",
			opts: [
				{ text: "Check if it fits the budget first", style: "planner" },
				{ text: "Skip it — a deal is not a deal if I was not buying it", style: "saver" },
				{ text: "Grab it — it is on sale!", style: "spender" },
				{ text: "Leave the tab open for a week", style: "avoider" }
			]
		}
	];

	var styles = {
		planner: {
			name: "The Planner",
			icon: "event_note",
			color: "#7E57C2",
			iconBg: "#F3E5F5",
			tipBg: "var(--color-bg-surface)",
			desc: "You like having a system and knowing exactly where your money goes. Structure gives you confidence, and you feel most at ease when every dollar has a job. Your strength is discipline, and your challenge is staying flexible when plans change.",
			tip: "Tip: Schedule a monthly \"budget review\" to adjust your plan based on real spending. A budget that adapts is one that lasts.",
			rec: "You would get the most out of a detailed budget spreadsheet with category tracking and monthly review dashboards.",
			cta: "Browse budget templates",
			url: "https://simplysheetdesign.etsy.com/listing/1854773368/budget-spreadsheet-for-google-excel?utm_source=simplysheetdesign.com&utm_medium=referral"
		},
		saver: {
			name: "The Saver",
			icon: "savings",
			color: "#2D9D78",
			iconBg: "#E8F5E9",
			tipBg: "var(--color-bg-surface)",
			desc: "You are naturally frugal and feel best when your savings are growing. You are great at saying no to impulse buys, but sometimes you might hold back too much on things that would genuinely improve your life.",
			tip: "Tip: Set a small \"fun money\" line item in your budget so you can enjoy spending guilt-free. Saving is the goal, not the whole picture.",
			rec: "A savings goals tracker can help you channel your saving instincts into clear targets with visible progress.",
			cta: "View savings tracker",
			url: "https://simplysheetdesign.etsy.com/listing/4483664616/sinking-funds-tracker-google-sheets?utm_source=simplysheetdesign.com&utm_medium=referral"
		},
		spender: {
			name: "The Spender",
			icon: "shopping_bag",
			color: "#E86A33",
			iconBg: "#FFF3E0",
			tipBg: "var(--color-bg-surface)",
			desc: "You enjoy the present and believe money is meant to be used. You are generous and spontaneous, which makes life fun. Your challenge is building habits that balance today's enjoyment with tomorrow's security.",
			tip: "Tip: Try the 24-hour rule for non-essential purchases over $50. If you still want it tomorrow, go for it.",
			rec: "A simple daily expense tracker can help you see patterns without feeling restricted. Awareness is the first step.",
			cta: "View budget spreadsheet",
			url: "https://simplysheetdesign.etsy.com/listing/1854773368/budget-spreadsheet-for-google-excel?utm_source=simplysheetdesign.com&utm_medium=referral"
		},
		avoider: {
			name: "The Avoider",
			icon: "visibility_off",
			color: "#196EDD",
			iconBg: "#E3F2FD",
			tipBg: "var(--color-bg-surface)",
			desc: "Money stresses you out, so you tend to put off financial decisions. This is more common than you think, and the good news is that even small steps can build big momentum. You do not need to overhaul everything at once.",
			tip: "Tip: Start with just one habit: check your bank balance every morning. That is it. Familiarity reduces anxiety over time.",
			rec: "A straightforward budget spreadsheet with minimal setup can make the first step feel approachable instead of overwhelming.",
			cta: "View simple budget template",
			url: "https://simplysheetdesign.etsy.com/listing/1854773368/budget-spreadsheet-for-google-excel?utm_source=simplysheetdesign.com&utm_medium=referral"
		}
	};

	var currentQ = 0;
	var answers = [];

	var questionsEl = document.getElementById(id + '-questions');
	var resultEl = document.getElementById(id + '-result');
	var progressText = document.getElementById(id + '-progress');
	var progressFill = document.getElementById(id + '-fill');
	var qText = document.getElementById(id + '-qtext');
	var optsEl = document.getElementById(id + '-opts');
	var iconEl = document.getElementById(id + '-icon');
	var styleEl = document.getElementById(id + '-style');
	var descEl = document.getElementById(id + '-desc');
	var tipEl = document.getElementById(id + '-tip');
	var recEl = document.getElementById(id + '-rec');
	var ctaEl = document.getElementById(id + '-cta');
	var retakeBtn = document.getElementById(id + '-retake');

	function renderQuestion() {
		var q = questions[currentQ];
		progressText.textContent = 'Question ' + (currentQ + 1) + ' of ' + questions.length;
		progressFill.style.width = ((currentQ + 1) / questions.length * 100) + '%';
		qText.textContent = q.q;
		optsEl.innerHTML = '';
		q.opts.forEach(function (opt) {
			var btn = document.createElement('button');
			btn.className = 'quiz-option';
			btn.textContent = opt.text;
			btn.addEventListener('click', function () {
				btn.classList.add('selected');
				var allBtns = optsEl.querySelectorAll('.quiz-option');
				allBtns.forEach(function (b) { b.disabled = true; });
				setTimeout(function () {
					answers.push(opt.style);
					if (currentQ < questions.length - 1) {
						currentQ++;
						renderQuestion();
					} else {
						showResult();
					}
				}, 250);
			});
			optsEl.appendChild(btn);
		});
	}

	function showResult() {
		var tally = { planner: 0, saver: 0, spender: 0, avoider: 0 };
		answers.forEach(function (s) { tally[s]++; });
		var winner = 'planner';
		Object.keys(tally).forEach(function (k) {
			if (tally[k] > tally[winner]) winner = k;
		});

		var s = styles[winner];
		iconEl.innerHTML = '<span class="material-symbols-rounded">' + s.icon + '</span>';
		iconEl.style.background = s.iconBg;
		iconEl.querySelector('.material-symbols-rounded').style.color = s.color;
		tipEl.style.background = s.tipBg;
		styleEl.textContent = 'Your Budgeting Style: ' + s.name;
		descEl.textContent = s.desc;
		tipEl.innerHTML = s.tip.replace(/^Tip:\s*/, '');
		recEl.textContent = s.rec;
		ctaEl.textContent = 'Browse budget templates';
		ctaEl.href = 'https://simplysheetdesign.etsy.com/?utm_source=simplysheetdesign.com&utm_medium=referral';

		questionsEl.hidden = true;
		resultEl.hidden = false;
	}

	retakeBtn.addEventListener('click', function () {
		currentQ = 0;
		answers = [];
		resultEl.hidden = true;
		questionsEl.hidden = false;
		renderQuestion();
	});

	renderQuestion();
})();
</script>
