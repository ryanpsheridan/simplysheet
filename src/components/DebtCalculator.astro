---
const id = `debt-${Math.random().toString(36).slice(2, 8)}`;

// Single source of truth for the example portfolio: the static header, the
// breakdown table, and the client-side payoff simulation all read from this.
const DEBTS = [
	{ name: 'Credit Card', balance: 3000, apr: 0.24 },
	{ name: 'Auto Loan', balance: 5000, apr: 0.07 },
	{ name: 'Student Loan', balance: 2000, apr: 0.05 },
];
const totalDebt = DEBTS.reduce((sum, d) => sum + d.balance, 0);
const formatCurrency = (n: number) => '$' + n.toLocaleString('en-US');
---

<div class="visualizer" id={id}>
	<p class="debt-baseline">Example Debt Profile: <strong>{formatCurrency(totalDebt)}</strong></p>

	<table class="debt-table">
		<colgroup>
			<col class="debt-table-col-name" />
			<col class="debt-table-col-balance" />
		</colgroup>
		<thead>
			<tr>
				<th scope="col">Debt</th>
				<th scope="col">Balance</th>
			</tr>
		</thead>
		<tbody>
			{DEBTS.map((d) => (
				<tr>
					<td>{d.name}</td>
					<td>{formatCurrency(d.balance)} at {Math.round(d.apr * 100)}% APR</td>
				</tr>
			))}
		</tbody>
	</table>

	<div class="slider-group">
		<label class="slider-label" for={`${id}-range`}>Extra monthly payment</label>
		<div class="slider-amount" id={`${id}-amount`}>$200</div>
		<input
			type="range"
			id={`${id}-range`}
			class="slider-input"
			min="0"
			max="1000"
			step="50"
			value="200"
		/>
		<div class="slider-range-labels">
			<span>$0</span>
			<span>$1,000</span>
		</div>
	</div>

	<div class="compare-card">
		<p class="compare-heading">Total interest paid <span class="compare-heading-hint">(shorter is better)</span></p>
		<div class="compare-row">
			<div class="compare-meta">
				<span class="compare-method compare-method--avalanche">Avalanche</span>
				<span class="compare-desc">Highest rate first</span>
			</div>
			<div class="compare-bar-row">
				<div class="compare-track">
					<div class="compare-fill compare-fill--avalanche" id={`${id}-aval`}></div>
				</div>
				<span class="compare-value" id={`${id}-aval-value`}>$0</span>
			</div>
		</div>
		<div class="compare-row">
			<div class="compare-meta">
				<span class="compare-method compare-method--snowball">Snowball</span>
				<span class="compare-desc">Smallest balance first</span>
			</div>
			<div class="compare-bar-row">
				<div class="compare-track">
					<div class="compare-fill compare-fill--snowball" id={`${id}-snow`}></div>
				</div>
				<span class="compare-value" id={`${id}-snow-value`}>$0</span>
			</div>
		</div>
		<p class="compare-context" id={`${id}-context`}></p>
	</div>

	<p class="compare-note">Estimated using typical interest rates — actual results may vary.</p>
</div>
<div class="calc-cta-divider"></div>
<a href="/spreadsheets/debt-payoff-tracker/" class="calc-product-link">Track your debt payoff <span class="arrow">&rarr;</span></a>

<style>
	/* No card, border, or fill — the visualizer sits directly in the page column. */
	.visualizer {
		border-top: 1px solid var(--color-border);
		padding-top: var(--space-lg);
		margin: var(--space-lg) 0;
	}

	/* ——— Baseline header + example portfolio table ——— */

	.debt-baseline {
		font-size: var(--text-body);
		color: var(--color-text-secondary);
		margin: 0 0 var(--space-md);
	}
	.debt-baseline strong {
		font-weight: var(--weight-medium);
		color: var(--color-text);
	}

	.debt-table {
		width: 100%;
		table-layout: fixed;
		border-collapse: collapse;
		margin-bottom: var(--space-lg);
	}
	.debt-table-col-name {
		width: 42%;
	}
	.debt-table-col-balance {
		width: 58%;
	}
	.debt-table th {
		text-align: left;
		font-size: var(--text-xs);
		font-weight: var(--weight-medium);
		color: var(--color-text-secondary);
		padding: 0 var(--space-sm) var(--space-xs);
	}
	.debt-table th:first-child,
	.debt-table td:first-child {
		padding-left: 0;
	}
	.debt-table th:last-child,
	.debt-table td:last-child {
		padding-right: 0;
		text-align: right;
	}
	.debt-table td {
		font-size: var(--text-small);
		color: var(--color-text-secondary);
		padding: var(--space-sm);
		border-top: 1px solid var(--color-border);
		white-space: nowrap;
	}
	.debt-table td:first-child {
		color: var(--color-text);
		white-space: normal;
	}

	/* ——— Slider ——— */

	.slider-group {
		margin-bottom: var(--space-lg);
	}

	.slider-label {
		display: block;
		font-size: var(--text-small);
		font-weight: var(--weight-normal);
		color: var(--color-text-secondary);
		margin-bottom: var(--space-2xs);
	}

	.slider-amount {
		font-size: clamp(2rem, 5vw, 2.75rem);
		font-weight: var(--weight-normal);
		color: var(--color-text);
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--space-md);
	}

	.slider-input {
		display: block;
		width: 100%;
		height: 6px;
		-webkit-appearance: none;
		appearance: none;
		background: var(--color-border);
		border-radius: 3px;
		outline: none;
		cursor: pointer;
	}
	.slider-input::-webkit-slider-thumb {
		-webkit-appearance: none;
		width: 22px;
		height: 22px;
		border-radius: 50%;
		background: var(--color-btn);
		border: 2px solid var(--color-bg-surface);
		box-shadow: 0 1px 4px rgba(0, 0, 0, 0.15);
		cursor: pointer;
	}
	.slider-input::-moz-range-thumb {
		width: 22px;
		height: 22px;
		border-radius: 50%;
		background: var(--color-btn);
		border: 2px solid var(--color-bg-surface);
		box-shadow: 0 1px 4px rgba(0, 0, 0, 0.15);
		cursor: pointer;
	}

	.slider-range-labels {
		display: flex;
		justify-content: space-between;
		font-size: var(--text-xs);
		color: var(--color-text-secondary);
		margin-top: var(--space-2xs);
	}

	/* ——— Comparison: no card — sits flush on the page like the rest of the site ——— */

	.compare-card {
		margin-bottom: var(--space-md);
	}

	.compare-heading {
		font-size: var(--text-xs);
		color: var(--color-text-secondary);
		margin: 0 0 var(--space-sm);
	}
	.compare-heading-hint {
		color: var(--color-text-muted);
	}

	.compare-row {
		margin-bottom: var(--space-md);
	}
	.compare-row:last-of-type {
		margin-bottom: 0;
	}

	.compare-meta {
		display: flex;
		align-items: baseline;
		gap: var(--space-xs);
		margin-bottom: var(--space-2xs);
	}

	.compare-method {
		font-size: var(--text-small);
		font-weight: var(--weight-normal);
		color: var(--color-text);
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
	}
	.compare-method::before {
		content: '';
		width: 0.5rem;
		height: 0.5rem;
		border-radius: 50%;
		flex-shrink: 0;
	}
	.compare-method--avalanche::before {
		background: var(--color-debt-avalanche);
	}
	.compare-method--snowball::before {
		background: var(--color-debt-snowball);
	}

	.compare-desc {
		font-size: var(--text-xs);
		color: var(--color-text-secondary);
	}

	/* Track + value sit in one row; the track shrinks first so the dollar
	   figure never wraps or gets pushed off narrow screens. */
	.compare-bar-row {
		display: flex;
		align-items: center;
		gap: var(--space-sm);
	}

	.compare-track {
		flex: 1;
		min-width: 0;
		height: 1.5rem;
		background: var(--color-bg-panel);
		border-radius: var(--radius-sm);
		overflow: hidden;
	}

	.compare-fill {
		height: 100%;
		border-radius: var(--radius-sm);
		transition: width 0.35s ease;
	}

	.compare-fill--avalanche {
		background: var(--color-debt-avalanche);
	}

	.compare-fill--snowball {
		background: var(--color-debt-snowball);
	}

	.compare-value {
		flex-shrink: 0;
		width: 4.5rem;
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		color: var(--color-text);
		text-align: right;
		font-variant-numeric: tabular-nums;
	}

	.compare-context {
		font-size: var(--text-small);
		font-weight: var(--weight-normal);
		color: var(--color-text);
		margin: var(--space-md) 0 0;
		line-height: var(--leading-normal);
	}
	.compare-context:empty {
		display: none;
	}

	:global(.compare-highlight) {
		color: var(--color-debt-avalanche);
	}

	.compare-note {
		font-size: var(--text-xs);
		color: var(--color-text-secondary);
		margin: 0;
		line-height: var(--leading-normal);
	}

	/* ——— Product link ——— */

	.calc-cta-divider {
		height: 1px;
		background: var(--color-border);
		margin-top: var(--space-lg);
	}
	.calc-product-link {
		display: block;
		width: fit-content;
		color: var(--color-accent-info);
		margin-top: var(--space-md);
		margin-bottom: var(--space-lg);
		font-size: 0.875rem;
		text-decoration: none;
	}
	.calc-product-link:hover {
		text-decoration: underline;
	}
	.calc-product-link .arrow {
		display: inline-block;
		transition: transform 0.15s ease;
	}
	.calc-product-link:hover .arrow {
		transform: translateX(2px);
	}

	/* ——— Responsive ——— */

	@media (max-width: 767px) {
		.visualizer {
			padding-top: var(--space-md);
		}
		.debt-table th,
		.debt-table td {
			font-size: var(--text-xs);
		}
		.compare-value {
			width: 4rem;
			font-size: var(--text-xs);
		}
	}
</style>

<script is:inline define:vars={{ id, DEBTS }}>
(function () {
	var slider = document.getElementById(id + '-range');
	var amountEl = document.getElementById(id + '-amount');
	var avalEl = document.getElementById(id + '-aval');
	var snowEl = document.getElementById(id + '-snow');
	var avalValueEl = document.getElementById(id + '-aval-value');
	var snowValueEl = document.getElementById(id + '-snow-value');
	var contextEl = document.getElementById(id + '-context');

	// Minimum payments aren't part of the displayed table (it only shows
	// balance + APR), so estimate a typical 2.5%-of-balance minimum per debt.
	var MIN_PAYMENT_RATE = 0.025;
	var debts = DEBTS.map(function (d) {
		return { balance: d.balance, apr: d.apr, minPayment: d.balance * MIN_PAYMENT_RATE };
	});

	// Avalanche (highest rate first) and snowball (smallest balance first)
	// disagree here: the Credit Card is both the highest-rate and a
	// mid-size balance, so the two methods genuinely attack in a different
	// order — that's what makes the comparison meaningful.
	var AVALANCHE_ORDER = debts.slice().sort(function (a, b) { return b.apr - a.apr; });
	var SNOWBALL_ORDER = debts.slice().sort(function (a, b) { return a.balance - b.balance; });

	// Simulates paying down `order` (a priority-sorted list of debts) with a
	// fixed monthly budget of (sum of minimums + extra), redirecting every
	// dollar beyond minimums to the highest-priority debt still owing —
	// exactly how the snowball/avalanche methods work in practice. Returns
	// total interest paid and months to $0 across all debts.
	function simulate(order, extra) {
		var sim = order.map(function (d) {
			return { balance: d.balance, apr: d.apr, minPayment: d.minPayment };
		});
		var totalInterest = 0;
		var months = 0;
		var MAX_MONTHS = 600; // 50-year safety cap

		while (months < MAX_MONTHS && sim.some(function (d) { return d.balance > 0.01; })) {
			months++;

			sim.forEach(function (d) {
				if (d.balance > 0) {
					var interest = d.balance * (d.apr / 12);
					totalInterest += interest;
					d.balance += interest;
				}
			});

			var budget = extra;
			sim.forEach(function (d) { if (d.balance > 0) budget += d.minPayment; });

			var target = sim.find(function (d) { return d.balance > 0; });
			sim.forEach(function (d) {
				if (d !== target && d.balance > 0) {
					var pay = Math.min(d.minPayment, d.balance);
					d.balance -= pay;
					budget -= pay;
				}
			});

			// Apply everything left to the priority target, cascading any
			// leftover to the next debt(s) in line the same month.
			while (budget > 0.01) {
				var next = sim.find(function (d) { return d.balance > 0.01; });
				if (!next) break;
				var pay = Math.min(budget, next.balance);
				next.balance -= pay;
				budget -= pay;
			}
		}

		return { interest: totalInterest, months: months };
	}

	function formatCurrency(n) {
		return '$' + Math.round(n).toLocaleString('en-US');
	}

	// Reference point for the summary line below: total interest and months
	// to debt-free with $0 extra (order doesn't matter at $0 — there's
	// nothing yet to redirect between debts).
	var BASELINE = simulate(AVALANCHE_ORDER, 0);

	function update() {
		var extra = parseInt(slider.value, 10);
		amountEl.textContent = '$' + extra.toLocaleString('en-US');

		var aval = simulate(AVALANCHE_ORDER, extra);
		var snow = simulate(SNOWBALL_ORDER, extra);

		// Bars represent total interest paid — shorter is the goal — scaled
		// against whichever method costs more, so the pricier one always
		// fills the full track and the cheaper one visibly falls short of it.
		var maxInterest = Math.max(aval.interest, snow.interest, 1);
		avalEl.style.width = (aval.interest / maxInterest * 100) + '%';
		snowEl.style.width = (snow.interest / maxInterest * 100) + '%';
		avalValueEl.textContent = formatCurrency(aval.interest);
		snowValueEl.textContent = formatCurrency(snow.interest);

		// Framed against the $0-extra baseline rather than Avalanche vs.
		// Snowball directly — that head-to-head gap shrinks as extra payments
		// grow, which reads as "less impact" even though the payoff is
		// objectively better. Comparing to baseline stays monotonic: more
		// extra always means less interest and a faster payoff.
		if (extra === 0) {
			contextEl.textContent = '';
		} else {
			var monthsFaster = BASELINE.months - aval.months;

			var html = 'By adding <strong class="compare-highlight">' + formatCurrency(extra) +
				'</strong> to your monthly payment, you slash your total interest down to as low as <strong class="compare-highlight">' +
				formatCurrency(aval.interest) + '</strong>';
			if (monthsFaster > 0) {
				html += ' and get debt-free <strong class="compare-highlight">' +
					monthsFaster + (monthsFaster === 1 ? ' month' : ' months') + ' faster</strong>.';
			} else {
				html += '.';
			}
			contextEl.innerHTML = html;
		}
	}

	slider.addEventListener('input', update);
	update();
})();
</script>
