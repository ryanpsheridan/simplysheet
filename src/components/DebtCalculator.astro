---
const id = `debt-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="visualizer" id={id}>
	<label class="slider-label" for={`${id}-range`}>Extra monthly payment</label>
	<div class="slider-amount" id={`${id}-amount`}>$200</div>
	<input
		type="range"
		id={`${id}-range`}
		class="slider-input"
		min="0"
		max="1000"
		step="50"
		value="200"
	/>
	<div class="slider-range-labels">
		<span>$0</span>
		<span>$1,000</span>
	</div>

	<div class="compare-card">
		<div class="compare-row">
			<div class="compare-meta">
				<span class="compare-method">Avalanche</span>
				<span class="compare-desc">Highest rate first</span>
			</div>
			<div class="compare-track">
				<div class="compare-fill compare-fill--avalanche" id={`${id}-aval`}></div>
			</div>
		</div>
		<div class="compare-row">
			<div class="compare-meta">
				<span class="compare-method">Snowball</span>
				<span class="compare-desc">Smallest balance first</span>
			</div>
			<div class="compare-track">
				<div class="compare-fill compare-fill--snowball" id={`${id}-snow`}></div>
			</div>
		</div>
		<p class="compare-context" id={`${id}-context`}>Avalanche is saving roughly 8% more in interest than Snowball.</p>
		<p class="compare-note" id={`${id}-note`}></p>
	</div>

	<a href="https://www.etsy.com/listing/4485879930/debt-payoff-tracker-for-google-sheets" class="btn btn-primary visualizer-cta" target="_blank" rel="noopener noreferrer">
		Get the Debt Payoff Tracker
		<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
	</a>
</div>

<style>
	.visualizer {
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		padding: var(--space-lg) var(--space-md);
		margin: var(--space-lg) 0;
		background: var(--color-bg-surface);
	}

	/* ——— Slider ——— */

	.slider-label {
		display: block;
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		color: var(--color-text-secondary);
		text-align: center;
		margin-bottom: var(--space-2xs);
	}

	.slider-amount {
		font-size: clamp(2rem, 5vw, 2.75rem);
		font-weight: var(--weight-bold);
		color: var(--color-text);
		text-align: center;
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--space-md);
	}

	.slider-input {
		display: block;
		width: 100%;
		height: 6px;
		-webkit-appearance: none;
		appearance: none;
		background: var(--color-border);
		border-radius: 3px;
		outline: none;
		cursor: pointer;
	}
	.slider-input::-webkit-slider-thumb {
		-webkit-appearance: none;
		width: 22px;
		height: 22px;
		border-radius: 50%;
		background: var(--color-btn);
		border: 2px solid var(--color-bg-surface);
		box-shadow: 0 1px 4px rgba(0, 0, 0, 0.15);
		cursor: pointer;
	}
	.slider-input::-moz-range-thumb {
		width: 22px;
		height: 22px;
		border-radius: 50%;
		background: var(--color-btn);
		border: 2px solid var(--color-bg-surface);
		box-shadow: 0 1px 4px rgba(0, 0, 0, 0.15);
		cursor: pointer;
	}

	.slider-range-labels {
		display: flex;
		justify-content: space-between;
		font-size: var(--text-xs);
		color: var(--color-text-muted);
		margin-top: var(--space-2xs);
		margin-bottom: var(--space-lg);
	}

	/* ——— Comparison card ——— */

	.compare-card {
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		padding: var(--space-md);
		margin-bottom: var(--space-md);
	}

	.compare-row {
		margin-bottom: var(--space-md);
	}
	.compare-row:last-of-type {
		margin-bottom: 0;
	}

	.compare-meta {
		display: flex;
		align-items: baseline;
		gap: var(--space-xs);
		margin-bottom: var(--space-2xs);
	}

	.compare-method {
		font-size: var(--text-small);
		font-weight: var(--weight-semibold);
		color: var(--color-text);
	}

	.compare-desc {
		font-size: var(--text-xs);
		color: var(--color-text-muted);
	}

	.compare-track {
		height: 1.5rem;
		background: var(--color-bg-panel);
		border-radius: var(--radius-sm);
		overflow: hidden;
	}

	.compare-fill {
		height: 100%;
		border-radius: var(--radius-sm);
		transition: width 0.35s ease;
	}

	.compare-fill--avalanche {
		background: #42A5F5;
	}

	.compare-fill--snowball {
		background: #E91E63;
	}

	.compare-context {
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		color: var(--color-text);
		text-align: center;
		margin: var(--space-md) 0 0;
		line-height: var(--leading-normal);
	}

	:global(.compare-pct) {
		color: var(--color-accent);
	}

	.compare-note {
		font-size: var(--text-xs);
		color: var(--color-text-muted);
		text-align: center;
		margin: var(--space-xs) 0 0;
		line-height: var(--leading-normal);
	}
	.compare-note:empty {
		display: none;
	}

	/* ——— CTA ——— */

	.visualizer-cta {
		width: 100%;
	}
</style>

<script is:inline define:vars={{ id }}>
(function () {
	var slider = document.getElementById(id + '-range');
	var amountEl = document.getElementById(id + '-amount');
	var avalEl = document.getElementById(id + '-aval');
	var snowEl = document.getElementById(id + '-snow');
	var contextEl = document.getElementById(id + '-context');
	var noteEl = document.getElementById(id + '-note');

	function update() {
		var extra = parseInt(slider.value, 10);
		var t = extra / 1000;

		amountEl.textContent = '$' + extra.toLocaleString('en-US');

		var avalPct = 100 - t * 78;
		var snowPct = 100 - t * 65;

		avalEl.style.width = avalPct + '%';
		snowEl.style.width = snowPct + '%';

		if (extra === 0) {
			contextEl.textContent = 'Drag the slider to see how extra payments affect each strategy differently.';
			noteEl.textContent = '';
		} else {
			var advantage = Math.round((1 - avalPct / snowPct) * 100);
			if (advantage < 1) advantage = 1;
			contextEl.innerHTML = 'Avalanche is saving roughly <strong class="compare-pct">' + advantage + '%</strong> more in interest than Snowball.';

			if (t >= 1) {
				noteEl.textContent = 'The exact dollar amount of these savings depends on your specific interest rates. Use the Debt Payoff Tracker to see your precise savings.';
			} else {
				noteEl.textContent = '';
			}
		}
	}

	slider.addEventListener('input', update);
	update();
})();
</script>
