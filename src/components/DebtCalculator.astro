---
const id = `debt-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="visualizer" id={id}>
	<div class="strategy-section">
		<span class="strategy-label">Strategy</span>
		<div class="strategy-toggle" id={`${id}-toggle`}>
			<button class="strategy-btn active" data-strategy="avalanche">Avalanche</button>
			<button class="strategy-btn" data-strategy="snowball">Snowball</button>
		</div>
		<p class="strategy-hint" id={`${id}-hint`}>Focuses on mathematical efficiency by prioritizing the debt with the highest interest rate.</p>
	</div>

	<label class="slider-label" for={`${id}-range`}>Extra monthly payment</label>
	<div class="slider-amount" id={`${id}-amount`}>$200</div>
	<input
		type="range"
		id={`${id}-range`}
		class="slider-input"
		min="0"
		max="1000"
		step="50"
		value="200"
	/>
	<div class="slider-range-labels">
		<span>$0</span>
		<span>$1,000</span>
	</div>

	<div class="burden-card">
		<span class="burden-label">Interest cost burden</span>
		<div class="burden-track">
			<div class="burden-fill" id={`${id}-fill`}></div>
		</div>
		<p class="burden-statement">Increasing your monthly payment reduces your total interest cost and accelerates your debt-free date regardless of the strategy used.</p>
	</div>

	<a href="https://www.etsy.com/listing/4485879930/debt-payoff-tracker-for-google-sheets" class="visualizer-cta" target="_blank" rel="noopener noreferrer">
		Get the Debt Payoff Tracker Spreadsheet
		<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
	</a>
</div>

<style>
	.visualizer {
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		padding: var(--space-lg) var(--space-md);
		margin: var(--space-lg) 0;
		background: var(--color-bg-surface);
	}

	/* ——— Strategy toggle ——— */

	.strategy-section {
		text-align: center;
		margin-bottom: var(--space-lg);
	}

	.strategy-label {
		display: block;
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		color: var(--color-text-secondary);
		margin-bottom: var(--space-xs);
	}

	.strategy-toggle {
		display: inline-flex;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		overflow: hidden;
	}

	.strategy-btn {
		font-family: var(--font-sans);
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		padding: 0.5rem 1.25rem;
		border: none;
		background: var(--color-bg);
		color: var(--color-text-secondary);
		cursor: pointer;
		transition: background 0.15s, color 0.15s;
	}
	.strategy-btn:not(:last-child) {
		border-right: 1px solid var(--color-border);
	}
	.strategy-btn.active {
		background: var(--color-btn);
		color: var(--color-bg);
	}

	.strategy-hint {
		font-size: var(--text-xs);
		color: var(--color-text-muted);
		margin: var(--space-xs) auto 0;
		line-height: var(--leading-normal);
		max-width: 28rem;
	}

	/* ——— Slider ——— */

	.slider-label {
		display: block;
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		color: var(--color-text-secondary);
		text-align: center;
		margin-bottom: var(--space-2xs);
	}

	.slider-amount {
		font-size: clamp(2rem, 5vw, 2.75rem);
		font-weight: var(--weight-bold);
		color: var(--color-text);
		text-align: center;
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--space-md);
	}

	.slider-input {
		display: block;
		width: 100%;
		height: 6px;
		-webkit-appearance: none;
		appearance: none;
		background: var(--color-border);
		border-radius: 3px;
		outline: none;
		cursor: pointer;
	}
	.slider-input::-webkit-slider-thumb {
		-webkit-appearance: none;
		width: 22px;
		height: 22px;
		border-radius: 50%;
		background: var(--color-btn);
		border: 2px solid var(--color-bg-surface);
		box-shadow: 0 1px 4px rgba(0, 0, 0, 0.15);
		cursor: pointer;
	}
	.slider-input::-moz-range-thumb {
		width: 22px;
		height: 22px;
		border-radius: 50%;
		background: var(--color-btn);
		border: 2px solid var(--color-bg-surface);
		box-shadow: 0 1px 4px rgba(0, 0, 0, 0.15);
		cursor: pointer;
	}

	.slider-range-labels {
		display: flex;
		justify-content: space-between;
		font-size: var(--text-xs);
		color: var(--color-text-muted);
		margin-top: var(--space-2xs);
		margin-bottom: var(--space-lg);
	}

	/* ——— Burden card ——— */

	.burden-card {
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		padding: var(--space-md);
		margin-bottom: var(--space-md);
	}

	.burden-label {
		display: block;
		font-size: var(--text-xs);
		font-weight: var(--weight-medium);
		color: var(--color-text-muted);
		text-align: center;
		margin-bottom: var(--space-sm);
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
	}

	.burden-track {
		height: 2rem;
		background: var(--color-bg-panel);
		border-radius: var(--radius-sm);
		overflow: hidden;
	}

	.burden-fill {
		height: 100%;
		background: var(--color-text);
		border-radius: var(--radius-sm);
		transition: width 0.3s ease;
		width: 80%;
	}

	.burden-statement {
		font-size: var(--text-small);
		line-height: var(--leading-normal);
		color: var(--color-text-secondary);
		text-align: center;
		margin: var(--space-md) 0 0;
	}

	/* ——— CTA ——— */

	.visualizer-cta {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.375rem;
		width: 100%;
		padding: 0.875rem;
		font-family: var(--font-sans);
		font-size: var(--text-body);
		font-weight: var(--weight-semibold);
		color: var(--color-bg);
		background: var(--color-btn);
		border-radius: var(--radius-sm);
		text-decoration: none;
		transition: background 0.15s;
	}
	.visualizer-cta:hover {
		background: var(--color-btn-hover);
	}
</style>

<script is:inline define:vars={{ id }}>
(function () {
	var slider = document.getElementById(id + '-range');
	var amountEl = document.getElementById(id + '-amount');
	var fillEl = document.getElementById(id + '-fill');
	var hintEl = document.getElementById(id + '-hint');
	var toggleEl = document.getElementById(id + '-toggle');
	var btns = toggleEl.querySelectorAll('.strategy-btn');

	var hints = {
		avalanche: 'Focuses on mathematical efficiency by prioritizing the debt with the highest interest rate.',
		snowball: 'Focuses on psychological momentum by prioritizing the debt with the smallest balance.'
	};

	function update() {
		var extra = parseInt(slider.value, 10);
		amountEl.textContent = '$' + extra.toLocaleString('en-US');
		var pct = 100 - (extra / 1000) * 80;
		fillEl.style.width = pct + '%';
	}

	btns.forEach(function (btn) {
		btn.addEventListener('click', function () {
			btns.forEach(function (b) { b.classList.remove('active'); });
			btn.classList.add('active');
			hintEl.textContent = hints[btn.dataset.strategy];
		});
	});

	slider.addEventListener('input', update);
	update();
})();
</script>
