---
const id = `debt-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="impact-slider" id={id}>
	<label class="slider-label" for={`${id}-range`}>Extra monthly payment</label>
	<div class="slider-amount" id={`${id}-amount`}>$200</div>
	<input
		type="range"
		id={`${id}-range`}
		class="slider-input"
		min="0"
		max="1000"
		step="50"
		value="200"
	/>
	<div class="slider-range-labels">
		<span>$0</span>
		<span>$1,000</span>
	</div>

	<div class="impact-card">
		<div class="impact-stats">
			<div class="impact-stat">
				<span class="impact-stat-label">Estimated interest saved</span>
				<span class="impact-stat-value" id={`${id}-saved`}>$8,200</span>
			</div>
			<div class="impact-stat">
				<span class="impact-stat-label">Estimated time saved</span>
				<span class="impact-stat-value" id={`${id}-time`}>3 years sooner</span>
			</div>
		</div>
		<p class="impact-note">Based on $30,000 in debt at a 7% average rate with minimum payments of $600/mo.</p>
	</div>

	<a href="https://www.etsy.com/listing/4485879930/debt-payoff-tracker-for-google-sheets" class="impact-cta" target="_blank" rel="noopener noreferrer">
		Get the Debt Payoff Tracker Spreadsheet
		<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
	</a>
</div>

<style>
	.impact-slider {
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		padding: var(--space-lg) var(--space-md);
		margin: var(--space-lg) 0;
		background: var(--color-bg-surface);
	}

	.slider-label {
		display: block;
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		color: var(--color-text-secondary);
		text-align: center;
		margin-bottom: var(--space-2xs);
	}

	.slider-amount {
		font-size: clamp(2rem, 5vw, 2.75rem);
		font-weight: var(--weight-bold);
		color: var(--color-text);
		text-align: center;
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--space-md);
	}

	.slider-input {
		display: block;
		width: 100%;
		height: 6px;
		-webkit-appearance: none;
		appearance: none;
		background: var(--color-border);
		border-radius: 3px;
		outline: none;
		cursor: pointer;
	}
	.slider-input::-webkit-slider-thumb {
		-webkit-appearance: none;
		width: 22px;
		height: 22px;
		border-radius: 50%;
		background: var(--color-btn);
		border: 2px solid var(--color-bg-surface);
		box-shadow: 0 1px 4px rgba(0, 0, 0, 0.15);
		cursor: pointer;
	}
	.slider-input::-moz-range-thumb {
		width: 22px;
		height: 22px;
		border-radius: 50%;
		background: var(--color-btn);
		border: 2px solid var(--color-bg-surface);
		box-shadow: 0 1px 4px rgba(0, 0, 0, 0.15);
		cursor: pointer;
	}

	.slider-range-labels {
		display: flex;
		justify-content: space-between;
		font-size: var(--text-xs);
		color: var(--color-text-muted);
		margin-top: var(--space-2xs);
		margin-bottom: var(--space-lg);
	}

	.impact-card {
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		padding: var(--space-md);
		margin-bottom: var(--space-md);
	}

	.impact-stats {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-md);
	}

	.impact-stat {
		text-align: center;
	}

	.impact-stat-label {
		display: block;
		font-size: var(--text-xs);
		color: var(--color-text-muted);
		margin-bottom: var(--space-2xs);
	}

	.impact-stat-value {
		display: block;
		font-size: var(--text-h2);
		font-weight: var(--weight-bold);
		color: var(--color-text);
		letter-spacing: var(--tracking-tight);
	}

	.impact-note {
		font-size: var(--text-xs);
		color: var(--color-text-muted);
		text-align: center;
		margin: var(--space-sm) 0 0;
		line-height: var(--leading-normal);
	}

	.impact-cta {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.375rem;
		width: 100%;
		padding: 0.875rem;
		font-family: var(--font-sans);
		font-size: var(--text-body);
		font-weight: var(--weight-semibold);
		color: var(--color-bg);
		background: var(--color-btn);
		border-radius: var(--radius-sm);
		text-decoration: none;
		transition: background 0.15s;
	}
	.impact-cta:hover {
		background: var(--color-btn-hover);
	}

	@media (max-width: 480px) {
		.impact-stats {
			grid-template-columns: 1fr;
			gap: var(--space-sm);
		}
	}
</style>

<script is:inline define:vars={{ id }}>
(function () {
	var slider = document.getElementById(id + '-range');
	var amountEl = document.getElementById(id + '-amount');
	var savedEl = document.getElementById(id + '-saved');
	var timeEl = document.getElementById(id + '-time');

	var BALANCE = 30000;
	var RATE = 0.07;
	var MIN_PAYMENT = 600;

	function simulate(extra) {
		var balance = BALANCE;
		var totalInterest = 0;
		var months = 0;
		var monthlyRate = RATE / 12;

		while (balance > 0 && months < 1200) {
			months++;
			var interest = balance * monthlyRate;
			totalInterest += interest;
			balance += interest;
			var payment = Math.min(MIN_PAYMENT + extra, balance);
			balance -= payment;
			if (balance < 0.01) balance = 0;
		}

		return { months: months, totalInterest: totalInterest };
	}

	function update() {
		var extra = parseInt(slider.value, 10);
		amountEl.textContent = '$' + extra.toLocaleString('en-US');

		var baseline = simulate(0);
		var withExtra = simulate(extra);

		var interestSaved = Math.round(baseline.totalInterest - withExtra.totalInterest);
		var monthsSaved = baseline.months - withExtra.months;

		savedEl.textContent = '$' + interestSaved.toLocaleString('en-US');

		if (monthsSaved <= 0) {
			timeEl.textContent = 'Same timeline';
		} else if (monthsSaved < 12) {
			timeEl.textContent = monthsSaved + (monthsSaved === 1 ? ' month sooner' : ' months sooner');
		} else {
			var years = Math.floor(monthsSaved / 12);
			var mos = monthsSaved % 12;
			if (mos === 0) {
				timeEl.textContent = years + (years === 1 ? ' year sooner' : ' years sooner');
			} else {
				timeEl.textContent = years + (years === 1 ? ' yr' : ' yrs') + ' ' + mos + (mos === 1 ? ' mo' : ' mos') + ' sooner';
			}
		}
	}

	slider.addEventListener('input', update);
	update();
})();
</script>
