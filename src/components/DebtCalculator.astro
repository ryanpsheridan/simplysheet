---
const id = `debt-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="impact-slider" id={id}>
	<div class="strategy-section">
		<span class="strategy-label">Strategy</span>
		<div class="strategy-toggle" id={`${id}-toggle`}>
			<button class="strategy-btn active" data-strategy="avalanche">Avalanche</button>
			<button class="strategy-btn" data-strategy="snowball">Snowball</button>
		</div>
		<p class="strategy-hint">Avalanche focuses on interest savings; Snowball focuses on quick wins.</p>
	</div>

	<label class="slider-label" for={`${id}-range`}>Extra monthly payment</label>
	<div class="slider-amount" id={`${id}-amount`}>$200</div>
	<input
		type="range"
		id={`${id}-range`}
		class="slider-input"
		min="0"
		max="1000"
		step="50"
		value="200"
	/>
	<div class="slider-range-labels">
		<span>$0</span>
		<span>$1,000</span>
	</div>

	<div class="impact-card">
		<div class="impact-stats">
			<div class="impact-stat">
				<span class="impact-stat-label">Estimated interest saved</span>
				<span class="impact-stat-value" id={`${id}-saved`}>$8,200</span>
			</div>
			<div class="impact-stat">
				<span class="impact-stat-label">Estimated time saved</span>
				<span class="impact-stat-value" id={`${id}-time`}>3 years sooner</span>
			</div>
		</div>
		<p class="impact-note">Based on $30,000 across three debts at varying rates with minimum payments totaling $600/mo. Your results will differ.</p>
	</div>

	<a href="https://www.etsy.com/listing/4485879930/debt-payoff-tracker-for-google-sheets" class="impact-cta" target="_blank" rel="noopener noreferrer">
		Get the Debt Payoff Tracker Spreadsheet
		<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
	</a>
</div>

<style>
	.impact-slider {
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		padding: var(--space-lg) var(--space-md);
		margin: var(--space-lg) 0;
		background: var(--color-bg-surface);
	}

	/* ——— Strategy toggle ——— */

	.strategy-section {
		text-align: center;
		margin-bottom: var(--space-lg);
	}

	.strategy-label {
		display: block;
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		color: var(--color-text-secondary);
		margin-bottom: var(--space-xs);
	}

	.strategy-toggle {
		display: inline-flex;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		overflow: hidden;
	}

	.strategy-btn {
		font-family: var(--font-sans);
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		padding: 0.5rem 1.25rem;
		border: none;
		background: var(--color-bg);
		color: var(--color-text-secondary);
		cursor: pointer;
		transition: background 0.15s, color 0.15s;
	}
	.strategy-btn:not(:last-child) {
		border-right: 1px solid var(--color-border);
	}
	.strategy-btn.active {
		background: var(--color-btn);
		color: var(--color-bg);
	}

	.strategy-hint {
		font-size: var(--text-xs);
		color: var(--color-text-muted);
		margin: var(--space-xs) 0 0;
		line-height: var(--leading-normal);
	}

	/* ——— Slider ——— */

	.slider-label {
		display: block;
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		color: var(--color-text-secondary);
		text-align: center;
		margin-bottom: var(--space-2xs);
	}

	.slider-amount {
		font-size: clamp(2rem, 5vw, 2.75rem);
		font-weight: var(--weight-bold);
		color: var(--color-text);
		text-align: center;
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--space-md);
	}

	.slider-input {
		display: block;
		width: 100%;
		height: 6px;
		-webkit-appearance: none;
		appearance: none;
		background: var(--color-border);
		border-radius: 3px;
		outline: none;
		cursor: pointer;
	}
	.slider-input::-webkit-slider-thumb {
		-webkit-appearance: none;
		width: 22px;
		height: 22px;
		border-radius: 50%;
		background: var(--color-btn);
		border: 2px solid var(--color-bg-surface);
		box-shadow: 0 1px 4px rgba(0, 0, 0, 0.15);
		cursor: pointer;
	}
	.slider-input::-moz-range-thumb {
		width: 22px;
		height: 22px;
		border-radius: 50%;
		background: var(--color-btn);
		border: 2px solid var(--color-bg-surface);
		box-shadow: 0 1px 4px rgba(0, 0, 0, 0.15);
		cursor: pointer;
	}

	.slider-range-labels {
		display: flex;
		justify-content: space-between;
		font-size: var(--text-xs);
		color: var(--color-text-muted);
		margin-top: var(--space-2xs);
		margin-bottom: var(--space-lg);
	}

	/* ——— Impact card ——— */

	.impact-card {
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		padding: var(--space-md);
		margin-bottom: var(--space-md);
	}

	.impact-stats {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-md);
	}

	.impact-stat {
		text-align: center;
	}

	.impact-stat-label {
		display: block;
		font-size: var(--text-xs);
		color: var(--color-text-muted);
		margin-bottom: var(--space-2xs);
	}

	.impact-stat-value {
		display: block;
		font-size: var(--text-h2);
		font-weight: var(--weight-bold);
		color: var(--color-text);
		letter-spacing: var(--tracking-tight);
	}

	.impact-note {
		font-size: var(--text-xs);
		color: var(--color-text-muted);
		text-align: center;
		margin: var(--space-sm) 0 0;
		line-height: var(--leading-normal);
	}

	/* ——— CTA ——— */

	.impact-cta {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.375rem;
		width: 100%;
		padding: 0.875rem;
		font-family: var(--font-sans);
		font-size: var(--text-body);
		font-weight: var(--weight-semibold);
		color: var(--color-bg);
		background: var(--color-btn);
		border-radius: var(--radius-sm);
		text-decoration: none;
		transition: background 0.15s;
	}
	.impact-cta:hover {
		background: var(--color-btn-hover);
	}

	@media (max-width: 480px) {
		.impact-stats {
			grid-template-columns: 1fr;
			gap: var(--space-sm);
		}
	}
</style>

<script is:inline define:vars={{ id }}>
(function () {
	var slider = document.getElementById(id + '-range');
	var amountEl = document.getElementById(id + '-amount');
	var savedEl = document.getElementById(id + '-saved');
	var timeEl = document.getElementById(id + '-time');
	var toggleEl = document.getElementById(id + '-toggle');
	var btns = toggleEl.querySelectorAll('.strategy-btn');

	var strategy = 'avalanche';

	var DEBTS = [
		{ balance: 2800, rate: 0.049, minPay: 75 },
		{ balance: 9200, rate: 0.219, minPay: 185 },
		{ balance: 18000, rate: 0.129, minPay: 340 }
	];

	function simulate(debts, extra) {
		var accounts = debts.map(function (d) {
			return { balance: d.balance, rate: d.rate, minPay: d.minPay, interest: 0 };
		});
		var totalInterest = 0;
		var month = 0;
		var rollingExtra = extra;

		while (month < 1200) {
			var allPaid = true;
			for (var i = 0; i < accounts.length; i++) {
				if (accounts[i].balance > 0) { allPaid = false; break; }
			}
			if (allPaid) break;
			month++;

			for (var i = 0; i < accounts.length; i++) {
				var a = accounts[i];
				if (a.balance <= 0) continue;
				var interest = a.balance * a.rate / 12;
				a.balance += interest;
				a.interest += interest;
				totalInterest += interest;
				var payment = Math.min(a.minPay, a.balance);
				a.balance -= payment;
				if (a.balance < 0.01) {
					rollingExtra += a.minPay;
					a.balance = 0;
				}
			}

			var pool = rollingExtra;
			for (var i = 0; i < accounts.length; i++) {
				var a = accounts[i];
				if (a.balance <= 0 || pool <= 0) continue;
				var apply = Math.min(pool, a.balance);
				a.balance -= apply;
				pool -= apply;
				if (a.balance < 0.01) {
					rollingExtra += a.minPay;
					a.balance = 0;
				}
			}
		}
		return { months: month, totalInterest: totalInterest };
	}

	function sortedDebts(method) {
		var copy = DEBTS.map(function (d) { return { balance: d.balance, rate: d.rate, minPay: d.minPay }; });
		if (method === 'avalanche') {
			copy.sort(function (a, b) { return b.rate - a.rate; });
		} else {
			copy.sort(function (a, b) { return a.balance - b.balance; });
		}
		return copy;
	}

	function formatTime(monthsSaved) {
		if (monthsSaved <= 0) return 'Same timeline';
		if (monthsSaved < 12) return monthsSaved + (monthsSaved === 1 ? ' month sooner' : ' months sooner');
		var years = Math.floor(monthsSaved / 12);
		var mos = monthsSaved % 12;
		if (mos === 0) return years + (years === 1 ? ' year sooner' : ' years sooner');
		return years + (years === 1 ? ' yr' : ' yrs') + ' ' + mos + (mos === 1 ? ' mo' : ' mos') + ' sooner';
	}

	var baselineResult = simulate(DEBTS.slice(), 0);

	function update() {
		var extra = parseInt(slider.value, 10);
		amountEl.textContent = '$' + extra.toLocaleString('en-US');

		var debts = sortedDebts(strategy);
		var withExtra = simulate(debts, extra);

		var interestSaved = Math.round(baselineResult.totalInterest - withExtra.totalInterest);
		var monthsSaved = baselineResult.months - withExtra.months;

		savedEl.textContent = '$' + interestSaved.toLocaleString('en-US');
		timeEl.textContent = formatTime(monthsSaved);
	}

	btns.forEach(function (btn) {
		btn.addEventListener('click', function () {
			btns.forEach(function (b) { b.classList.remove('active'); });
			btn.classList.add('active');
			strategy = btn.dataset.strategy;
			update();
		});
	});

	slider.addEventListener('input', update);
	update();
})();
</script>
