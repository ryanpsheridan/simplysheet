---
const id = `debt-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="visualizer" id={id}>
	<label class="slider-label" for={`${id}-range`}>Extra monthly payment</label>
	<div class="slider-amount" id={`${id}-amount`}>$200</div>
	<input
		type="range"
		id={`${id}-range`}
		class="slider-input"
		min="0"
		max="1000"
		step="50"
		value="200"
	/>
	<div class="slider-range-labels">
		<span>$0</span>
		<span>$1,000</span>
	</div>

	<div class="compare-card">
		<div class="compare-row">
			<div class="compare-meta">
				<span class="compare-method compare-method--avalanche">Avalanche</span>
				<span class="compare-desc">Highest rate first</span>
			</div>
			<div class="compare-track">
				<div class="compare-fill compare-fill--avalanche" id={`${id}-aval`}></div>
			</div>
		</div>
		<div class="compare-row">
			<div class="compare-meta">
				<span class="compare-method compare-method--snowball">Snowball</span>
				<span class="compare-desc">Smallest balance first</span>
			</div>
			<div class="compare-track">
				<div class="compare-fill compare-fill--snowball" id={`${id}-snow`}></div>
			</div>
		</div>
		<p class="compare-context" id={`${id}-context`}>Avalanche is saving roughly 8% more in interest than Snowball.</p>
		<p class="compare-note" id={`${id}-note`}></p>
	</div>

</div>
<div class="calc-cta-divider"></div>
<a href="/spreadsheets/debt-payoff-tracker/" class="calc-product-link">Track your debt payoff <span class="arrow">&rarr;</span></a>

<style>
	/* No card, border, or fill — the visualizer sits directly in the page column. */
	.visualizer {
		border-top: 1px solid var(--color-border);
		padding-top: var(--space-lg);
		margin: var(--space-lg) 0;
	}

	/* ——— Slider ——— */

	.slider-label {
		display: block;
		font-size: var(--text-small);
		font-weight: var(--weight-normal);
		color: var(--color-text-secondary);
		text-align: center;
		margin-bottom: var(--space-2xs);
	}

	.slider-amount {
		font-size: clamp(2rem, 5vw, 2.75rem);
		font-weight: var(--weight-normal);
		color: var(--color-text);
		text-align: center;
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--space-md);
	}

	.slider-input {
		display: block;
		width: 100%;
		height: 6px;
		-webkit-appearance: none;
		appearance: none;
		background: var(--color-border);
		border-radius: 3px;
		outline: none;
		cursor: pointer;
	}
	.slider-input::-webkit-slider-thumb {
		-webkit-appearance: none;
		width: 22px;
		height: 22px;
		border-radius: 50%;
		background: var(--color-btn);
		border: 2px solid var(--color-bg-surface);
		box-shadow: 0 1px 4px rgba(0, 0, 0, 0.15);
		cursor: pointer;
	}
	.slider-input::-moz-range-thumb {
		width: 22px;
		height: 22px;
		border-radius: 50%;
		background: var(--color-btn);
		border: 2px solid var(--color-bg-surface);
		box-shadow: 0 1px 4px rgba(0, 0, 0, 0.15);
		cursor: pointer;
	}

	.slider-range-labels {
		display: flex;
		justify-content: space-between;
		font-size: var(--text-xs);
		color: var(--color-text-secondary);
		margin-top: var(--space-2xs);
		margin-bottom: var(--space-lg);
	}

	/* ——— Comparison card: the one tinted card in the layout, reserved for the result ——— */

	.compare-card {
		background: var(--color-bg-panel);
		border-radius: var(--radius-md);
		padding: var(--space-md);
		margin-bottom: var(--space-md);
	}

	.compare-row {
		margin-bottom: var(--space-md);
	}
	.compare-row:last-of-type {
		margin-bottom: 0;
	}

	.compare-meta {
		display: flex;
		align-items: baseline;
		gap: var(--space-xs);
		margin-bottom: var(--space-2xs);
	}

	.compare-method {
		font-size: var(--text-small);
		font-weight: var(--weight-normal);
		color: var(--color-text);
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
	}
	.compare-method::before {
		content: '';
		width: 0.5rem;
		height: 0.5rem;
		border-radius: 50%;
		flex-shrink: 0;
	}
	.compare-method--avalanche::before {
		background: var(--color-debt-avalanche);
	}
	.compare-method--snowball::before {
		background: var(--color-debt-snowball);
	}

	.compare-desc {
		font-size: var(--text-xs);
		color: var(--color-text-secondary);
	}

	.compare-track {
		height: 1.5rem;
		background: var(--color-bg-surface);
		border-radius: var(--radius-sm);
		overflow: hidden;
	}

	.compare-fill {
		height: 100%;
		border-radius: var(--radius-sm);
		transition: width 0.35s ease;
	}

	.compare-fill--avalanche {
		background: var(--color-debt-avalanche);
	}

	.compare-fill--snowball {
		background: var(--color-debt-snowball);
	}

	.compare-context {
		font-size: var(--text-small);
		font-weight: var(--weight-normal);
		color: var(--color-text);
		text-align: center;
		margin: var(--space-md) 0 0;
		line-height: var(--leading-normal);
	}

	:global(.compare-pct) {
		color: var(--color-link);
	}

	.compare-note {
		font-size: var(--text-xs);
		color: var(--color-text-secondary);
		text-align: center;
		margin: var(--space-xs) 0 0;
		line-height: var(--leading-normal);
	}
	.compare-note:empty {
		display: none;
	}

	/* ——— Product link ——— */

	.calc-cta-divider {
		height: 1px;
		background: var(--color-border);
		margin-top: var(--space-lg);
	}
	.calc-product-link {
		display: block;
		width: fit-content;
		color: var(--color-accent-info);
		margin-top: var(--space-md);
		margin-bottom: var(--space-lg);
		font-size: 0.875rem;
		text-decoration: none;
	}
	.calc-product-link:hover {
		text-decoration: underline;
	}
	.calc-product-link .arrow {
		display: inline-block;
		transition: transform 0.15s ease;
	}
	.calc-product-link:hover .arrow {
		transform: translateX(2px);
	}

	/* ——— Responsive ——— */

	@media (max-width: 767px) {
		.visualizer {
			padding-top: var(--space-md);
		}
	}
</style>

<script is:inline define:vars={{ id }}>
(function () {
	var slider = document.getElementById(id + '-range');
	var amountEl = document.getElementById(id + '-amount');
	var avalEl = document.getElementById(id + '-aval');
	var snowEl = document.getElementById(id + '-snow');
	var contextEl = document.getElementById(id + '-context');
	var noteEl = document.getElementById(id + '-note');

	function update() {
		var extra = parseInt(slider.value, 10);
		var t = extra / 1000;

		amountEl.textContent = '$' + extra.toLocaleString('en-US');

		var avalPct = 100 - t * 78;
		var snowPct = 100 - t * 65;

		avalEl.style.width = avalPct + '%';
		snowEl.style.width = snowPct + '%';

		if (extra === 0) {
			contextEl.textContent = 'Drag the slider to see how extra payments affect each strategy differently.';
		} else {
			var advantage = Math.round((1 - avalPct / snowPct) * 100);
			if (advantage < 1) advantage = 1;
			contextEl.innerHTML = 'Avalanche is saving roughly <strong class="compare-pct">' + advantage + '%</strong> more in interest than Snowball.';
		}
		noteEl.textContent = 'The exact savings depend on your specific interest rates and balances. Use the Debt Payoff Tracker to see your precise numbers.';
	}

	slider.addEventListener('input', update);
	update();
})();
</script>
