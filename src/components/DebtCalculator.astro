---
const id = `debt-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="visualizer" id={id}>
	<div class="calc-input-group">
		<label class="calc-label" for={`${id}-total`}>Total debt balance</label>
		<div class="calc-field">
			<span class="calc-prefix">$</span>
			<input
				type="text"
				id={`${id}-total`}
				class="calc-input"
				inputmode="decimal"
				value="10,000"
				autocomplete="off"
			/>
		</div>
	</div>

	<div class="slider-group">
		<label class="slider-label" for={`${id}-range`}>Extra monthly payment</label>
		<div class="slider-amount" id={`${id}-amount`}>$200</div>
		<input
			type="range"
			id={`${id}-range`}
			class="slider-input"
			min="0"
			max="1000"
			step="50"
			value="200"
		/>
		<div class="slider-range-labels">
			<span>$0</span>
			<span>$1,000</span>
		</div>
	</div>

	<div class="compare-card">
		<p class="compare-heading">Total interest paid <span class="compare-heading-hint">(shorter is better)</span></p>
		<div class="compare-row">
			<div class="compare-meta">
				<span class="compare-method compare-method--avalanche">Avalanche</span>
				<span class="compare-desc">Highest rate first</span>
			</div>
			<div class="compare-bar-row">
				<div class="compare-track">
					<div class="compare-fill compare-fill--avalanche" id={`${id}-aval`}></div>
				</div>
				<span class="compare-value" id={`${id}-aval-value`}>$0</span>
			</div>
		</div>
		<div class="compare-row">
			<div class="compare-meta">
				<span class="compare-method compare-method--snowball">Snowball</span>
				<span class="compare-desc">Smallest balance first</span>
			</div>
			<div class="compare-bar-row">
				<div class="compare-track">
					<div class="compare-fill compare-fill--snowball" id={`${id}-snow`}></div>
				</div>
				<span class="compare-value" id={`${id}-snow-value`}>$0</span>
			</div>
		</div>
		<p class="compare-context" id={`${id}-context`}></p>
	</div>

	<p class="compare-note">Estimated using typical interest rates — actual results may vary.</p>
</div>
<div class="calc-cta-divider"></div>
<a href="/spreadsheets/debt-payoff-tracker/" class="calc-product-link">Track your debt payoff <span class="arrow">&rarr;</span></a>

<style>
	/* No card, border, or fill — the visualizer sits directly in the page column. */
	.visualizer {
		border-top: 1px solid var(--color-border);
		padding-top: var(--space-lg);
		margin: var(--space-lg) 0;
	}

	/* ——— Total debt input ——— */

	.calc-input-group {
		margin-bottom: var(--space-lg);
	}
	.calc-label {
		display: block;
		font-size: var(--text-small);
		font-weight: var(--weight-normal);
		color: var(--color-text);
		margin-bottom: var(--space-xs);
	}
	.calc-field {
		display: flex;
		align-items: center;
		height: 2.75rem;
		box-sizing: border-box;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		overflow: hidden;
		background: var(--color-bg-surface);
		transition: border-color 0.15s;
	}
	.calc-field:focus-within {
		border-color: var(--color-link);
	}
	.calc-prefix {
		padding: 0.625rem 0 0.625rem 0.75rem;
		font-size: var(--text-body);
		color: var(--color-text-muted);
		user-select: none;
	}
	.calc-input {
		flex: 1;
		border: none;
		outline: none;
		font-family: var(--font-sans);
		font-size: var(--text-body);
		padding: 0.625rem 0.75rem 0.625rem 0.25rem;
		color: var(--color-text);
		background: transparent;
	}

	/* ——— Slider ——— */

	.slider-group {
		margin-bottom: var(--space-lg);
	}

	.slider-label {
		display: block;
		font-size: var(--text-small);
		font-weight: var(--weight-normal);
		color: var(--color-text-secondary);
		margin-bottom: var(--space-2xs);
	}

	.slider-amount {
		font-size: clamp(2rem, 5vw, 2.75rem);
		font-weight: var(--weight-normal);
		color: var(--color-text);
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--space-md);
	}

	.slider-input {
		display: block;
		width: 100%;
		height: 6px;
		-webkit-appearance: none;
		appearance: none;
		background: var(--color-border);
		border-radius: 3px;
		outline: none;
		cursor: pointer;
	}
	.slider-input::-webkit-slider-thumb {
		-webkit-appearance: none;
		width: 22px;
		height: 22px;
		border-radius: 50%;
		background: var(--color-btn);
		border: 2px solid var(--color-bg-surface);
		box-shadow: 0 1px 4px rgba(0, 0, 0, 0.15);
		cursor: pointer;
	}
	.slider-input::-moz-range-thumb {
		width: 22px;
		height: 22px;
		border-radius: 50%;
		background: var(--color-btn);
		border: 2px solid var(--color-bg-surface);
		box-shadow: 0 1px 4px rgba(0, 0, 0, 0.15);
		cursor: pointer;
	}

	.slider-range-labels {
		display: flex;
		justify-content: space-between;
		font-size: var(--text-xs);
		color: var(--color-text-secondary);
		margin-top: var(--space-2xs);
	}

	/* ——— Comparison: no card — sits flush on the page like the rest of the site ——— */

	.compare-card {
		margin-bottom: var(--space-md);
	}

	.compare-heading {
		font-size: var(--text-xs);
		color: var(--color-text-secondary);
		margin: 0 0 var(--space-sm);
	}
	.compare-heading-hint {
		color: var(--color-text-muted);
	}

	.compare-row {
		margin-bottom: var(--space-md);
	}
	.compare-row:last-of-type {
		margin-bottom: 0;
	}

	.compare-meta {
		display: flex;
		align-items: baseline;
		gap: var(--space-xs);
		margin-bottom: var(--space-2xs);
	}

	.compare-method {
		font-size: var(--text-small);
		font-weight: var(--weight-normal);
		color: var(--color-text);
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
	}
	.compare-method::before {
		content: '';
		width: 0.5rem;
		height: 0.5rem;
		border-radius: 50%;
		flex-shrink: 0;
	}
	.compare-method--avalanche::before {
		background: var(--color-debt-avalanche);
	}
	.compare-method--snowball::before {
		background: var(--color-debt-snowball);
	}

	.compare-desc {
		font-size: var(--text-xs);
		color: var(--color-text-secondary);
	}

	/* Track + value sit in one row; the track shrinks first so the dollar
	   figure never wraps or gets pushed off narrow screens. */
	.compare-bar-row {
		display: flex;
		align-items: center;
		gap: var(--space-sm);
	}

	.compare-track {
		flex: 1;
		min-width: 0;
		height: 1.5rem;
		background: var(--color-bg-panel);
		border-radius: var(--radius-sm);
		overflow: hidden;
	}

	.compare-fill {
		height: 100%;
		border-radius: var(--radius-sm);
		transition: width 0.35s ease;
	}

	.compare-fill--avalanche {
		background: var(--color-debt-avalanche);
	}

	.compare-fill--snowball {
		background: var(--color-debt-snowball);
	}

	.compare-value {
		flex-shrink: 0;
		width: 4.5rem;
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		color: var(--color-text);
		text-align: right;
		font-variant-numeric: tabular-nums;
	}

	.compare-context {
		font-size: var(--text-small);
		font-weight: var(--weight-normal);
		color: var(--color-text);
		margin: var(--space-md) 0 0;
		line-height: var(--leading-normal);
	}
	.compare-context:empty {
		display: none;
	}

	:global(.compare-highlight) {
		color: var(--color-debt-avalanche);
	}

	.compare-note {
		font-size: var(--text-xs);
		color: var(--color-text-secondary);
		margin: 0;
		line-height: var(--leading-normal);
	}

	/* ——— Product link ——— */

	.calc-cta-divider {
		height: 1px;
		background: var(--color-border);
		margin-top: var(--space-lg);
	}
	.calc-product-link {
		display: block;
		width: fit-content;
		color: var(--color-accent-info);
		margin-top: var(--space-md);
		margin-bottom: var(--space-lg);
		font-size: 0.875rem;
		text-decoration: none;
	}
	.calc-product-link:hover {
		text-decoration: underline;
	}
	.calc-product-link .arrow {
		display: inline-block;
		transition: transform 0.15s ease;
	}
	.calc-product-link:hover .arrow {
		transform: translateX(2px);
	}

	/* ——— Responsive ——— */

	@media (max-width: 767px) {
		.visualizer {
			padding-top: var(--space-md);
		}
		.compare-value {
			width: 4rem;
			font-size: var(--text-xs);
		}
	}
</style>

<script is:inline define:vars={{ id }}>
(function () {
	var totalInput = document.getElementById(id + '-total');
	var slider = document.getElementById(id + '-range');
	var amountEl = document.getElementById(id + '-amount');
	var avalEl = document.getElementById(id + '-aval');
	var snowEl = document.getElementById(id + '-snow');
	var avalValueEl = document.getElementById(id + '-aval-value');
	var snowValueEl = document.getElementById(id + '-snow-value');
	var contextEl = document.getElementById(id + '-context');

	// Illustrative three-card shape (relative balances + APRs), scaled to
	// whatever total the user enters above. Sized so avalanche and snowball
	// genuinely disagree on priority order: the highest-rate card also
	// carries the largest balance, and the lowest-rate card the smallest, so
	// avalanche (highest rate first) and snowball (smallest balance first)
	// attack the debts in opposite order. Minimum payments scale with each
	// card's balance (2.5%), same as the baseline shape.
	var BASELINE_SHARE = [
		{ share: 0.53, apr: 0.26 },
		{ share: 0.35, apr: 0.19 },
		{ share: 0.12, apr: 0.14 }
	];
	var MIN_PAYMENT_RATE = 0.025;

	function buildDebts(total) {
		return BASELINE_SHARE.map(function (d) {
			var balance = total * d.share;
			return { balance: balance, apr: d.apr, minPayment: balance * MIN_PAYMENT_RATE };
		});
	}

	// Simulates paying down `order` (a priority-sorted list of debts) with a
	// fixed monthly budget of (sum of minimums + extra), redirecting every
	// dollar beyond minimums to the highest-priority debt still owing —
	// exactly how the snowball/avalanche methods work in practice. Returns
	// total interest paid and months to $0 across all debts.
	function simulate(order, extra) {
		var debts = order.map(function (d) {
			return { balance: d.balance, apr: d.apr, minPayment: d.minPayment };
		});
		var totalInterest = 0;
		var months = 0;
		var MAX_MONTHS = 600; // 50-year safety cap

		while (months < MAX_MONTHS && debts.some(function (d) { return d.balance > 0.01; })) {
			months++;

			debts.forEach(function (d) {
				if (d.balance > 0) {
					var interest = d.balance * (d.apr / 12);
					totalInterest += interest;
					d.balance += interest;
				}
			});

			var budget = extra;
			debts.forEach(function (d) { if (d.balance > 0) budget += d.minPayment; });

			var target = debts.find(function (d) { return d.balance > 0; });
			debts.forEach(function (d) {
				if (d !== target && d.balance > 0) {
					var pay = Math.min(d.minPayment, d.balance);
					d.balance -= pay;
					budget -= pay;
				}
			});

			// Apply everything left to the priority target, cascading any
			// leftover to the next debt(s) in line the same month.
			while (budget > 0.01) {
				var next = debts.find(function (d) { return d.balance > 0.01; });
				if (!next) break;
				var pay = Math.min(budget, next.balance);
				next.balance -= pay;
				budget -= pay;
			}
		}

		return { interest: totalInterest, months: months };
	}

	function formatCurrency(n) {
		return '$' + Math.round(n).toLocaleString('en-US');
	}

	function formatInput(val) {
		var num = val.replace(/[^0-9.]/g, '');
		var parts = num.split('.');
		if (parts[0]) parts[0] = parseInt(parts[0], 10).toLocaleString('en-US');
		return parts.join('.');
	}

	function update() {
		var rawTotal = totalInput.value.replace(/[^0-9.]/g, '');
		var total = parseFloat(rawTotal) || 0;
		var extra = parseInt(slider.value, 10);
		amountEl.textContent = '$' + extra.toLocaleString('en-US');

		var debts = buildDebts(total);
		var avalancheOrder = debts.slice().sort(function (a, b) { return b.apr - a.apr; });
		var snowballOrder = debts.slice().sort(function (a, b) { return a.balance - b.balance; });

		var aval = simulate(avalancheOrder, extra);
		var snow = simulate(snowballOrder, extra);

		// Bars represent total interest paid — shorter is the goal — scaled
		// against whichever method costs more, so the pricier one always
		// fills the full track and the cheaper one visibly falls short of it.
		var maxInterest = Math.max(aval.interest, snow.interest, 1);
		avalEl.style.width = (aval.interest / maxInterest * 100) + '%';
		snowEl.style.width = (snow.interest / maxInterest * 100) + '%';
		avalValueEl.textContent = formatCurrency(aval.interest);
		snowValueEl.textContent = formatCurrency(snow.interest);

		if (extra === 0 || total <= 0) {
			contextEl.textContent = '';
		} else {
			var interestSaved = Math.round(snow.interest - aval.interest);
			var monthsFaster = snow.months - aval.months;

			var html = 'Avalanche saves you <strong class="compare-highlight">' +
				formatCurrency(interestSaved) + ' more</strong> in interest';
			if (monthsFaster > 0) {
				html += ' and gets you debt-free <strong class="compare-highlight">' +
					monthsFaster + (monthsFaster === 1 ? ' month' : ' months') + ' faster</strong>.';
			} else {
				html += ', in the same amount of time.';
			}
			contextEl.innerHTML = html;
		}
	}

	totalInput.addEventListener('input', function () {
		var pos = totalInput.selectionStart;
		var before = totalInput.value.length;
		totalInput.value = formatInput(totalInput.value);
		var after = totalInput.value.length;
		totalInput.setSelectionRange(pos + (after - before), pos + (after - before));
		update();
	});
	slider.addEventListener('input', update);
	update();
})();
</script>
