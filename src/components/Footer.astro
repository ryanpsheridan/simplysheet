---
import { ETSY_SHOP_URL, withEtsyTracking } from '../consts';

const year = new Date().getFullYear();
---

<footer>
	<div class="footer-inner">
		<div class="footer-top">
			<div class="footer-brand">
				<a href="/" class="footer-logo-link">
					<img src="/images/logo-svg.svg" alt="Simply Sheet Design logo" class="footer-logo" width="28" height="30" />
					<span>Simply Sheet Design</span>
				</a>
				<p class="footer-tagline">Budget spreadsheets that actually get used.</p>
			</div>

			<nav class="footer-nav" aria-label="Footer navigation">
				<div class="footer-col">
					<p class="footer-heading">Site</p>
					<ul>
						<li><a href="/">Home</a></li>
						<li><a href="/articles/">Articles</a></li>
						<li><a href="/tools/">Tools</a></li>
						<li><a href="/quiz/budgeting-style/">Budgeting Style Quiz</a></li>
						<li><a href="/about/">About</a></li>
					</ul>
				</div>
				<div class="footer-col">
					<p class="footer-heading">Spreadsheets</p>
					<ul>
						<li><a href="/spreadsheets/budget-spreadsheet/">Budget Spreadsheet</a></li>
						<li><a href="/spreadsheets/couples-budget-spreadsheet/">Couples Budget</a></li>
						<li><a href="/spreadsheets/debt-payoff-tracker/">Debt Payoff Tracker</a></li>
						<li><a href="/spreadsheets/savings-goals-tracker/">Savings Goals Tracker</a></li>
						<li><a href="/spreadsheets/" class="footer-view-all">View all</a></li>
					</ul>
				</div>
				<div class="footer-col">
					<p class="footer-heading">Shop</p>
					<ul>
						<li><a href={withEtsyTracking(ETSY_SHOP_URL)} data-cta="footer_etsy_link">Etsy Store</a></li>
					</ul>
				</div>
			</nav>
		</div>

		<div class="footer-bottom">
			<p>&copy; {year} Simply Sheet Design</p>
		</div>
	</div>
</footer>

<style>
	footer {
		border-top: 1px solid var(--color-border);
		padding: var(--space-xl) var(--space-md) var(--space-lg);
		background: var(--color-bg-panel);
	}
	.footer-inner {
		max-width: var(--max-width);
		margin: 0 auto;
	}

	/* ——— Top section ——— */

	.footer-top {
		display: flex;
		justify-content: space-between;
		gap: var(--space-xl);
		padding-bottom: var(--space-lg);
		border-bottom: 1px solid var(--color-border);
	}

	/* ——— Brand column ——— */

	.footer-brand {
		flex-shrink: 0;
	}
	.footer-logo-link {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		font-family: var(--font-heading);
		font-size: 1.2rem;
		font-weight: var(--weight-normal);
		color: var(--color-text);
		text-decoration: none;
		letter-spacing: -0.02em;
		line-height: 1.29;
	}
	.footer-logo {
		display: block;
		width: 24px;
		height: 26px;
	}
	.footer-tagline {
		margin-top: var(--space-xs);
		font-size: var(--text-small);
		color: var(--color-text-muted);
	}

	/* ——— Nav columns ——— */

	.footer-nav {
		display: flex;
		gap: var(--space-xl);
	}
	.footer-col ul {
		list-style: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: var(--space-2xs);
	}
	.footer-heading {
		font-size: var(--text-small);
		font-weight: var(--weight-normal);
		color: var(--color-text);
		margin-bottom: var(--space-xs);
	}
	.footer-col a {
		font-size: var(--text-small);
		color: var(--color-text-secondary);
		text-decoration: none;
		transition: color 0.15s;
	}
	.footer-col a:hover {
		color: var(--color-text);
	}
	.footer-view-all {
		margin-top: var(--space-2xs);
	}

	/* ——— Bottom bar ——— */

	.footer-bottom {
		padding-top: var(--space-md);
	}
	.footer-bottom p {
		font-size: var(--text-small);
		color: var(--color-text-muted);
		margin: 0;
	}

	/* ——— Responsive ——— */

	@media (max-width: 768px) {
		.footer-top {
			flex-direction: column;
			gap: var(--space-lg);
		}
		.footer-nav {
			gap: var(--space-lg);
			flex-wrap: wrap;
		}
	}

	@media (max-width: 480px) {
		.footer-nav {
			flex-direction: column;
			gap: var(--space-md);
		}
	}
</style>
