---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

interface Heading {
	depth: number;
	slug: string;
	text: string;
}

type Props = CollectionEntry<'articles'>['data'] & {
	id?: string;
	headings?: Heading[];
};

const { title, description, pubDate, updatedDate, id, headings = [] } = Astro.props;

const tocHeadings = headings.filter((h) => h.depth === 2);

const allArticles = await getCollection('articles');
const related = allArticles
	.filter((a) => a.id !== id)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const schema = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: title,
	description,
	datePublished: pubDate.toISOString(),
	...(updatedDate && { dateModified: updatedDate.toISOString() }),
	author: {
		'@type': 'Person',
		name: 'Ryan Sheridan',
	},
	publisher: {
		'@type': 'Organization',
		name: SITE_TITLE,
		url: Astro.site?.toString(),
	},
	mainEntityOfPage: {
		'@type': 'WebPage',
		'@id': Astro.url.toString(),
	},
};
---

<html lang="en">
	<head>
		<BaseHead title={`${title} — ${SITE_TITLE}`} description={description} />
		<script type="application/ld+json" set:html={JSON.stringify(schema)} />
	</head>
	<body>
		<Header />
		<div class="article-layout">
			{tocHeadings.length > 0 && (
				<aside class="toc-sidebar">
					<nav class="toc" aria-label="Table of contents">
						<ul>
							{tocHeadings.map((h) => (
								<li>
									<a href={`#${h.slug}`} class="toc-link">{h.text}</a>
								</li>
							))}
						</ul>
					</nav>
				</aside>
			)}

			<main>
				<article>
					<header class="article-header">
						<p class="date">
							<FormattedDate date={pubDate} />
							{updatedDate && (
								<span class="updated">
									(Updated <FormattedDate date={updatedDate} />)
								</span>
							)}
						</p>
						<h1>{title}</h1>
					</header>
					<div class="prose">
						<slot />
					</div>
				</article>

				{related.length > 0 && (
					<aside class="related">
						<h2 class="related-heading">Related articles</h2>
						<ul class="related-list">
							{related.map((r) => (
								<li>
									<a href={`/articles/${r.id}/`}>{r.data.title}</a>
								</li>
							))}
						</ul>
					</aside>
				)}
			</main>
		</div>
		<Footer />

		<script>
			function initToc() {
				const links = document.querySelectorAll('.toc-link');
				if (!links.length) return;

				const ids = Array.from(links).map((l) =>
					l.getAttribute('href')!.slice(1)
				);
				const headings = ids
					.map((id) => document.getElementById(id))
					.filter(Boolean) as HTMLElement[];

				function update() {
					let current = '';
					for (const h of headings) {
						if (h.getBoundingClientRect().top <= 100) {
							current = h.id;
						}
					}
					links.forEach((link) => {
						link.classList.toggle(
							'active',
							link.getAttribute('href') === `#${current}`
						);
					});
				}

				window.addEventListener('scroll', update, { passive: true });
				update();
			}

			initToc();
		</script>
	</body>
</html>

<style>
	.article-layout {
		max-width: var(--max-width);
		margin: 0 auto;
		display: grid;
		grid-template-columns: 13rem 1fr;
		gap: var(--space-xl);
		padding: 0 var(--space-md);
	}

	main {
		width: 100%;
		max-width: var(--max-width-narrow);
		padding: var(--space-xl) 0;
		margin: 0;
	}

	/* ——— TOC sidebar ——— */

	.toc-sidebar {
		padding-top: var(--space-xl);
	}

	.toc {
		position: sticky;
		top: 6rem;
	}

	.toc ul {
		list-style: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: var(--space-2xs);
		border-left: 1px solid var(--color-border);
		padding-left: var(--space-sm);
	}

	.toc-link {
		display: block;
		font-size: var(--text-small);
		line-height: var(--leading-snug);
		color: var(--color-text-muted);
		text-decoration: none;
		padding: var(--space-2xs) 0;
		transition: color 0.15s;
	}

	.toc-link:hover {
		color: var(--color-text);
	}

	.toc-link.active {
		color: var(--color-accent);
		font-weight: var(--weight-medium);
	}

	/* ——— Article header ——— */

	.article-header {
		margin-bottom: var(--space-lg);
	}

	.article-header h1 {
		margin-top: var(--space-xs);
		font-size: var(--text-h1);
	}

	.date {
		font-size: var(--text-small);
		color: var(--color-text-muted);
		margin-bottom: 0;
	}

	.updated {
		font-style: italic;
	}

	/* ——— Related articles ——— */

	.related {
		margin-top: var(--space-2xl);
		padding-top: var(--space-lg);
		border-top: 1px solid var(--color-border);
	}

	.related-heading {
		font-size: var(--text-h3);
		font-weight: var(--weight-semibold);
		margin-bottom: var(--space-sm);
	}

	.related-list {
		list-style: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
	}

	.related-list a {
		font-size: var(--text-body);
		text-decoration: none;
	}

	.related-list a:hover {
		text-decoration: underline;
	}

	/* ——— Responsive ——— */

	@media (max-width: 960px) {
		.article-layout {
			grid-template-columns: 1fr;
		}

		.toc-sidebar {
			display: none;
		}

		main {
			max-width: calc(100% - 2em);
			margin: 0 auto;
		}
	}
</style>
