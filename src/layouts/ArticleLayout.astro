---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ProductPromo from '../components/ProductPromo.astro';
import { SITE_TITLE } from '../consts';

interface Heading {
	depth: number;
	slug: string;
	text: string;
}

type Props = CollectionEntry<'articles'>['data'] & {
	id?: string;
	headings?: Heading[];
	readTime?: number;
};

const { title, description, pubDate, updatedDate, image, cardImage, id, headings = [], readTime, faq, tags = [] } = Astro.props;
const heroImage = cardImage || image;

const tocHeadings = headings.filter((h) => h.depth === 2);

const allArticles = await getCollection('articles');
const related = allArticles
	.filter((a) => a.id !== id)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);

const schema = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: title,
	description,
	datePublished: pubDate.toISOString(),
	...(updatedDate && { dateModified: updatedDate.toISOString() }),
	author: {
		'@type': 'Person',
		name: 'Ryan Sheridan',
	},
	publisher: {
		'@type': 'Organization',
		name: SITE_TITLE,
		url: Astro.site?.toString(),
	},
	mainEntityOfPage: {
		'@type': 'WebPage',
		'@id': Astro.url.toString(),
	},
};

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{
			'@type': 'ListItem',
			position: 1,
			name: 'Home',
			item: Astro.site?.toString(),
		},
		{
			'@type': 'ListItem',
			position: 2,
			name: 'Articles',
			item: new URL('/articles', Astro.site).toString(),
		},
		{
			'@type': 'ListItem',
			position: 3,
			name: title,
		},
	],
};

const faqSchema = faq?.length ? {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faq.map(({ question, answer }: { question: string; answer: string }) => ({
		'@type': 'Question',
		name: question,
		acceptedAnswer: { '@type': 'Answer', text: answer },
	})),
} : null;

const articleUrl = Astro.url.toString();
const emailShareUrl = `mailto:?subject=${encodeURIComponent(title)}&body=${encodeURIComponent(`Check out this article: ${articleUrl}`)}`;

const productSlugs: Record<string, string> = {
	budget: 'budget-spreadsheet',
	couples: 'couples-budget-spreadsheet',
	debt: 'debt-payoff-tracker',
	savings: 'savings-goals-tracker',
};

const tagProductMap: Record<string, string[]> = {
	'expense-tracking': ['budget', 'savings'],
	'couples-budgeting': ['couples', 'budget'],
	'debt-payoff': ['debt', 'budget'],
	'savings-goals': ['savings', 'budget'],
	'irregular-income': ['budget', 'savings'],
	'net-worth': ['budget', 'savings'],
	'budgeting-styles': ['budget', 'couples'],
};

const productIds = tags.flatMap((tag: string) => tagProductMap[tag] ?? []);
const seen = new Set<string>();
const uniqueProductIds = productIds.filter((pid: string) => {
	if (seen.has(pid)) return false;
	seen.add(pid);
	return true;
}).slice(0, 2);
const recommendedSlugs = (uniqueProductIds.length >= 2 ? uniqueProductIds : ['budget', 'savings'])
	.map((pid: string) => productSlugs[pid]);
---

<html lang="en">
	<head>
		<BaseHead title={`${title} — ${SITE_TITLE}`} description={description} image={cardImage || image} />
		<script type="application/ld+json" set:html={JSON.stringify(schema)} />
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
		{faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
	</head>
	<body>
		<Header />
		<div class="reading-progress" id="reading-progress"></div>

		<main class:list={['article-main', { 'has-toc': tocHeadings.length > 1 }]}>
			<Breadcrumbs crumbs={[{ label: 'Articles', href: '/articles' }, { label: title }]} />
			<div class="article-grid">
				{tocHeadings.length > 1 && (
					<nav class="toc" aria-label="Table of contents">
						<p class="toc-heading">On this page</p>
						<ul class="toc-list">
							{tocHeadings.map((h) => (
								<li><a href={`#${h.slug}`} data-toc-slug={h.slug}>{h.text}</a></li>
							))}
						</ul>
					</nav>
				)}

				<article>
					<header class="article-header">
						<h1 class="article-title">{title}</h1>
						<p class="article-meta">
							{readTime && <span>{readTime} min read</span>}
						</p>
					</header>

					{heroImage && (
						<div class="article-hero-img">
							<img src={heroImage} alt={title} />
						</div>
					)}

					<div class="article-actions">
						<button class="action-btn" id="share-btn" aria-label="Share this article">
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
								<path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8" />
								<polyline points="16 6 12 2 8 6" />
								<line x1="12" y1="2" x2="12" y2="15" />
							</svg>
							<span>Share</span>
						</button>
						<a href={emailShareUrl} class="action-btn" aria-label="Share via email">
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
								<rect x="2" y="4" width="20" height="16" rx="2" />
								<path d="M22 4l-10 8L2 4" />
							</svg>
							<span>Email</span>
						</a>
					</div>

					<div class="prose">
						<slot />
					</div>
				</article>
			</div>

			{related.length > 0 && (
				<aside class="related">
					<h2 class="related-heading">Related articles</h2>
					<ul class="related-list">
						{related.map((r) => (
							<li>
								<a href={`/articles/${r.id}/`}>{r.data.title}</a>
							</li>
						))}
					</ul>
				</aside>
			)}

			{faq && faq.length > 0 && (
				<section class="faq">
					<h2 class="faq-heading">Frequently asked questions</h2>
					<div class="faq-list">
						{faq.map(({ question, answer }: { question: string; answer: string }) => (
							<details class="faq-item">
								<summary class="faq-q">
									<span>{question}</span>
									<svg class="faq-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<polyline points="6 9 12 15 18 9" />
									</svg>
								</summary>
								<div class="faq-a-wrap">
									<p class="faq-a">{answer}</p>
								</div>
							</details>
						))}
					</div>
				</section>
			)}

			<section class="recommended-products">
				{recommendedSlugs.map((slug) => (
					<ProductPromo slug={slug} variant="row" />
				))}
			</section>
		</main>
		<Footer />

		<script>
			document.querySelectorAll('.faq-item').forEach((details) => {
				const summary = details.querySelector('summary');
				const wrap = details.querySelector('.faq-a-wrap');
				if (!summary || !wrap) return;

				summary.addEventListener('click', (e) => {
					e.preventDefault();
					if (details.open) {
						wrap.style.gridTemplateRows = '0fr';
						wrap.addEventListener('transitionend', () => {
							details.open = false;
							wrap.style.gridTemplateRows = '';
						}, { once: true });
					} else {
						details.open = true;
					}
				});
			});

			const shareBtn = document.getElementById('share-btn');
			shareBtn?.addEventListener('click', async () => {
				const url = window.location.href;
				const title = document.title;

				if (navigator.share) {
					try {
						await navigator.share({ title, url });
					} catch {}
				} else {
					await navigator.clipboard.writeText(url);
					const label = shareBtn.querySelector('span');
					if (label) {
						const original = label.textContent;
						label.textContent = 'Copied!';
						setTimeout(() => { label.textContent = original; }, 2000);
					}
				}
			});

			const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('.toc-list a[data-toc-slug]'));
			if (tocLinks.length > 0) {
				const headingEls = tocLinks
					.map((link) => document.getElementById(link.dataset.tocSlug!))
					.filter((el): el is HTMLElement => el !== null);

				let currentActive: HTMLAnchorElement | null = null;

				function setActive(link: HTMLAnchorElement | null) {
					if (link === currentActive) return;
					currentActive?.classList.remove('active');
					link?.classList.add('active');
					currentActive = link;
				}

				const TOC_SCROLL_OFFSET = 96;
				let tocTicking = false;

				function updateActiveToc() {
					let current = tocLinks[0];
					for (let i = 0; i < headingEls.length; i++) {
						if (headingEls[i].getBoundingClientRect().top <= TOC_SCROLL_OFFSET) {
							current = tocLinks[i];
						}
					}
					setActive(current);
					tocTicking = false;
				}

				window.addEventListener('scroll', () => {
					if (!tocTicking) {
						requestAnimationFrame(updateActiveToc);
						tocTicking = true;
					}
				}, { passive: true });

				updateActiveToc();
			}

			const progressBar = document.getElementById('reading-progress');
			if (progressBar) {
				let pTicking = false;
				window.addEventListener('scroll', () => {
					if (!pTicking) {
						requestAnimationFrame(() => {
							const docHeight = document.documentElement.scrollHeight - window.innerHeight;
							const progress = docHeight > 0 ? (window.scrollY / docHeight) * 100 : 0;
							progressBar.style.width = `${Math.min(progress, 100)}%`;
							pTicking = false;
						});
						pTicking = true;
					}
				}, { passive: true });
			}
		</script>
	</body>
</html>

<style>
	/* ——— Reading progress bar ——— */

	.reading-progress {
		position: fixed;
		top: 3.5rem;
		left: 0;
		height: 3px;
		background: var(--color-text-heading);
		width: 0%;
		z-index: 49;
		transition: width 50ms linear;
		display: none;
	}

	@media (max-width: 960px) {
		.reading-progress {
			display: block;
		}
		.toc {
			display: none;
		}
	}

	/* ——— Article hero image ——— */

	.article-hero-img {
		margin-bottom: var(--space-lg);
		border-radius: var(--radius-md);
		overflow: hidden;
	}

	.article-hero-img img {
		display: block;
		width: 100%;
		height: auto;
	}


	/* ——— Article main ——— */

	.article-main {
		--toc-rail-width: 220px;
		--toc-gap: calc(var(--space-xl) + 3rem);
		max-width: calc(var(--max-width-narrow) + var(--space-md) * 2);
		margin: 0 auto;
		padding: var(--space-lg) var(--space-md) var(--space-2xl);
	}

	@media (min-width: 1100px) {
		.article-main.has-toc {
			/* Header's nav is max-width(--max-width) plus its own space-md padding outside that;
			   mirror the same total width here so the TOC's left edge lines up with the logo/nav. */
			max-width: calc(var(--max-width) + var(--space-md) * 2);
		}
	}

	.article-grid {
		padding-top: 3rem;
	}

	/* ——— Fallback header (no image) ——— */

	.article-header {
		margin-bottom: var(--space-lg);
	}

	.article-title {
		font-size: clamp(1.75rem, 3vw + 0.5rem, 2.5rem);
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--space-sm);
	}

	.article-meta {
		font-size: var(--text-small);
		color: var(--color-text-muted);
		margin: 0;
		display: flex;
		align-items: center;
		gap: 0.375rem;
	}

	/* ——— Share / actions ——— */

	.article-actions {
		display: flex;
		align-items: center;
		gap: var(--space-xs);
		padding: var(--space-sm) 0;
		margin-bottom: var(--space-lg);
		border-top: 1px solid var(--color-border);
		border-bottom: 1px solid var(--color-border);
	}

	.action-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		font-family: var(--font-sans);
		font-size: var(--text-small);
		font-weight: var(--weight-normal);
		color: var(--color-text-secondary);
		background: none;
		border: 1px solid var(--color-divider);
		border-radius: var(--radius-full);
		padding: 0.375rem 0.875rem;
		cursor: pointer;
		text-decoration: none;
		transition: color 0.15s, border-color 0.15s;
	}

	.action-btn:hover {
		color: var(--color-text);
		border-color: var(--color-text-muted);
	}

	/* ——— Table of contents ——— */

	.toc {
		margin-bottom: calc(var(--space-lg) + 3rem);
	}

	.toc-heading {
		font-size: 0.875rem;
		font-weight: var(--weight-normal);
		color: var(--color-text);
		margin: 0 0 var(--space-sm);
	}

	.toc-list {
		list-style: none;
		display: flex;
		flex-direction: column;
		margin: 0;
		padding: 0;
		border-left: 1px solid var(--color-border);
	}

	.toc-list a {
		display: block;
		padding: 0.375rem 0 0.375rem var(--space-sm);
		margin-left: -1px;
		border-left: 2px solid transparent;
		font-size: 0.875rem;
		line-height: var(--leading-snug);
		color: var(--color-text-muted);
		text-decoration: none;
		transition: color 0.15s, border-color 0.15s;
	}

	.toc-list a:hover {
		color: var(--color-text);
	}

	.toc-list a.active {
		color: var(--color-text-heading);
		font-weight: var(--weight-normal);
		border-left-color: var(--color-text-heading);
	}

	/* ——— Table of contents — sticky left rail on wide viewports ——— */

	@media (min-width: 1100px) {
		.has-toc .article-grid {
			display: grid;
			grid-template-columns: var(--toc-rail-width) minmax(0, var(--max-width-narrow));
			column-gap: var(--toc-gap);
			align-items: start;
		}

		.has-toc .toc {
			position: sticky;
			top: 4.5rem;
			margin-bottom: 0;
		}

		.has-toc .related,
		.has-toc .faq,
		.has-toc .recommended-products {
			max-width: var(--max-width-narrow);
			margin-left: calc(var(--toc-rail-width) + var(--toc-gap));
			margin-right: auto;
		}
	}

	/* ——— FAQ section ——— */

	.faq {
		margin-top: var(--space-2xl);
		padding-top: var(--space-lg);
		border-top: 1px solid var(--color-border);
	}

	.faq-heading {
		font-size: var(--text-h2);
		margin-bottom: var(--space-md);
	}

	.faq-list {
		display: flex;
		flex-direction: column;
	}

	.faq-item {
		border-bottom: 1px solid var(--color-border);
	}

	.faq-item:last-child {
		border-bottom: none;
	}

	.faq-q {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-sm);
		width: 100%;
		padding: var(--space-md) 0;
		font-size: var(--text-body);
		font-weight: var(--weight-normal);
		color: var(--color-text);
		cursor: pointer;
		list-style: none;
		transition: color 0.15s;
	}

	.faq-q::-webkit-details-marker {
		display: none;
	}

	.faq-q::marker {
		display: none;
		content: '';
	}

	.faq-q:hover {
		color: var(--color-text);
	}

	.faq-arrow {
		flex-shrink: 0;
		transition: transform 300ms ease;
	}

	.faq-item[open] .faq-arrow {
		transform: rotate(180deg);
	}

	.faq-a-wrap {
		display: grid;
		grid-template-rows: 0fr;
		transition: grid-template-rows 300ms ease;
	}

	.faq-item[open] .faq-a-wrap {
		grid-template-rows: 1fr;
	}

	.faq-a-wrap > .faq-a {
		overflow: hidden;
	}

	.faq-a {
		font-size: var(--text-body);
		line-height: var(--leading-normal);
		color: var(--color-text-secondary);
		margin: 0;
		padding-bottom: var(--space-md);
	}

	/* ——— Recommended products ——— */

	.recommended-products {
		margin-top: var(--space-2xl);
		padding-top: var(--space-lg);
		border-top: 1px solid var(--color-border);
	}

	/* ——— Related articles ——— */

	.related {
		margin-top: var(--space-2xl);
		padding-top: var(--space-lg);
		border-top: 1px solid var(--color-border);
	}

	.related-heading {
		font-size: var(--text-h3);
		margin-bottom: var(--space-sm);
	}

	.related-list {
		list-style: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0;
	}
	.related-list li {
		padding: var(--space-sm) 0;
		border-bottom: 1px solid var(--color-border);
	}
	.related-list li:last-child {
		border-bottom: none;
		padding-bottom: 0;
	}
	.related-list li:first-child {
		padding-top: 0;
	}

	.related-list a {
		font-size: var(--text-body);
		text-decoration: none;
	}

	.related-list a:hover {
		text-decoration: underline;
	}
</style>
