---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { SITE_TITLE } from '../consts';

type Props = CollectionEntry<'templates'>['data'] & {
	id?: string;
};

const { title, description, badge, platforms, darkListing, lightListing, heroImage, lightImage, midImage, midImageLight, features, relatedArticles, bundles, faq, reviews, id, price, sku } = Astro.props;

const allArticles = await getCollection('articles');
const linkedArticles = relatedArticles
	.map((slug: string) => allArticles.find((a) => a.id === slug))
	.filter(Boolean)
	.slice(0, 4);

const allTemplates = await getCollection('templates');
const otherTemplates = allTemplates
	.filter((t) => t.id !== id)
	.sort((a, b) => a.data.order - b.data.order)
	.slice(0, 3);

const platformLabels: Record<string, string> = {
	'google-sheets': 'Google Sheets',
	'excel': 'Excel',
};

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://simplysheetdesign.com';
const imageUrl = `${siteUrl}${heroImage}`;

const reviewSchema = reviews?.map((r: { name: string; text: string }) => ({
	'@type': 'Review',
	author: { '@type': 'Person', name: r.name },
	reviewBody: r.text,
	reviewRating: { '@type': 'Rating', ratingValue: 5, bestRating: 5 },
}));

const aggregateRating = reviews?.length ? {
	'@type': 'AggregateRating',
	ratingValue: 5,
	reviewCount: reviews.length,
	bestRating: 5,
	worstRating: 1,
} : undefined;

const schema = {
	'@context': 'https://schema.org',
	'@type': 'Product',
	name: title,
	description,
	image: imageUrl,
	sku,
	brand: {
		'@type': 'Brand',
		name: SITE_TITLE,
	},
	...(reviewSchema?.length ? { review: reviewSchema } : {}),
	...(aggregateRating ? { aggregateRating } : {}),
	offers: {
		'@type': 'Offer',
		price: price.toFixed(2),
		priceCurrency: 'USD',
		availability: 'https://schema.org/InStock',
		url: darkListing,
		seller: {
			'@type': 'Organization',
			name: SITE_TITLE,
		},
		shippingDetails: {
			'@type': 'OfferShippingDetails',
			doesNotShip: true,
		},
		hasMerchantReturnPolicy: {
			'@type': 'MerchantReturnPolicy',
			applicableCountry: 'US',
			returnPolicyCategory: 'https://schema.org/MerchantReturnNotPermitted',
		},
	},
};

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{
			'@type': 'ListItem',
			position: 1,
			name: 'Home',
			item: Astro.site?.toString(),
		},
		{
			'@type': 'ListItem',
			position: 2,
			name: 'Templates',
			item: new URL('/templates', Astro.site).toString(),
		},
		{
			'@type': 'ListItem',
			position: 3,
			name: title,
		},
	],
};

const faqSchema = faq?.length ? {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faq.map(({ question, answer }: { question: string; answer: string }) => ({
		'@type': 'Question',
		name: question,
		acceptedAnswer: { '@type': 'Answer', text: answer },
	})),
} : null;

const templateId = Math.random().toString(36).slice(2, 10);
---

<html lang="en">
	<head>
		<BaseHead title={`${title} — ${SITE_TITLE}`} description={description} image={heroImage} />
		<script type="application/ld+json" set:html={JSON.stringify(schema)} />
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
		{faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
	</head>
	<body>
		<Header />

		<main class="template-main">
			<Breadcrumbs crumbs={[{ label: 'Templates', href: '/templates' }, { label: title }]} />

			<section class="product-hero">
				<div class="product-image">
					<img src={heroImage} alt={`${title} preview`} width="960" height="640" id={`hero-img-${templateId}`} />
				</div>
				<div class="product-info">
					{badge && <span class="product-badge">{badge}</span>}
					<h1 class="product-title">{title}</h1>
					<p class="product-desc">{description}</p>

					<div class="theme-toggle" id={`theme-toggle-${templateId}`}>
						<button class="theme-btn active" data-theme="dark">Dark</button>
						<button class="theme-btn" data-theme="light">Light</button>
					</div>

					<a
						href={darkListing}
						class="btn btn-primary product-cta"
						id={`cta-${templateId}`}
						target="_blank"
						rel="noopener noreferrer"
					>
						Get this template on Etsy
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
					</a>

					<div class="product-platforms">
						{platforms.map((p: string) => (
							<span class="platform-tag">{platformLabels[p] ?? p}</span>
						))}
					</div>
				</div>
			</section>

			{features.length > 0 && (
				<section class="product-features">
					<h2>What's included</h2>
					<ul class="features-grid">
						{features.map((f: string) => (
							<li>
								<svg class="check-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
								<span>{f}</span>
							</li>
						))}
					</ul>
				</section>
			)}

			{midImage && (
				<section class="product-mid-image">
					<img src={midImage} alt={`${title} preview`} width="960" height="540" id={`mid-img-${templateId}`} loading="lazy" />
				</section>
			)}

			<section class="product-howto">
				<div class="product-body prose">
					<slot />
				</div>
				<div class="product-howto-visual">
					<img src={heroImage} alt={`${title} preview`} width="960" height="640" loading="lazy" />
				</div>
			</section>

			{bundles && bundles.length > 0 && (
				<section class="product-bundles">
					<h2>Save with a bundle</h2>
					<div class="bundles-grid">
						{bundles.map((b: { name: string; darkUrl: string; lightUrl: string }) => (
							<a
								href={b.darkUrl}
								class="bundle-card"
								data-dark-url={b.darkUrl}
								data-light-url={b.lightUrl}
								target="_blank"
								rel="noopener noreferrer"
							>
								<span class="bundle-name">{b.name}</span>
								<span class="bundle-link">View on Etsy <span class="arrow">&rarr;</span></span>
							</a>
						))}
					</div>
				</section>
			)}

			{linkedArticles.length > 0 && (
				<section class="product-articles">
					<h2>Related articles</h2>
					<ul class="product-articles-list">
						{linkedArticles.map((a: any) => (
							<li>
								<a href={`/articles/${a.id}/`}>{a.data.title}</a>
							</li>
						))}
					</ul>
				</section>
			)}

			{faq && faq.length > 0 && (
				<section class="faq">
					<h2 class="faq-heading">Frequently asked questions</h2>
					<div class="faq-list">
						{faq.map(({ question, answer }: { question: string; answer: string }) => (
							<details class="faq-item">
								<summary class="faq-q">
									<span>{question}</span>
									<svg class="faq-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<polyline points="6 9 12 15 18 9" />
									</svg>
								</summary>
								<div class="faq-a-wrap">
									<p class="faq-a">{answer}</p>
								</div>
							</details>
						))}
					</div>
				</section>
			)}

			{reviews && reviews.length > 0 && (
				<section class="product-reviews">
					<div class="reviews-inner">
						<div class="reviews-label">What people are saying</div>
						<div class="reviews-content">
							<div class="reviews-track" id={`reviews-track-${templateId}`}>
								{reviews.map((r: { name: string; text: string }) => (
									<blockquote class="review-card">
										<div class="review-stars" aria-label="5 out of 5 stars">
											{Array.from({ length: 5 }).map(() => (
												<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
											))}
										</div>
										<p class="review-text">{r.text}</p>
										<cite class="review-name">{r.name}</cite>
									</blockquote>
								))}
							</div>
							{reviews.length > 1 && (
								<div class="reviews-nav">
									<button class="reviews-arrow" id={`reviews-prev-${templateId}`} aria-label="Previous review">
										<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6" /></svg>
									</button>
									<div class="reviews-dots" id={`reviews-dots-${templateId}`}>
										{reviews.map((_: unknown, i: number) => (
											<button class="reviews-dot" data-index={i} aria-label={`Go to review ${i + 1}`}></button>
										))}
									</div>
									<button class="reviews-arrow" id={`reviews-next-${templateId}`} aria-label="Next review">
										<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6" /></svg>
									</button>
								</div>
							)}
						</div>
					</div>
				</section>
			)}

			{otherTemplates.length > 0 && (
				<section class="other-templates">
					<h2>More spreadsheets</h2>
					<div class="other-templates-grid">
						{otherTemplates.map((t) => (
							<a href={`/templates/${t.id}/`} class="template-card">
								<div class="template-thumb">
									<img src={t.data.heroImage} alt={`${t.data.title} preview`} width="600" height="400" loading="lazy" />
								</div>
								{t.data.badge && <span class="template-badge">{t.data.badge}</span>}
								<h3 class="template-name">{t.data.title.replace(/ for Google Sheets & Excel$/, '')}</h3>
								<p class="template-desc">{t.data.description}</p>
							</a>
						))}
					</div>
				</section>
			)}
		</main>
		<Footer />

		<script is:inline define:vars={{ templateId, darkListing, lightListing, heroImage, lightImage, midImage, midImageLight }}>
			const toggle = document.getElementById(`theme-toggle-${templateId}`);
			const cta = document.getElementById(`cta-${templateId}`);
			const heroImg = document.getElementById(`hero-img-${templateId}`);
			const midImg = document.getElementById(`mid-img-${templateId}`);

			if (toggle && cta) {
				toggle.addEventListener('click', (e) => {
					const btn = e.target.closest('.theme-btn');
					if (!btn) return;

					toggle.querySelectorAll('.theme-btn').forEach((b) => b.classList.remove('active'));
					btn.classList.add('active');

					const theme = btn.dataset.theme;
					cta.href = theme === 'light' ? lightListing : darkListing;

					if (heroImg && lightImage) {
						heroImg.src = theme === 'light' ? lightImage : heroImage;
					}

					if (midImg && midImageLight) {
						midImg.src = theme === 'light' ? midImageLight : midImage;
					}

					document.querySelectorAll('.bundle-card').forEach((card) => {
						card.href = theme === 'light' ? card.dataset.lightUrl : card.dataset.darkUrl;
					});
				});
			}

			document.querySelectorAll('.faq-item').forEach((details) => {
				const summary = details.querySelector('summary');
				const wrap = details.querySelector('.faq-a-wrap');
				if (!summary || !wrap) return;

				summary.addEventListener('click', (e) => {
					e.preventDefault();
					if (details.open) {
						wrap.style.gridTemplateRows = '0fr';
						wrap.addEventListener('transitionend', () => {
							details.open = false;
							wrap.style.gridTemplateRows = '';
						}, { once: true });
					} else {
						details.open = true;
					}
				});
			});
		</script>

		{reviews && reviews.length > 1 && (
			<script is:inline define:vars={{ templateId }}>
				const track = document.getElementById(`reviews-track-${templateId}`);
				const prevBtn = document.getElementById(`reviews-prev-${templateId}`);
				const nextBtn = document.getElementById(`reviews-next-${templateId}`);
				const dots = Array.from(document.querySelectorAll(`#reviews-dots-${templateId} .reviews-dot`));

				function updateDots() {
					if (!track) return;
					const index = Math.round(track.scrollLeft / track.clientWidth);
					dots.forEach((d, i) => d.classList.toggle('active', i === index));
				}

				function goTo(index) {
					if (!track) return;
					track.scrollTo({ left: index * track.clientWidth, behavior: 'smooth' });
				}

				prevBtn?.addEventListener('click', () => {
					const index = Math.max(0, Math.round(track.scrollLeft / track.clientWidth) - 1);
					goTo(index);
				});
				nextBtn?.addEventListener('click', () => {
					const index = Math.min(dots.length - 1, Math.round(track.scrollLeft / track.clientWidth) + 1);
					goTo(index);
				});
				dots.forEach((d) => d.addEventListener('click', () => goTo(Number(d.dataset.index))));
				track?.addEventListener('scroll', () => {
					window.requestAnimationFrame(updateDots);
				});

				updateDots();
			</script>
		)}
	</body>
</html>

<style>
	.template-main {
		max-width: calc(var(--max-width) + var(--space-md) * 2);
		margin: 0 auto;
		padding: var(--space-lg) var(--space-md) var(--space-2xl);
	}

	/* ——— Product hero ——— */

	.product-hero {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-xl);
		align-items: start;
		margin-bottom: var(--space-2xl);
	}

	.product-image {
		border-radius: var(--radius-md);
		overflow: hidden;
		background: var(--color-bg-panel);
	}

	.product-image img {
		display: block;
		width: 100%;
		height: auto;
	}

	.product-badge {
		display: inline-block;
		font-size: var(--text-xs);
		font-weight: var(--weight-semibold);
		color: var(--color-accent);
		background: var(--color-accent-light);
		border-radius: var(--radius-full);
		padding: 0.25rem 0.75rem;
		margin-bottom: var(--space-sm);
	}

	.product-title {
		font-size: clamp(1.5rem, 2.5vw + 0.5rem, 2.25rem);
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--space-xs);
	}

	.product-desc {
		font-size: var(--text-body);
		line-height: var(--leading-normal);
		color: var(--color-text-secondary);
		margin-bottom: var(--space-md);
	}

	/* ——— Theme toggle ——— */

	.theme-toggle {
		display: inline-flex;
		gap: 0;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-full);
		padding: 0.1875rem;
		margin-bottom: var(--space-md);
	}

	.theme-btn {
		font-family: var(--font-sans);
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		color: var(--color-text-muted);
		background: none;
		border: none;
		border-radius: var(--radius-full);
		padding: 0.375rem 1rem;
		cursor: pointer;
		transition: color 0.15s, background 0.15s;
	}

	.theme-btn:hover {
		color: var(--color-text);
	}

	.theme-btn.active {
		color: var(--color-bg-surface);
		background: var(--color-btn);
	}

	/* ——— CTA ——— */

	.product-cta {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		width: 100%;
		justify-content: center;
		margin-bottom: var(--space-md);
	}

	.product-platforms {
		display: flex;
		gap: var(--space-xs);
	}

	.platform-tag {
		font-size: var(--text-xs);
		color: var(--color-text-muted);
		background: var(--color-bg-panel);
		border-radius: var(--radius-full);
		padding: 0.25rem 0.75rem;
	}

	/* ——— Features ——— */

	.product-features {
		margin-bottom: var(--space-2xl);
		padding: var(--space-xl) 0;
		border-top: 1px solid var(--color-border);
		border-bottom: 1px solid var(--color-border);
	}

	.product-features h2 {
		font-size: var(--text-h2);
		margin-bottom: var(--space-lg);
	}

	.features-grid {
		list-style: none;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--space-md) var(--space-2xl);
	}

	.features-grid li {
		display: flex;
		align-items: flex-start;
		gap: var(--space-sm);
		font-size: var(--text-body);
		line-height: var(--leading-normal);
		color: var(--color-text);
	}

	.check-icon {
		flex-shrink: 0;
		color: var(--color-accent);
		margin-top: 0.1875rem;
	}

	/* ——— Mid-page product image ——— */

	.product-mid-image {
		display: flex;
		justify-content: center;
		background: var(--color-bg-panel);
		border-radius: var(--radius-md);
		padding: var(--space-md);
		margin-bottom: var(--space-2xl);
	}

	.product-mid-image img {
		display: block;
		width: 90%;
		height: auto;
	}

	@media (max-width: 600px) {
		.product-mid-image img {
			width: 95%;
		}
	}

	/* ——— How it works (sticky visual) ——— */

	.product-howto {
		display: grid;
		grid-template-columns: minmax(0, var(--max-width-narrow)) 1fr;
		gap: var(--space-xl);
		align-items: start;
		margin-bottom: var(--space-2xl);
	}

	.product-howto-visual {
		position: sticky;
		top: 6rem;
		overflow: visible;
	}

	.product-howto-visual img {
		display: block;
		width: 160%;
		max-width: none;
		height: auto;
		margin-left: auto;
	}

	@media (max-width: 960px) {
		.product-howto-visual {
			display: none;
		}
	}

	/* ——— Body content ——— */

	.product-body {
		max-width: var(--max-width-narrow);
		margin-bottom: 0;
	}

	/* ——— Bundles ——— */

	.product-bundles {
		margin-bottom: var(--space-2xl);
		padding-top: var(--space-lg);
		border-top: 1px solid var(--color-border);
	}

	.product-bundles h2 {
		font-size: var(--text-h2);
		margin-bottom: var(--space-md);
	}

	.bundles-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--space-md);
	}

	.bundle-card {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: var(--space-md) var(--space-lg);
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		text-decoration: none;
		transition: border-color 0.15s, box-shadow 0.2s ease;
	}

	.bundle-card:hover {
		border-color: var(--color-divider);
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
	}

	.bundle-name {
		font-size: var(--text-body);
		font-weight: var(--weight-medium);
		color: var(--color-text);
	}

	.bundle-link {
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		color: var(--color-accent);
	}

	/* ——— Related articles ——— */

	.product-articles {
		margin-bottom: var(--space-2xl);
		padding-top: var(--space-lg);
		border-top: 1px solid var(--color-border);
	}

	.product-articles h2 {
		font-size: var(--text-h2);
		margin-bottom: var(--space-sm);
	}

	.product-articles-list {
		list-style: none;
		padding: 0;
	}

	.product-articles-list li {
		padding: var(--space-sm) 0;
		border-bottom: 1px solid var(--color-border);
	}

	.product-articles-list li:last-child {
		border-bottom: none;
		padding-bottom: 0;
	}

	.product-articles-list li:first-child {
		padding-top: 0;
	}

	.product-articles-list a {
		font-size: var(--text-body);
		text-decoration: none;
	}

	.product-articles-list a:hover {
		text-decoration: underline;
	}

	/* ——— FAQ (matches article layout) ——— */

	.faq {
		max-width: var(--max-width-narrow);
		margin-bottom: var(--space-2xl);
		padding-top: var(--space-lg);
		border-top: 1px solid var(--color-border);
	}

	.faq-heading {
		font-size: var(--text-h2);
		margin-bottom: var(--space-md);
	}

	.faq-list {
		display: flex;
		flex-direction: column;
	}

	.faq-item {
		border-bottom: 1px solid var(--color-border);
	}

	.faq-item:last-child {
		border-bottom: none;
	}

	.faq-q {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-sm);
		width: 100%;
		padding: var(--space-md) 0;
		font-size: var(--text-body);
		font-weight: var(--weight-semibold);
		color: var(--color-text);
		cursor: pointer;
		list-style: none;
		transition: color 0.15s;
	}

