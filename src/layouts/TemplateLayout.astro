---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { SITE_TITLE } from '../consts';

type Props = CollectionEntry<'templates'>['data'] & {
	id?: string;
};

const { title, description, badge, platforms, darkListing, lightListing, heroImage, lightImage, midImage, midImageLight, features, relatedArticles, bundles, faq, reviews, id, price, sku } = Astro.props;

const allArticles = await getCollection('articles');
const linkedArticles = relatedArticles
	.map((slug: string) => allArticles.find((a) => a.id === slug))
	.filter(Boolean)
	.slice(0, 4);

const allTemplates = await getCollection('templates');
const otherTemplates = allTemplates
	.filter((t) => t.id !== id)
	.sort((a, b) => a.data.order - b.data.order)
	.slice(0, 3);

const platformLabels: Record<string, string> = {
	'google-sheets': 'Google Sheets',
	'excel': 'Excel',
};

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://www.simplysheetdesign.com';
const imageUrl = `${siteUrl}${heroImage}`;

const reviewSchema = reviews?.map((r: { name: string; text: string; date?: string }) => ({
	'@type': 'Review',
	author: { '@type': 'Person', name: r.name },
	reviewBody: r.text,
	reviewRating: { '@type': 'Rating', ratingValue: 5, bestRating: 5 },
	...(r.date ? { datePublished: r.date } : {}),
}));

const aggregateRating = reviews?.length ? {
	'@type': 'AggregateRating',
	ratingValue: 5,
	reviewCount: reviews.length,
	bestRating: 5,
	worstRating: 1,
} : undefined;

const schema = {
	'@context': 'https://schema.org',
	'@type': 'Product',
	name: title,
	description,
	image: imageUrl,
	sku,
	brand: {
		'@type': 'Brand',
		name: SITE_TITLE,
	},
	...(reviewSchema?.length ? { review: reviewSchema } : {}),
	...(aggregateRating ? { aggregateRating } : {}),
	offers: {
		'@type': 'Offer',
		price: price.toFixed(2),
		priceCurrency: 'USD',
		availability: 'https://schema.org/InStock',
		url: darkListing,
		seller: {
			'@type': 'Organization',
			name: SITE_TITLE,
		},
		shippingDetails: {
			'@type': 'OfferShippingDetails',
			doesNotShip: true,
		},
		hasMerchantReturnPolicy: {
			'@type': 'MerchantReturnPolicy',
			applicableCountry: 'US',
			returnPolicyCategory: 'https://schema.org/MerchantReturnNotPermitted',
		},
	},
};

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{
			'@type': 'ListItem',
			position: 1,
			name: 'Home',
			item: Astro.site?.toString(),
		},
		{
			'@type': 'ListItem',
			position: 2,
			name: 'Templates',
			item: new URL('/templates', Astro.site).toString(),
		},
		{
			'@type': 'ListItem',
			position: 3,
			name: title,
		},
	],
};

const faqSchema = faq?.length ? {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faq.map(({ question, answer }: { question: string; answer: string }) => ({
		'@type': 'Question',
		name: question,
		acceptedAnswer: { '@type': 'Answer', text: answer },
	})),
} : null;

const templateId = Math.random().toString(36).slice(2, 10);

function featureIcon(text: string): string {
	const t = text.toLowerCase();
	// Income / earnings
	if (t.includes('income') && !t.includes('dual')) return '<path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>';
	// Dual / partners / couples
	if (t.includes('dual') || t.includes('partner') || (t.includes('both') && t.includes('income'))) return '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>';
	// Progress bars / visual progress
	if (t.includes('progress bar')) return '<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>';
	// Dashboard / overview
	if (t.includes('dashboard') || t.includes('overview')) return '<rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>';
	// Trends / spending trends
	if (t.includes('trend')) return '<polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>';
	// Log / logging / daily expense
	if (t.includes('log') || t.includes('logging')) return '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>';
	// Categories / customize / pre-built
	if (t.includes('categor') || t.includes('customize')) return '<line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/>';
	// Goals / target / savings goal
	if (t.includes('goal') || t.includes('target')) return '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>';
	// Contribution / combined savings
	if (t.includes('contribution')) return '<line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>';
	// Deadline / date
	if (t.includes('deadline') || t.includes('monthly') || t.includes('month')) return '<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>';
	// Debt / balance / credit
	if (t.includes('debt') || t.includes('balance') || t.includes('credit')) return '<rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/>';
	// Interest / percent
	if (t.includes('interest')) return '<line x1="19" y1="5" x2="5" y2="19"/><circle cx="6.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/>';
	// Shared / personal / split / bill
	if (t.includes('shared') || t.includes('personal') || t.includes('split') || t.includes('bill')) return '<path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>';
	// Spreadsheet / Google Sheets / Excel / works with
	if (t.includes('google sheets') || t.includes('excel') || t.includes('spreadsheet')) return '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M3 15h18M9 3v18"/>';
	// Default checkmark
	return '<polyline points="20 6 9 17 4 12"/>';
}
---

<html lang="en">
	<head>
		<BaseHead title={`${title} — ${SITE_TITLE}`} description={description} image={heroImage} />
		<script type="application/ld+json" set:html={JSON.stringify(schema)} />
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
		{faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
	</head>
	<body>
		<Header />

		<main class="template-main">
			<Breadcrumbs crumbs={[{ label: 'Templates', href: '/templates' }, { label: title }]} />

			<section class="product-hero">
				<div class="product-image">
					<img src={heroImage} alt={`${title} preview`} width="960" height="640" id={`hero-img-${templateId}`} />
				</div>
				<div class="product-info">
					{badge && <span class="product-badge">{badge}</span>}
					<h1 class="product-title">{title}</h1>
					<p class="product-desc">{description}</p>

					<div class="theme-toggle" id={`theme-toggle-${templateId}`}>
						<button class="theme-btn active" data-theme="dark">Dark</button>
						<button class="theme-btn" data-theme="light">Light</button>
					</div>

					<a
						href={darkListing}
						class="btn btn-primary product-cta"
						id={`cta-${templateId}`}
						target="_blank"
						rel="noopener noreferrer"
					>
						Get this template on Etsy
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
					</a>

					<div class="product-platforms">
						{platforms.map((p: string) => (
							<span class="platform-tag">{platformLabels[p] ?? p}</span>
						))}
					</div>
				</div>
			</section>

			{features.length > 0 && (
				<section class="product-features">
					<h2>What's included</h2>
					<ul class="features-list">
						{features.map((f: string) => (
							<li>
								<svg class="check-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={featureIcon(f)} />
								<span>{f}</span>
							</li>
						))}
					</ul>
				</section>
			)}

			{midImage && (
				<section class="product-mid-image">
					<img src={midImage} alt={`${title} preview`} width="960" height="540" id={`mid-img-${templateId}`} loading="lazy" />
				</section>
			)}

			<section class="product-howto">
				<div class="product-body prose">
					<slot />
				</div>
				<div class="product-howto-visual">
					<img src={heroImage} alt={`${title} preview`} width="960" height="640" loading="lazy" />
				</div>
			</section>

			{bundles && bundles.length > 0 && (
				<section class="product-bundles">
					<h2>Save with a bundle</h2>
					<div class="bundles-grid">
						{bundles.map((b: { name: string; darkUrl: string; lightUrl: string }) => (
							<a
								href={b.darkUrl}
								class="bundle-card"
								data-dark-url={b.darkUrl}
								data-light-url={b.lightUrl}
								target="_blank"
								rel="noopener noreferrer"
							>
								<span class="bundle-name">{b.name}</span>
								<span class="bundle-link">View on Etsy <span class="arrow">&rarr;</span></span>
							</a>
						))}
					</div>
				</section>
			)}

			{reviews && reviews.length > 0 && (
				<section class={`product-reviews${reviews.length > 1 ? ' is-multi' : ' is-single'}`} id={`reviews-${templateId}`}>
					<div class="reviews-quote-col">
						<div class="reviews-quote-stack">
							{reviews.map((r: { name: string; text: string }, i: number) => (
								<div class={`review-entry${i === 0 ? ' is-active' : ''}`} data-review-entry>
									<div class="review-stars" aria-label="5 out of 5 stars">
										{Array.from({ length: 5 }).map(() => (
											<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
										))}
									</div>
									<p class="reviews-quote" data-review-quote>{r.text}</p>
									<cite class="reviews-entry-name">{r.name}</cite>
								</div>
							))}
						</div>
						{reviews.length > 1 && (
							<span class="reviews-progress-track"><span class="reviews-progress-fill" data-review-progress></span></span>
						)}
						{reviews.length === 1 && (
							<a
								class="btn btn-secondary btn-sm reviews-etsy-link"
								href="https://www.etsy.com/shop/SimplySheetDesign?ref=dashboard-header#reviews"
								target="_blank"
								rel="noopener noreferrer"
							>
								See all Etsy reviews <span class="arrow">&rarr;</span>
							</a>
						)}
					</div>
					{reviews.length > 1 && (
						<div class="reviews-name-col">
							<span class="reviews-eyebrow">What people are saying</span>
							<div class="reviews-nav">
								<button type="button" class="reviews-nav-btn" data-review-prev aria-label="Previous review">
									<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
								</button>
								<button type="button" class="reviews-nav-btn" data-review-next aria-label="Next review">
									<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
								</button>
								<span class="reviews-count" data-review-count>1 of {reviews.length}</span>
							</div>
						</div>
					)}
					{reviews.length > 1 && (
						<a
							class="btn btn-secondary btn-sm reviews-etsy-link"
							href="https://www.etsy.com/shop/SimplySheetDesign?ref=dashboard-header#reviews"
							target="_blank"
							rel="noopener noreferrer"
						>
							See all Etsy reviews <span class="arrow">&rarr;</span>
						</a>
					)}
				</section>
			)}

			{linkedArticles.length > 0 && (
				<section class="product-articles">
					<h2>Related articles</h2>
					<ul class="product-articles-list">
						{linkedArticles.map((a: any) => (
							<li>
								<a href={`/articles/${a.id}/`}>{a.data.title}</a>
							</li>
						))}
					</ul>
				</section>
			)}

			{faq && faq.length > 0 && (
				<section class="faq">
					<h2 class="faq-heading">Frequently asked questions</h2>
					<div class="faq-list">
						{faq.map(({ question, answer }: { question: string; answer: string }) => (
							<details class="faq-item">
								<summary class="faq-q">
									<span>{question}</span>
									<svg class="faq-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<polyline points="6 9 12 15 18 9" />
									</svg>
								</summary>
								<div class="faq-a-wrap">
									<p class="faq-a">{answer}</p>
								</div>
							</details>
						))}
					</div>
				</section>
			)}

			{otherTemplates.length > 0 && (
				<section class="other-templates">
					<h2>More spreadsheets</h2>
					<div class="other-templates-grid">
						{otherTemplates.map((t) => (
							<a href={`/templates/${t.id}/`} class="template-card">
								<div class="template-thumb">
									<img src={t.data.heroImage} alt={`${t.data.title} preview`} width="600" height="400" loading="lazy" />
								</div>
								{t.data.badge && <span class="template-badge">{t.data.badge}</span>}
								<h3 class="template-name">{t.data.title.replace(/ for Google Sheets & Excel$/, '')}</h3>
								<p class="template-desc">{t.data.description}</p>
							</a>
						))}
					</div>
				</section>
			)}
		</main>
		<Footer />

		<script is:inline define:vars={{ templateId, darkListing, lightListing, heroImage, lightImage, midImage, midImageLight }}>
			const toggle = document.getElementById(`theme-toggle-${templateId}`);
			const cta = document.getElementById(`cta-${templateId}`);
			const heroImg = document.getElementById(`hero-img-${templateId}`);
			const midImg = document.getElementById(`mid-img-${templateId}`);

			if (toggle && cta) {
				toggle.addEventListener('click', (e) => {
					const btn = e.target.closest('.theme-btn');
					if (!btn) return;

					toggle.querySelectorAll('.theme-btn').forEach((b) => b.classList.remove('active'));
					btn.classList.add('active');

					const theme = btn.dataset.theme;
					cta.href = theme === 'light' ? lightListing : darkListing;

					if (heroImg && lightImage) {
						heroImg.src = theme === 'light' ? lightImage : heroImage;
					}

					if (midImg && midImageLight) {
						midImg.src = theme === 'light' ? midImageLight : midImage;
					}

					document.querySelectorAll('.bundle-card').forEach((card) => {
						card.href = theme === 'light' ? card.dataset.lightUrl : card.dataset.darkUrl;
					});
				});
			}

			document.querySelectorAll('.faq-item').forEach((details) => {
				const summary = details.querySelector('summary');
				const wrap = details.querySelector('.faq-a-wrap');
				if (!summary || !wrap) return;

				summary.addEventListener('click', (e) => {
					e.preventDefault();
					if (details.open) {
						wrap.style.gridTemplateRows = '0fr';
						wrap.addEventListener('transitionend', () => {
							details.open = false;
							wrap.style.gridTemplateRows = '';
						}, { once: true });
					} else {
						details.open = true;
					}
				});
			});
		</script>

		{reviews && reviews.length > 1 && (
			<script is:inline define:vars={{ templateId }}>
				const reviewsSection = document.getElementById(`reviews-${templateId}`);
				const stackEl = reviewsSection.querySelector('.reviews-quote-stack');
				const entryEls = Array.from(reviewsSection.querySelectorAll('[data-review-entry]'));
				const progressFill = reviewsSection.querySelector('[data-review-progress]');
				const progressTrack = reviewsSection.querySelector('.reviews-progress-track');
				const countEl = reviewsSection.querySelector('[data-review-count]');
				const prevBtn = reviewsSection.querySelector('[data-review-prev]');
				const nextBtn = reviewsSection.querySelector('[data-review-next]');
				const mobileQuery = window.matchMedia('(max-width: 720px)');
				const DURATION = 6500;
				let activeIndex = 0;
				let elapsed = 0;
				let lastTick = performance.now();
				let manualMode = false;
				let inView = false;

				function syncStackHeight() {
					if (mobileQuery.matches) return;
					const max = Math.max(...entryEls.map((el) => el.offsetHeight));
					const minHeight = window.innerHeight * 0.8;
					stackEl.style.height = `${Math.max(max, minHeight)}px`;
				}

				function setActive(index) {
					activeIndex = (index + entryEls.length) % entryEls.length;
					elapsed = 0;
					lastTick = performance.now();
					if (progressFill) {
						progressFill.style.transition = 'none';
						progressFill.style.width = '0%';
					}
					if (progressTrack) {
						progressTrack.style.display = manualMode ? 'none' : 'block';
					}
					if (countEl) {
						countEl.textContent = `${activeIndex + 1} of ${entryEls.length}`;
					}
					entryEls.forEach((el, i) => el.classList.toggle('is-active', i === activeIndex));
				}

				function tick(now) {
					if (!manualMode && inView && !mobileQuery.matches) {
						elapsed += now - lastTick;
						const progress = Math.min(1, elapsed / DURATION);
						if (progressFill) {
							progressFill.style.transition = 'none';
							progressFill.style.width = `${progress * 100}%`;
						}
						if (progress >= 1) {
							setActive(activeIndex + 1);
						}
					}
					lastTick = now;
					requestAnimationFrame(tick);
				}

				prevBtn?.addEventListener('click', () => {
					manualMode = true;
					setActive(activeIndex - 1);
				});
				nextBtn?.addEventListener('click', () => {
					manualMode = true;
					setActive(activeIndex + 1);
				});

				const observer = new IntersectionObserver((entries) => {
					entries.forEach((entry) => {
						inView = entry.isIntersecting;
						if (inView) lastTick = performance.now();
					});
				}, { threshold: 0.5 });
				observer.observe(reviewsSection);

				let resizeTimer;
				window.addEventListener('resize', () => {
					clearTimeout(resizeTimer);
					resizeTimer = setTimeout(syncStackHeight, 150);
				});

				setActive(0);
				syncStackHeight();
				if (document.fonts && document.fonts.ready) {
					document.fonts.ready.then(syncStackHeight);
				}
				requestAnimationFrame(tick);
			</script>
		)}
	</body>
</html>

<style>
	.template-main {
		max-width: calc(var(--max-width) + var(--space-md) * 2);
		margin: 0 auto;
		padding: var(--space-lg) var(--space-md) var(--space-2xl);
	}

	/* ——— Product hero ——— */

	.product-hero {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-xl);
		align-items: start;
		margin-bottom: var(--space-2xl);
	}

	.product-image {
		border-radius: var(--radius-md);
		overflow: hidden;
		background: var(--color-bg-panel);
	}

	.product-image img {
		display: block;
		width: 100%;
		height: auto;
	}

	.product-badge {
		display: inline-block;
		font-size: var(--text-xs);
		font-weight: var(--weight-semibold);
		color: var(--color-accent);
		background: var(--color-accent-light);
		border-radius: var(--radius-full);
		padding: 0.25rem 0.75rem;
		margin-bottom: var(--space-sm);
	}

	.product-title {
		font-size: clamp(1.5rem, 2.5vw + 0.5rem, 2.25rem);
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--space-xs);
	}

	.product-desc {
		font-size: var(--text-body);
		line-height: var(--leading-normal);
		color: var(--color-text-secondary);
		margin-bottom: var(--space-md);
	}

	/* ——— Theme toggle ——— */

	.theme-toggle {
		display: inline-flex;
		gap: 0;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-full);
		padding: 0.1875rem;
		margin-bottom: var(--space-md);
	}

	.theme-btn {
		font-family: var(--font-sans);
