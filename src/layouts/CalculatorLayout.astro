---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ProductPromo from '../components/ProductPromo.astro';
import { SITE_TITLE } from '../consts';
import { TOOLS } from '../data/tools';

function slugifyFaq(text: string): string {
	return text
		.toLowerCase()
		.replace(/[^a-z0-9]+/g, '-')
		.replace(/(^-|-$)/g, '');
}

interface TocEntry {
	slug: string;
	text: string;
}

interface FaqEntry {
	question: string;
	answer: string;
}

interface Props {
	title: string;
	metaTitle: string;
	description: string;
	breadcrumbLabel: string;
	kind?: 'calculator' | 'assessment';
	toc: TocEntry[];
	faq?: FaqEntry[];
	tags?: string[];
	productSlug: string;
	productLabel?: string;
	relatedToolUrls?: string[];
}

const {
	title,
	metaTitle,
	description,
	breadcrumbLabel,
	kind = 'calculator',
	toc,
	faq = [],
	tags = [],
	productSlug,
	productLabel,
	relatedToolUrls,
} = Astro.props;

const currentPath = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const otherTools = TOOLS.filter((t) => t.url !== currentPath);
const relatedTools = relatedToolUrls
	? relatedToolUrls.map((url) => otherTools.find((t) => t.url === url)).filter((t): t is (typeof TOOLS)[number] => Boolean(t))
	: otherTools.slice(0, 4);

const allArticles = await getCollection('articles');
const sorted = allArticles.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const tagMatched = sorted.filter((a) => a.data.tags?.some((t) => tags.includes(t)));
const untagged = sorted.filter((a) => !tagMatched.includes(a));
const related = [...tagMatched, ...untagged].slice(0, 4);

const kindLabel = kind === 'assessment' ? 'Assessment' : 'Calculator';
const tocEntries: TocEntry[] = [
	{ slug: 'calculator', text: kindLabel },
	...toc,
	...(faq.length ? [{ slug: 'faq', text: 'Frequently asked questions' }] : []),
	{ slug: 'more-tools', text: 'More free tools' },
	...(related.length ? [{ slug: 'related-articles', text: 'Related articles' }] : []),
];

const appSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebApplication',
	name: title,
	description,
	url: Astro.url.toString(),
	applicationCategory: 'FinanceApplication',
	operatingSystem: 'Any',
	offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
	publisher: {
		'@type': 'Organization',
		name: SITE_TITLE,
		url: Astro.site?.toString(),
	},
};

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{
			'@type': 'ListItem',
			position: 1,
			name: 'Home',
			item: Astro.site?.toString(),
		},
		{
			'@type': 'ListItem',
			position: 2,
			name: 'Tools',
			item: new URL('/tools/', Astro.site).toString(),
		},
		{
			'@type': 'ListItem',
			position: 3,
			name: breadcrumbLabel,
		},
	],
};

const faqSchema = faq.length ? {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faq.map(({ question, answer }) => ({
		'@type': 'Question',
		name: question,
		acceptedAnswer: { '@type': 'Answer', text: answer },
	})),
} : null;
---

<html lang="en">
	<head>
		<BaseHead title={`${metaTitle} — ${SITE_TITLE}`} description={description} />
		<script type="application/ld+json" set:html={JSON.stringify(appSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
		{faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
	</head>
	<body>
		<Header />
		<div class="reading-progress" id="reading-progress"></div>

		<main class="calc-main">
			<Breadcrumbs crumbs={[{ label: 'Tools', href: '/tools' }, { label: breadcrumbLabel }]} />
			<div class="calc-grid">
				<div class="toc-rail">
					<nav class="toc" aria-label="Table of contents">
						<p class="toc-heading">On this page</p>
						<ul class="toc-list">
							{tocEntries.map((h) => (
								<li><a href={`#${h.slug}`} data-toc-slug={h.slug}>{h.text}</a></li>
							))}
						</ul>
					</nav>
					<ProductPromo slug={productSlug} variant="mini" />
				</div>

				<article>
					<header class="calc-header">
						<h1>{title}</h1>
						<p class="calc-intro"><slot name="intro" /></p>
					</header>

					<div class="calc-embed" id="calculator">
						<slot name="calculator" />
					</div>

					<div class="prose">
						<slot />
					</div>

					{faq.length > 0 && (
						<section class="faq" id="faq">
							<h2 class="faq-heading">Frequently asked questions</h2>
							<div class="faq-list">
								{faq.map(({ question, answer }) => (
									<details class="faq-item" id={slugifyFaq(question)}>
										<summary class="faq-q">
											<span>{question}</span>
											<svg class="faq-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
												<polyline points="6 9 12 15 18 9" />
											</svg>
										</summary>
										<div class="faq-a-wrap">
											<p class="faq-a" set:html={answer} />
										</div>
									</details>
								))}
							</div>
						</section>
					)}

					<section class="more-tools" id="more-tools">
						<h2 class="more-tools-heading">More free tools</h2>
						<div class="more-tools-grid">
							{relatedTools.map((tool) => (
								<a href={tool.url} class="more-tool">
									{tool.thumb ? (
										<img class="more-tool-thumb" src={tool.thumb} alt={tool.name} width="960" height="540" loading="lazy" />
									) : (
										<span class="more-tool-thumb more-tool-thumb--placeholder" set:html={`<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">${tool.icon}</svg>`} />
									)}
									<div class="more-tool-text">
										<h3 class="more-tool-title">{tool.name}</h3>
										<p class="more-tool-desc">{tool.desc}</p>
									</div>
								</a>
							))}
						</div>
						<p class="more-tools-all"><a href="/tools/">View all tools <span class="arrow">&rarr;</span></a></p>
					</section>

					{related.length > 0 && (
						<aside class="related" id="related-articles">
							<h2 class="related-heading">Related articles</h2>
							<ul class="related-list">
								{related.map((r) => (
									<li>
										<a href={`/articles/${r.id}/`}>{r.data.title}</a>
									</li>
								))}
							</ul>
						</aside>
					)}

					<section class="calc-product">
						<ProductPromo slug={productSlug} variant="interstitial" label={productLabel} />
					</section>
				</article>
			</div>
		</main>
		<Footer />

		<script>
			if (location.hash) {
				const linkedFaq = document.getElementById(location.hash.slice(1));
				if (linkedFaq && linkedFaq.classList.contains('faq-item')) linkedFaq.open = true;
			}

			document.querySelectorAll<HTMLDetailsElement>('.faq-item').forEach((details) => {
				const summary = details.querySelector('summary');
				const wrap = details.querySelector<HTMLElement>('.faq-a-wrap');
				if (!summary || !wrap) return;

				summary.addEventListener('click', (e) => {
					e.preventDefault();
					if (details.open) {
						wrap.style.gridTemplateRows = '0fr';
						wrap.addEventListener('transitionend', () => {
							details.open = false;
							wrap.style.gridTemplateRows = '';
						}, { once: true });
					} else {
						details.open = true;
					}
				});
			});

			const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('.toc-list a[data-toc-slug]'));
			if (tocLinks.length > 0) {
				const headingEls = tocLinks
					.map((link) => document.getElementById(link.dataset.tocSlug!))
					.filter((el): el is HTMLElement => el !== null);

				let currentActive: HTMLAnchorElement | null = null;

				function setActive(link: HTMLAnchorElement | null) {
					if (link === currentActive) return;
					currentActive?.classList.remove('active');
					link?.classList.add('active');
					currentActive = link;
				}

				const TOC_SCROLL_OFFSET = 96;
				let tocTicking = false;

				function updateActiveToc() {
					let current = tocLinks[0];
					for (let i = 0; i < headingEls.length; i++) {
						if (headingEls[i].getBoundingClientRect().top <= TOC_SCROLL_OFFSET) {
							current = tocLinks[i];
						}
					}
					setActive(current);
					tocTicking = false;
				}

				window.addEventListener('scroll', () => {
					if (!tocTicking) {
						requestAnimationFrame(updateActiveToc);
						tocTicking = true;
					}
				}, { passive: true });

				updateActiveToc();
			}

			const progressBar = document.getElementById('reading-progress');
			if (progressBar) {
				let pTicking = false;
				window.addEventListener('scroll', () => {
					if (!pTicking) {
						requestAnimationFrame(() => {
							const docHeight = document.documentElement.scrollHeight - window.innerHeight;
							const progress = docHeight > 0 ? (window.scrollY / docHeight) * 100 : 0;
							progressBar.style.width = `${Math.min(progress, 100)}%`;
							pTicking = false;
						});
						pTicking = true;
					}
				}, { passive: true });
			}
		</script>
	</body>
</html>

<style>
	/* ——— Reading progress bar ——— */

	.reading-progress {
		position: fixed;
		top: 3.5rem;
		left: 0;
		height: 3px;
		background: var(--color-text-heading);
		width: 0%;
		z-index: 49;
		transition: width 50ms linear;
		display: none;
	}

	@media (max-width: 960px) {
		.reading-progress {
			display: block;
		}
		.toc-rail {
			display: none;
		}
	}

	/* ——— Main layout ——— */

	.calc-main {
		--toc-rail-width: 220px;
		--toc-gap: calc(var(--space-xl) + 3rem);
		max-width: calc(var(--max-width-narrow) + var(--space-md) * 2);
		margin: 0 auto;
		padding: var(--space-lg) var(--space-md) var(--space-2xl);
	}

	@media (min-width: 1100px) {
		.calc-main {
			/* Header's nav is max-width(--max-width) plus its own space-md padding outside that;
			   mirror the same total width here so the TOC's left edge lines up with the logo/nav. */
			max-width: calc(var(--max-width) + var(--space-md) * 2);
		}
	}

	.calc-grid {
		padding-top: var(--space-lg);
	}

	@media (min-width: 1100px) {
		.calc-grid {
			display: grid;
			grid-template-columns: var(--toc-rail-width) minmax(0, var(--max-width-narrow));
			column-gap: var(--toc-gap);
			align-items: start;
		}

		.toc-rail {
			position: sticky;
			top: 4.5rem;
			margin-bottom: 0;
		}
	}

	/* ——— Header ——— */

	.calc-header {
		margin-bottom: var(--space-sm);
	}

	.calc-header h1 {
		font-size: var(--text-h1);
	}

	.calc-intro {
		font-size: var(--text-body);
		line-height: var(--leading-normal);
		color: var(--color-text-secondary);
	}

	.calc-embed {
		scroll-margin-top: 4.5rem;
	}

	/* ——— Table of contents ——— */

	.toc-rail {
		margin-bottom: calc(var(--space-lg) + 1.5rem);
	}

	.toc-heading {
		font-size: 0.875rem;
		font-weight: var(--weight-normal);
		color: var(--color-text);
		margin: 0 0 var(--space-sm);
	}

	.toc-list {
		list-style: none;
		display: flex;
		flex-direction: column;
		margin: 0;
		padding: 0;
		border-left: 1px solid var(--color-border);
	}

	.toc-list a {
		display: block;
		padding: 0.375rem 0 0.375rem var(--space-sm);
		margin-left: -1px;
		border-left: 2px solid transparent;
		font-size: 0.875rem;
		line-height: var(--leading-snug);
		color: var(--color-text-muted);
		text-decoration: none;
		transition: color 0.15s, border-color 0.15s;
	}

	.toc-list a:hover {
		color: var(--color-text);
	}

	.toc-list a.active {
		color: var(--color-text-heading);
		font-weight: var(--weight-normal);
		border-left-color: var(--color-text-heading);
	}

	/* ——— FAQ section ——— */

	.faq {
		margin-top: var(--space-2xl);
		padding-top: var(--space-lg);
		border-top: 1px solid var(--color-border);
		scroll-margin-top: 4.5rem;
	}

	.faq-heading {
		font-size: var(--text-h2);
		margin-bottom: var(--space-md);
	}

	.faq-list {
		display: flex;
		flex-direction: column;
	}

	.faq-item {
		border-bottom: 1px solid var(--color-border);
		scroll-margin-top: 4.5rem;
	}

	.faq-item:last-child {
		border-bottom: none;
	}

	.faq-q {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-sm);
		width: 100%;
		padding: var(--space-md) 0;
		font-size: var(--text-body);
		font-weight: var(--weight-normal);
		color: var(--color-text);
		cursor: pointer;
		list-style: none;
		transition: color 0.15s;
	}

	.faq-q::-webkit-details-marker {
		display: none;
	}

	.faq-q::marker {
		display: none;
		content: '';
	}

	.faq-arrow {
		flex-shrink: 0;
		transition: transform 300ms ease;
	}

	.faq-item[open] .faq-arrow {
		transform: rotate(180deg);
	}

	.faq-a-wrap {
		display: grid;
		grid-template-rows: 0fr;
		transition: grid-template-rows 300ms ease;
	}

	.faq-item[open] .faq-a-wrap {
		grid-template-rows: 1fr;
	}

	.faq-a-wrap > .faq-a {
		overflow: hidden;
	}

	.faq-a {
		font-size: var(--text-body);
		line-height: var(--leading-normal);
		color: var(--color-text-secondary);
		margin: 0;
		padding-bottom: var(--space-md);
	}

	/* ——— More tools ——— */

	.more-tools {
		margin-top: var(--space-2xl);
		padding-top: var(--space-lg);
		border-top: 1px solid var(--color-border);
		scroll-margin-top: 4.5rem;
	}

	.more-tools-heading {
		font-size: var(--text-h3);
		margin-bottom: var(--space-md);
	}

	.more-tools-grid {
		display: grid;
		grid-template-columns: 1fr;
		row-gap: var(--space-lg);
	}

	.more-tool {
		display: flex;
		align-items: center;
		gap: var(--space-md);
		text-decoration: none;
		color: inherit;
	}

	.more-tool-thumb {
		flex-shrink: 0;
		width: 180px;
		height: auto;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		border-radius: var(--radius-md);
		border: 1px solid var(--color-border);
		transition: opacity 0.15s ease;
	}

	.more-tool-thumb--placeholder {
		display: flex;
		align-items: center;
		justify-content: center;
		background: var(--color-bg-panel);
		color: var(--color-text-secondary);
	}

	@media (hover: hover) {
		.more-tool:hover .more-tool-thumb {
			opacity: 0.85;
		}
		.more-tool:hover .more-tool-title {
			text-decoration: underline;
		}
	}

	.more-tool-text {
		min-width: 0;
	}

	.more-tool-title {
		font-size: var(--text-body);
		font-weight: var(--weight-normal);
		line-height: 1.35;
		margin: 0 0 var(--space-2xs);
		color: var(--color-text);
	}

	.more-tool-desc {
		font-size: var(--text-small);
		line-height: var(--leading-snug);
		color: var(--color-text-secondary);
		margin: 0;
	}

	.more-tools-all {
		margin: var(--space-lg) 0 0;
		font-size: var(--text-small);
	}

	.more-tools-all a {
		text-decoration: none;
	}

	.more-tools-all a:hover {
		text-decoration: underline;
	}

	@media (max-width: 480px) {
		.more-tool-thumb {
			width: 132px;
		}
	}

	/* ——— Related articles ——— */

	.related {
		margin-top: var(--space-2xl);
		padding-top: var(--space-lg);
		border-top: 1px solid var(--color-border);
		scroll-margin-top: 4.5rem;
	}

	.related-heading {
		font-size: var(--text-h3);
		margin-bottom: var(--space-sm);
	}

	.related-list {
		list-style: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0;
	}
	.related-list li {
		padding: var(--space-sm) 0;
		border-bottom: 1px solid var(--color-border);
	}
	.related-list li:last-child {
		border-bottom: none;
		padding-bottom: 0;
	}
	.related-list li:first-child {
		padding-top: 0;
	}

	.related-list a {
		font-size: var(--text-body);
		text-decoration: none;
	}

	.related-list a:hover {
		text-decoration: underline;
	}

	/* ——— Recommended product ——— */

	.calc-product {
		margin-top: var(--space-2xl);
		padding-top: var(--space-lg);
		border-top: 1px solid var(--color-border);
	}
</style>
