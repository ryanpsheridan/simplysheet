---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BudgetingStyleQuiz from '../../components/BudgetingStyleQuiz.astro';
import { SITE_TITLE } from '../../consts';

const title = "Find Your Budgeting Style";
const description = 'Take our 60-second quiz to uncover your unique money personality and get one actionable tip to reach your goals faster.';
---

<BaseLayout title={`${title} — ${SITE_TITLE}`} description={description}>
	<main>
		<article>
			<header class="quiz-header">
				<h1>Find Your Budgeting Style</h1>
				<p class="quiz-intro">Take our 60-second quiz to uncover your unique money personality and get one actionable tip to reach your goals faster.</p>
			</header>

			<BudgetingStyleQuiz />

			<div class="quiz-article-link">
				<a href="/articles/budgeting-styles/">
					<img src="/images/card-budgeting-styles.svg" alt="The 4 Budgeting Styles" width="960" height="540" loading="lazy" />
					<div class="quiz-article-link-text">
						<span class="quiz-article-link-label">Related article</span>
						<span class="quiz-article-link-title">The 4 Budgeting Styles: Which One Are You?</span>
						<span class="quiz-article-link-desc">Learn what each budgeting style looks like, what trips each one up, and how to build a system that works with your natural tendencies.</span>
					</div>
				</a>
			</div>

			<section class="quiz-why">
				<h2>Why Your Budget Type Matters</h2>
				<p>A one-size-fits-all budget rarely works. Understanding your natural financial tendencies helps you build a system that sticks, so you can stop stressing and start reaching your goals.</p>
			</section>

			<div class="quiz-callout">
				<p class="quiz-callout-text">No matter your type, the right spreadsheet can help you stay on track. Browse all of our <a href="https://simplysheetdesign.etsy.com">budget templates</a> to find the one that fits how you manage money.</p>
			</div>
		</article>
	</main>
</BaseLayout>

<style>
	.quiz-header {
		margin-bottom: var(--space-sm);
	}
	.quiz-header h1 {
		font-size: var(--text-h1);
		font-weight: var(--weight-bold);
	}
	.quiz-intro {
		font-size: var(--text-body);
		line-height: var(--leading-normal);
		color: var(--color-text-secondary);
	}
	.quiz-callout {
		margin-top: var(--space-xl);
		padding: var(--space-md);
		background: var(--color-bg-panel);
		border-radius: var(--radius-md);
	}
	.quiz-callout-text {
		font-size: var(--text-small);
		line-height: var(--leading-normal);
		color: var(--color-text-secondary);
		margin: 0;
	}
	.quiz-callout-text a {
		font-weight: var(--weight-medium);
	}
	.quiz-article-link {
		margin-top: var(--space-xl);
	}
	.quiz-article-link a {
		display: block;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		overflow: hidden;
		text-decoration: none;
		color: inherit;
		transition: border-color 0.15s, box-shadow 0.15s;
	}
	.quiz-article-link a:hover {
		border-color: var(--color-text-muted);
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
	}
	.quiz-article-link img {
		width: 100%;
		height: auto;
		display: block;
	}
	.quiz-article-link-text {
		padding: var(--space-md);
	}
	.quiz-article-link-label {
		display: block;
		font-size: var(--text-small);
		font-weight: var(--weight-semibold);
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
		color: var(--color-text-muted);
		margin-bottom: var(--space-2xs);
	}
	.quiz-article-link-title {
		display: block;
		font-size: var(--text-h3);
		font-weight: var(--weight-semibold);
		color: var(--color-text);
		margin-bottom: var(--space-xs);
	}
	.quiz-article-link-desc {
		display: block;
		font-size: var(--text-small);
		line-height: var(--leading-normal);
		color: var(--color-text-secondary);
	}
	.quiz-why {
		margin-top: var(--space-xl);
	}
	.quiz-why h2 {
		font-size: var(--text-h2);
		font-weight: var(--weight-semibold);
		margin-bottom: var(--space-sm);
	}
	.quiz-why p {
		font-size: var(--text-body);
		line-height: var(--leading-normal);
		color: var(--color-text-secondary);
	}
</style>
