---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import BudgetCalculator from '../../components/BudgetCalculator.astro';
import { SITE_TITLE } from '../../consts';

const title = `50/30/20 Budget Calculator — Find Your Monthly Targets`;
const description = 'Free 50/30/20 budget calculator. Enter your take-home pay and instantly see how much to spend on needs, wants, and savings each month.';
---

<BaseLayout title={`${title} — ${SITE_TITLE}`} description={description}>
	<main>
		<Breadcrumbs crumbs={[{ label: 'Tools', href: '/tools' }, { label: '50/30/20 Budget Calculator' }]} />
		<article>
			<header class="calc-header">
				<h1>50/30/20 Budget Calculator</h1>
				<p class="calc-intro">The 50/30/20 rule splits your after-tax income into three categories: 50% to needs (rent, groceries, insurance), 30% to wants (dining out, hobbies, subscriptions), and 20% to savings and debt payoff. Enter your monthly take-home pay below to see your target dollar amounts for each category.</p>
			</header>

			<BudgetCalculator />

			<div class="calc-callout">
				<p class="calc-callout-text">Now that you know your targets, a <a href="/templates/budget-spreadsheet/">budget spreadsheet</a> tracks your actual spending against them every month — so you can see whether you're hitting the split or where you're drifting.</p>
			</div>
		</article>
	</main>
</BaseLayout>

<style>
	main {
		max-width: calc(var(--max-width-narrow) + var(--space-md) * 2);
	}
	.calc-header {
		margin-bottom: var(--space-sm);
	}
	.calc-header h1 {
		font-size: var(--text-h1);
	}
	.calc-intro {
		font-size: var(--text-body);
		line-height: var(--leading-normal);
		color: var(--color-text-secondary);
	}
	.calc-callout {
		margin-top: var(--space-xl);
		padding: var(--space-md);
		background: var(--color-bg-panel);
		border-radius: var(--radius-md);
	}
	.calc-callout-text {
		font-size: var(--text-small);
		line-height: var(--leading-normal);
		color: var(--color-text-secondary);
		margin: 0;
	}
	.calc-callout-text a {
		font-weight: var(--weight-medium);
	}
</style>
