---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SinkingFundCalculator from '../../components/SinkingFundCalculator.astro';
import { SITE_TITLE } from '../../consts';

const title = 'Is a Sinking Fund Right for This Expense? — Free Assessment';
const description = 'Answer 5 quick questions to find out whether an upcoming expense fits a sinking fund, your emergency fund, or your regular monthly budget.';
---

<BaseLayout title={`${title} — ${SITE_TITLE}`} description={description}>
	<main>
		<Breadcrumbs crumbs={[{ label: 'Tools', href: '/tools' }, { label: 'Sinking Fund Assessment' }]} />
		<article>
			<header class="calc-header">
				<h1>Is a Sinking Fund Right for This Expense?</h1>
				<p class="calc-intro">Not every upcoming cost belongs in a sinking fund — some are better covered by your emergency fund, and some are really just a monthly budget category. Answer 5 quick questions about the expense you're thinking about, and this assessment will tell you which one fits best.</p>
			</header>

			<SinkingFundCalculator mode="assessment" />

			<div class="calc-callout">
				<p class="calc-callout-text">For a deeper look at how sinking funds work and why they make budgeting feel easier, read <a href="/articles/sinking-funds-explained/">How Sinking Funds Help You Stop Paying for Emergencies That Aren't Actually Emergencies</a>. Once you've confirmed it's a good fit, use the <a href="/tools/sinking-fund-calculator/">sinking fund calculator</a> to see exactly how much to save each month.</p>
			</div>
		</article>
	</main>
</BaseLayout>

<style>
	main {
		max-width: calc(var(--max-width-narrow) + var(--space-md) * 2);
	}
	.calc-header {
		margin-bottom: var(--space-sm);
	}
	.calc-header h1 {
		font-size: var(--text-h1);
	}
	.calc-intro {
		font-size: var(--text-body);
		line-height: var(--leading-normal);
		color: var(--color-text-secondary);
	}
	.calc-callout {
		margin-top: var(--space-xl);
		padding: var(--space-md);
		background: var(--color-bg-panel);
		border-radius: var(--radius-md);
	}
	.calc-callout-text {
		font-size: var(--text-small);
		line-height: var(--leading-normal);
		color: var(--color-text-secondary);
		margin: 0;
	}
	.calc-callout-text a {
		font-weight: var(--weight-normal);
	}
</style>
