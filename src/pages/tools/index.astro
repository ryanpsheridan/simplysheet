---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { SITE_TITLE } from '../../consts';
import { TOOLS } from '../../data/tools';

const title = 'Free Budgeting Calculators & Tools';
const description = 'Free calculators and assessments to help you manage your money. Compare debt payoff strategies, find your ideal budget split, and more.';

const calculators = TOOLS.filter((t) => t.group === 'calculator');
const assessments = TOOLS.filter((t) => t.group === 'assessment');
---

<BaseLayout title={`${title} — ${SITE_TITLE}`} description={description}>
	<main>
		<Breadcrumbs crumbs={[{ label: 'Tools' }]} />
		<header class="tools-header">
			<h1>Tools</h1>
			<p class="tools-intro">Free calculators and assessments to help you make clearer decisions about your money.</p>
		</header>

		<div class="tools-rows">
			<div class="tools-row">
				<div class="tools-row-label">
					<h2 class="tools-row-heading">Calculators</h2>
				</div>
				<div class="tools-row-items">
					{calculators.map((tool) => (
						<a href={tool.url} class="tools-row-item">
							<span class="tools-row-icon" set:html={`<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">${tool.icon}</svg>`} />
							<div class="tools-row-text">
								<h3 class="tools-row-title">{tool.name}</h3>
								<p class="tools-row-desc">{tool.desc}</p>
							</div>
						</a>
					))}
				</div>
			</div>

			<div class="tools-row">
				<div class="tools-row-label">
					<h2 class="tools-row-heading">Assessments</h2>
				</div>
				<div class="tools-row-items">
					{assessments.map((tool) => (
						<a href={tool.url} class="tools-row-item">
							<span class="tools-row-icon" set:html={`<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">${tool.icon}</svg>`} />
							<div class="tools-row-text">
								<h3 class="tools-row-title">{tool.name}</h3>
								<p class="tools-row-desc">{tool.desc}</p>
							</div>
						</a>
					))}
				</div>
			</div>
		</div>
	</main>
</BaseLayout>

<style>
	.tools-header {
		margin-bottom: var(--space-lg);
	}
	.tools-header h1 {
		font-size: var(--text-h1);
	}
	.tools-intro {
		font-size: var(--text-body);
		line-height: var(--leading-normal);
		color: var(--color-text-secondary);
	}

	.tools-row {
		display: grid;
		grid-template-columns: 12rem 1fr;
		gap: var(--space-xl);
		padding: var(--space-lg) 0;
		border-top: 1px solid var(--color-border);
	}
	.tools-row-heading {
		font-size: var(--text-h3);
		font-weight: var(--weight-normal);
		margin: 0;
	}
	.tools-row-items {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		row-gap: 3rem;
		column-gap: 2rem;
	}
	.tools-row-item {
		display: flex;
		align-items: flex-start;
		gap: var(--space-sm);
		text-decoration: none;
		color: inherit;
		transition: opacity 0.15s ease;
	}
	@media (hover: hover) {
		.tools-row-item:hover {
			opacity: 0.7;
		}
	}
	.tools-row-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		width: 2.5rem;
		height: 2.5rem;
		border-radius: var(--radius-full);
		background: var(--color-bg-panel);
		color: var(--color-text);
	}
	.tools-row-text {
		min-width: 0;
	}
	.tools-row-title {
		font-size: var(--text-body);
		font-weight: var(--weight-normal);
		line-height: 1.35;
		margin: 0 0 var(--space-2xs);
		color: var(--color-text);
	}
	.tools-row-desc {
		font-size: var(--text-small);
		line-height: var(--leading-snug);
		color: var(--color-text-secondary);
		margin: 0;
	}

	@media (max-width: 960px) {
		.tools-row-items {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 768px) {
		.tools-row {
			grid-template-columns: 1fr;
			gap: var(--space-sm);
		}
	}

	@media (max-width: 600px) {
		.tools-row-items {
			grid-template-columns: 1fr;
		}
	}
</style>
