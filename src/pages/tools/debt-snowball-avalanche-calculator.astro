---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DebtCalculator from '../../components/DebtCalculator.astro';
import { SITE_TITLE } from '../../consts';

const title = 'How Much Could Extra Payments Save You?';
const description = 'See how much interest you could save and how much sooner you could be debt-free by putting extra money toward your debt each month.';
---

<BaseLayout title={`${title} — ${SITE_TITLE}`} description={description}>
	<main>
		<article>
			<header class="calc-header">
				<h1>How much could extra payments save you?</h1>
				<p class="calc-intro">Most people know that paying more than the minimum helps. But it can be hard to feel how much of a difference even a small extra payment makes until you see the numbers. Drag the slider below to find out.</p>
			</header>

			<DebtCalculator />
		</article>
	</main>
</BaseLayout>

<style>
	.calc-header {
		margin-bottom: var(--space-sm);
	}
	.calc-header h1 {
		font-size: var(--text-h1);
		font-weight: var(--weight-bold);
	}
	.calc-intro {
		font-size: var(--text-body);
		line-height: var(--leading-normal);
		color: var(--color-text-secondary);
	}
</style>
