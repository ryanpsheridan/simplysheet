---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DebtCalculator from '../../components/DebtCalculator.astro';
import { SITE_TITLE } from '../../consts';

const title = 'Debt Snowball vs. Avalanche Calculator';
const description = 'Compare snowball and avalanche debt payoff methods side by side. Enter your debts and see which approach saves more money and gets you debt-free faster.';
---

<BaseLayout title={`${title} — ${SITE_TITLE}`} description={description}>
	<main>
		<article>
			<header class="calc-header">
				<h1>Debt Snowball vs. Avalanche Calculator</h1>
				<p class="calc-intro">Enter each debt below with its current balance, interest rate, and minimum payment. Add an extra monthly payment if you have one. The calculator will simulate both the snowball method (smallest balance first) and the avalanche method (highest rate first), then show you exactly how they compare on time and total interest.</p>
			</header>

			<DebtCalculator />
		</article>
	</main>
</BaseLayout>

<style>
	.calc-header {
		margin-bottom: var(--space-sm);
	}
	.calc-header h1 {
		font-size: var(--text-h1);
		font-weight: var(--weight-bold);
	}
	.calc-intro {
		font-size: var(--text-body);
		line-height: var(--leading-normal);
		color: var(--color-text-secondary);
	}
</style>
