---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import EmergencyFundCalculator from '../../components/EmergencyFundCalculator.astro';
import { SITE_TITLE } from '../../consts';

const title = `Emergency Fund Calculator — Find Your Target`;
const description = 'Free emergency fund calculator. Enter your essential monthly expenses and see how much you need saved for 3, 6, 9, or 12 months of coverage.';
---

<BaseLayout title={`${title} — ${SITE_TITLE}`} description={description}>
	<main>
		<Breadcrumbs crumbs={[{ label: 'Tools', href: '/tools' }, { label: 'Emergency Fund Calculator' }]} />
		<article>
			<header class="calc-header">
				<h1>Emergency Fund Calculator</h1>
				<p class="calc-intro">An emergency fund covers essential expenses if your income stops. Enter your essential monthly expenses below, choose how many months of coverage fits your situation, and see your target amount. Essential expenses are the costs that continue regardless of income: housing, utilities, groceries, minimum debt payments, insurance, and transportation.</p>
			</header>

			<EmergencyFundCalculator />

			<div class="calc-callout">
				<p class="calc-callout-text">For a deeper look at how to choose the right number of months for your situation, <a href="/articles/emergency-fund-sizing/">How Much Should You Keep in an Emergency Fund?</a> walks through the factors that move the target up or down. Once you have your number, a <a href="/spreadsheets/savings-goals-tracker/">savings goals tracker</a> can help you monitor your progress toward the target.</p>
			</div>
		</article>
	</main>
</BaseLayout>

<style>
	main {
		max-width: calc(var(--max-width-narrow) + var(--space-md) * 2);
	}
	.calc-header {
		margin-bottom: var(--space-sm);
	}
	.calc-header h1 {
		font-size: var(--text-h1);
	}
	.calc-intro {
		font-size: var(--text-body);
		line-height: var(--leading-normal);
		color: var(--color-text-secondary);
	}
	.calc-callout {
		margin-top: var(--space-xl);
		padding: var(--space-md);
		background: var(--color-bg-panel);
		border-radius: var(--radius-md);
	}
	.calc-callout-text {
		font-size: var(--text-small);
		line-height: var(--leading-normal);
		color: var(--color-text-secondary);
		margin: 0;
	}
	.calc-callout-text a {
		font-weight: var(--weight-normal);
	}
</style>
