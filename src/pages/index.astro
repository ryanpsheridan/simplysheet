---
import BaseLayout from '../layouts/BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getCollection } from 'astro:content';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const articles = (await getCollection('articles'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 6);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<section class="hero">
		<div class="hero-inner">
			<h1 class="hero-headline">Take control of your budget with spreadsheets you'll actually use</h1>
			<p class="hero-sub">Clear, actionable budgeting guidance paired with Google Sheets and Excel templates — no apps, no account syncing, no fluff. Just the tools and know-how to understand where your money goes.</p>
		</div>
	</section>

	<section class="story">
		<div class="story-inner">
			<h2 class="story-heading">Six years of budgeting in a spreadsheet</h2>
			<p class="story-body">I started budgeting for the first time about six years ago with a basic spreadsheet and very simple formulas. The one habit that changed everything was tracking my expenses daily. It sounds small, but actually seeing where my money went — category by category — gave me clarity I never had before. Using frameworks like the 50/30/20 rule gave me a north star to work toward.</p>
			<p class="story-body">Over the next couple of years, I kept optimizing. I dialed in how much income was coming in, how much was going to my 401(k) and savings accounts, how I was splitting bills with my spouse, and I built a real-time progress indicator that showed me during the month whether I was ahead or behind on spending. That visibility changed everything — I finally felt comfortable because I knew exactly where I stood.</p>
			<p class="story-body">When friends and family started asking about my spreadsheet, I shared it, got their feedback, and realized this could help a lot more people. With over 12 years of UX and visual design experience, I cleaned it up and turned it into a real product — focused on being simple, easy to use, and solving one problem well. It's now one of the bestselling budget spreadsheets on Etsy.</p>
			<a href="/about" class="story-link">Read the full story &rarr;</a>
		</div>
	</section>

	<section class="latest">
		<div class="latest-inner">
			<h2 class="latest-heading">Latest articles</h2>
			<ul class="article-list">
				{articles.map((article) => (
					<li>
						<a href={`/articles/${article.id}/`} class="article-card">
							<h3 class="article-title">{article.data.title}</h3>
							<p class="article-desc">{article.data.description}</p>
							<p class="article-date"><FormattedDate date={article.data.pubDate} /></p>
						</a>
					</li>
				))}
			</ul>
		</div>
	</section>

	<section class="templates">
		<div class="templates-inner">
			<h2 class="templates-heading">Ready-to-use budget templates</h2>
			<ul class="templates-list">
				<li><a href="https://simplysheetdesign.etsy.com/listing/1854773368">Budget Spreadsheet</a></li>
				<li><a href="https://simplysheetdesign.etsy.com/listing/4396395102">Couples Budget Spreadsheet</a></li>
				<li><a href="https://simplysheetdesign.etsy.com/listing/4485879930">Debt Payoff Tracker</a></li>
				<li><a href="https://simplysheetdesign.etsy.com/listing/4483664616">Savings Goals Tracker</a></li>
			</ul>
			<a href="https://simplysheetdesign.etsy.com" class="btn btn-primary">Explore all on Etsy</a>
		</div>
	</section>
</BaseLayout>

<style>
	/* ——— Hero ——— */

	.hero {
		padding: var(--space-section) var(--space-md);
		border-bottom: 1px solid var(--color-border);
	}
	.hero-inner {
		max-width: var(--max-width);
		margin: 0 auto;
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
	}
	.hero-headline {
		font-size: var(--text-display);
		font-weight: var(--weight-bold);
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		max-width: 20ch;
	}
	.hero-sub {
		margin-top: var(--space-md);
		font-size: var(--text-body);
		line-height: var(--leading-normal);
		color: var(--color-text-secondary);
		max-width: 38rem;
	}

	/* ——— Story ——— */

	.story {
		padding: var(--space-section) var(--space-md);
		border-bottom: 1px solid var(--color-border);
	}
	.story-inner {
		max-width: var(--max-width-narrow);
		margin: 0 auto;
	}
	.story-heading {
		font-size: var(--text-h2);
		font-weight: var(--weight-semibold);
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--space-md);
	}
	.story-body {
		font-size: var(--text-body);
		line-height: var(--leading-normal);
		color: var(--color-text-secondary);
	}
	.story-link {
		display: inline-block;
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		text-decoration: none;
		margin-top: var(--space-xs);
	}

	/* ——— Latest articles ——— */

	.latest {
		padding: var(--space-section) var(--space-md);
		border-bottom: 1px solid var(--color-border);
	}
	.latest-inner {
		max-width: var(--max-width);
		margin: 0 auto;
	}
	.latest-heading {
		font-size: var(--text-h2);
		font-weight: var(--weight-semibold);
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--space-lg);
	}
	.article-list {
		list-style: none;
		padding: 0;
		display: flex;
		flex-direction: column;
	}
	.article-list li {
		border-bottom: 1px solid var(--color-border);
	}
	.article-list li:last-child {
		border-bottom: none;
	}
	.article-card {
		display: block;
		padding: var(--space-md) 0;
		text-decoration: none;
		transition: opacity 0.15s;
	}
	.article-card:hover {
		opacity: 0.7;
	}
	.article-title {
		font-size: var(--text-h3);
		font-weight: var(--weight-semibold);
		color: var(--color-text);
		margin-bottom: var(--space-2xs);
	}
	.article-desc {
		font-size: var(--text-small);
		color: var(--color-text-secondary);
		margin-bottom: var(--space-xs);
		line-height: var(--leading-snug);
	}
	.article-date {
		font-size: var(--text-small);
		color: var(--color-text-muted);
		margin: 0;
	}

	/* ——— Templates ——— */

	.templates {
		padding: var(--space-section) var(--space-md);
	}
	.templates-inner {
		max-width: var(--max-width-narrow);
		margin: 0 auto;
		text-align: center;
	}
	.templates-heading {
		font-size: var(--text-h2);
		font-weight: var(--weight-semibold);
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--space-md);
	}
	.templates-list {
		list-style: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
		margin-bottom: var(--space-lg);
	}
	.templates-list a {
		font-size: var(--text-body);
		font-weight: var(--weight-medium);
		text-decoration: none;
		color: var(--color-text);
		transition: color 0.15s;
	}
	.templates-list a:hover {
		color: var(--color-accent);
	}
</style>
