---
import BaseLayout from '../layouts/BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getCollection } from 'astro:content';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const TAG_MAP: Record<string, string> = {
	'expense-tracking': 'Expense Tracking',
	'couples-budgeting': 'Couples Budgeting',
	'debt-payoff': 'Debt Payoff',
	'savings-goals': 'Savings Goals',
	'irregular-income': 'Irregular Income',
	'net-worth': 'Net Worth',
	'budgeting-styles': 'Budgeting Styles',
};

const ARTICLE_COLORS: Record<string, { bg: string; accent: string; accent2?: string }> = {
	'50-30-20-budget-rule':           { bg: '#E3F2FD', accent: '#196EDD', accent2: '#90CAF9' },
	'awareness-vs-automation':        { bg: '#E0F2F1', accent: '#00897B', accent2: '#80CBC4' },
	'budgeting-styles':               { bg: '#F3E5F5', accent: '#7E57C2', accent2: '#CE93D8' },
	'couples-budgeting':              { bg: '#FCE4EC', accent: '#E91E63', accent2: '#F48FB1' },
	'where-is-my-money-going':        { bg: '#FFF3E0', accent: '#E86A33', accent2: '#FFCC80' },
	'budgeting-with-irregular-income': { bg: '#E8F5E9', accent: '#2D9D78', accent2: '#A5D6A7' },
	'debt-snowball-vs-avalanche':     { bg: '#E8EDF2', accent: '#2C3E50', accent2: '#90A4AE' },
	'how-to-pay-off-debt':            { bg: '#EDE7F6', accent: '#7E57C2', accent2: '#B39DDB' },
	'emergency-fund-sizing':          { bg: '#E8EAF6', accent: '#5C6BC0', accent2: '#9FA8DA' },
	'why-most-budgets-fail':          { bg: '#FFF8E1', accent: '#F9A825', accent2: '#FFE082' },
};

const allArticles = (await getCollection('articles'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.map((article) => {
		const wordCount = article.body?.split(/\s+/).filter(Boolean).length ?? 0;
		const readTime = Math.max(1, Math.ceil(wordCount / 200));
		return { ...article, readTime };
	});

const featuredSlug = '50-30-20-budget-rule';
const featured = allArticles.find((a) => a.id === featuredSlug) ?? allArticles[0];
const rest = allArticles.filter((a) => a.id !== featured.id).slice(0, 6);

const templates = (await getCollection('templates'))
	.sort((a, b) => a.data.order - b.data.order)
	.slice(0, 4)
	.map((t) => ({
		name: t.data.title.replace(/ for Google Sheets & Excel$/, ''),
		desc: t.data.description,
		url: `/templates/${t.id}/`,
		image: t.data.heroImage,
		badge: t.data.badge,
	}));
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<section class="hero">
		<div class="hero-inner">
			<div class="hero-text">
				<h1 class="hero-title">A simpler way to manage your personal finances.</h1>
				<p class="hero-desc">Whether you are paying off debt or navigating an irregular income, find the guidance and tools you need to organize your money, stay on track, and move forward with confidence.</p>
			</div>
			{featured && (
				<a href={`/articles/${featured.id}/`} class="hero-featured">
					{(featured.data.cardImage || featured.data.image) && (
						<div class="hero-featured-thumb">
							<img src={featured.data.cardImage ?? featured.data.image} alt={featured.data.title} width="960" height="540" />
						</div>
					)}
					<span class="hero-featured-label">Featured Article</span>
					<h2 class="hero-featured-title">{featured.data.title}</h2>
					<p class="hero-featured-meta">
						<FormattedDate date={featured.data.pubDate} />
						<span>&middot;</span>
						<span>{featured.readTime} min read</span>
					</p>
				</a>
			)}
		</div>
	</section>

	<div class="section-divider"></div>

	{rest.length > 0 && (
		<section class="articles">
			<div class="articles-inner">
				<h2 class="articles-section-heading">Latest articles</h2>
				<div class="articles-grid">
					{rest.map((article) => {
						const palette = ARTICLE_COLORS[article.id] ?? { bg: '#E8EAF6', accent: '#5C6BC0', accent2: '#9FA8DA' };
						return (
							<a href={`/articles/${article.id}/`} class="article-card">
								<div class="article-card-bg" style={`background: linear-gradient(135deg, ${palette.bg} 0%, ${palette.accent2 ?? palette.bg} 50%, ${palette.accent}e6 100%);`}>
									{article.data.image && (
										<img src={article.data.image} alt="" width="960" height="540" loading="lazy" />
									)}
								</div>
								<div class="article-card-panel">
									<span class="article-card-read">{article.readTime} min read</span>
									<h3 class="article-card-title">{article.data.title}</h3>
									<p class="article-card-desc">{article.data.description}</p>
									<p class="article-card-meta">
										<FormattedDate date={article.data.pubDate} />
									</p>
								</div>
							</a>
						);
					})}
				</div>
				<div class="articles-more">
					<a href="/articles" class="btn btn-secondary">All articles <span class="arrow">&rarr;</span></a>
				</div>
			</div>
		</section>
	)}

	<section class="quiz-banner">
		<div class="quiz-banner-inner">
			<h6 class="quiz-banner-heading">Curious which budgeting style fits you best?</h6>
			<a href="/quiz/budgeting-style" class="btn btn-primary">Take the 60-second quiz</a>
		</div>
	</section>

	<section class="about-brief" id="about-brief">
		<div class="about-brief-inner">
			<div class="about-brief-label">Creating a sustainable system</div>
			<div class="about-brief-content">
				<p class="about-brief-body" id="about-text">I spent years frustrated by complicated budgeting apps that didn't fit my life. After six years of refining my own spreadsheet systems, I realized that clarity comes from simplicity, not extra features. I combined my background in UX design with my passion for personal finance to build the tools I wish I had from the start.</p>
				<a href="/about" class="btn btn-secondary about-brief-link">Read the full story <span class="arrow">&rarr;</span></a>
			</div>
		</div>
	</section>

	<section class="templates">
		<div class="templates-inner">
			<h2 class="templates-heading">Ready-made spreadsheets</h2>
			<div class="templates-grid">
				{templates.map((t) => (
					<a href={t.url} class="template-card">
						<div class="template-thumb">
							{t.image
								? <img src={t.image} alt={`${t.name} preview`} width="600" height="400" loading="lazy" />
								: <svg class="template-placeholder-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" /><path d="M3 16l5-5 4 4 4-4 5 5" /><circle cx="8.5" cy="8.5" r="1.5" /></svg>
							}
						</div>
						{t.badge && <span class="template-badge">{t.badge}</span>}
						<h3 class="template-name">{t.name}</h3>
						<p class="template-desc">{t.desc}</p>
					</a>
				))}
			</div>
			<div class="templates-cta-wrap">
				<a href="/templates" class="btn btn-primary">View all templates <span class="arrow">&rarr;</span></a>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	/* ——— Hero (2-col) ——— */

	.hero {
		padding: var(--space-section) var(--space-md);
	}
	.hero-inner {
		max-width: var(--max-width);
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-xl);
		align-items: center;
	}
	.hero-text {
		display: flex;
		flex-direction: column;
	}
	.hero-title {
		font-size: var(--text-display);
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		margin-bottom: var(--space-sm);
	}
	.hero-desc {
		font-size: var(--text-body);
		line-height: var(--leading-normal);
		color: var(--color-text-secondary);
		margin: 0;
	}
	.hero-featured {
		display: flex;
		flex-direction: column;
		text-decoration: none;
	}
	.hero-featured-thumb {
		border-radius: var(--radius-md);
		overflow: hidden;
		margin-bottom: var(--space-md);
		background: var(--color-bg-panel);
	}
	.hero-featured-thumb img {
		display: block;
		width: 100%;
		height: auto;
	}
	.hero-featured-label {
		display: inline-block;
		font-size: var(--text-xs);
		font-weight: var(--weight-semibold);
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
		color: var(--color-accent);
		margin-bottom: var(--space-2xs);
	}
	.hero-featured-title {
		font-size: var(--text-h3);
		line-height: var(--leading-snug);
		color: var(--color-text);
		margin-bottom: var(--space-xs);
		text-decoration: underline transparent;
		text-underline-offset: 3px;
		transition: text-decoration-color 100ms ease;
	}
	.hero-featured:hover .hero-featured-title {
		text-decoration-color: var(--color-text);
	}
	.hero-featured-meta {
		font-size: var(--text-small);
		color: var(--color-text-muted);
		margin: 0;
		display: flex;
		align-items: center;
		gap: 0.375rem;
	}

	/* ——— Section divider ——— */

	.section-divider {
		max-width: var(--max-width);
		margin: 0 auto;
		border-top: 1px solid var(--color-border);
	}

	/* ——— Articles 3-col grid ——— */

	.articles-section-heading {
		font-size: var(--text-h2);
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--space-md);
	}
	.articles {
		padding: var(--space-lg) var(--space-md) var(--space-section);
	}
	.articles-inner {
		max-width: var(--max-width);
		margin: 0 auto;
	}
	.articles-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--space-md);
		margin-bottom: var(--space-md);
	}
	.article-card {
		position: relative;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		border-radius: 1rem;
		overflow: hidden;
		text-decoration: none;
		min-height: 22rem;
		transition: box-shadow 0.2s ease, transform 0.2s ease;
	}
	.article-card:hover {
		box-shadow: 0 12px 32px rgba(0, 0, 0, 0.14);
		transform: translateY(-2px);
	}
	.article-card-bg {
		position: absolute;
		inset: 0;
		z-index: 0;
		overflow: hidden;
	}
	.article-card-bg img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		opacity: 0.35;
		mix-blend-mode: overlay;
		transform: scale(1.2);
	}
	.article-card-panel {
		position: relative;
		z-index: 1;
		background: rgba(255, 255, 255, 0.88);
		backdrop-filter: blur(16px) saturate(1.4);
		-webkit-backdrop-filter: blur(16px) saturate(1.4);
		border-radius: 0.5rem;
		margin: 0.5rem;
		padding: var(--space-md);
		display: flex;
		flex-direction: column;
		flex: 1;
		transition: background 0.2s ease;
	}
	.article-card:hover .article-card-panel {
		background: rgba(255, 255, 255, 0.90);
	}
	.article-card-read {
		font-size: var(--text-xs);
		color: var(--color-text-muted);
		margin-bottom: var(--space-sm);
	}
	.article-card-title {
		font-size: clamp(1.125rem, 1.5vw + 0.5rem, 1.5rem);
		font-weight: var(--weight-bold);
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		margin-bottom: var(--space-xs);
	}
	.article-card-desc {
		font-size: var(--text-small);
		line-height: var(--leading-snug);
		color: var(--color-text-secondary);
		margin: 0 0 var(--space-sm);
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.article-card-meta {
		margin-top: auto;
		font-size: var(--text-xs);
		color: var(--color-text-muted);
		padding-top: var(--space-xs);
		border-top: 1px solid rgba(0, 0, 0, 0.06);
	}
	.articles-more {
		padding-top: var(--space-sm);
	}

	/* ——— Quiz banner ——— */

	.quiz-banner {
		padding: var(--space-lg) var(--space-md);
		background: var(--color-bg-panel);
		border-top: 1px solid var(--color-border);
		border-bottom: 1px solid var(--color-border);
		text-align: center;
	}
	.quiz-banner-inner {
		max-width: var(--max-width);
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-sm);
	}
	.quiz-banner-heading {
		font-size: var(--text-body);
		font-weight: var(--weight-medium);
		color: var(--color-text-secondary);
		margin: 0;
	}

	/* ——— About brief ——— */

	.about-brief {
		padding: clamp(5rem, 12vw, 8rem) var(--space-md);
		background: var(--color-bg);
		color: var(--color-text);
	}
	.about-brief-inner {
		max-width: var(--max-width);
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1fr 2fr;
		gap: var(--space-xl);
		align-items: start;
	}
	.about-brief-label {
		font-size: var(--text-body);
		font-weight: var(--weight-medium);
		color: var(--color-text-muted);
		padding-top: 0.35em;
	}
	.about-brief-content {
		max-width: 38rem;
	}
	.about-brief-body {
		font-size: clamp(1.5rem, 2vw + 0.4rem, 1.75rem);
		font-weight: var(--weight-normal);
		line-height: 1.5;
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		margin: 0;
	}
	:global(.about-brief-body .word) {
		color: #A09890;
		transition: color 0.15s ease;
	}
	:global(.about-brief-body .word.lit) {
		color: #000000;
	}
	.about-brief-link {
		margin-top: var(--space-md);
	}

	/* ——— Tools (4-col grid) ——— */

	.templates {
		padding: var(--space-section) var(--space-md);
	}
	.templates-inner {
		max-width: var(--max-width);
		margin: 0 auto;
	}
	.templates-heading {
		font-size: var(--text-h2);
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--space-lg);
	}
	.templates-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: var(--space-md);
		margin-bottom: var(--space-lg);
	}
	.template-card {
		display: flex;
		flex-direction: column;
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		text-decoration: none;
		overflow: hidden;
		transition: border-color 0.15s, box-shadow 0.2s ease;
	}
	.template-card:hover {
		border-color: var(--color-divider);
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
	}
	.template-thumb {
		aspect-ratio: 3 / 2;
		background: var(--color-bg-panel);
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
	}
	.template-thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
	.template-placeholder-icon {
		color: var(--color-divider);
	}
	.template-badge {
		display: inline-block;
		align-self: flex-start;
		font-size: var(--text-xs);
		font-weight: var(--weight-semibold);
		color: var(--color-accent);
		background: var(--color-accent-light);
		border-radius: var(--radius-full);
		padding: 0.125rem 0.5rem;
		line-height: 1.4;
		white-space: nowrap;
		margin: var(--space-md) var(--space-md) 0;
	}
	.template-name {
		font-size: var(--text-body);
		color: var(--color-text);
		margin-bottom: var(--space-xs);
		padding: var(--space-xs) var(--space-md) 0;
		display: flex;
		align-items: center;
		gap: 0.375rem;
	}
	.template-card:not(:has(.template-badge)) .template-name {
		padding-top: var(--space-md);
	}
	.template-desc {
		font-size: var(--text-small);
		color: var(--color-text-secondary);
		line-height: var(--leading-snug);
		margin: 0;
		padding: 0 var(--space-md) var(--space-md);
	}
	.templates-cta-wrap {
		text-align: center;
	}

	/* ——— Responsive ——— */

	@media (max-width: 960px) {
		.hero-inner {
			grid-template-columns: 1fr;
		}
		.articles-grid {
			grid-template-columns: 1fr;
		}
		.about-brief-inner {
			grid-template-columns: 1fr;
			gap: var(--space-md);
		}
		.templates-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 600px) {
		.templates-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

<script>
	const textEl = document.getElementById('about-text');
	if (textEl) {
		const raw = textEl.textContent || '';
		textEl.innerHTML = raw.split(/(\s+)/).map(part =>
			/\S/.test(part) ? `<span class="word">${part}</span>` : part
		).join('');

		const words = textEl.querySelectorAll<HTMLSpanElement>('.word');
		words.forEach((w, i) => {
			w.style.transitionDelay = `${i * 3}ms`;
		});
		const section = document.getElementById('about-brief');
		let ticking = false;

		function updateWords() {
			if (!section) return;
			const rect = section.getBoundingClientRect();
			const vh = window.innerHeight;
			const start = vh * 0.45;
			const end = vh * 0.15;
			const progress = Math.max(0, Math.min(1, (start - rect.top) / (start - end)));
			const litCount = Math.round(progress * words.length);
			words.forEach((w, i) => w.classList.toggle('lit', i < litCount));
		}

		window.addEventListener('scroll', () => {
			if (!ticking) {
				requestAnimationFrame(() => { updateWords(); ticking = false; });
				ticking = true;
			}
		}, { passive: true });
		updateWords();
	}
</script>
