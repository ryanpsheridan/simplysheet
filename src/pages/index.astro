---
import BaseLayout from '../layouts/BaseLayout.astro';
import TagPills from '../components/TagPills.astro';
import { getCollection } from 'astro:content';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const TAG_MAP: Record<string, string> = {
	'expense-tracking': 'Expense Tracking',
	'couples-budgeting': 'Couples Budgeting',
	'debt-payoff': 'Debt Payoff',
	'savings-goals': 'Savings Goals',
	'irregular-income': 'Irregular Income',
	'net-worth': 'Net Worth',
	'budgeting-styles': 'Budgeting Styles',
};

const allArticles = (await getCollection('articles'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.map((article) => {
		const wordCount = article.body?.split(/\s+/).filter(Boolean).length ?? 0;
		const readTime = Math.max(1, Math.ceil(wordCount / 200));
		return { ...article, readTime };
	});

const featuredSlug = '50-30-20-budget-rule';
const featured = allArticles.find((a) => a.id === featuredSlug) ?? allArticles[0];
const rest = allArticles.filter((a) => a.id !== featured.id);

const latest = rest.slice(0, 6);

const tools = [
	{
		name: '50/30/20 Budget Calculator',
		url: '/tools/50-30-20-budget-calculator/',
		icon: '<rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="8" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="12" y2="14"/>',
	},
	{
		name: 'Emergency Fund Calculator',
		url: '/tools/emergency-fund-calculator/',
		icon: '<path d="M19 5c-1.5 0-2.8 1.4-3 2-3.5-1.5-11-.3-11 5 0 1.8 0 3 2 4.5V20h4v-2h3v2h4v-4c1-.5 1.7-1 2-2h2v-4h-2c0-1-.5-1.5-1-2"/><circle cx="17" cy="10" r="1"/>',
	},
	{
		name: 'Sinking Fund Calculator',
		url: '/tools/sinking-fund-calculator/',
		icon: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
	},
];

const templates = (await getCollection('templates'))
	.sort((a, b) => a.data.order - b.data.order)
	.slice(0, 4)
	.map((t) => ({
		name: t.data.title.replace(/ for Google Sheets & Excel$/, ''),
		desc: t.data.description,
		url: `/spreadsheets/${t.id}/`,
		image: t.data.heroImage,
		badge: t.data.badge,
	}));
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<section class="hero">
		<div class="hero-inner">
			<div class="hero-text">
				<h1 class="hero-title">A simpler way to manage your personal finances.</h1>
				<p class="hero-desc">Whether you are paying off debt or navigating an irregular income, find the guidance and tools you need to organize your money, stay on track, and move forward with confidence.</p>
			</div>
			{featured && (
				<a href={`/articles/${featured.id}/`} class="hero-featured">
					{(featured.data.cardImage || featured.data.image) && (
						<div class="hero-featured-thumb">
							<img src={featured.data.cardImage ?? featured.data.image} alt={featured.data.title} width="960" height="540" />
						</div>
					)}
					<TagPills tags={featured.data.tags} tagMap={TAG_MAP} />
					<h2 class="hero-featured-title">{featured.data.title}</h2>
					<p class="hero-featured-meta">
						<span>{featured.readTime} min read</span>
					</p>
				</a>
			)}
		</div>
	</section>

	<div class="section-divider"></div>

	<section class="home-rows">
		<div class="home-rows-inner">
			{latest.length > 0 && (
				<div class="home-row">
					<div class="home-row-label">
						<h3 class="home-row-heading">Latest</h3>
					</div>
					<div class="home-row-items">
						{latest.map((article) => (
							<a href={`/articles/${article.id}/`} class="home-row-item">
								{(article.data.cardImage || article.data.image) && (
									<div class="home-row-thumb">
										<img src={article.data.cardImage ?? article.data.image} alt={article.data.title} width="960" height="540" loading="lazy" />
									</div>
								)}
								<div class="home-row-text">
									<TagPills tags={article.data.tags} tagMap={TAG_MAP} />
									<h4 class="home-row-title">{article.data.title}</h4>
									<span class="home-row-meta">{article.readTime} min read</span>
								</div>
							</a>
						))}
					</div>
				</div>
			)}
			<div class="home-row tools-row">
				<div class="home-row-label">
					<h3 class="home-row-heading">Free tools</h3>
				</div>
				<div class="home-row-items tools-row-items">
					{tools.map((tool) => (
						<a href={tool.url} class="home-row-item tool-item">
							<span class="tool-icon" set:html={`<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">${tool.icon}</svg>`} />
							<div class="home-row-text">
								<h4 class="home-row-title">{tool.name}</h4>
							</div>
						</a>
					))}
					<a href="/tools/" class="home-row-item tool-item">
						<span class="tool-icon" set:html={`<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>`} />
						<div class="home-row-text">
							<h4 class="home-row-title">View all tools</h4>
						</div>
					</a>
				</div>
			</div>
		</div>
		<div class="home-rows-cta-wrap">
			<a href="/articles" class="btn btn-secondary">All articles <span class="arrow">&rarr;</span></a>
		</div>
	</section>

	<section class="quiz-banner">
		<div class="quiz-banner-inner">
			<h6 class="quiz-banner-heading">Curious which budgeting style fits you best?</h6>
			<a href="/quiz/budgeting-style" class="btn btn-primary">Take the 60-second quiz</a>
		</div>
	</section>

	<section class="about-brief" id="about-brief">
		<div class="about-brief-inner">
			<div class="about-brief-label">Creating a sustainable system</div>
			<div class="about-brief-content">
				<p class="about-brief-body" id="about-text">I spent years frustrated by complicated budgeting apps that didn't fit my life. After six years of refining my own spreadsheet systems, I realized that clarity comes from simplicity, not extra features. I combined my background in UX design with my passion for personal finance to build the tools I wish I had from the start.</p>
				<a href="/about" class="btn btn-secondary about-brief-link">Read the full story <span class="arrow">&rarr;</span></a>
			</div>
		</div>
	</section>

	<section class="templates">
		<div class="templates-inner">
			<h2 class="templates-heading">Ready-made spreadsheets</h2>
			<div class="templates-grid">
				{templates.map((t) => (
					<a href={t.url} class="template-card">
						<div class="template-thumb">
							{t.image
								? <img src={t.image} alt={`${t.name} preview`} width="600" height="400" loading="lazy" />
								: <svg class="template-placeholder-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" /><path d="M3 16l5-5 4 4 4-4 5 5" /><circle cx="8.5" cy="8.5" r="1.5" /></svg>
							}
						</div>
						{t.badge && <span class="template-badge">{t.badge}</span>}
						<h3 class="template-name">{t.name}</h3>
						<p class="template-desc">{t.desc}</p>
					</a>
				))}
			</div>
			<div class="templates-cta-wrap">
				<a href="/spreadsheets" class="btn btn-primary">View all spreadsheets <span class="arrow">&rarr;</span></a>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	/* ——— Hero (2-col) ——— */

	.hero {
		padding: var(--space-section) var(--space-md);
	}
	.hero-inner {
		max-width: var(--max-width);
		margin: 0 auto;
		display: grid;
		grid-template-columns: 0.75fr 1fr;
		gap: var(--space-xl);
		align-items: center;
	}
	.hero-text {
		display: flex;
		flex-direction: column;
	}
	.hero-title {
		font-size: var(--text-display);
		font-weight: var(--weight-normal);
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-tight);
		color: var(--color-text-heading);
		margin-bottom: var(--space-sm);
	}
	.hero-desc {
		font-size: var(--text-body);
		line-height: var(--leading-normal);
		color: var(--color-text-secondary);
		margin: 0;
	}
	.hero-featured {
		display: flex;
		flex-direction: column;
		text-decoration: none;
		transition: opacity 0.15s ease;
	}
	@media (hover: hover) {
		.hero-featured:hover {
			opacity: 0.7;
		}
	}
	.hero-featured-thumb {
		position: relative;
		border-radius: var(--radius-md);
		overflow: hidden;
		margin-bottom: var(--space-md);
		background: var(--color-bg-panel);
		padding: 1.5rem;
	}
	.hero-featured-thumb img {
		display: block;
		width: 100%;
		height: auto;
		border-radius: var(--radius-sm);
	}
	.hero-featured-title {
		font-size: var(--text-h3);
		line-height: var(--leading-snug);
		color: var(--color-text);
		margin-bottom: var(--space-xs);
	}
	.hero-featured-meta {
		font-size: var(--text-small);
		color: var(--color-text-muted);
		margin: 0;
		display: flex;
		align-items: center;
		gap: 0.375rem;
	}

	/* ——— Section divider ——— */

	.section-divider {
		max-width: var(--max-width);
		margin: 0 auto;
		border-top: 1px solid var(--color-border);
	}

	/* ——— Home rows (label left / items right) ——— */

	.home-rows {
		padding: var(--space-lg) var(--space-md) var(--space-section);
	}
	.home-rows-inner {
		max-width: var(--max-width);
		margin: 0 auto;
	}
	.home-row {
		display: grid;
		grid-template-columns: 12rem 1fr;
		gap: var(--space-xl);
		padding: var(--space-lg) 0;
		border-top: 1px solid var(--color-border);
	}
	.home-row:first-child {
		border-top: none;
		padding-top: 0;
	}
	.home-row-heading {
		font-size: var(--text-h3);
		font-weight: var(--weight-normal);
		margin: 0;
	}
	.home-row-items {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}
	.home-row-item {
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
		text-decoration: none;
		color: inherit;
		transition: opacity 0.15s ease;
	}
	@media (hover: hover) {
		.home-row-item:hover {
			opacity: 0.7;
		}
	}
	.home-row-thumb {
		position: relative;
		width: 100%;
		aspect-ratio: 3 / 2;
		border-radius: var(--radius-md);
		overflow: hidden;
		background: var(--color-bg-panel);
		padding: 1.5rem;
	}
	.home-row-thumb img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: var(--radius-sm);
	}
	.home-row-text {
		min-width: 0;
	}
	.home-row-title {
		font-size: var(--text-body);
		font-weight: var(--weight-normal);
		line-height: 1.35;
		margin: 0 0 var(--space-2xs);
		color: var(--color-text);
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.home-row-meta {
		font-size: var(--text-xs);
		color: var(--color-text-muted);
	}

	/* ——— Tools row ——— */

	.tools-row-items {
		grid-template-columns: repeat(4, 1fr);
	}
	.tool-item {
		flex-direction: row;
		align-items: center;
	}
	.tool-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		width: 2.5rem;
		height: 2.5rem;
		border-radius: var(--radius-full);
		background: var(--color-bg-panel);
		color: var(--color-text);
	}
	.tool-item .home-row-title {
		font-size: var(--text-small);
		-webkit-line-clamp: 2;
	}

	.home-rows-cta-wrap {
		max-width: var(--max-width);
		margin: var(--space-lg) auto 0;
	}

	/* ——— Quiz banner ——— */

	.quiz-banner {
		padding: var(--space-lg) var(--space-md);
		background: var(--color-bg-panel);
		border-top: 1px solid var(--color-border);
		border-bottom: 1px solid var(--color-border);
		text-align: center;
	}
	.quiz-banner-inner {
		max-width: var(--max-width);
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-sm);
	}
	.quiz-banner-heading {
		font-size: var(--text-body);
		font-weight: var(--weight-normal);
		color: var(--color-text-secondary);
		margin: 0;
	}

	/* ——— About brief ——— */

	.about-brief {
		padding: clamp(5rem, 12vw, 8rem) var(--space-md);
		background: var(--color-bg);
		color: var(--color-text);
	}
	.about-brief-inner {
		max-width: var(--max-width);
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1fr 2fr;
		gap: var(--space-xl);
		align-items: start;
	}
	.about-brief-label {
		font-size: var(--text-body);
		font-weight: var(--weight-normal);
		color: var(--color-text-muted);
		padding-top: 0.35em;
	}
	.about-brief-content {
		max-width: 38rem;
	}
	.about-brief-body {
		font-size: clamp(1.5rem, 2vw + 0.4rem, 1.75rem);
		font-weight: var(--weight-normal);
		line-height: 1.5;
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		margin: 0;
	}
	:global(.about-brief-body .word) {
		color: #B0B0B0;
		transition: color 0.15s ease;
	}
	:global(.about-brief-body .word.lit) {
		color: #000000;
	}
	.about-brief-link {
		margin-top: var(--space-md);
	}

	/* ——— Templates (4-col grid) ——— */

	.templates {
		padding: var(--space-section) var(--space-md);
	}
	.templates-inner {
		max-width: var(--max-width);
		margin: 0 auto;
	}
	.templates-heading {
		font-size: var(--text-h2);
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--space-lg);
	}
	.templates-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: var(--space-md);
		margin-bottom: var(--space-lg);
	}
	.template-card {
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
		text-decoration: none;
		color: inherit;
		transition: opacity 0.15s ease;
	}
	@media (hover: hover) {
		.template-card:hover {
			opacity: 0.7;
		}
	}
	.template-thumb {
		position: relative;
		width: 100%;
		aspect-ratio: 1 / 1;
		border-radius: var(--radius-md);
		overflow: hidden;
		background: var(--color-bg-panel);
		padding: 1.5rem 0 1.5rem 1.5rem;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.template-thumb img {
		width: 100%;
		height: 100%;
		object-fit: contain;
		object-position: right center;
		border-radius: var(--radius-sm);
		display: block;
	}
	.template-placeholder-icon {
		color: var(--color-divider);
	}
	.template-badge {
		display: inline-block;
		align-self: flex-start;
		font-size: var(--text-xs);
		font-weight: var(--weight-normal);
		color: var(--color-text);
		background: var(--color-surface-tint);
		border: 1px solid var(--color-divider);
		border-radius: var(--radius-sm);
		padding: 0.125rem 0.5rem;
		line-height: 1.4;
		white-space: nowrap;
	}
	.template-name {
		font-size: var(--text-body);
		color: var(--color-text);
		margin: 0;
		display: flex;
		align-items: center;
		gap: 0.375rem;
	}
	.template-desc {
		font-size: var(--text-small);
		color: var(--color-text-secondary);
		line-height: var(--leading-snug);
		margin: 0;
	}
	.templates-cta-wrap {
		text-align: center;
	}

	/* ——— Responsive ——— */

	@media (max-width: 960px) {
		.hero-inner {
			grid-template-columns: 1fr;
		}
		.about-brief-inner {
			grid-template-columns: 1fr;
			gap: var(--space-md);
		}
		.templates-grid {
			grid-template-columns: repeat(2, 1fr);
		}
		.home-row-items {
			grid-template-columns: repeat(2, 1fr);
		}
		.tools-row-items {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	@media (max-width: 768px) {
		.home-row {
			grid-template-columns: 1fr;
			gap: var(--space-sm);
		}
	}

	@media (max-width: 600px) {
		.home-row-items {
			grid-template-columns: 1fr;
		}
		.tools-row-items {
			grid-template-columns: 1fr;
		}
		.home-row-item:not(.tool-item) .home-row-title {
			font-size: 1.25rem;
		}
		.templates-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

<script>
	const textEl = document.getElementById('about-text');
	if (textEl) {
		const raw = textEl.textContent || '';
		textEl.innerHTML = raw.split(/(\s+)/).map(part =>
			/\S/.test(part) ? `<span class="word">${part}</span>` : part
		).join('');

		const words = textEl.querySelectorAll<HTMLSpanElement>('.word');
		words.forEach((w, i) => {
			w.style.transitionDelay = `${i * 3}ms`;
		});
		const section = document.getElementById('about-brief');
		let ticking = false;

		function updateWords() {
			if (!section) return;
			const rect = section.getBoundingClientRect();
			const vh = window.innerHeight;
			const start = vh * 0.45;
			const end = vh * 0.15;
			const progress = Math.max(0, Math.min(1, (start - rect.top) / (start - end)));
			const litCount = Math.round(progress * words.length);
			words.forEach((w, i) => w.classList.toggle('lit', i < litCount));
		}

		window.addEventListener('scroll', () => {
			if (!ticking) {
				requestAnimationFrame(() => { updateWords(); ticking = false; });
				ticking = true;
			}
		}, { passive: true });
		updateWords();
	}
</script>
