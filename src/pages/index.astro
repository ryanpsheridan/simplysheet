---
import BaseLayout from '../layouts/BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getCollection } from 'astro:content';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const articles = (await getCollection('articles'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 6)
	.map((article) => {
		const wordCount = article.body?.split(/\s+/).filter(Boolean).length ?? 0;
		const readTime = Math.max(1, Math.ceil(wordCount / 200));
		return { ...article, readTime };
	});

const templates = [
	{
		name: 'Budget Spreadsheet',
		desc: 'Track income and daily expenses with real-time progress indicators that show where you stand each month.',
		url: 'https://simplysheetdesign.etsy.com/listing/1854773368',
	},
	{
		name: 'Couples Budget Spreadsheet',
		desc: 'Split bills, track shared and personal expenses, and manage savings together. Built for two incomes.',
		url: 'https://simplysheetdesign.etsy.com/listing/4396395102',
	},
	{
		name: 'Debt Payoff Tracker',
		desc: 'See your total debt, log payments, and watch your balances drop month by month with clear visual progress.',
		url: 'https://simplysheetdesign.etsy.com/listing/4485879930',
	},
	{
		name: 'Savings Goals Tracker',
		desc: 'Set multiple savings goals, automate contributions, and track your progress toward each one.',
		url: 'https://simplysheetdesign.etsy.com/listing/4483664616',
	},
];
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<section class="hero">
		<div class="hero-inner">
			<h1 class="hero-headline">Take control of your budget with spreadsheets you'll actually use</h1>
			<p class="hero-sub">Clear, actionable budgeting guidance paired with Google Sheets and Excel templates — no apps, no account syncing, no fluff. Just the tools and know-how to understand where your money goes.</p>
		</div>
	</section>

	<section class="story">
		<div class="story-inner">
			<h2 class="story-heading">Six years of budgeting in a spreadsheet</h2>
			<p class="story-body">I started budgeting for the first time about six years ago with a basic spreadsheet and very simple formulas. The one habit that changed everything was tracking my expenses daily. It sounds small, but actually seeing where my money went — category by category — gave me clarity I never had before. Using frameworks like the 50/30/20 rule gave me a north star to work toward.</p>
			<p class="story-body">Over the next couple of years, I kept optimizing. I dialed in how much income was coming in, how much was going to my 401(k) and savings accounts, how I was splitting bills with my spouse, and I built a real-time progress indicator that showed me during the month whether I was ahead or behind on spending. That visibility changed everything — I finally felt comfortable because I knew exactly where I stood.</p>
			<p class="story-body">When friends and family started asking about my spreadsheet, I shared it, got their feedback, and realized this could help a lot more people. With over 12 years of UX and visual design experience, I cleaned it up and turned it into a real product — focused on being simple, easy to use, and solving one problem well. It's now one of the bestselling budget spreadsheets on Etsy.</p>
			<a href="/about" class="story-link">Read the full story &rarr;</a>
		</div>
	</section>

	<section class="latest">
		<div class="latest-inner">
			<h2 class="latest-heading">Latest articles</h2>
			<ul class="article-grid">
				{articles.map((article) => (
					<li>
						<a href={`/articles/${article.id}/`} class="article-card">
							<h3 class="article-title">{article.data.title}</h3>
							<p class="article-desc">{article.data.description}</p>
							<p class="article-meta">
								<FormattedDate date={article.data.pubDate} />
								<span>&middot;</span>
								<span>{article.readTime} min read</span>
							</p>
						</a>
					</li>
				))}
			</ul>
		</div>
	</section>

	<section class="templates">
		<div class="templates-inner">
			<h2 class="templates-heading">Ready-to-use budget templates</h2>
			<div class="templates-grid">
				{templates.map((t) => (
					<a href={t.url} class="template-card">
						<h3 class="template-name">{t.name}</h3>
						<p class="template-desc">{t.desc}</p>
					</a>
				))}
			</div>
			<div class="templates-cta-wrap">
				<a href="https://simplysheetdesign.etsy.com" class="btn btn-primary">Explore all on Etsy</a>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	/* ——— Hero ——— */

	.hero {
		padding: var(--space-section) var(--space-md);
		border-bottom: 1px solid var(--color-border);
	}
	.hero-inner {
		max-width: var(--max-width);
		margin: 0 auto;
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
	}
	.hero-headline {
		font-size: var(--text-display);
		font-weight: var(--weight-bold);
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		max-width: 20ch;
	}
	.hero-sub {
		margin-top: var(--space-md);
		font-size: var(--text-body);
		line-height: var(--leading-normal);
		color: var(--color-text-secondary);
		max-width: 38rem;
	}

	/* ——— Story ——— */

	.story {
		padding: var(--space-section) var(--space-md);
		border-bottom: 1px solid var(--color-border);
	}
	.story-inner {
		max-width: var(--max-width-narrow);
		margin: 0 auto;
	}
	.story-heading {
		font-size: var(--text-h2);
		font-weight: var(--weight-semibold);
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--space-md);
	}
	.story-body {
		font-size: var(--text-body);
		line-height: var(--leading-normal);
		color: var(--color-text-secondary);
	}
	.story-link {
		display: inline-block;
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		text-decoration: none;
		margin-top: var(--space-xs);
	}

	/* ——— Latest articles (3-col grid) ——— */

	.latest {
		padding: var(--space-section) var(--space-md);
		border-bottom: 1px solid var(--color-border);
	}
	.latest-inner {
		max-width: var(--max-width);
		margin: 0 auto;
	}
	.latest-heading {
		font-size: var(--text-h2);
		font-weight: var(--weight-semibold);
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--space-lg);
	}
	.article-grid {
		list-style: none;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--space-md);
	}
	.article-card {
		display: flex;
		flex-direction: column;
		padding: var(--space-md);
		text-decoration: none;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		transition: border-color 0.15s;
		height: 100%;
	}
	.article-card:hover {
		border-color: var(--color-divider);
	}
	.article-title {
		font-size: var(--text-h3);
		font-weight: var(--weight-semibold);
		color: var(--color-text);
		margin-bottom: var(--space-xs);
	}
	.article-desc {
		font-size: var(--text-small);
		color: var(--color-text-secondary);
		margin-bottom: var(--space-sm);
		line-height: var(--leading-snug);
		flex: 1;
	}
	.article-meta {
		font-size: var(--text-small);
		color: var(--color-text-muted);
		margin: 0;
		display: flex;
		align-items: center;
		gap: 0.375rem;
	}

	/* ——— Templates (4-col grid) ——— */

	.templates {
		padding: var(--space-section) var(--space-md);
	}
	.templates-inner {
		max-width: var(--max-width);
		margin: 0 auto;
	}
	.templates-heading {
		font-size: var(--text-h2);
		font-weight: var(--weight-semibold);
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--space-lg);
	}
	.templates-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: var(--space-md);
		margin-bottom: var(--space-lg);
	}
	.template-card {
		display: block;
		padding: var(--space-md);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		text-decoration: none;
		transition: border-color 0.15s;
	}
	.template-card:hover {
		border-color: var(--color-divider);
	}
	.template-name {
		font-size: var(--text-body);
		font-weight: var(--weight-semibold);
		color: var(--color-text);
		margin-bottom: var(--space-xs);
	}
	.template-desc {
		font-size: var(--text-small);
		color: var(--color-text-secondary);
		line-height: var(--leading-snug);
		margin: 0;
	}
	.templates-cta-wrap {
		text-align: center;
	}

	/* ——— Responsive ——— */

	@media (max-width: 960px) {
		.article-grid {
			grid-template-columns: repeat(2, 1fr);
		}
		.templates-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 600px) {
		.article-grid {
			grid-template-columns: 1fr;
		}
		.templates-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
