---
import BaseLayout from '../layouts/BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getCollection } from 'astro:content';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const allArticles = (await getCollection('articles'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.map((article) => {
		const wordCount = article.body?.split(/\s+/).filter(Boolean).length ?? 0;
		const readTime = Math.max(1, Math.ceil(wordCount / 200));
		return { ...article, readTime };
	});

const featured = allArticles[0];
const rest = allArticles.slice(1, 7);

const templates = [
	{
		name: 'Budget Spreadsheet',
		desc: 'Track income and daily expenses with real-time progress indicators that show where you stand each month.',
		url: 'https://simplysheetdesign.etsy.com/listing/1854773368',
		image: '',
	},
	{
		name: 'Couples Budget Spreadsheet',
		desc: 'Split bills, track shared and personal expenses, and manage savings together. Built for two incomes.',
		url: 'https://simplysheetdesign.etsy.com/listing/4396395102',
		image: '',
	},
	{
		name: 'Debt Payoff Tracker',
		desc: 'See your total debt, log payments, and watch your balances drop month by month with clear visual progress.',
		url: 'https://simplysheetdesign.etsy.com/listing/4485879930',
		image: '',
	},
	{
		name: 'Savings Goals Tracker',
		desc: 'Set multiple savings goals, automate contributions, and track your progress toward each one.',
		url: 'https://simplysheetdesign.etsy.com/listing/4483664616',
		image: '',
	},
];
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<section class="editorial">
		<div class="editorial-inner">
			<div class="editorial-grid">
				{featured && (
					<div class="editorial-featured">
						<span class="featured-label">Latest</span>
						<a href={`/articles/${featured.id}/`} class="featured-link">
							<h2 class="featured-title">{featured.data.title}</h2>
							<p class="featured-desc">{featured.data.description}</p>
							<p class="featured-meta">
								<FormattedDate date={featured.data.pubDate} />
								<span>&middot;</span>
								<span>{featured.readTime} min read</span>
							</p>
						</a>
					</div>
				)}
				{rest.length > 0 && (
					<div class="editorial-sidebar">
						<ul class="article-list">
							{rest.map((article) => (
								<li>
									<a href={`/articles/${article.id}/`} class="article-row">
										<h3 class="article-row-title">{article.data.title}</h3>
										<p class="article-row-meta">
											<FormattedDate date={article.data.pubDate} />
											<span>&middot;</span>
											<span>{article.readTime} min read</span>
										</p>
									</a>
								</li>
							))}
						</ul>
						<div class="articles-more">
							<a href="/articles" class="articles-more-link">All articles <span class="arrow">&rarr;</span></a>
						</div>
					</div>
				)}
			</div>
		</div>
	</section>

	<section class="about-brief">
		<div class="about-brief-inner">
			<p class="about-brief-tagline">Practical budgeting advice, simple systems, and the tools to help you understand where your money goes.</p>
			<h2 class="about-brief-heading">Six years of budgeting in a spreadsheet</h2>
			<p class="about-brief-body">I started budgeting six years ago with a blank Google Sheet. The one habit that changed everything was tracking expenses daily — that visibility gave me clarity I never had before. After years of refining and sharing with friends, I turned it into a product. With over 12 years of UX and visual design experience, I focused on making it simple enough that people actually use it.</p>
			<a href="/about" class="about-brief-link">Read the full story <span class="arrow">&rarr;</span></a>
		</div>
	</section>

	<section class="templates">
		<div class="templates-inner">
			<h2 class="templates-heading">Tools I built</h2>
			<div class="templates-grid">
				{templates.map((t) => (
					<a href={t.url} class="template-card">
						<div class="template-thumb">
							{t.image
								? <img src={t.image} alt={`${t.name} preview`} width="600" height="400" loading="lazy" />
								: <svg class="template-placeholder-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" /><path d="M3 16l5-5 4 4 4-4 5 5" /><circle cx="8.5" cy="8.5" r="1.5" /></svg>
							}
						</div>
						<h3 class="template-name">{t.name}</h3>
						<p class="template-desc">{t.desc}</p>
					</a>
				))}
			</div>
			<div class="templates-cta-wrap">
				<a href="https://simplysheetdesign.etsy.com" class="btn btn-primary">Explore all on Etsy</a>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	/* ——— Editorial (articles hero) ——— */

	.editorial {
		padding: var(--space-section) var(--space-md);
		border-bottom: 1px solid var(--color-border);
	}
	.editorial-inner {
		max-width: var(--max-width);
		margin: 0 auto;
	}
	.editorial-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-xl);
		align-items: start;
	}
	.editorial-featured {
		padding-right: var(--space-lg);
	}
	.featured-label {
		display: inline-block;
		font-size: var(--text-xs);
		font-weight: var(--weight-semibold);
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
		color: var(--color-accent);
		margin-bottom: var(--space-sm);
	}
	.featured-link {
		display: block;
		text-decoration: none;
	}
	.featured-title {
		font-size: var(--text-h1);
		font-weight: var(--weight-bold);
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		margin-bottom: var(--space-sm);
		transition: color 0.15s;
	}
	.featured-link:hover .featured-title {
		color: var(--color-accent);
	}
	.featured-desc {
		font-size: var(--text-body);
		line-height: var(--leading-normal);
		color: var(--color-text-secondary);
		margin-bottom: var(--space-sm);
	}
	.featured-meta {
		font-size: var(--text-small);
		color: var(--color-text-muted);
		margin: 0;
		display: flex;
		align-items: center;
		gap: 0.375rem;
	}

	/* ——— Sidebar article list ——— */

	.editorial-sidebar {
		border-left: 1px solid var(--color-border);
		padding-left: var(--space-lg);
	}
	.article-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
	}
	.article-list li + li {
		border-top: 1px solid var(--color-border);
	}
	.article-row {
		display: block;
		padding: var(--space-sm) 0;
		text-decoration: none;
	}
	.article-list li:first-child .article-row {
		padding-top: 0;
	}
	.article-row:hover .article-row-title {
		color: var(--color-accent);
	}
	.article-row-title {
		font-size: var(--text-body);
		font-weight: var(--weight-semibold);
		color: var(--color-text);
		margin-bottom: var(--space-2xs);
		line-height: var(--leading-snug);
		transition: color 0.15s;
	}
	.article-row-meta {
		font-size: var(--text-small);
		color: var(--color-text-muted);
		margin: 0;
		display: flex;
		align-items: center;
		gap: 0.375rem;
	}
	.articles-more {
		padding-top: var(--space-sm);
		border-top: 1px solid var(--color-border);
		margin-top: var(--space-sm);
	}
	.articles-more-link {
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		text-decoration: none;
	}

	/* ——— About brief ——— */

	.about-brief {
		padding: var(--space-section) var(--space-md);
		background: var(--color-bg-panel);
		border-bottom: 1px solid var(--color-border);
	}
	.about-brief-inner {
		max-width: var(--max-width-narrow);
		margin: 0 auto;
	}
	.about-brief-tagline {
		font-size: var(--text-h3);
		font-weight: var(--weight-normal);
		line-height: var(--leading-snug);
		letter-spacing: var(--tracking-tight);
		color: var(--color-text-muted);
		margin-bottom: var(--space-lg);
		padding-bottom: var(--space-lg);
		border-bottom: 1px solid var(--color-border);
	}
	.about-brief-heading {
		font-size: var(--text-h2);
		font-weight: var(--weight-semibold);
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--space-md);
	}
	.about-brief-body {
		font-size: var(--text-body);
		line-height: var(--leading-normal);
		color: var(--color-text-secondary);
	}
	.about-brief-link {
		display: inline-block;
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		text-decoration: none;
		margin-top: var(--space-xs);
	}

	/* ——— Tools (4-col grid) ——— */

	.templates {
		padding: var(--space-section) var(--space-md);
	}
	.templates-inner {
		max-width: var(--max-width);
		margin: 0 auto;
	}
	.templates-heading {
		font-size: var(--text-h2);
		font-weight: var(--weight-semibold);
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--space-lg);
	}
	.templates-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: var(--space-md);
		margin-bottom: var(--space-lg);
	}
	.template-card {
		display: flex;
		flex-direction: column;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		text-decoration: none;
		overflow: hidden;
		transition: border-color 0.15s;
	}
	.template-card:hover {
		border-color: var(--color-divider);
	}
	.template-thumb {
		aspect-ratio: 3 / 2;
		background: var(--color-bg-panel);
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
	}
	.template-thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
	.template-placeholder-icon {
		color: var(--color-divider);
	}
	.template-name {
		font-size: var(--text-body);
		font-weight: var(--weight-semibold);
		color: var(--color-text);
		margin-bottom: var(--space-xs);
		padding: var(--space-md) var(--space-md) 0;
	}
	.template-desc {
		font-size: var(--text-small);
		color: var(--color-text-secondary);
		line-height: var(--leading-snug);
		margin: 0;
		padding: 0 var(--space-md) var(--space-md);
	}
	.templates-cta-wrap {
		text-align: center;
	}

	/* ——— Responsive ——— */

	@media (max-width: 960px) {
		.editorial-grid {
			grid-template-columns: 1fr;
			gap: var(--space-lg);
		}
		.editorial-featured {
			padding-right: 0;
		}
		.editorial-sidebar {
			border-left: none;
			padding-left: 0;
			border-top: 1px solid var(--color-border);
			padding-top: var(--space-lg);
		}
		.templates-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 600px) {
		.templates-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
