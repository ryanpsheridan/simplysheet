---
import BaseLayout from '../layouts/BaseLayout.astro';
import TagPills from '../components/TagPills.astro';
import SpreadsheetsToolsRows from '../components/SpreadsheetsToolsRows.astro';
import { getCollection } from 'astro:content';
import { ALL_TAGS, SITE_DESCRIPTION, SITE_TITLE, TAG_MAP } from '../consts';

const allArticles = (await getCollection('articles'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.map((article) => {
		const wordCount = article.body?.split(/\s+/).filter(Boolean).length ?? 0;
		const readTime = Math.max(1, Math.ceil(wordCount / 200));
		return { ...article, readTime };
	});

const featuredSlug = '50-30-20-budget-rule';
const featured = allArticles.find((a) => a.id === featuredSlug) ?? allArticles[0];
const rest = allArticles.filter((a) => a.id !== featured.id);

const latest = rest.slice(0, 6);

const usedTags = new Set(allArticles.flatMap((a) => a.data.tags ?? []));
const topicTags = ALL_TAGS.filter((t) => usedTags.has(t.slug));

const organizationSchema = {
	'@context': 'https://schema.org',
	'@type': 'Organization',
	name: SITE_TITLE,
	url: Astro.site?.toString(),
	logo: new URL('/images/logo-256px.jpg', Astro.site).toString(),
	description: SITE_DESCRIPTION,
	founder: {
		'@type': 'Person',
		name: 'Ryan Sheridan',
	},
	sameAs: ['https://simplysheetdesign.etsy.com'],
};

const websiteSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: SITE_TITLE,
	url: Astro.site?.toString(),
	description: SITE_DESCRIPTION,
	publisher: {
		'@type': 'Organization',
		name: SITE_TITLE,
	},
};
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
	<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
	<section class="hero">
		<div class="hero-inner">
			<div class="hero-text">
				<h1 class="hero-title">A simpler way to manage your personal finances.</h1>
				<p class="hero-desc">Whether you are paying off debt or navigating an irregular income, find the guidance and tools you need to organize your money, stay on track, and move forward with confidence.</p>
			</div>
			{featured && (
				<a href={`/articles/${featured.id}/`} class="hero-featured">
					{(featured.data.cardImage || featured.data.image) && (
						<div class="hero-featured-thumb">
							<img src={featured.data.cardImage ?? featured.data.image} alt={featured.data.title} width="960" height="540" />
						</div>
					)}
					<TagPills tags={featured.data.tags} tagMap={TAG_MAP} />
					<h2 class="hero-featured-title">{featured.data.title}</h2>
					<p class="hero-featured-meta">
						<span>{featured.readTime} min read</span>
					</p>
				</a>
			)}
		</div>
	</section>

	<div class="section-divider"></div>

	<section class="topic-nav">
		<div class="topic-nav-inner">
			<span class="topic-nav-label">Browse by topic</span>
			<div class="topic-nav-pills">
				{topicTags.map((tag) => (
					<a href={`/articles/tag/${tag.slug}/`} class="topic-pill">{tag.label}</a>
				))}
			</div>
		</div>
	</section>

	<section class="home-rows">
		<div class="home-rows-inner">
			{latest.length > 0 && (
				<div class="home-row">
					<div class="home-row-label">
						<h3 class="home-row-heading">Latest</h3>
					</div>
					<div class="home-row-items">
						{latest.map((article) => (
							<a href={`/articles/${article.id}/`} class="home-row-item">
								{(article.data.cardImage || article.data.image) && (
									<div class="home-row-thumb">
										<img src={article.data.cardImage ?? article.data.image} alt={article.data.title} width="960" height="540" loading="lazy" />
									</div>
								)}
								<div class="home-row-text">
									<TagPills tags={article.data.tags} tagMap={TAG_MAP} />
									<h4 class="home-row-title">{article.data.title}</h4>
									<span class="home-row-meta">{article.readTime} min read</span>
								</div>
							</a>
						))}
						<div class="home-row-viewall">
							<a href="/articles/" class="btn btn-secondary">All articles <span class="arrow">&rarr;</span></a>
						</div>
					</div>
				</div>
			)}
			<SpreadsheetsToolsRows />
		</div>
	</section>

	<section class="quiz-banner">
		<div class="quiz-banner-inner">
			<h2 class="quiz-banner-heading">Curious which budgeting style fits you best?</h2>
			<a href="/quiz/budgeting-style/" class="btn btn-primary">Take the 60-second quiz</a>
		</div>
	</section>

	<section class="about-brief" id="about-brief">
		<div class="about-brief-inner">
			<div class="about-brief-label">Creating a sustainable system</div>
			<div class="about-brief-content">
				<p class="about-brief-body" id="about-text">I spent years frustrated by complicated budgeting apps that didn't fit my life. After six years of refining my own spreadsheet systems, I realized that clarity comes from simplicity, not extra features. I combined my background in UX design with my passion for personal finance to build the tools I wish I had from the start.</p>
				<a href="/about/" class="btn btn-secondary about-brief-link">Read the full story <span class="arrow">&rarr;</span></a>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	/* ——— Hero (2-col) ——— */

	.hero {
		padding: var(--space-section) var(--space-md);
	}
	.hero-inner {
		max-width: var(--max-width);
		margin: 0 auto;
		display: grid;
		grid-template-columns: 0.75fr 1fr;
		gap: var(--space-xl);
		align-items: center;
	}
	.hero-text {
		display: flex;
		flex-direction: column;
	}
	.hero-title {
		font-size: var(--text-display);
		font-weight: var(--weight-normal);
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-tight);
		color: var(--color-text-heading);
		margin-bottom: var(--space-sm);
	}
	.hero-desc {
		font-size: var(--text-body);
		line-height: var(--leading-normal);
		color: var(--color-text-secondary);
		margin: 0;
	}
	.hero-featured {
		display: flex;
		flex-direction: column;
		text-decoration: none;
	}
	/* Hover zooms only the thumbnail (transform, so the text below doesn't
	   reflow), leaving the title/meta text untouched for contrast. */
	@media (hover: hover) {
		.hero-featured:hover .hero-featured-thumb img {
			transform: scale(1.01);
		}
	}
	.hero-featured-thumb {
		position: relative;
		border-radius: var(--radius-md);
		overflow: hidden;
		margin-bottom: var(--space-md);
		background: var(--color-bg-panel);
		padding: 1.5rem;
	}
	.hero-featured-thumb img {
		display: block;
		width: 100%;
		height: auto;
		border-radius: var(--radius-sm);
		transition: transform 0.3s ease;
	}
	.hero-featured-title {
		font-size: var(--text-h3);
		line-height: var(--leading-snug);
		color: var(--color-text);
		margin-bottom: var(--space-xs);
	}
	.hero-featured-meta {
		font-size: var(--text-small);
		color: var(--color-text-muted);
		margin: 0;
		display: flex;
		align-items: center;
		gap: 0.375rem;
	}

	/* ——— Section divider ——— */

	.section-divider {
		max-width: var(--max-width);
		margin: 0 auto;
		border-top: 1px solid var(--color-border);
	}

	/* ——— Topic nav (tag pills) ——— */

	.topic-nav {
		padding: var(--space-lg) var(--space-md) 0;
	}
	.topic-nav-inner {
		max-width: var(--max-width);
		margin: 0 auto;
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: var(--space-sm) var(--space-md);
	}
	.topic-nav-label {
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		color: var(--color-text-muted);
		flex-shrink: 0;
	}
	.topic-nav-pills {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-xs);
	}
	.topic-pill {
		font-family: var(--font-sans);
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		color: var(--color-text-secondary);
		background: var(--color-bg-panel);
		border: 1px solid transparent;
		border-radius: var(--radius-full);
		padding: 0.5rem 1rem;
		text-decoration: none;
		transition: color 0.15s, background 0.15s;
	}
	@media (hover: hover) {
		.topic-pill:hover {
			color: var(--color-text);
			background: var(--color-bg-panel);
		}
	}

	/* ——— Quiz banner ——— */

	.quiz-banner {
		padding: var(--space-lg) var(--space-md);
		background: var(--color-bg-panel);
		border-top: 1px solid var(--color-border);
		border-bottom: 1px solid var(--color-border);
		text-align: center;
	}
	.quiz-banner-inner {
		max-width: var(--max-width);
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-sm);
	}
	.quiz-banner-heading {
		font-size: var(--text-body);
		font-weight: var(--weight-normal);
		color: var(--color-text-secondary);
		margin: 0;
	}

	/* ——— About brief ——— */

	.about-brief {
		padding: clamp(5rem, 12vw, 8rem) var(--space-md);
		background: var(--color-bg);
		color: var(--color-text);
	}
	.about-brief-inner {
		max-width: var(--max-width);
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1fr 2fr;
		gap: var(--space-xl);
		align-items: start;
	}
	.about-brief-label {
		font-size: var(--text-body);
		font-weight: var(--weight-normal);
		color: var(--color-text-muted);
		padding-top: 0.35em;
	}
	.about-brief-content {
		max-width: 38rem;
	}
	.about-brief-body {
		font-size: clamp(1.5rem, 2vw + 0.4rem, 1.75rem);
		font-weight: var(--weight-normal);
		line-height: 1.5;
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		margin: 0;
	}
	:global(.about-brief-body .word) {
		color: #B0B0B0;
		transition: color 0.15s ease;
	}
	:global(.about-brief-body .word.lit) {
		color: #000000;
	}
	.about-brief-link {
		margin-top: var(--space-md);
	}

	/* ——— Responsive ——— */

	@media (max-width: 960px) {
		.hero-inner {
			grid-template-columns: 1fr;
		}
		.about-brief-inner {
			grid-template-columns: 1fr;
			gap: var(--space-md);
		}
	}
</style>

<script>
	const textEl = document.getElementById('about-text');
	if (textEl) {
		const raw = textEl.textContent || '';
		textEl.innerHTML = raw.split(/(\s+)/).map(part =>
			/\S/.test(part) ? `<span class="word">${part}</span>` : part
		).join('');

		const words = textEl.querySelectorAll<HTMLSpanElement>('.word');
		words.forEach((w, i) => {
			w.style.transitionDelay = `${i * 3}ms`;
		});
		const section = document.getElementById('about-brief');
		let ticking = false;

		function updateWords() {
			if (!section) return;
			const rect = section.getBoundingClientRect();
			const vh = window.innerHeight;
			const start = vh * 0.45;
			const end = vh * 0.15;
			const progress = Math.max(0, Math.min(1, (start - rect.top) / (start - end)));
			const litCount = Math.round(progress * words.length);
			words.forEach((w, i) => w.classList.toggle('lit', i < litCount));
		}

		window.addEventListener('scroll', () => {
			if (!ticking) {
				requestAnimationFrame(() => { updateWords(); ticking = false; });
				ticking = true;
			}
		}, { passive: true });
		updateWords();
	}
</script>
