---
import BaseLayout from '../layouts/BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getCollection } from 'astro:content';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const allArticles = (await getCollection('articles'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.map((article) => {
		const wordCount = article.body?.split(/\s+/).filter(Boolean).length ?? 0;
		const readTime = Math.max(1, Math.ceil(wordCount / 200));
		return { ...article, readTime };
	});

const featured = allArticles[0];
const rest = allArticles.slice(1, 7);

const templates = [
	{
		name: 'Budget Spreadsheet',
		desc: 'Track income and daily expenses with real-time progress indicators that show where you stand each month.',
		url: 'https://simplysheetdesign.etsy.com/listing/1854773368',
	},
	{
		name: 'Couples Budget Spreadsheet',
		desc: 'Split bills, track shared and personal expenses, and manage savings together. Built for two incomes.',
		url: 'https://simplysheetdesign.etsy.com/listing/4396395102',
	},
	{
		name: 'Debt Payoff Tracker',
		desc: 'See your total debt, log payments, and watch your balances drop month by month with clear visual progress.',
		url: 'https://simplysheetdesign.etsy.com/listing/4485879930',
	},
	{
		name: 'Savings Goals Tracker',
		desc: 'Set multiple savings goals, automate contributions, and track your progress toward each one.',
		url: 'https://simplysheetdesign.etsy.com/listing/4483664616',
	},
];
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<section class="hero">
		<div class="hero-inner">
			<h1 class="hero-headline">Take control of your budget with spreadsheets you'll actually use</h1>
			<p class="hero-sub">Clear, actionable budgeting guidance paired with Google Sheets and Excel templates — no apps, no account syncing, no fluff. Just the tools and know-how to understand where your money goes.</p>
		</div>
	</section>

	{featured && (
		<section class="featured">
			<div class="featured-inner">
				<span class="featured-label">Latest</span>
				<a href={`/articles/${featured.id}/`} class="featured-link">
					<h2 class="featured-title">{featured.data.title}</h2>
					<p class="featured-desc">{featured.data.description}</p>
					<p class="featured-meta">
						<FormattedDate date={featured.data.pubDate} />
						<span>&middot;</span>
						<span>{featured.readTime} min read</span>
					</p>
				</a>
			</div>
		</section>
	)}

	{rest.length > 0 && (
		<section class="articles">
			<div class="articles-inner">
				<ul class="article-list">
					{rest.map((article) => (
						<li>
							<a href={`/articles/${article.id}/`} class="article-row">
								<div class="article-row-body">
									<h3 class="article-row-title">{article.data.title}</h3>
									<p class="article-row-desc">{article.data.description}</p>
								</div>
								<p class="article-row-meta">
									<FormattedDate date={article.data.pubDate} />
									<span>&middot;</span>
									<span>{article.readTime} min read</span>
								</p>
							</a>
						</li>
					))}
				</ul>
				<div class="articles-more">
					<a href="/articles" class="articles-more-link">All articles &rarr;</a>
				</div>
			</div>
		</section>
	)}

	<section class="templates">
		<div class="templates-inner">
			<h2 class="templates-heading">Ready-to-use budget templates</h2>
			<div class="templates-grid">
				{templates.map((t) => (
					<a href={t.url} class="template-card">
						<h3 class="template-name">{t.name}</h3>
						<p class="template-desc">{t.desc}</p>
					</a>
				))}
			</div>
			<div class="templates-cta-wrap">
				<a href="https://simplysheetdesign.etsy.com" class="btn btn-primary">Explore all on Etsy</a>
			</div>
		</div>
	</section>

	<section class="about-brief">
		<div class="about-brief-inner">
			<h2 class="about-brief-heading">About SimplySheetDesign</h2>
			<p class="about-brief-body">I started budgeting six years ago with a blank Google Sheet. The one habit that changed everything was tracking expenses daily — that visibility gave me clarity I never had before. After years of refining and sharing with friends, I turned it into a product. With over 12 years of UX and visual design experience, I focused on making it simple enough that people actually use it.</p>
			<a href="/about" class="about-brief-link">Read the full story &rarr;</a>
		</div>
	</section>
</BaseLayout>

<style>
	/* ——— Hero ——— */

	.hero {
		padding: var(--space-section) var(--space-md);
		border-bottom: 1px solid var(--color-border);
	}
	.hero-inner {
		max-width: var(--max-width);
		margin: 0 auto;
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
	}
	.hero-headline {
		font-size: var(--text-display);
		font-weight: var(--weight-bold);
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		max-width: 20ch;
	}
	.hero-sub {
		margin-top: var(--space-md);
		font-size: var(--text-body);
		line-height: var(--leading-normal);
		color: var(--color-text-secondary);
		max-width: 38rem;
	}

	/* ——— Featured article ——— */

	.featured {
		padding: var(--space-section) var(--space-md);
		border-bottom: 1px solid var(--color-border);
	}
	.featured-inner {
		max-width: var(--max-width-narrow);
		margin: 0 auto;
	}
	.featured-label {
		display: inline-block;
		font-size: var(--text-xs);
		font-weight: var(--weight-semibold);
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
		color: var(--color-accent);
		margin-bottom: var(--space-sm);
	}
	.featured-link {
		display: block;
		text-decoration: none;
	}
	.featured-title {
		font-size: var(--text-h1);
		font-weight: var(--weight-bold);
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		margin-bottom: var(--space-sm);
		transition: color 0.15s;
	}
	.featured-link:hover .featured-title {
		color: var(--color-accent);
	}
	.featured-desc {
		font-size: var(--text-body);
		line-height: var(--leading-normal);
		color: var(--color-text-secondary);
		margin-bottom: var(--space-sm);
	}
	.featured-meta {
		font-size: var(--text-small);
		color: var(--color-text-muted);
		margin: 0;
		display: flex;
		align-items: center;
		gap: 0.375rem;
	}

	/* ——— Article list ——— */

	.articles {
		padding: var(--space-lg) var(--space-md) var(--space-section);
		border-bottom: 1px solid var(--color-border);
	}
	.articles-inner {
		max-width: var(--max-width-narrow);
		margin: 0 auto;
	}
	.article-list {
		list-style: none;
		padding: 0;
		display: flex;
		flex-direction: column;
	}
	.article-list li {
		border-top: 1px solid var(--color-border);
	}
	.article-row {
		display: block;
		padding: var(--space-md) 0;
		text-decoration: none;
		transition: background 0.15s;
	}
	.article-row:hover .article-row-title {
		color: var(--color-accent);
	}
	.article-row-body {
		margin-bottom: var(--space-xs);
	}
	.article-row-title {
		font-size: var(--text-h3);
		font-weight: var(--weight-semibold);
		color: var(--color-text);
		margin-bottom: var(--space-2xs);
		transition: color 0.15s;
	}
	.article-row-desc {
		font-size: var(--text-small);
		line-height: var(--leading-snug);
		color: var(--color-text-secondary);
		margin: 0;
	}
	.article-row-meta {
		font-size: var(--text-small);
		color: var(--color-text-muted);
		margin: 0;
		display: flex;
		align-items: center;
		gap: 0.375rem;
	}
	.articles-more {
		padding-top: var(--space-md);
	}
	.articles-more-link {
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		text-decoration: none;
	}

	/* ——— Templates (4-col grid) ——— */

	.templates {
		padding: var(--space-section) var(--space-md);
		border-bottom: 1px solid var(--color-border);
	}
	.templates-inner {
		max-width: var(--max-width);
		margin: 0 auto;
	}
	.templates-heading {
		font-size: var(--text-h2);
		font-weight: var(--weight-semibold);
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--space-lg);
	}
	.templates-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: var(--space-md);
		margin-bottom: var(--space-lg);
	}
	.template-card {
		display: block;
		padding: var(--space-md);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		text-decoration: none;
		transition: border-color 0.15s;
	}
	.template-card:hover {
		border-color: var(--color-divider);
	}
	.template-name {
		font-size: var(--text-body);
		font-weight: var(--weight-semibold);
		color: var(--color-text);
		margin-bottom: var(--space-xs);
	}
	.template-desc {
		font-size: var(--text-small);
		color: var(--color-text-secondary);
		line-height: var(--leading-snug);
		margin: 0;
	}
	.templates-cta-wrap {
		text-align: center;
	}

	/* ——— About brief ——— */

	.about-brief {
		padding: var(--space-section) var(--space-md);
	}
	.about-brief-inner {
		max-width: var(--max-width-narrow);
		margin: 0 auto;
	}
	.about-brief-heading {
		font-size: var(--text-h3);
		font-weight: var(--weight-semibold);
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--space-sm);
	}
	.about-brief-body {
		font-size: var(--text-small);
		line-height: var(--leading-normal);
		color: var(--color-text-secondary);
	}
	.about-brief-link {
		display: inline-block;
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		text-decoration: none;
		margin-top: var(--space-xs);
	}

	/* ——— Responsive ——— */

	@media (max-width: 960px) {
		.templates-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 600px) {
		.templates-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
