---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE } from '../../consts';

const title = 'Budget Templates for Google Sheets & Excel';
const description = 'Ready-made spreadsheet templates to track your budget, pay off debt, and hit savings goals. Available for Google Sheets and Microsoft Excel.';

const templates = (await getCollection('templates'))
	.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title={`${title} — ${SITE_TITLE}`} description={description}>
	<main class="templates-page">
		<Breadcrumbs crumbs={[{ label: 'Spreadsheets' }]} />
		<header class="templates-header">
			<h1>{title}</h1>
			<p class="templates-intro">Simple, visual spreadsheets designed to help you understand where your money goes and stay on track — no subscriptions, no apps, just a spreadsheet you own.</p>
		</header>

		<div class="templates-grid">
			{templates.map((t) => (
				<a href={`/spreadsheets/${t.id}/`} class="template-card">
					<div class="template-thumb">
						<img src={t.data.heroImage} alt={`${t.data.title} preview`} width="600" height="400" loading="lazy" />
						{t.data.badge && <span class="template-badge">{t.data.badge}</span>}
					</div>
					<h2 class="template-name">{t.data.title.replace(/ for Google Sheets & Excel$/, '')}</h2>
					<p class="template-desc">{t.data.description}</p>
				</a>
			))}
		</div>

		<div class="templates-etsy-cta">
			<a href="https://simplysheetdesign.etsy.com" class="btn btn-secondary" target="_blank" rel="noopener noreferrer" data-cta="spreadsheets_index_etsy_link">
				Browse all on Etsy
				<svg class="arrow external-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
			</a>
		</div>
	</main>
</BaseLayout>

<style>
	.templates-page {
		max-width: calc(var(--max-width) + var(--space-md) * 2);
		margin: 0 auto;
		padding: var(--space-lg) var(--space-md) var(--space-2xl);
	}

	.templates-header {
		margin-bottom: var(--space-xl);
	}

	.templates-header h1 {
		font-size: var(--text-h1);
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--space-xs);
	}

	.templates-intro {
		font-size: var(--text-body);
		line-height: var(--leading-normal);
		color: var(--color-text-secondary);
		max-width: var(--max-width-narrow);
	}

	.templates-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--space-md);
		margin-bottom: var(--space-xl);
	}

	.template-card {
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
		text-decoration: none;
		color: inherit;
		transition: opacity 0.15s ease;
	}

	@media (hover: hover) {
		.template-card:hover {
			opacity: 0.7;
		}
	}

	.template-thumb {
		position: relative;
		width: 100%;
		aspect-ratio: 10 / 9;
		border-radius: var(--radius-md);
		overflow: hidden;
		background: var(--color-bg-panel);
		padding: 1.5rem 0 1.5rem 1.5rem;
	}

	.template-thumb img {
		width: 100%;
		height: 100%;
		object-fit: contain;
		object-position: right center;
		border-radius: var(--radius-sm);
		display: block;
	}

	.template-badge {
		position: absolute;
		left: 0.75rem;
		bottom: 0.75rem;
		font-size: var(--text-xs);
		font-weight: var(--weight-normal);
		color: var(--color-text);
		background: var(--color-bg);
		border: 1px solid var(--color-divider);
		border-radius: var(--radius-sm);
		padding: 0.125rem 0.5rem;
		line-height: 1.4;
	}

	.template-name {
		font-size: var(--text-h3);
		color: var(--color-text);
		line-height: var(--leading-snug);
		margin: 0;
	}

	.template-desc {
		font-size: var(--text-small);
		color: var(--color-text-secondary);
		line-height: var(--leading-snug);
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.templates-etsy-cta {
		text-align: center;
	}

	@media (max-width: 960px) {
		.templates-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 600px) {
		.templates-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
