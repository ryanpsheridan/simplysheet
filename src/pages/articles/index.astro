---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../consts';

const ALL_TAGS = [
	{ slug: 'expense-tracking', label: 'Expense Tracking' },
	{ slug: 'couples-budgeting', label: 'Couples Budgeting' },
	{ slug: 'debt-payoff', label: 'Debt Payoff' },
	{ slug: 'savings-goals', label: 'Savings Goals' },
	{ slug: 'irregular-income', label: 'Irregular Income' },
	{ slug: 'net-worth', label: 'Net Worth' },
	{ slug: 'budgeting-styles', label: 'Budgeting Styles' },
];

const TAG_MAP: Record<string, string> = {};
ALL_TAGS.forEach((t) => { TAG_MAP[t.slug] = t.label; });

const articles = (await getCollection('articles'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.map((article) => {
		const wordCount = article.body?.split(/\s+/).filter(Boolean).length ?? 0;
		const readTime = Math.max(1, Math.ceil(wordCount / 200));
		return { ...article, readTime };
	});

const usedTags = new Set(articles.flatMap((a) => a.data.tags ?? []));
const visibleTags = ALL_TAGS.filter((t) => usedTags.has(t.slug));

const templates = [
	{
		name: 'Budget Template',
		desc: 'Track income and daily expenses with real-time progress indicators that show where you stand each month.',
		url: 'https://www.etsy.com/listing/1854773368/budget-spreadsheet-for-google-excel?utm_source=simplysheetdesign_site&utm_medium=article&utm_campaign=articles',
		image: '/images/featured budget thumbnail- budget template.jpg',
		badge: 'Best Seller',
	},
	{
		name: 'Couples Budget Spreadsheet',
		desc: 'Split bills, track shared and personal expenses, and manage savings together. Built for two incomes.',
		url: 'https://www.etsy.com/listing/4396395102/couples-budget-spreadsheet-google-sheets?utm_source=simplysheetdesign_site&utm_medium=article&utm_campaign=articles',
		image: '/images/featured budget thumbnail-couples.jpg',
	},
	{
		name: 'Debt Payoff Tracker',
		desc: 'See your total debt, log payments, and watch your balances drop month by month with clear visual progress.',
		url: 'https://www.etsy.com/listing/4485879930/debt-payoff-tracker-for-google-sheets?utm_source=simplysheetdesign_site&utm_medium=article&utm_campaign=articles',
		image: '/images/featured budget thumbnail-debt-tracker.jpg',
	},
	{
		name: 'Savings Goals Tracker',
		desc: 'Set multiple savings goals, automate contributions, and track your progress toward each one.',
		url: 'https://www.etsy.com/listing/4483664616/sinking-funds-tracker-google-sheets?utm_source=simplysheetdesign_site&utm_medium=article&utm_campaign=articles',
		image: '/images/featured budget thumbnail-savings goals tracker.jpg',
	},
];
---

<BaseLayout title={`Articles — ${SITE_TITLE}`} description="Straightforward writing about budgeting, spreadsheets, and managing your money without the stress.">
	<main class="articles-page">
		<Breadcrumbs crumbs={[{ label: 'Articles' }]} />
		<div class="articles-header">
			<h1>Articles</h1>
			<button class="filter-toggle" id="filter-toggle" aria-label="Filter and sort articles">
				<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="6" x2="20" y2="6"/><line x1="6" y1="12" x2="18" y2="12"/><line x1="9" y1="18" x2="15" y2="18"/></svg>
				Filter &amp; Sort
			</button>
		</div>

		<ul class="article-list" id="article-list">
			{articles.map((article) => (
				<li data-tags={JSON.stringify(article.data.tags ?? [])} data-date={article.data.pubDate.valueOf().toString()} data-title={article.data.title}>
					<a href={`/articles/${article.id}/`}>
						{(article.data.cardImage || article.data.image) && (
							<div class="thumb">
								<img src={article.data.cardImage ?? article.data.image} alt={article.data.title} width="600" height="340" loading="lazy" />
							</div>
						)}
						<div class="card-body">
							{(article.data.tags ?? []).length > 0 && (
								<div class="card-tags">
									{(article.data.tags ?? []).map((slug: string) => (
										<span class="card-tag">{TAG_MAP[slug] ?? slug}</span>
									))}
								</div>
							)}
							<h2 class="title">{article.data.title}</h2>
							<p class="description">{article.data.description}</p>
							<p class="meta">
								<FormattedDate date={article.data.pubDate} />
								<span>&middot;</span>
								<span>{article.readTime} min read</span>
							</p>
						</div>
					</a>
				</li>
			))}
		</ul>

		<p class="no-results" hidden>No articles match this filter.</p>

		<section class="resources">
			<h2 class="resources-heading">More resources</h2>
			<div class="resources-grid">
				{templates.map((t) => (
					<a href={t.url} class="resource-card" target="_blank" rel="noopener noreferrer">
						<div class="resource-thumb">
							<img src={t.image} alt={`${t.name} preview`} width="600" height="400" loading="lazy" />
						</div>
						{t.badge && <span class="resource-badge">{t.badge}</span>}
						<h3 class="resource-name">{t.name}</h3>
						<p class="resource-desc">{t.desc}</p>
					</a>
				))}
			</div>
			<div class="resources-cta-wrap">
				<a href="https://simplysheetdesign.etsy.com?utm_source=simplysheetdesign_site&utm_medium=article&utm_campaign=articles" class="btn btn-primary" target="_blank" rel="noopener noreferrer">Explore all on Etsy <svg class="arrow external-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg></a>
			</div>
		</section>
	</main>

	<div class="filter-overlay" id="filter-overlay">
		<div class="filter-panel">
			<div class="filter-panel-header">
				<h2 class="filter-panel-title">Filter &amp; Sort</h2>
				<button class="filter-close" id="filter-close" aria-label="Close filters">
					<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
						<line x1="6" y1="6" x2="18" y2="18" />
						<line x1="6" y1="18" x2="18" y2="6" />
					</svg>
				</button>
			</div>

			<div class="filter-section">
				<h3 class="filter-label">Topic</h3>
				<div class="tag-filters" role="group" aria-label="Filter articles by topic">
					<button class="tag-pill active" data-tag="all">All</button>
					{visibleTags.map((tag) => (
						<button class="tag-pill" data-tag={tag.slug}>{tag.label}</button>
					))}
				</div>
			</div>

			<div class="filter-section">
				<h3 class="filter-label">Sort by</h3>
				<div class="sort-options" role="group" aria-label="Sort articles">
					<button class="tag-pill active" data-sort="newest">Newest first</button>
					<button class="tag-pill" data-sort="oldest">Oldest first</button>
					<button class="tag-pill" data-sort="title">Title A–Z</button>
				</div>
			</div>

			<div class="filter-actions">
				<button class="filter-reset" id="filter-reset">Reset all</button>
			</div>
		</div>
	</div>
</BaseLayout>

<style>
	.articles-page {
		max-width: var(--max-width);
		padding: var(--space-xl) var(--space-md) var(--space-2xl);
	}

	.articles-header {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: var(--space-md);
		margin-bottom: var(--space-lg);
	}

	h1 {
		margin-bottom: 0;
	}

	/* ——— Filter toggle ——— */

	.filter-toggle {
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		font-family: var(--font-sans);
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		color: var(--color-text-secondary);
		background: none;
		border: 1px solid var(--color-divider);
		border-radius: var(--radius-full);
		padding: 0.5rem 1rem;
		cursor: pointer;
		transition: color 0.15s, border-color 0.15s, background 0.15s;
	}
	.filter-toggle:hover {
		color: var(--color-text);
		border-color: var(--color-text-muted);
		background: var(--color-bg-panel);
	}

	/* ——— Filter drawer overlay ——— */

	.filter-overlay {
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.4);
		z-index: 100;
		opacity: 0;
		visibility: hidden;
		transition: opacity 0.25s ease, visibility 0.25s ease;
	}
	.filter-overlay.open {
		opacity: 1;
		visibility: visible;
	}

	.filter-panel {
		position: absolute;
		top: 0;
		right: 0;
		bottom: 0;
		width: min(22rem, 85vw);
		background: var(--color-bg);
		transform: translateX(100%);
		transition: transform 0.3s ease;
		padding: var(--space-md) var(--space-md) var(--space-lg);
		display: flex;
		flex-direction: column;
		gap: var(--space-lg);
		overflow-y: auto;
	}
	.filter-overlay.open .filter-panel {
		transform: translateX(0);
	}

	.filter-panel-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.filter-panel-title {
		font-size: var(--text-h3);
		margin: 0;
	}
	.filter-close {
		display: flex;
		align-items: center;
		justify-content: center;
		background: none;
		border: none;
		cursor: pointer;
		color: var(--color-text);
		padding: var(--space-xs);
		margin-right: calc(-1 * var(--space-xs));
	}

	.filter-section {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
	}
	.filter-label {
		font-size: var(--text-small);
		color: var(--color-text);
		margin: 0;
	}

	/* ——— Tag filter pills ——— */

	.tag-filters,
	.sort-options {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-xs);
	}
	.tag-pill {
		font-family: var(--font-sans);
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		color: var(--color-text-secondary);
		background: var(--color-bg-surface);
		border: 1px solid var(--color-divider);
		border-radius: var(--radius-full);
		padding: 0.4375rem 0.875rem;
		cursor: pointer;
		transition: color 0.15s, border-color 0.15s, background 0.15s;
	}
	.tag-pill:hover {
		color: var(--color-text);
		border-color: var(--color-text-muted);
	}
	.tag-pill.active {
		color: var(--color-bg);
		background: var(--color-bg-inverse);
		border-color: var(--color-bg-inverse);
	}

	/* ——— Filter actions ——— */

	.filter-actions {
		margin-top: auto;
		padding-top: var(--space-md);
		border-top: 1px solid var(--color-border);
	}
	.filter-reset {
		font-family: var(--font-sans);
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		color: var(--color-accent);
		background: none;
		border: none;
		cursor: pointer;
		padding: 0;
		transition: color 0.15s;
	}
	.filter-reset:hover {
		color: var(--color-accent-hover);
	}

	/* ——— Article grid ——— */

	.article-list {
		list-style: none;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--space-md);
	}
	.article-list li[hidden] {
		display: none;
	}
	.article-list li a {
		display: flex;
		flex-direction: column;
		text-decoration: none;
		height: 100%;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		overflow: hidden;
		background: var(--color-bg-surface);
		transition: box-shadow 0.2s ease;
	}
	.article-list li a:hover {
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
	}
	.thumb {
		overflow: hidden;
	}
	.thumb img {
		display: block;
		width: 100%;
		height: auto;
	}
	.card-body {
		padding: var(--space-md);
		display: flex;
		flex-direction: column;
		flex: 1;
	}
	.card-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
		margin-bottom: var(--space-xs);
	}
	.card-tag {
		font-size: var(--text-xs);
		font-weight: var(--weight-medium);
		color: var(--color-text-muted);
		background: var(--color-bg-emphasis);
		border-radius: var(--radius-full);
		padding: 0.1875rem 0.625rem;
		line-height: 1.4;
	}
	.title {
		font-size: var(--text-h3);
		color: var(--color-text);
		margin-bottom: var(--space-xs);
		text-decoration: underline transparent;
		text-underline-offset: 3px;
		transition: text-decoration-color 100ms ease;
	}
	.article-list li a:hover .title {
		text-decoration-color: var(--color-text);
	}
	.description {
		font-size: var(--text-small);
		color: var(--color-text-secondary);
		margin: 0 0 auto;
		padding-bottom: var(--space-sm);
		line-height: var(--leading-snug);
	}
	.meta {
		font-size: var(--text-small);
		color: var(--color-text-muted);
		margin: 0;
		display: flex;
		align-items: center;
		gap: 0.375rem;
	}

	/* ——— Empty state ——— */

	.no-results {
		font-size: var(--text-small);
		color: var(--color-text-muted);
		padding: var(--space-lg) 0;
	}

	/* ——— Resources section ——— */

	.resources {
		margin-top: var(--space-2xl);
		padding-top: var(--space-xl);
		border-top: 1px solid var(--color-border);
	}
	.resources-heading {
		font-size: var(--text-h2);
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--space-lg);
	}
	.resources-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: var(--space-md);
		margin-bottom: var(--space-lg);
	}
	.resource-card {
		display: flex;
		flex-direction: column;
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		text-decoration: none;
		overflow: hidden;
		transition: border-color 0.15s, box-shadow 0.2s ease;
	}
	.resource-card:hover {
		border-color: var(--color-divider);
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
	}
	.resource-thumb {
		aspect-ratio: 3 / 2;
		background: var(--color-bg-panel);
		overflow: hidden;
	}
	.resource-thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
	.resource-badge {
		display: inline-block;
		align-self: flex-start;
		font-size: var(--text-xs);
		font-weight: var(--weight-semibold);
		color: var(--color-accent);
		background: var(--color-accent-light);
		border-radius: var(--radius-full);
		padding: 0.125rem 0.5rem;
		line-height: 1.4;
		white-space: nowrap;
		margin: var(--space-md) var(--space-md) 0;
	}
	.resource-name {
		font-size: var(--text-body);
		color: var(--color-text);
		margin-bottom: var(--space-xs);
		padding: var(--space-xs) var(--space-md) 0;
	}
	.resource-card:not(:has(.resource-badge)) .resource-name {
		padding-top: var(--space-md);
	}
	.resource-desc {
		font-size: var(--text-small);
		color: var(--color-text-secondary);
		line-height: var(--leading-snug);
		margin: 0;
		padding: 0 var(--space-md) var(--space-md);
	}
	.resources-cta-wrap {
		text-align: center;
	}

	@media (max-width: 960px) {
		.article-list {
			grid-template-columns: 1fr;
		}
		.resources-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 600px) {
		.resources-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

<script>
	const toggleBtn = document.getElementById('filter-toggle');
	const overlay = document.getElementById('filter-overlay');
	const closeBtn = document.getElementById('filter-close');
	const resetBtn = document.getElementById('filter-reset');
	const tagPills = document.querySelectorAll<HTMLButtonElement>('.tag-filters .tag-pill');
	const sortPills = document.querySelectorAll<HTMLButtonElement>('.sort-options .tag-pill');
	const list = document.getElementById('article-list');
	const items = Array.from(document.querySelectorAll<HTMLLIElement>('#article-list li'));
	const noResults = document.querySelector<HTMLParagraphElement>('.no-results');

	let activeTag = 'all';
	let activeSort = 'newest';

	function openDrawer() {
		overlay?.classList.add('open');
		document.body.style.overflow = 'hidden';
	}

	function closeDrawer() {
		overlay?.classList.remove('open');
		document.body.style.overflow = '';
	}

	toggleBtn?.addEventListener('click', openDrawer);
	closeBtn?.addEventListener('click', closeDrawer);

	overlay?.addEventListener('click', (e) => {
		if (e.target === overlay) closeDrawer();
	});

	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape') closeDrawer();
	});

	tagPills.forEach((pill) => {
		pill.addEventListener('click', () => {
			activeTag = pill.dataset.tag!;
			tagPills.forEach((p) => p.classList.remove('active'));
			pill.classList.add('active');
			applyFilterAndSort();
		});
	});

	sortPills.forEach((pill) => {
		pill.addEventListener('click', () => {
			activeSort = pill.dataset.sort!;
			sortPills.forEach((p) => p.classList.remove('active'));
			pill.classList.add('active');
			applyFilterAndSort();
		});
	});

	resetBtn?.addEventListener('click', () => {
		activeTag = 'all';
		activeSort = 'newest';
		tagPills.forEach((p) => p.classList.toggle('active', p.dataset.tag === 'all'));
		sortPills.forEach((p) => p.classList.toggle('active', p.dataset.sort === 'newest'));
		applyFilterAndSort();
	});

	function applyFilterAndSort() {
		let visible = 0;

		items.forEach((li) => {
			const tags: string[] = JSON.parse(li.dataset.tags || '[]');
			const show = activeTag === 'all' || tags.includes(activeTag);
			li.hidden = !show;
			if (show) visible++;
		});

		const visibleItems = items.filter((li) => !li.hidden);
		visibleItems.sort((a, b) => {
			if (activeSort === 'newest') {
				return Number(b.dataset.date || 0) - Number(a.dataset.date || 0);
			} else if (activeSort === 'oldest') {
				return Number(a.dataset.date || 0) - Number(b.dataset.date || 0);
			} else {
				return (a.dataset.title || '').localeCompare(b.dataset.title || '');
			}
		});

		visibleItems.forEach((li) => list?.appendChild(li));
		items.filter((li) => li.hidden).forEach((li) => list?.appendChild(li));

		if (noResults) noResults.hidden = visible > 0;
	}
</script>
