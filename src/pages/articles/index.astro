---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../consts';

const ALL_TAGS = [
	{ slug: 'expense-tracking', label: 'Expense Tracking' },
	{ slug: 'couples-budgeting', label: 'Couples Budgeting' },
	{ slug: 'debt-payoff', label: 'Debt Payoff' },
	{ slug: 'savings-goals', label: 'Savings Goals' },
	{ slug: 'irregular-income', label: 'Irregular Income' },
	{ slug: 'net-worth', label: 'Net Worth' },
];

const articles = (await getCollection('articles'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.map((article) => {
		const wordCount = article.body?.split(/\s+/).filter(Boolean).length ?? 0;
		const readTime = Math.max(1, Math.ceil(wordCount / 200));
		return { ...article, readTime };
	});

const usedTags = new Set(articles.flatMap((a) => a.data.tags ?? []));
const visibleTags = ALL_TAGS.filter((t) => usedTags.has(t.slug));
---

<BaseLayout title={`Articles — ${SITE_TITLE}`} description="Straightforward writing about budgeting, spreadsheets, and managing your money without the stress.">
	<main class="articles-page">
		<h1>Articles</h1>

		{visibleTags.length > 0 && (
			<div class="tag-filters" role="group" aria-label="Filter articles by topic">
				<button class="tag-pill active" data-tag="all">All</button>
				{visibleTags.map((tag) => (
					<button class="tag-pill" data-tag={tag.slug}>{tag.label}</button>
				))}
			</div>
		)}

		<ul class="article-list">
			{articles.map((article) => (
				<li data-tags={JSON.stringify(article.data.tags ?? [])}>
					<a href={`/articles/${article.id}/`}>
						{(article.data.image || article.data.cardImage) && (
							<div class="thumb">
								<img src={article.data.image ?? article.data.cardImage} alt="" width="600" height="340" loading="lazy" />
							</div>
						)}
						<div class="card-body">
							<h2 class="title">{article.data.title}</h2>
							<p class="description">{article.data.description}</p>
							<p class="meta">
								<FormattedDate date={article.data.pubDate} />
								<span>&middot;</span>
								<span>{article.readTime} min read</span>
							</p>
						</div>
					</a>
				</li>
			))}
		</ul>

		<p class="no-results" hidden>No articles match this filter.</p>
	</main>
</BaseLayout>

<style>
	.articles-page {
		max-width: var(--max-width);
		padding: var(--space-xl) var(--space-md) var(--space-2xl);
	}

	h1 {
		margin-bottom: var(--space-sm);
	}

	/* ——— Tag filter pills ——— */

	.tag-filters {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-xs);
		margin-bottom: var(--space-lg);
	}
	.tag-pill {
		font-family: var(--font-sans);
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		color: var(--color-text-secondary);
		background: none;
		border: 1px solid var(--color-divider);
		border-radius: var(--radius-full);
		padding: 0.375rem 0.875rem;
		cursor: pointer;
		transition: color 0.15s, border-color 0.15s, background 0.15s;
	}
	.tag-pill:hover {
		color: var(--color-text);
		border-color: var(--color-text-muted);
	}
	.tag-pill.active {
		color: var(--color-bg);
		background: var(--color-bg-inverse);
		border-color: var(--color-bg-inverse);
	}

	/* ——— Article grid ——— */

	.article-list {
		list-style: none;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--space-md);
	}
	.article-list li[hidden] {
		display: none;
	}
	.article-list li a {
		display: flex;
		flex-direction: column;
		position: relative;
		text-decoration: none;
		height: 100%;
		border-radius: 0.75rem;
		overflow: hidden;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}
	.article-list li a:hover {
		transform: translateY(-4px);
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
	}
	.thumb {
		position: absolute;
		inset: 0;
		z-index: 0;
	}
	.thumb img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.card-body {
		position: relative;
		z-index: 1;
		background: var(--color-bg-surface);
		border-radius: var(--radius-md) 0 0 0;
		padding: var(--space-md);
		margin: var(--space-md) 0 0 var(--space-md);
		display: flex;
		flex-direction: column;
	}
	.title {
		font-size: var(--text-h3);
		font-weight: var(--weight-semibold);
		color: var(--color-text);
		margin-bottom: var(--space-xs);
		text-decoration: underline transparent;
		text-underline-offset: 3px;
		transition: text-decoration-color 100ms ease;
	}
	.article-list li a:hover .title {
		text-decoration-color: var(--color-text);
	}
	.description {
		font-size: var(--text-small);
		color: var(--color-text-secondary);
		margin: 0 0 auto;
		padding-bottom: var(--space-sm);
		line-height: var(--leading-snug);
	}
	.meta {
		font-size: var(--text-small);
		color: var(--color-text-muted);
		margin: 0;
		display: flex;
		align-items: center;
		gap: 0.375rem;
	}

	/* ——— Empty state ——— */

	.no-results {
		font-size: var(--text-small);
		color: var(--color-text-muted);
		padding: var(--space-lg) 0;
	}

	@media (max-width: 960px) {
		.article-list {
			grid-template-columns: 1fr;
		}
	}
</style>

<script>
	const pills = document.querySelectorAll<HTMLButtonElement>('.tag-pill');
	const items = document.querySelectorAll<HTMLLIElement>('.article-list li');
	const noResults = document.querySelector<HTMLParagraphElement>('.no-results');

	pills.forEach((pill) => {
		pill.addEventListener('click', () => {
			const tag = pill.dataset.tag!;

			pills.forEach((p) => p.classList.remove('active'));
			pill.classList.add('active');

			let visible = 0;
			items.forEach((li) => {
				const tags: string[] = JSON.parse(li.dataset.tags || '[]');
				const show = tag === 'all' || tags.includes(tag);
				li.hidden = !show;
				if (show) visible++;
			});

			if (noResults) noResults.hidden = visible > 0;
		});
	});
</script>
