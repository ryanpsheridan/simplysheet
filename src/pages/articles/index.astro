---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import TagPills from '../../components/TagPills.astro';
import { SITE_TITLE } from '../../consts';

const ALL_TAGS = [
	{ slug: 'expense-tracking', label: 'Expense Tracking' },
	{ slug: 'couples-budgeting', label: 'Couples Budgeting' },
	{ slug: 'debt-payoff', label: 'Debt Payoff' },
	{ slug: 'savings-goals', label: 'Savings Goals' },
	{ slug: 'irregular-income', label: 'Irregular Income' },
	{ slug: 'net-worth', label: 'Net Worth' },
	{ slug: 'budgeting-styles', label: 'Budgeting Styles' },
];

const TAG_MAP: Record<string, string> = {};
ALL_TAGS.forEach((t) => { TAG_MAP[t.slug] = t.label; });

const articles = (await getCollection('articles'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.map((article) => {
		const wordCount = article.body?.split(/\s+/).filter(Boolean).length ?? 0;
		const readTime = Math.max(1, Math.ceil(wordCount / 200));
		return { ...article, readTime };
	});

const usedTags = new Set(articles.flatMap((a) => a.data.tags ?? []));
const visibleTags = ALL_TAGS.filter((t) => usedTags.has(t.slug));

const templates = [
	{
		name: 'Budget Template',
		desc: 'Track income and daily expenses with real-time progress indicators that show where you stand each month.',
		url: 'https://www.etsy.com/listing/1854773368/budget-spreadsheet-for-google-excel',
		image: '/images/featured budget thumbnail- budget template-right-positioned.png',
		badge: 'Best Seller',
	},
	{
		name: 'Couples Budget Spreadsheet',
		desc: 'Split bills, track shared and personal expenses, and manage savings together. Built for two incomes.',
		url: 'https://www.etsy.com/listing/4396395102/couples-budget-spreadsheet-google-sheets',
		image: '/images/featured budget thumbnail-couples-right-positioned.png',
	},
	{
		name: 'Debt Payoff Tracker',
		desc: 'See your total debt, log payments, and watch your balances drop month by month with clear visual progress.',
		url: 'https://www.etsy.com/listing/4485879930/debt-payoff-tracker-for-google-sheets',
		image: '/images/featured budget thumbnail-debt-tracker-right-positioned.png',
	},
	{
		name: 'Savings Goals Tracker',
		desc: 'Set multiple savings goals, automate contributions, and track your progress toward each one.',
		url: 'https://www.etsy.com/listing/4483664616/sinking-funds-tracker-google-sheets',
		image: '/images/featured budget thumbnail-savings goals tracker-right-positioned.png',
	},
];
---

<BaseLayout title={`Articles — ${SITE_TITLE}`} description="Straightforward writing about budgeting, spreadsheets, and managing your money without the stress.">
	<main class="articles-page">
		<Breadcrumbs crumbs={[{ label: 'Articles' }]} />
		<div class="articles-header">
			<h1>Articles</h1>
		</div>

		<div class="articles-filters">
			<div class="filter-tabs" id="filter-tabs" role="group" aria-label="Filter articles by topic">
				<button class="filter-tab active" data-tag="all">All articles</button>
				{visibleTags.map((tag) => (
					<button class="filter-tab" data-tag={tag.slug}>{tag.label}</button>
				))}
			</div>
			<div class="filter-controls">
				<div class="filter-select-wrap">
					<select id="sort-select" class="filter-select" aria-label="Sort articles">
						<option value="newest">Newest first</option>
						<option value="oldest">Oldest first</option>
						<option value="title">Title A–Z</option>
					</select>
					<svg class="filter-select-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9" /></svg>
				</div>
				<div class="filter-search">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
					<input type="search" id="search-input" class="search-input" placeholder="Search articles" aria-label="Search articles" />
				</div>
			</div>
		</div>

		<div class="articles-main">
			<div class="article-list" id="article-list">
				{articles.map((article) => (
					<a href={`/articles/${article.id}/`} class="article-list-item" data-tags={JSON.stringify(article.data.tags ?? [])} data-date={article.data.pubDate.valueOf().toString()} data-title={article.data.title} data-desc={article.data.description}>
						<div class="article-list-text">
							<TagPills tags={article.data.tags} tagMap={TAG_MAP} />
							<h2 class="article-list-title">{article.data.title}</h2>
							<p class="article-list-desc">{article.data.description}</p>
							<span class="article-list-read">{article.readTime} min read</span>
						</div>
						{(article.data.cardImage || article.data.image) && (
							<div class="article-list-thumb">
								<img src={article.data.cardImage ?? article.data.image} alt={article.data.title} width="960" height="540" loading="lazy" />
							</div>
						)}
					</a>
				))}
			</div>

			<p class="no-results" hidden>No articles match this filter.</p>
		</div>

		<section class="resources">
			<h2 class="resources-heading">More resources</h2>
			<div class="resources-grid">
				{templates.map((t) => (
					<a href={t.url} class="resource-card" target="_blank" rel="noopener noreferrer">
						<div class="resource-thumb">
							<img src={t.image} alt={`${t.name} preview`} width="600" height="400" loading="lazy" />
						</div>
						{t.badge && <span class="resource-badge">{t.badge}</span>}
						<h3 class="resource-name">{t.name}</h3>
						<p class="resource-desc">{t.desc}</p>
					</a>
				))}
			</div>
			<div class="resources-cta-wrap">
				<a href="https://simplysheetdesign.etsy.com" class="btn btn-primary" target="_blank" rel="noopener noreferrer">Explore all on Etsy <svg class="arrow external-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg></a>
			</div>
		</section>
	</main>
</BaseLayout>

<style>
	.articles-page {
		max-width: var(--max-width);
		padding: var(--space-xl) var(--space-md) var(--space-2xl);
	}

	.articles-header {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: var(--space-md);
		margin-bottom: var(--space-lg);
	}

	h1 {
		margin-bottom: 0;
	}

	/* ——— Main content ——— */

	.articles-main {
		min-width: 0;
	}

	/* ——— Filter bar (tabs + dropdowns) ——— */

	.articles-filters {
		margin-bottom: var(--space-lg);
	}
	.filter-tabs {
		display: flex;
		flex-wrap: nowrap;
		overflow-x: auto;
		gap: var(--space-xs);
		margin-bottom: var(--space-sm);
		scrollbar-width: none;
	}
	.filter-tabs::-webkit-scrollbar {
		display: none;
	}
	.filter-tab {
		flex-shrink: 0;
		font-family: var(--font-sans);
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		color: var(--color-text-secondary);
		background: var(--color-bg-panel);
		border: 1px solid transparent;
		border-radius: var(--radius-full);
		padding: 0.5rem 1rem;
		cursor: pointer;
		transition: color 0.15s, border-color 0.15s, background 0.15s;
	}
	.filter-tab:hover {
		color: var(--color-text);
	}
	.filter-tab.active {
		color: var(--color-bg);
		background: var(--color-bg-inverse);
	}
	.filter-controls {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-sm);
	}
	.filter-select-wrap {
		position: relative;
		display: flex;
		align-items: center;
	}
	.filter-select {
		appearance: none;
		font-family: var(--font-sans);
		font-size: var(--text-small);
		color: var(--color-text);
		background: var(--color-bg-surface);
		border: 1px solid var(--color-divider);
		border-radius: var(--radius-sm);
		padding: 0.5rem 2rem 0.5rem 0.875rem;
		cursor: pointer;
		transition: border-color 0.15s;
	}
	.filter-select:hover,
	.filter-select:focus-visible {
		border-color: var(--color-text-muted);
		outline: none;
	}
	.filter-select-chevron {
		position: absolute;
		right: 0.75rem;
		pointer-events: none;
		color: var(--color-text-muted);
	}
	.filter-search {
		display: flex;
		align-items: center;
		gap: var(--space-xs);
		border: 1px solid var(--color-divider);
		border-radius: var(--radius-sm);
		padding: 0.5rem 0.875rem;
		color: var(--color-text-muted);
		transition: border-color 0.15s;
		flex: 1;
		min-width: 12rem;
		max-width: 20rem;
	}
	.filter-search:focus-within {
		border-color: var(--color-text-muted);
	}
	.filter-search svg {
		flex-shrink: 0;
	}
	.search-input {
		flex: 1;
		min-width: 0;
		font-family: var(--font-sans);
		font-size: var(--text-small);
		color: var(--color-text);
		background: none;
		border: none;
		outline: none;
	}
	.search-input::placeholder {
		color: var(--color-text-muted);
	}

	/* ——— Article list — single column ——— */

	.article-list {
		display: flex;
		flex-direction: column;
	}
	.article-list-item {
		display: flex;
		gap: var(--space-lg);
		align-items: flex-start;
		padding: var(--space-lg) 0;
		border-bottom: 1px solid var(--color-border);
		text-decoration: none;
		color: inherit;
		transition: opacity 0.15s ease;
	}
	.article-list-item:first-child {
		padding-top: 0;
	}
	.article-list-item:last-child {
		border-bottom: none;
	}
	.article-list-item:hover {
		opacity: 0.75;
	}
	.article-list-item[hidden] {
		display: none;
	}
	.article-list-text {
		flex: 1;
		min-width: 0;
	}
	.article-list-title {
		font-family: var(--font-heading);
		font-size: 1.35rem;
		font-weight: var(--weight-normal);
		line-height: 1.3;
		margin: 0 0 var(--space-xs) 0;
		color: var(--color-text);
	}
	.article-list-desc {
		font-size: var(--text-body);
		color: var(--color-text-secondary);
		line-height: 1.5;
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.article-list-read {
		display: inline-block;
		margin-top: var(--space-xs);
		font-size: var(--text-xs);
		color: var(--color-text-muted);
	}
	.article-list-thumb {
		position: relative;
		flex-shrink: 0;
		width: 160px;
		height: 107px;
		border-radius: var(--radius-md);
		overflow: hidden;
		background: var(--color-bg-panel);
		padding: 1.5rem;
	}
	.article-list-thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: var(--radius-sm);
	}

	/* ——— Empty state ——— */

	.no-results {
		font-size: var(--text-small);
		color: var(--color-text-muted);
		padding: var(--space-lg) 0;
	}

	/* ——— Resources section ——— */

	.resources {
		margin-top: var(--space-2xl);
		padding-top: var(--space-xl);
		border-top: 1px solid var(--color-border);
	}
	.resources-heading {
		font-size: var(--text-h2);
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--space-lg);
	}
	.resources-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: var(--space-md);
		margin-bottom: var(--space-lg);
	}
	.resource-card {
		display: flex;
		flex-direction: column;
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		text-decoration: none;
		overflow: hidden;
		transition: border-color 0.15s, background 0.15s;
	}
	.resource-card:hover {
		border-color: var(--color-text-muted);
		background: var(--color-bg-panel);
	}
	.resource-thumb {
		aspect-ratio: 3 / 2;
		background: var(--color-bg-panel);
		overflow: hidden;
	}
	.resource-thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
	.resource-badge {
		display: inline-block;
		align-self: flex-start;
		font-size: var(--text-xs);
		font-weight: var(--weight-normal);
		color: var(--color-link);
		background: var(--color-surface-tint);
		border-radius: var(--radius-sm);
		padding: 0.125rem 0.5rem;
		line-height: 1.4;
		white-space: nowrap;
		margin: var(--space-md) var(--space-md) 0;
	}
	.resource-name {
		font-size: var(--text-body);
		color: var(--color-text);
		margin-bottom: var(--space-xs);
		padding: var(--space-xs) var(--space-md) 0;
	}
	.resource-card:not(:has(.resource-badge)) .resource-name {
		padding-top: var(--space-md);
	}
	.resource-desc {
		font-size: var(--text-small);
		color: var(--color-text-secondary);
		line-height: var(--leading-snug);
		margin: 0;
		padding: 0 var(--space-md) var(--space-md);
	}
	.resources-cta-wrap {
		text-align: center;
	}

	@media (max-width: 960px) {
		.resources-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 600px) {
		.article-list-item {
			flex-direction: column;
			gap: var(--space-md);
		}
		.article-list-thumb {
			width: 100%;
			height: auto;
			aspect-ratio: 16 / 9;
			order: -1;
		}
		.resources-grid {
			grid-template-columns: 1fr;
		}
		.filter-search {
			min-width: 0;
			max-width: none;
			flex-basis: 100%;
		}
	}
</style>

<script>
	const tagButtons = document.querySelectorAll<HTMLButtonElement>('.filter-tab');
	const sortSelect = document.getElementById('sort-select') as HTMLSelectElement | null;
	const searchInput = document.getElementById('search-input') as HTMLInputElement | null;

	const list = document.getElementById('article-list');
	const items = Array.from(document.querySelectorAll<HTMLAnchorElement>('#article-list .article-list-item'));
	const noResults = document.querySelector<HTMLParagraphElement>('.no-results');

	let activeTag = 'all';
	let activeSort = 'newest';
	let searchQuery = '';

	function setTag(tag: string) {
		activeTag = tag;
		tagButtons.forEach((b) => b.classList.toggle('active', b.dataset.tag === tag));
		applyFilterAndSort();
	}

	tagButtons.forEach((b) => b.addEventListener('click', () => setTag(b.dataset.tag!)));

	sortSelect?.addEventListener('change', () => {
		activeSort = sortSelect.value;
		applyFilterAndSort();
	});

	searchInput?.addEventListener('input', () => {
		searchQuery = searchInput.value.trim().toLowerCase();
		applyFilterAndSort();
	});

	function applyFilterAndSort() {
		let visible = 0;

		items.forEach((li) => {
			const tags: string[] = JSON.parse(li.dataset.tags || '[]');
			const matchesTag = activeTag === 'all' || tags.includes(activeTag);
			const matchesSearch = !searchQuery
				|| (li.dataset.title || '').toLowerCase().includes(searchQuery)
				|| (li.dataset.desc || '').toLowerCase().includes(searchQuery);
			const show = matchesTag && matchesSearch;
			li.hidden = !show;
			if (show) visible++;
		});

		const visibleItems = items.filter((li) => !li.hidden);
		visibleItems.sort((a, b) => {
			if (activeSort === 'newest') {
				return Number(b.dataset.date || 0) - Number(a.dataset.date || 0);
			} else if (activeSort === 'oldest') {
				return Number(a.dataset.date || 0) - Number(b.dataset.date || 0);
			} else {
				return (a.dataset.title || '').localeCompare(b.dataset.title || '');
			}
		});

		visibleItems.forEach((li) => list?.appendChild(li));
		items.filter((li) => li.hidden).forEach((li) => list?.appendChild(li));

		if (noResults) noResults.hidden = visible > 0;
	}
</script>
