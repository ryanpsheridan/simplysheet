---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { SITE_TITLE } from '../../consts';

const ALL_TAGS = [
	{ slug: 'expense-tracking', label: 'Expense Tracking' },
	{ slug: 'couples-budgeting', label: 'Couples Budgeting' },
	{ slug: 'debt-payoff', label: 'Debt Payoff' },
	{ slug: 'savings-goals', label: 'Savings Goals' },
	{ slug: 'irregular-income', label: 'Irregular Income' },
	{ slug: 'net-worth', label: 'Net Worth' },
	{ slug: 'budgeting-styles', label: 'Budgeting Styles' },
];

const TAG_MAP: Record<string, string> = {};
ALL_TAGS.forEach((t) => { TAG_MAP[t.slug] = t.label; });

const articles = (await getCollection('articles'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.map((article) => {
		const wordCount = article.body?.split(/\s+/).filter(Boolean).length ?? 0;
		const readTime = Math.max(1, Math.ceil(wordCount / 200));
		return { ...article, readTime };
	});

const usedTags = new Set(articles.flatMap((a) => a.data.tags ?? []));
const visibleTags = ALL_TAGS.filter((t) => usedTags.has(t.slug));

const templates = [
	{
		name: 'Budget Template',
		desc: 'Track income and daily expenses with real-time progress indicators that show where you stand each month.',
		url: 'https://www.etsy.com/listing/1854773368/budget-spreadsheet-for-google-excel',
		image: '/images/featured budget thumbnail- budget template-right-positioned.png',
		badge: 'Best Seller',
	},
	{
		name: 'Couples Budget Spreadsheet',
		desc: 'Split bills, track shared and personal expenses, and manage savings together. Built for two incomes.',
		url: 'https://www.etsy.com/listing/4396395102/couples-budget-spreadsheet-google-sheets',
		image: '/images/featured budget thumbnail-couples-right-positioned.png',
	},
	{
		name: 'Debt Payoff Tracker',
		desc: 'See your total debt, log payments, and watch your balances drop month by month with clear visual progress.',
		url: 'https://www.etsy.com/listing/4485879930/debt-payoff-tracker-for-google-sheets',
		image: '/images/featured budget thumbnail-debt-tracker-right-positioned.png',
	},
	{
		name: 'Savings Goals Tracker',
		desc: 'Set multiple savings goals, automate contributions, and track your progress toward each one.',
		url: 'https://www.etsy.com/listing/4483664616/sinking-funds-tracker-google-sheets',
		image: '/images/featured budget thumbnail-savings goals tracker-right-positioned.png',
	},
];
---

<BaseLayout title={`Articles — ${SITE_TITLE}`} description="Straightforward writing about budgeting, spreadsheets, and managing your money without the stress.">
	<main class="articles-page">
		<Breadcrumbs crumbs={[{ label: 'Articles' }]} />
		<div class="articles-header">
			<h1>Articles</h1>
			<button class="filter-toggle" id="filter-toggle" aria-label="Filter and sort articles">
				<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="6" x2="20" y2="6"/><line x1="6" y1="12" x2="18" y2="12"/><line x1="9" y1="18" x2="15" y2="18"/></svg>
				Filter &amp; Sort
			</button>
		</div>

		<div class="articles-layout">
			<div class="articles-main">
				<div class="article-list" id="article-list">
					{articles.map((article) => (
						<a href={`/articles/${article.id}/`} class="article-list-item" data-tags={JSON.stringify(article.data.tags ?? [])} data-date={article.data.pubDate.valueOf().toString()} data-title={article.data.title} data-desc={article.data.description}>
							<div class="article-list-text">
								<div class="article-list-meta">
									{(article.data.tags ?? []).map((slug: string) => (
										<span class="article-list-tag">{TAG_MAP[slug] ?? slug}</span>
									))}
								</div>
								<h2 class="article-list-title">{article.data.title}</h2>
								<p class="article-list-desc">{article.data.description}</p>
								<span class="article-list-read">{article.readTime} min read</span>
							</div>
							{(article.data.cardImage || article.data.image) && (
								<div class="article-list-thumb">
									<img src={article.data.cardImage ?? article.data.image} alt={article.data.title} width="960" height="540" loading="lazy" />
								</div>
							)}
						</a>
					))}
				</div>

				<p class="no-results" hidden>No articles match this filter.</p>
			</div>

			<aside class="articles-sidebar">
				<div class="sidebar-search">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
					<input type="search" id="sidebar-search-input" class="search-input" placeholder="Search articles" aria-label="Search articles" />
				</div>
				<details class="sidebar-section" open>
					<summary class="sidebar-label">
						Topic
						<svg class="sidebar-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9" /></svg>
					</summary>
					<div class="sidebar-tag-filters" role="group" aria-label="Filter articles by topic">
						<button class="sidebar-pill active" data-tag="all">All</button>
						{visibleTags.map((tag) => (
							<button class="sidebar-pill" data-tag={tag.slug}>{tag.label}</button>
						))}
					</div>
				</details>
				<details class="sidebar-section">
					<summary class="sidebar-label">
						Sort by
						<svg class="sidebar-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9" /></svg>
					</summary>
					<div class="sidebar-sort-options" role="group" aria-label="Sort articles">
						<button class="sidebar-pill active" data-sort="newest">Newest first</button>
						<button class="sidebar-pill" data-sort="oldest">Oldest first</button>
						<button class="sidebar-pill" data-sort="title">Title A–Z</button>
					</div>
				</details>
				<button class="sidebar-reset" id="sidebar-reset">Reset all</button>
			</aside>
		</div>

		<section class="resources">
			<h2 class="resources-heading">More resources</h2>
			<div class="resources-grid">
				{templates.map((t) => (
					<a href={t.url} class="resource-card" target="_blank" rel="noopener noreferrer">
						<div class="resource-thumb">
							<img src={t.image} alt={`${t.name} preview`} width="600" height="400" loading="lazy" />
						</div>
						{t.badge && <span class="resource-badge">{t.badge}</span>}
						<h3 class="resource-name">{t.name}</h3>
						<p class="resource-desc">{t.desc}</p>
					</a>
				))}
			</div>
			<div class="resources-cta-wrap">
				<a href="https://simplysheetdesign.etsy.com" class="btn btn-primary" target="_blank" rel="noopener noreferrer">Explore all on Etsy <svg class="arrow external-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg></a>
			</div>
		</section>
	</main>

	<div class="filter-overlay" id="filter-overlay">
		<div class="filter-panel">
			<div class="filter-panel-header">
				<h2 class="filter-panel-title">Filter &amp; Sort</h2>
				<button class="filter-close" id="filter-close" aria-label="Close filters">
					<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
						<line x1="6" y1="6" x2="18" y2="18" />
						<line x1="6" y1="18" x2="18" y2="6" />
					</svg>
				</button>
			</div>

			<div class="sidebar-search">
				<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
				<input type="search" id="drawer-search-input" class="search-input" placeholder="Search articles" aria-label="Search articles" />
			</div>

			<div class="filter-section">
				<h3 class="filter-label">Topic</h3>
				<div class="tag-filters" role="group" aria-label="Filter articles by topic">
					<button class="tag-pill active" data-tag="all">All</button>
					{visibleTags.map((tag) => (
						<button class="tag-pill" data-tag={tag.slug}>{tag.label}</button>
					))}
				</div>
			</div>

			<div class="filter-section">
				<h3 class="filter-label">Sort by</h3>
				<div class="sort-options" role="group" aria-label="Sort articles">
					<button class="tag-pill active" data-sort="newest">Newest first</button>
					<button class="tag-pill" data-sort="oldest">Oldest first</button>
					<button class="tag-pill" data-sort="title">Title A–Z</button>
				</div>
			</div>

			<div class="filter-actions">
				<button class="filter-reset" id="filter-reset">Reset all</button>
			</div>
		</div>
	</div>
</BaseLayout>

<style>
	.articles-page {
		max-width: var(--max-width);
		padding: var(--space-xl) var(--space-md) var(--space-2xl);
	}

	.articles-header {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: var(--space-md);
		margin-bottom: var(--space-lg);
	}

	h1 {
		margin-bottom: 0;
	}

	/* ——— Layout grid ——— */

	.articles-layout {
		display: grid;
		grid-template-columns: 2fr 1fr;
		gap: var(--space-xl);
		align-items: start;
	}
	.articles-main {
		min-width: 0;
	}

	/* ——— Sidebar filters ——— */

	.articles-sidebar {
		position: sticky;
		top: 96px;
	}
	.sidebar-search {
		display: flex;
		align-items: center;
		gap: var(--space-xs);
		border: 1px solid var(--color-divider);
		border-radius: var(--radius-sm);
		padding: 0.5rem 0.875rem;
		margin-bottom: var(--space-lg);
		color: var(--color-text-muted);
		transition: border-color 0.15s;
	}
	.sidebar-search:focus-within {
		border-color: var(--color-text-muted);
	}
	.sidebar-search svg {
		flex-shrink: 0;
	}
	.search-input {
		flex: 1;
		min-width: 0;
		font-family: var(--font-sans);
		font-size: var(--text-small);
		color: var(--color-text);
		background: none;
		border: none;
		outline: none;
	}
	.search-input::placeholder {
		color: var(--color-text-muted);
	}
	.sidebar-section {
		margin-bottom: var(--space-lg);
		border-bottom: 1px solid var(--color-border);
		padding-bottom: var(--space-sm);
	}
	.sidebar-label {
		display: flex;
		align-items: center;
		justify-content: space-between;
		font-size: var(--text-xs);
		font-weight: var(--weight-semibold);
		color: var(--color-text-muted);
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
		margin: 0 0 var(--space-sm) 0;
		cursor: pointer;
		list-style: none;
		transition: color 0.15s;
	}
	.sidebar-label::-webkit-details-marker {
		display: none;
	}
	.sidebar-label:hover {
		color: var(--color-text);
	}
	.sidebar-chevron {
		flex-shrink: 0;
		transition: transform 0.2s ease;
	}
	.sidebar-section[open] .sidebar-label .sidebar-chevron {
		transform: rotate(180deg);
	}
	.sidebar-section[open] .sidebar-label {
		margin-bottom: var(--space-sm);
	}
	.sidebar-tag-filters,
	.sidebar-sort-options {
		display: flex;
		flex-direction: column;
		gap: 0.125rem;
		margin-top: var(--space-sm);
	}
	.sidebar-pill {
		display: flex;
		align-items: center;
		font-family: var(--font-sans);
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		color: var(--color-text-secondary);
		background: none;
		border: none;
		border-radius: var(--radius-sm);
		padding: var(--space-xs) var(--space-sm);
		cursor: pointer;
		text-align: left;
		transition: color 0.15s, background 0.15s;
	}
	.sidebar-pill:hover {
		color: var(--color-text);
		background: var(--color-bg-panel);
	}
	.sidebar-pill.active {
		color: var(--color-text);
		font-weight: var(--weight-semibold);
		background: var(--color-bg-panel);
	}
	.sidebar-reset {
		font-family: var(--font-sans);
		font-size: var(--text-xs);
		font-weight: var(--weight-medium);
		color: var(--color-link);
		background: none;
		border: none;
		cursor: pointer;
		padding: 0;
		transition: color 0.15s;
	}
	.sidebar-reset:hover {
		color: var(--color-link-hover);
	}

	/* ——— Filter toggle (mobile only) ——— */

	.filter-toggle {
		display: none;
		align-items: center;
		gap: 0.375rem;
		font-family: var(--font-sans);
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		color: var(--color-text-secondary);
		background: none;
		border: 1px solid var(--color-divider);
		border-radius: var(--radius-sm);
		padding: 0.5rem 1rem;
		cursor: pointer;
		transition: color 0.15s, border-color 0.15s, background 0.15s;
	}
	.filter-toggle:hover {
		color: var(--color-text);
		border-color: var(--color-text-muted);
		background: var(--color-bg-panel);
	}

	/* ——— Filter drawer overlay ——— */

	.filter-overlay {
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.4);
		z-index: 100;
		opacity: 0;
		visibility: hidden;
		transition: opacity 0.25s ease, visibility 0.25s ease;
	}
	.filter-overlay.open {
		opacity: 1;
		visibility: visible;
	}

	.filter-panel {
		position: absolute;
		top: 0;
		right: 0;
		bottom: 0;
		width: min(22rem, 85vw);
		background: var(--color-bg);
		transform: translateX(100%);
		transition: transform 0.3s ease;
		padding: var(--space-md) var(--space-md) var(--space-lg);
		display: flex;
		flex-direction: column;
		gap: var(--space-lg);
		overflow-y: auto;
	}
	.filter-overlay.open .filter-panel {
		transform: translateX(0);
	}

	.filter-panel-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.filter-panel-title {
		font-size: var(--text-h3);
		margin: 0;
	}
	.filter-close {
		display: flex;
		align-items: center;
		justify-content: center;
		background: none;
		border: none;
		cursor: pointer;
		color: var(--color-text);
		padding: var(--space-xs);
		margin-right: calc(-1 * var(--space-xs));
	}

	.filter-section {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
	}
	.filter-label {
		font-size: var(--text-small);
		color: var(--color-text);
		margin: 0;
	}

	/* ——— Tag filter pills ——— */

	.tag-filters,
	.sort-options {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-xs);
	}
	.tag-pill {
		font-family: var(--font-sans);
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		color: var(--color-text-secondary);
		background: var(--color-bg-surface);
		border: 1px solid var(--color-divider);
		border-radius: var(--radius-sm);
		padding: 0.4375rem 0.875rem;
		cursor: pointer;
		transition: color 0.15s, border-color 0.15s, background 0.15s;
	}
	.tag-pill:hover {
		color: var(--color-text);
		border-color: var(--color-text-muted);
	}
	.tag-pill.active {
		color: var(--color-bg);
		background: var(--color-bg-inverse);
		border-color: var(--color-bg-inverse);
	}

	/* ——— Filter actions ——— */

	.filter-actions {
		margin-top: auto;
		padding-top: var(--space-md);
		border-top: 1px solid var(--color-border);
	}
	.filter-reset {
		font-family: var(--font-sans);
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		color: var(--color-link);
		background: none;
		border: none;
		cursor: pointer;
		padding: 0;
		transition: color 0.15s;
	}
	.filter-reset:hover {
		color: var(--color-link-hover);
	}

	/* ——— Article list — single column ——— */

	.article-list {
		display: flex;
		flex-direction: column;
	}
	.article-list-item {
		display: flex;
		gap: var(--space-lg);
		align-items: flex-start;
		padding: var(--space-lg) 0;
		border-bottom: 1px solid var(--color-border);
		text-decoration: none;
		color: inherit;
		transition: opacity 0.15s ease;
	}
	.article-list-item:first-child {
		padding-top: 0;
	}
	.article-list-item:last-child {
		border-bottom: none;
	}
	.article-list-item:hover {
		opacity: 0.75;
	}
	.article-list-item[hidden] {
		display: none;
	}
	.article-list-text {
		flex: 1;
		min-width: 0;
	}
	.article-list-meta {
		display: flex;
		align-items: center;
		gap: var(--space-xs);
		margin-bottom: var(--space-xs);
	}
	.article-list-tag {
		font-size: var(--text-xs);
		font-weight: var(--weight-semibold);
		color: var(--color-link);
	}
	.article-list-title {
		font-family: var(--font-heading);
		font-size: 1.25rem;
		font-weight: var(--weight-bold);
		line-height: 1.3;
		margin: 0 0 var(--space-xs) 0;
		color: var(--color-text);
	}
	.article-list-desc {
		font-size: var(--text-body);
		color: var(--color-text-secondary);
		line-height: 1.5;
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.article-list-read {
		display: inline-block;
		margin-top: var(--space-xs);
		font-size: var(--text-xs);
		color: var(--color-text-muted);
	}
	.article-list-thumb {
		flex-shrink: 0;
		width: 160px;
		height: 107px;
		border-radius: var(--radius-md);
		overflow: hidden;
	}
	.article-list-thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	/* ——— Empty state ——— */

	.no-results {
		font-size: var(--text-small);
		color: var(--color-text-muted);
		padding: var(--space-lg) 0;
	}

	/* ——— Resources section ——— */

	.resources {
		margin-top: var(--space-2xl);
		padding-top: var(--space-xl);
		border-top: 1px solid var(--color-border);
	}
	.resources-heading {
		font-size: var(--text-h2);
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--space-lg);
	}
	.resources-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: var(--space-md);
		margin-bottom: var(--space-lg);
	}
	.resource-card {
		display: flex;
		flex-direction: column;
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		text-decoration: none;
		overflow: hidden;
		transition: border-color 0.15s, background 0.15s;
	}
	.resource-card:hover {
		border-color: var(--color-text-muted);
		background: var(--color-bg-panel);
	}
	.resource-thumb {
		aspect-ratio: 3 / 2;
		background: var(--color-bg-panel);
		overflow: hidden;
	}
	.resource-thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
	.resource-badge {
		display: inline-block;
		align-self: flex-start;
		font-size: var(--text-xs);
		font-weight: var(--weight-semibold);
		color: var(--color-link);
		background: var(--color-surface-tint);
		border-radius: var(--radius-sm);
		padding: 0.125rem 0.5rem;
		line-height: 1.4;
		white-space: nowrap;
		margin: var(--space-md) var(--space-md) 0;
	}
	.resource-name {
		font-size: var(--text-body);
		color: var(--color-text);
		margin-bottom: var(--space-xs);
		padding: var(--space-xs) var(--space-md) 0;
	}
	.resource-card:not(:has(.resource-badge)) .resource-name {
		padding-top: var(--space-md);
	}
	.resource-desc {
		font-size: var(--text-small);
		color: var(--color-text-secondary);
		line-height: var(--leading-snug);
		margin: 0;
		padding: 0 var(--space-md) var(--space-md);
	}
	.resources-cta-wrap {
		text-align: center;
	}

	@media (max-width: 960px) {
		.resources-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 768px) {
		.articles-layout {
			grid-template-columns: 1fr;
		}
		.articles-sidebar {
			display: none;
		}
		.filter-toggle {
			display: inline-flex;
		}
	}

	@media (max-width: 600px) {
		.article-list-item {
			flex-direction: column;
			gap: var(--space-md);
		}
		.article-list-thumb {
			width: 100%;
			height: auto;
			aspect-ratio: 16 / 9;
			order: -1;
		}
		.article-list-title {
			font-size: 1.05rem;
		}
		.resources-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

<script>
	const toggleBtn = document.getElementById('filter-toggle');
	const overlay = document.getElementById('filter-overlay');
	const closeBtn = document.getElementById('filter-close');
	const resetBtn = document.getElementById('filter-reset');
	const sidebarResetBtn = document.getElementById('sidebar-reset');

	const drawerTagPills = document.querySelectorAll<HTMLButtonElement>('.tag-filters .tag-pill');
	const drawerSortPills = document.querySelectorAll<HTMLButtonElement>('.sort-options .tag-pill');
	const sidebarTagPills = document.querySelectorAll<HTMLButtonElement>('.sidebar-tag-filters .sidebar-pill');
	const sidebarSortPills = document.querySelectorAll<HTMLButtonElement>('.sidebar-sort-options .sidebar-pill');
	const searchInputs = document.querySelectorAll<HTMLInputElement>('.search-input');

	const list = document.getElementById('article-list');
	const items = Array.from(document.querySelectorAll<HTMLAnchorElement>('#article-list .article-list-item'));
	const noResults = document.querySelector<HTMLParagraphElement>('.no-results');

	let activeTag = 'all';
	let activeSort = 'newest';
	let searchQuery = '';

	function syncAllPills() {
		drawerTagPills.forEach((p) => p.classList.toggle('active', p.dataset.tag === activeTag));
		drawerSortPills.forEach((p) => p.classList.toggle('active', p.dataset.sort === activeSort));
		sidebarTagPills.forEach((p) => p.classList.toggle('active', p.dataset.tag === activeTag));
		sidebarSortPills.forEach((p) => p.classList.toggle('active', p.dataset.sort === activeSort));
	}

	function openDrawer() {
		overlay?.classList.add('open');
		document.body.style.overflow = 'hidden';
	}

	function closeDrawer() {
		overlay?.classList.remove('open');
		document.body.style.overflow = '';
	}

	toggleBtn?.addEventListener('click', openDrawer);
	closeBtn?.addEventListener('click', closeDrawer);

	overlay?.addEventListener('click', (e) => {
		if (e.target === overlay) closeDrawer();
	});

	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape') closeDrawer();
	});

	function setTag(tag: string) {
		activeTag = tag;
		syncAllPills();
		applyFilterAndSort();
	}

	function setSort(sort: string) {
		activeSort = sort;
		syncAllPills();
		applyFilterAndSort();
	}

	function setSearch(query: string) {
		searchQuery = query.trim().toLowerCase();
		searchInputs.forEach((input) => {
			if (input.value !== query) input.value = query;
		});
		applyFilterAndSort();
	}

	function resetAll() {
		activeTag = 'all';
		activeSort = 'newest';
		searchQuery = '';
		searchInputs.forEach((input) => { input.value = ''; });
		syncAllPills();
		applyFilterAndSort();
	}

	drawerTagPills.forEach((p) => p.addEventListener('click', () => setTag(p.dataset.tag!)));
	drawerSortPills.forEach((p) => p.addEventListener('click', () => setSort(p.dataset.sort!)));
	sidebarTagPills.forEach((p) => p.addEventListener('click', () => setTag(p.dataset.tag!)));
	sidebarSortPills.forEach((p) => p.addEventListener('click', () => setSort(p.dataset.sort!)));
	searchInputs.forEach((input) => input.addEventListener('input', () => setSearch(input.value)));

	resetBtn?.addEventListener('click', resetAll);
	sidebarResetBtn?.addEventListener('click', resetAll);

	function applyFilterAndSort() {
		let visible = 0;

		items.forEach((li) => {
			const tags: string[] = JSON.parse(li.dataset.tags || '[]');
			const matchesTag = activeTag === 'all' || tags.includes(activeTag);
			const matchesSearch = !searchQuery
				|| (li.dataset.title || '').toLowerCase().includes(searchQuery)
				|| (li.dataset.desc || '').toLowerCase().includes(searchQuery);
			const show = matchesTag && matchesSearch;
			li.hidden = !show;
			if (show) visible++;
		});

		const visibleItems = items.filter((li) => !li.hidden);
		visibleItems.sort((a, b) => {
			if (activeSort === 'newest') {
				return Number(b.dataset.date || 0) - Number(a.dataset.date || 0);
			} else if (activeSort === 'oldest') {
				return Number(a.dataset.date || 0) - Number(b.dataset.date || 0);
			} else {
				return (a.dataset.title || '').localeCompare(b.dataset.title || '');
			}
		});

		visibleItems.forEach((li) => list?.appendChild(li));
		items.filter((li) => li.hidden).forEach((li) => list?.appendChild(li));

		if (noResults) noResults.hidden = visible > 0;
	}
</script>
