---
import BaseLayout from '../layouts/BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE } from '../consts';

const colors = [
	{ token: '--color-text',           label: 'Text',           hex: '#1A1A2E' },
	{ token: '--color-text-secondary', label: 'Text Secondary', hex: '#555566' },
	{ token: '--color-text-muted',     label: 'Text Muted',     hex: '#8B8B9A' },
	{ token: '--color-accent',         label: 'Accent',         hex: '#00856F' },
	{ token: '--color-accent-hover',   label: 'Accent Hover',   hex: '#006B59' },
	{ token: '--color-bg',             label: 'Background',     hex: '#FFFFFF' },
	{ token: '--color-bg-panel',       label: 'Panel',          hex: '#F5F5F7' },
	{ token: '--color-bg-emphasis',    label: 'Emphasis',       hex: '#EAEAED' },
	{ token: '--color-bg-inverse',     label: 'Inverse',        hex: '#1A1A2E' },
	{ token: '--color-border',         label: 'Border',         hex: '#E0E0E5' },
	{ token: '--color-divider',        label: 'Divider',        hex: '#D0D0D8' },
];

const typeScale = [
	{ token: '--text-display', label: 'Display',  sample: 'Practical budgeting help' },
	{ token: '--text-h1',      label: 'H1',       sample: 'Page heading' },
	{ token: '--text-h2',      label: 'H2',       sample: 'Section heading' },
	{ token: '--text-h3',      label: 'H3',       sample: 'Subsection heading' },
	{ token: '--text-body-lg', label: 'Body Lg',  sample: 'Introductory paragraph text at a comfortable reading size.' },
	{ token: '--text-body',    label: 'Body',     sample: 'Standard paragraph text for articles and general content.' },
	{ token: '--text-small',   label: 'Small',    sample: 'Captions, labels, metadata' },
	{ token: '--text-stat',    label: 'Stat',     sample: '$2,400' },
];

const spacingScale = [
	{ token: '--space-2xs', label: '2xs', px: '4' },
	{ token: '--space-xs',  label: 'xs',  px: '8' },
	{ token: '--space-sm',  label: 'sm',  px: '16' },
	{ token: '--space-md',  label: 'md',  px: '24' },
	{ token: '--space-lg',  label: 'lg',  px: '40' },
	{ token: '--space-xl',  label: 'xl',  px: '64' },
	{ token: '--space-2xl', label: '2xl', px: '96' },
];
---

<BaseLayout title={`Style Guide — ${SITE_TITLE}`} description="Living reference for SimplySheetDesign components, tokens, and patterns.">
	<div class="guide">

		<header class="guide-header">
			<h1>Style Guide</h1>
			<p class="guide-intro">Living reference for every component, token, and pattern in the design system. Add new items here as they're built.</p>
		</header>

		<!-- ============ COLORS ============ -->
		<section class="guide-section">
			<h2 class="section-title">Colors</h2>
			<div class="color-grid">
				{colors.map((c) => (
					<div class="color-card">
						<div class="color-swatch" style={`background-color: var(${c.token})`} />
						<div class="color-info">
							<span class="color-label">{c.label}</span>
							<code class="color-token">{c.token}</code>
							<span class="color-hex">{c.hex}</span>
						</div>
					</div>
				))}
			</div>
		</section>

		<!-- ============ TYPE SCALE ============ -->
		<section class="guide-section">
			<h2 class="section-title">Type Scale</h2>
			<div class="type-list">
				{typeScale.map((t) => (
					<div class="type-row">
						<div class="type-meta">
							<span class="type-label">{t.label}</span>
							<code class="type-token">{t.token}</code>
						</div>
						<div class="type-sample" style={`font-size: var(${t.token})`}>
							{t.sample}
						</div>
					</div>
				))}
			</div>
		</section>

		<!-- ============ FONT WEIGHTS ============ -->
		<section class="guide-section">
			<h2 class="section-title">Font Weights</h2>
			<div class="weight-list">
				<p style="font-weight: var(--weight-normal)">400 Normal — The quick brown fox jumps over the lazy dog</p>
				<p style="font-weight: var(--weight-medium)">500 Medium — The quick brown fox jumps over the lazy dog</p>
				<p style="font-weight: var(--weight-semibold)">600 Semibold — The quick brown fox jumps over the lazy dog</p>
				<p style="font-weight: var(--weight-bold)">700 Bold — The quick brown fox jumps over the lazy dog</p>
			</div>
		</section>

		<!-- ============ SPACING ============ -->
		<section class="guide-section">
			<h2 class="section-title">Spacing Scale</h2>
			<div class="spacing-list">
				{spacingScale.map((s) => (
					<div class="spacing-row">
						<code class="spacing-token">{s.token}</code>
						<span class="spacing-px">{s.px}px</span>
						<div class="spacing-bar" style={`width: var(${s.token})`} />
					</div>
				))}
			</div>
		</section>

		<!-- ============ HEADLINE TREATMENTS ============ -->
		<section class="guide-section">
			<h2 class="section-title">Headline Treatments</h2>
			<p class="section-desc">Hero headlines use the display size. Section headings use H2. Accent color highlights key phrases sparingly.</p>

			<div class="headline-demo">
				<h1 class="demo-display">Practical budgeting help for people who use <span class="accent">Google Sheets and Excel</span></h1>
			</div>

			<div class="headline-demo">
				<h2 class="demo-h2">How do you budget when your <span class="accent">income changes every month</span></h2>
			</div>
		</section>

		<!-- ============ ARTICLE CARD ============ -->
		<section class="guide-section">
			<h2 class="section-title">Article Card</h2>
			<p class="section-desc">Used on the homepage grid and /articles listing. Cards have a subtle border and hover state.</p>

			<ul class="article-list">
				<li>
					<a href="#" class="article-card">
						<h3 class="article-title">How to budget when your income changes every month</h3>
						<p class="article-desc">A straightforward approach to budgeting on irregular income — freelancers, gig workers, commission earners.</p>
						<p class="article-date"><FormattedDate date={new Date('2026-06-23')} /></p>
					</a>
				</li>
				<li>
					<a href="#" class="article-card">
						<h3 class="article-title">The 15-minute weekly budget check-in</h3>
						<p class="article-desc">You don't need to track every coffee. Once a week, sit down for 15 minutes, enter your totals, and move on.</p>
						<p class="article-date"><FormattedDate date={new Date('2026-06-16')} /></p>
					</a>
				</li>
			</ul>
		</section>

		<!-- ============ RELATED ARTICLES ============ -->
		<section class="guide-section">
			<h2 class="section-title">Related Articles</h2>
			<p class="section-desc">Shown at the bottom of each article for internal linking. Pulls the 2-3 most recent articles excluding the current one.</p>

			<aside class="related-demo">
				<h2 class="related-heading">Related articles</h2>
				<ul class="related-list">
					<li><a href="#">How to budget when your income changes every month</a></li>
					<li><a href="#">Budgeting as a couple without losing your mind</a></li>
					<li><a href="#">What to do when you're afraid to look at your bank account</a></li>
				</ul>
			</aside>
		</section>

		<!-- ============ TEMPLATES SECTION ============ -->
		<section class="guide-section">
			<h2 class="section-title">Templates Section</h2>
			<p class="section-desc">Product links near the bottom of the homepage. Four named templates, no prices, with a button to explore all on Etsy.</p>
		</section>

		<div class="templates-demo">
			<h2 class="templates-heading">Explore templates to help you budget</h2>
			<ul class="templates-list">
				<li><a href="#">Budget Spreadsheet</a></li>
				<li><a href="#">Couples Budget Spreadsheet</a></li>
				<li><a href="#">Debt Payoff Tracker</a></li>
				<li><a href="#">Savings Goals Tracker</a></li>
			</ul>
			<a href="#" class="templates-cta">Explore all on Etsy</a>
		</div>

		<!-- ============ SECTION PANELS ============ -->
		<section class="guide-section">
			<h2 class="section-title">Section Panels</h2>
			<p class="section-desc">Sections transition using soft background color panels instead of hard borders.</p>
		</section>

		<div class="panel-demo-default">
			<p class="panel-label">Default background <code>--color-bg</code></p>
			<p class="panel-body">Content on the standard page background.</p>
		</div>
		<div class="panel-demo-panel">
			<p class="panel-label">Panel background <code>--color-bg-panel</code></p>
			<p class="panel-body">Content on the panel background. A subtle shift that creates rhythm.</p>
		</div>
		<div class="panel-demo-emphasis">
			<p class="panel-label">Emphasis background <code>--color-bg-emphasis</code></p>
			<p class="panel-body">Content on the emphasis background. Stronger contrast for callouts.</p>
		</div>
		<div class="panel-demo-inverse">
			<p class="panel-label">Inverse background <code>--color-bg-inverse</code></p>
			<p class="panel-body">Light text on the dark inverse background. Used for the footer.</p>
		</div>

		<!-- ============ BUTTONS ============ -->
		<section class="guide-section">
			<h2 class="section-title">Buttons</h2>
			<div class="button-row">
				<button class="btn btn-primary">Primary button</button>
				<button class="btn btn-secondary">Secondary button</button>
				<button class="btn btn-ghost">Ghost button</button>
			</div>
			<div class="button-row" style="margin-top: var(--space-sm)">
				<button class="btn btn-primary btn-sm">Small primary</button>
				<button class="btn btn-secondary btn-sm">Small secondary</button>
				<button class="btn btn-ghost btn-sm">Small ghost</button>
			</div>
		</section>

		<!-- ============ PROSE ============ -->
		<section class="guide-section">
			<h2 class="section-title">Prose / Article Body</h2>
			<p class="section-desc">How long-form article content renders. Applied via the <code>.prose</code> class. Articles use semantic H2s that mirror how people phrase questions to Google.</p>

			<div class="prose">
				<h2>How do you budget when your income changes every month</h2>
				<p>Start with your baseline — the lowest amount you've earned in the past six months. Build your budget around that number, not your average and definitely not your best month.</p>
				<h3>List your non-negotiable expenses first</h3>
				<p>Rent, utilities, groceries, insurance, minimum debt payments. These get funded before anything else. Write them down with <strong>real numbers</strong> from last month, not estimates.</p>
				<blockquote>The point isn't to predict your income. It's to stop pretending it's predictable and plan around that reality instead.</blockquote>
				<ul>
					<li>An unordered list item</li>
					<li>Another list item with enough text to wrap onto a second line so you can check the spacing</li>
					<li>A third item</li>
				</ul>
				<p>A paragraph with <code>inline code</code> and an <a href="#">inline link</a> styled naturally within the reading flow.</p>
			</div>
		</section>

		<!-- ============ SCHEMA.ORG ============ -->
		<section class="guide-section">
			<h2 class="section-title">Schema.org Structured Data</h2>
			<p class="section-desc">Each article page includes JSON-LD <code>Article</code> structured data with headline, description, dates, author (Ryan Sheridan), and publisher (SimplySheetDesign). This helps Google and AI assistants understand and surface content.</p>
		</section>

		<!-- ============ CONTENT STRATEGY ============ -->
		<section class="guide-section">
			<h2 class="section-title">Content Strategy Notes</h2>
			<p class="section-desc">Articles are structured for SEO and AEO (Answer Engine Optimization). Each article frontmatter supports an optional <code>relatedProduct</code> field with <code>name</code> and <code>url</code> for structured product mentions.</p>
			<div class="strategy-list">
				<p><strong>H2s as questions:</strong> mirror how people phrase searches ("How do I budget with irregular income")</p>
				<p><strong>Direct answer first:</strong> answer the question plainly near the top, then go deep</p>
				<p><strong>One product mention max:</strong> mid-article, advice-first voice, no pitch language</p>
				<p><strong>Related articles:</strong> 2-3 links at the bottom for internal linking and session depth</p>
			</div>
		</section>

		<!-- ============ RADII ============ -->
		<section class="guide-section">
			<h2 class="section-title">Border Radii</h2>
			<div class="radii-row">
				<div class="radius-demo" style="border-radius: var(--radius-sm)">
					<code>--radius-sm</code>
					<span>6px</span>
				</div>
				<div class="radius-demo" style="border-radius: var(--radius-md)">
					<code>--radius-md</code>
					<span>12px</span>
				</div>
			</div>
		</section>

		<!-- ============ HEADER & FOOTER ============ -->
		<section class="guide-section">
			<h2 class="section-title">Header / Navigation</h2>
			<p class="section-desc">Minimal header: site name linking home, and "Articles" link. No other navigation items.</p>
		</section>

		<section class="guide-section">
			<h2 class="section-title">Footer</h2>
			<p class="section-desc">Dark navy inverse background with muted copyright text. Visible at the bottom of this page.</p>
		</section>

	</div>
</BaseLayout>

<style>
	/* ——— Guide layout ——— */

	.guide {
		max-width: var(--max-width);
		margin: 0 auto;
	}

	.guide-header {
		padding: var(--space-xl) var(--space-md) var(--space-lg);
	}

	.guide-header h1 {
		font-size: var(--text-h1);
		font-weight: var(--weight-bold);
		margin-bottom: var(--space-xs);
	}

	.guide-intro {
		font-size: var(--text-body-lg);
		color: var(--color-text-secondary);
		max-width: 50ch;
	}

	.guide-section {
		padding: var(--space-xl) var(--space-md) var(--space-md);
	}

	.section-title {
		font-size: var(--text-h2);
		font-weight: var(--weight-semibold);
		margin-bottom: var(--space-2xs);
	}

	.section-desc {
		color: var(--color-text-secondary);
		margin-bottom: var(--space-md);
		max-width: 60ch;
	}

	.section-desc code {
		padding: 2px 6px;
		background: var(--color-bg-panel);
		border-radius: var(--radius-sm);
		font-size: 0.9em;
	}

	/* ——— Colors ——— */

	.color-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(9rem, 1fr));
		gap: var(--space-sm);
	}

	.color-card {
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		overflow: hidden;
	}

	.color-swatch {
		height: 4.5rem;
	}

	.color-info {
		padding: var(--space-xs);
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.color-label {
		font-size: var(--text-small);
		font-weight: var(--weight-semibold);
	}

	.color-token {
		font-size: 0.7rem;
		color: var(--color-text-muted);
		background: none;
		padding: 0;
	}

	.color-hex {
		font-size: 0.75rem;
		color: var(--color-text-muted);
		font-family: monospace;
	}

	/* ——— Type scale ——— */

	.type-list {
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
	}

	.type-row {
		border-bottom: 1px solid var(--color-border);
		padding-bottom: var(--space-md);
	}

	.type-row:last-child {
		border-bottom: none;
	}

	.type-meta {
		display: flex;
		align-items: baseline;
		gap: var(--space-sm);
		margin-bottom: var(--space-xs);
	}

	.type-label {
		font-size: var(--text-small);
		font-weight: var(--weight-semibold);
		color: var(--color-text-secondary);
		min-width: 5rem;
	}

	.type-token {
		font-size: 0.75rem;
		color: var(--color-text-muted);
		background: none;
		padding: 0;
	}

	.type-sample {
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-tight);
		font-weight: var(--weight-semibold);
		color: var(--color-text);
	}

	/* ——— Font weights ——— */

	.weight-list {
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
	}

	.weight-list p {
		font-size: var(--text-body-lg);
		margin-bottom: 0;
	}

	/* ——— Spacing ——— */

	.spacing-list {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
	}

	.spacing-row {
		display: flex;
		align-items: center;
		gap: var(--space-sm);
	}

	.spacing-token {
		font-size: 0.75rem;
		color: var(--color-text-muted);
		min-width: 8rem;
		text-align: right;
		background: none;
		padding: 0;
	}

	.spacing-px {
		font-size: var(--text-small);
		color: var(--color-text-secondary);
		min-width: 3rem;
	}

	.spacing-bar {
		height: 0.75rem;
		background: var(--color-accent);
		border-radius: var(--radius-sm);
		opacity: 0.7;
	}

	/* ——— Headline treatments ——— */

	.headline-demo {
		padding: var(--space-lg) 0;
		border-bottom: 1px solid var(--color-border);
	}

	.headline-demo:last-child {
		border-bottom: none;
	}

	.demo-display {
		font-size: var(--text-display);
		font-weight: var(--weight-bold);
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
	}

	.demo-h2 {
		font-size: var(--text-h2);
		font-weight: var(--weight-semibold);
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
	}

	.accent {
		color: var(--color-accent);
	}

	/* ——— Article cards ——— */

	.article-list {
		list-style: none;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr));
		gap: var(--space-sm);
		max-width: var(--max-width);
	}

	.article-card {
		display: block;
		padding: var(--space-md);
		border-radius: var(--radius-md);
		text-decoration: none;
		border: 1px solid var(--color-border);
		transition: background 0.15s, border-color 0.15s;
	}

	.article-card:hover {
		background: var(--color-bg-panel);
		border-color: var(--color-divider);
	}

	.article-title {
		font-size: var(--text-h3);
		font-weight: var(--weight-semibold);
		color: var(--color-text);
		margin-bottom: var(--space-2xs);
	}

	.article-desc {
		font-size: var(--text-body);
		color: var(--color-text-secondary);
		margin-bottom: var(--space-xs);
	}

	.article-date {
		font-size: var(--text-small);
		color: var(--color-text-muted);
	}

	/* ——— Related articles ——— */

	.related-demo {
		padding: var(--space-lg) var(--space-md);
		border-top: 1px solid var(--color-border);
		max-width: var(--max-width-narrow);
	}

	.related-heading {
		font-size: var(--text-h3);
		font-weight: var(--weight-semibold);
		margin-bottom: var(--space-sm);
	}

	.related-list {
		list-style: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
	}

	.related-list a {
		font-size: var(--text-body);
		text-decoration: none;
	}

	.related-list a:hover {
		text-decoration: underline;
	}

	/* ——— Templates section ——— */

	.templates-demo {
		background: var(--color-bg-panel);
		padding: var(--space-xl) var(--space-md);
		text-align: center;
		margin-bottom: var(--space-sm);
	}

	.templates-heading {
		font-size: var(--text-h2);
		font-weight: var(--weight-semibold);
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--space-md);
	}

	.templates-list {
		list-style: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
		margin-bottom: var(--space-lg);
	}

	.templates-list a {
		font-size: var(--text-body-lg);
		font-weight: var(--weight-medium);
		text-decoration: none;
	}

	.templates-list a:hover {
		text-decoration: underline;
	}

	.templates-cta {
		display: inline-block;
		font-family: var(--font-sans);
		font-size: var(--text-body);
		font-weight: var(--weight-medium);
		color: white;
		background: var(--color-accent);
		padding: 0.75rem 1.5rem;
		border-radius: var(--radius-sm);
		text-decoration: none;
		transition: background 0.15s;
	}

	.templates-cta:hover {
		background: var(--color-accent-hover);
		color: white;
	}

	/* ——— Section panels ——— */

	.panel-demo-default,
	.panel-demo-panel,
	.panel-demo-emphasis,
	.panel-demo-inverse {
		padding: var(--space-lg) var(--space-md);
	}

	.panel-demo-default {
		background: var(--color-bg);
	}

	.panel-demo-panel {
		background: var(--color-bg-panel);
	}

	.panel-demo-emphasis {
		background: var(--color-bg-emphasis);
	}

	.panel-demo-inverse {
		background: var(--color-bg-inverse);
		color: var(--color-bg);
	}

	.panel-demo-inverse code {
		color: var(--color-bg);
		opacity: 0.6;
	}

	.panel-label {
		font-size: var(--text-small);
		font-weight: var(--weight-semibold);
		margin-bottom: var(--space-2xs);
	}

	.panel-label code {
		font-weight: var(--weight-normal);
		opacity: 0.6;
		font-size: 0.85em;
	}

	.panel-body {
		color: inherit;
		opacity: 0.75;
	}

	/* ——— Buttons ——— */

	.button-row {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-sm);
		align-items: center;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		font-family: var(--font-sans);
		font-size: var(--text-body);
		font-weight: var(--weight-medium);
		line-height: 1;
		padding: 0.75rem 1.5rem;
		border-radius: var(--radius-sm);
		border: 1px solid transparent;
		cursor: pointer;
		transition: background 0.15s, color 0.15s, border-color 0.15s;
