---
import BaseLayout from '../layouts/BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE } from '../consts';

const allArticles = (await getCollection('articles'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const masonryArticles = allArticles.slice(0, 6).map((a) => {
	const wordCount = a.body?.split(/\s+/).filter(Boolean).length ?? 0;
	const readTime = Math.max(1, Math.ceil(wordCount / 200));
	return { ...a, readTime };
});
const sampleArticles = allArticles.slice(0, 3).map((a) => {
	const wordCount = a.body?.split(/\s+/).filter(Boolean).length ?? 0;
	const readTime = Math.max(1, Math.ceil(wordCount / 200));
	return { ...a, readTime };
});

const templates = (await getCollection('templates'))
	.sort((a, b) => a.data.order - b.data.order)
	.slice(0, 2)
	.map((t) => ({
		name: t.data.title.replace(/ for Google Sheets & Excel$/, ''),
		desc: t.data.description,
		url: `/templates/${t.id}/`,
		image: t.data.heroImage,
		badge: t.data.badge,
	}));

const ARTICLE_COLORS: Record<string, { bg: string; accent: string; accent2?: string }> = {
	'50-30-20-budget-rule':           { bg: '#E3F2FD', accent: '#196EDD', accent2: '#90CAF9' },
	'awareness-vs-automation':        { bg: '#E0F2F1', accent: '#00897B', accent2: '#80CBC4' },
	'budgeting-styles':               { bg: '#F3E5F5', accent: '#7E57C2', accent2: '#CE93D8' },
	'couples-budgeting':              { bg: '#FCE4EC', accent: '#E91E63', accent2: '#F48FB1' },
	'where-is-my-money-going':        { bg: '#FFF3E0', accent: '#E86A33', accent2: '#FFCC80' },
	'budgeting-with-irregular-income': { bg: '#E8F5E9', accent: '#2D9D78', accent2: '#A5D6A7' },
	'debt-snowball-vs-avalanche':     { bg: '#E8EDF2', accent: '#2C3E50', accent2: '#90A4AE' },
	'how-to-pay-off-debt':            { bg: '#EDE7F6', accent: '#7E57C2', accent2: '#B39DDB' },
	'emergency-fund-sizing':          { bg: '#E8EAF6', accent: '#5C6BC0', accent2: '#9FA8DA' },
	'why-most-budgets-fail':          { bg: '#FFF8E1', accent: '#F9A825', accent2: '#FFE082' },
};

const TAG_MAP: Record<string, string> = {
	'expense-tracking': 'Expense Tracking',
	'couples-budgeting': 'Couples Budgeting',
	'debt-payoff': 'Debt Payoff',
	'savings-goals': 'Savings Goals',
	'irregular-income': 'Irregular Income',
	'net-worth': 'Net Worth',
	'budgeting-styles': 'Budgeting Styles',
};

const colors = [
	{ token: '--color-text',           label: 'Text',           hex: '#2A2522' },
	{ token: '--color-text-secondary', label: 'Text Secondary', hex: '#6B6B6B' },
	{ token: '--color-text-muted',     label: 'Text Muted',     hex: '#8C8C8C' },
	{ token: '--color-accent',         label: 'Accent',         hex: '#196EDD' },
	{ token: '--color-accent-hover',   label: 'Accent Hover',   hex: '#1259B8' },
	{ token: '--color-accent-light',   label: 'Accent Light',   hex: '#EEF4FF' },
	{ token: '--color-btn',            label: 'Button',         hex: '#000000' },
	{ token: '--color-btn-hover',      label: 'Button Hover',   hex: '#333333' },
	{ token: '--color-bg',             label: 'Background',     hex: '#F7F6F4' },
	{ token: '--color-bg-surface',     label: 'Surface',        hex: '#FFFFFF' },
	{ token: '--color-bg-panel',       label: 'Panel',          hex: '#F2F2F2' },
	{ token: '--color-bg-emphasis',    label: 'Emphasis',       hex: '#EDEAE7' },
	{ token: '--color-bg-inverse',     label: 'Inverse',        hex: '#2A2522' },
	{ token: '--color-border',         label: 'Border',         hex: '#E8E4E0' },
	{ token: '--color-divider',        label: 'Divider',        hex: '#D9D4CF' },
];

const typeScale = [
	{ token: '--text-display', label: 'Display',  sample: 'Practical budgeting help' },
	{ token: '--text-h1',      label: 'H1',       sample: 'Page heading' },
	{ token: '--text-h2',      label: 'H2',       sample: 'Section heading' },
	{ token: '--text-h3',      label: 'H3',       sample: 'Subsection heading' },
	{ token: '--text-body-lg', label: 'Body Lg',  sample: 'Introductory paragraph text at a comfortable reading size.' },
	{ token: '--text-body',    label: 'Body',     sample: 'Standard paragraph text for articles and general content.' },
	{ token: '--text-small',   label: 'Small',    sample: 'Captions, labels, metadata' },
	{ token: '--text-xs',      label: 'XS',       sample: 'Fine print, timestamps' },
];

const spacingScale = [
	{ token: '--space-2xs', label: '2xs', px: '4' },
	{ token: '--space-xs',  label: 'xs',  px: '8' },
	{ token: '--space-sm',  label: 'sm',  px: '16' },
	{ token: '--space-md',  label: 'md',  px: '24' },
	{ token: '--space-lg',  label: 'lg',  px: '40' },
	{ token: '--space-xl',  label: 'xl',  px: '64' },
	{ token: '--space-2xl', label: '2xl', px: '96' },
];
---

<BaseLayout title={`Style Guide — ${SITE_TITLE}`} description="Living reference for Simply Sheet Design components, tokens, and patterns.">
	<div class="guide">

		<header class="guide-header">
			<h1>Style Guide</h1>
			<p class="guide-intro">Living reference for every component, token, and pattern in the design system.</p>
		</header>

		<!-- ============ COLORS ============ -->
		<section class="guide-section">
			<h2 class="section-title">Colors</h2>
			<div class="color-grid">
				{colors.map((c) => (
					<div class="color-card">
						<div class="color-swatch" style={`background-color: var(${c.token})`} />
						<div class="color-info">
							<span class="color-label">{c.label}</span>
							<code class="color-token">{c.token}</code>
							<span class="color-hex">{c.hex}</span>
						</div>
					</div>
				))}
			</div>
		</section>

		<!-- ============ TYPE SCALE ============ -->
		<section class="guide-section">
			<h2 class="section-title">Type Scale</h2>
			<div class="type-list">
				{typeScale.map((t) => (
					<div class="type-row">
						<div class="type-meta">
							<span class="type-label">{t.label}</span>
							<code class="type-token">{t.token}</code>
						</div>
						<div class="type-sample" style={`font-size: var(${t.token})`}>
							{t.sample}
						</div>
					</div>
				))}
			</div>
		</section>

		<!-- ============ FONT WEIGHTS ============ -->
		<section class="guide-section">
			<h2 class="section-title">Font Weights</h2>
			<div class="weight-list">
				<p style="font-weight: var(--weight-normal)">400 Normal — The quick brown fox jumps over the lazy dog</p>
				<p style="font-weight: var(--weight-medium)">500 Medium — The quick brown fox jumps over the lazy dog</p>
				<p style="font-weight: var(--weight-semibold)">600 Semibold — The quick brown fox jumps over the lazy dog</p>
				<p style="font-weight: var(--weight-bold)">700 Bold — The quick brown fox jumps over the lazy dog</p>
			</div>
		</section>

		<!-- ============ SPACING ============ -->
		<section class="guide-section">
			<h2 class="section-title">Spacing Scale</h2>
			<div class="spacing-list">
				{spacingScale.map((s) => (
					<div class="spacing-row">
						<code class="spacing-token">{s.token}</code>
						<span class="spacing-px">{s.px}px</span>
						<div class="spacing-bar" style={`width: var(${s.token})`} />
					</div>
				))}
			</div>
		</section>

		<!-- ============ HEADLINE TREATMENTS ============ -->
		<section class="guide-section">
			<h2 class="section-title">Headline Treatments</h2>
			<p class="section-desc">Hero headlines use the display size. Section headings use H2.</p>

			<div class="headline-demo">
				<h1 class="demo-display">Practical budgeting help for people who use <span class="accent">Google Sheets and Excel</span></h1>
			</div>

			<div class="headline-demo">
				<h2 class="demo-h2">How do you budget when your <span class="accent">income changes every month</span></h2>
			</div>
		</section>

		<!-- ============ ARTICLE LIST ============ -->
		<section class="guide-section">
			<h2 class="section-title">Article List</h2>
			<p class="section-desc">Articles are displayed as a clean list with thin dividers between items.</p>

			<ul class="article-list">
				<li>
					<a href="#" class="article-card">
						<h3 class="article-title">How to budget when your income changes every month</h3>
						<p class="article-desc">A straightforward approach to budgeting on irregular income — freelancers, gig workers, commission earners.</p>
						<p class="article-date"><FormattedDate date={new Date('2026-06-23')} /></p>
					</a>
				</li>
				<li>
					<a href="#" class="article-card">
						<h3 class="article-title">The 15-minute weekly budget check-in</h3>
						<p class="article-desc">You don't need to track every coffee. Once a week, sit down for 15 minutes, enter your totals, and move on.</p>
						<p class="article-date"><FormattedDate date={new Date('2026-06-16')} /></p>
					</a>
				</li>
			</ul>
		</section>

		<!-- ============ CARDS: EDITORIAL (HOMEPAGE) ============ -->
		<section class="guide-section">
			<h2 class="section-title">Article Card — Editorial</h2>
			<p class="section-desc">Used on the homepage. Thumbnail image on top with text below — no containing card or border. Uses the <code>cardImage</code> SVG.</p>
			<div class="card-demo-grid card-demo-3col">
				{sampleArticles.map((article) => (
					<a href={`/articles/${article.id}/`} class="editorial-card">
						{(article.data.cardImage || article.data.image) && (
							<div class="editorial-card-thumb">
								<img src={article.data.cardImage ?? article.data.image} alt={article.data.title} width="960" height="540" loading="lazy" />
							</div>
						)}
						{(article.data.tags ?? []).length > 0 && (
							<div class="demo-card-tags">
								{(article.data.tags ?? []).map((tag: string) => (
									<span class="demo-card-tag">{TAG_MAP[tag] ?? tag}</span>
								))}
							</div>
						)}
						<h3 class="editorial-card-title">{article.data.title}</h3>
						<p class="editorial-card-desc">{article.data.description}</p>
						<p class="editorial-card-meta">
							<FormattedDate date={article.data.pubDate} />
							<span>&middot;</span>
							<span>{article.readTime} min read</span>
						</p>
					</a>
				))}
			</div>
		</section>

		<!-- ============ CARDS: CONTAINED (ARTICLES INDEX) ============ -->
		<section class="guide-section">
			<h2 class="section-title">Article Card — Contained</h2>
			<p class="section-desc">Used on the articles index page. Thumbnail + text inside a bordered card with subtle hover shadow. Uses <code>cardImage</code> SVG.</p>
			<div class="card-demo-grid card-demo-3col">
				{sampleArticles.map((article) => (
					<a href={`/articles/${article.id}/`} class="contained-card">
						{(article.data.cardImage || article.data.image) && (
							<div class="contained-card-thumb">
								<img src={article.data.cardImage ?? article.data.image} alt={article.data.title} width="960" height="540" loading="lazy" />
							</div>
						)}
						<div class="contained-card-body">
							{(article.data.tags ?? []).length > 0 && (
								<div class="demo-card-tags">
									{(article.data.tags ?? []).map((tag: string) => (
										<span class="demo-card-tag">{TAG_MAP[tag] ?? tag}</span>
									))}
								</div>
							)}
							<h3 class="contained-card-title">{article.data.title}</h3>
							<p class="contained-card-desc">{article.data.description}</p>
							<p class="contained-card-meta">
								<FormattedDate date={article.data.pubDate} />
								<span>&middot;</span>
								<span>{article.readTime} min read</span>
							</p>
						</div>
					</a>
				))}
			</div>
		</section>

		<!-- ============ CARDS: GRADIENT OVERLAY (LEGACY) ============ -->
		<section class="guide-section">
			<h2 class="section-title">Article Card — Gradient Overlay</h2>
			<p class="section-desc">Hero gradient as full-bleed background with a centered white text overlay. Uses the abstract <code>image</code> SVG. Previously used on the homepage; available for carousels and related content sections.</p>
			<div class="card-demo-grid card-demo-3col">
				{sampleArticles.map((article) => (
					<a href={`/articles/${article.id}/`} class="gradient-card">
						{article.data.image && (
							<div class="gradient-card-thumb">
								<img src={article.data.image} alt={article.data.title} width="960" height="540" loading="lazy" />
							</div>
						)}
						<div class="gradient-card-body">
							<h3 class="gradient-card-title">{article.data.title}</h3>
							<p class="gradient-card-desc">{article.data.description}</p>
							<p class="gradient-card-meta">
								<FormattedDate date={article.data.pubDate} />
								<span>&middot;</span>
								<span>5 min read</span>
							</p>
						</div>
					</a>
				))}
			</div>
		</section>

		<!-- ============ CARDS: GLASS OVERLAY ============ -->
		<section class="guide-section">
			<h2 class="section-title">Article Card — Glass Overlay</h2>
			<p class="section-desc">Gradient background with a frosted-glass white panel (slight blue tint, 96% opacity). Masonry-style grid with varied card heights. Read time badge at top, bold title, description, and metadata.</p>
			<div class="glass-grid">
				{masonryArticles.map((article, i) => (
					<a href={`/articles/${article.id}/`} class={`glass-card ${i === 1 || i === 4 ? 'glass-card-tall' : ''}`}>
						{article.data.image && (
							<div class="glass-card-bg">
								<img src={article.data.image} alt="" width="960" height="540" loading="lazy" />
							</div>
						)}
						<div class="glass-card-panel">
							<span class="glass-card-read">{article.readTime} min read</span>
							<h3 class="glass-card-title">{article.data.title}</h3>
							<p class="glass-card-desc">{article.data.description}</p>
							<div class="glass-card-footer">
								<FormattedDate date={article.data.pubDate} />
							</div>
						</div>
					</a>
				))}
			</div>
		</section>

		<!-- ============ CARDS: GLASS OVERLAY v2 ============ -->
		<section class="guide-section">
			<h2 class="section-title">Article Card — Glass Overlay v2</h2>
			<p class="section-desc">Each card gets a unique multi-stop gradient background derived from the article's accent color palette, with the hero SVG layered on top at low opacity for texture. More visual variety than the uniform SVG-only approach.</p>
			<div class="glass2-grid">
				{masonryArticles.map((article) => {
					const palette = ARTICLE_COLORS[article.id] ?? { bg: '#E8EAF6', accent: '#5C6BC0', accent2: '#9FA8DA' };
					return (
						<a href={`/articles/${article.id}/`} class="glass2-card">
							<div class="glass2-card-bg" style={`background: linear-gradient(135deg, ${palette.bg} 0%, ${palette.accent2 ?? palette.bg} 40%, ${palette.accent} 100%);`}>
								{article.data.image && (
									<img src={article.data.image} alt="" width="960" height="540" loading="lazy" />
								)}
							</div>
							<div class="glass2-card-panel">
								<span class="glass2-card-read">{article.readTime} min read</span>
								<h3 class="glass2-card-title">{article.data.title}</h3>
								<p class="glass2-card-desc">{article.data.description}</p>
								<div class="glass2-card-footer">
									<FormattedDate date={article.data.pubDate} />
								</div>
							</div>
						</a>
					);
				})}
			</div>
		</section>

		<!-- ============ CARDS: PRODUCT / TEMPLATE ============ -->
		<section class="guide-section">
			<h2 class="section-title">Product Card — Template</h2>
			<p class="section-desc">Used for spreadsheet templates on the homepage and article pages. Bordered card with optional badge.</p>
			<div class="card-demo-grid card-demo-2col">
				{templates.map((t) => (
					<a href={t.url} class="template-demo-card">
						<div class="template-demo-thumb">
							{t.image && <img src={t.image} alt={`${t.name} preview`} width="600" height="400" loading="lazy" />}
						</div>
						{t.badge && <span class="template-demo-badge">{t.badge}</span>}
						<h3 class="template-demo-name">{t.name}</h3>
						<p class="template-demo-desc">{t.desc}</p>
					</a>
				))}
			</div>
		</section>

		<!-- ============ CARDS: FEATURED ARTICLE ============ -->
		<section class="guide-section">
			<h2 class="section-title">Featured Article Card</h2>
			<p class="section-desc">Used in the homepage hero. Large thumbnail with "Featured Article" label, title, and metadata.</p>
			<div style="max-width: 32rem;">
				{sampleArticles[0] && (
					<a href={`/articles/${sampleArticles[0].id}/`} class="featured-demo">
						{(sampleArticles[0].data.cardImage || sampleArticles[0].data.image) && (
							<div class="featured-demo-thumb">
								<img src={sampleArticles[0].data.cardImage ?? sampleArticles[0].data.image} alt={sampleArticles[0].data.title} width="960" height="540" loading="lazy" />
							</div>
						)}
						<span class="featured-demo-label">Featured Article</span>
						<h2 class="featured-demo-title">{sampleArticles[0].data.title}</h2>
						<p class="featured-demo-meta">
							<FormattedDate date={sampleArticles[0].data.pubDate} />
							<span>&middot;</span>
							<span>{sampleArticles[0].readTime} min read</span>
						</p>
					</a>
				)}
			</div>
		</section>

		<!-- ============ BUTTONS ============ -->
		<section class="guide-section">
			<h2 class="section-title">Buttons</h2>
			<p class="section-desc">Pill-shaped buttons with three variants. Used for CTAs and actions.</p>
			<div class="button-row">
				<button class="btn btn-primary">Primary button</button>
				<button class="btn btn-secondary">Secondary button</button>
				<button class="btn btn-ghost">Ghost button</button>
			</div>
			<div class="button-row" style="margin-top: var(--space-sm)">
				<button class="btn btn-primary btn-sm">Small primary</button>
				<button class="btn btn-secondary btn-sm">Small secondary</button>
				<button class="btn btn-ghost btn-sm">Small ghost</button>
			</div>
		</section>

		<!-- ============ PROSE ============ -->
		<section class="guide-section">
			<h2 class="section-title">Prose / Article Body</h2>
			<p class="section-desc">How long-form article content renders. Applied via the <code>.prose</code> class.</p>

			<div class="prose">
				<h2>How do you budget when your income changes every month</h2>
				<p>Start with your baseline — the lowest amount you've earned in the past six months. Build your budget around that number, not your average and definitely not your best month.</p>
				<h3>List your non-negotiable expenses first</h3>
				<p>Rent, utilities, groceries, insurance, minimum debt payments. These get funded before anything else. Write them down with <strong>real numbers</strong> from last month, not estimates.</p>
				<blockquote>The point isn't to predict your income. It's to stop pretending it's predictable and plan around that reality instead.</blockquote>
				<ul>
					<li>An unordered list item</li>
					<li>Another list item with enough text to wrap onto a second line so you can check the spacing</li>
					<li>A third item</li>
				</ul>
				<p>A paragraph with <code>inline code</code> and an <a href="#">inline link</a> styled naturally within the reading flow.</p>
			</div>
		</section>

		<!-- ============ BORDER RADII ============ -->
		<section class="guide-section">
			<h2 class="section-title">Border Radii</h2>
			<div class="radii-row">
				<div class="radius-demo" style="border-radius: var(--radius-sm)">
					<code>--radius-sm</code>
					<span>4px</span>
				</div>
				<div class="radius-demo" style="border-radius: var(--radius-md)">
					<code>--radius-md</code>
					<span>8px</span>
				</div>
				<div class="radius-demo" style="border-radius: var(--radius-full)">
					<code>--radius-full</code>
					<span>99px</span>
				</div>
			</div>
		</section>

		<!-- ============ DIVIDERS ============ -->
		<section class="guide-section">
			<h2 class="section-title">Dividers</h2>
			<p class="section-desc">Thin 1px lines separate content sections instead of alternating background colors.</p>
			<div class="divider-demo">
				<div class="divider-sample">
					<p>Content above divider</p>
					<hr />
					<p>Content below divider</p>
				</div>
			</div>
		</section>

		<!-- ============ NAVIGATION ============ -->
		<section class="guide-section">
			<h2 class="section-title">Navigation</h2>
			<p class="section-desc">Hamburger menu with a slide-out panel from the right. Site title on the left, menu icon on the right.</p>
		</section>

		<!-- ============ FOOTER ============ -->
		<section class="guide-section">
			<h2 class="section-title">Footer</h2>
			<p class="section-desc">Minimal footer with a top divider line and muted copyright text.</p>
		</section>

	</div>
</BaseLayout>

<style>
	/* ——— Guide layout ——— */

	.guide {
		max-width: var(--max-width);
		margin: 0 auto;
	}

	.guide-header {
		padding: var(--space-xl) var(--space-md) var(--space-lg);
	}

	.guide-header h1 {
		font-size: var(--text-h1);
		margin-bottom: var(--space-xs);
	}

	.guide-intro {
		font-size: var(--text-body);
		color: var(--color-text-secondary);
		max-width: 50ch;
	}

	.guide-section {
		padding: var(--space-xl) var(--space-md) var(--space-md);
		border-top: 1px solid var(--color-border);
	}

	.section-title {
		font-size: var(--text-h2);
		font-weight: var(--weight-semibold);
		margin-bottom: var(--space-2xs);
	}

	.section-desc {
		color: var(--color-text-secondary);
		margin-bottom: var(--space-md);
		max-width: 60ch;
	}

	.section-desc code {
		padding: 2px 6px;
		background: var(--color-bg-panel);
		border-radius: var(--radius-sm);
		font-size: 0.9em;
	}

	/* ——— Colors ——— */

	.color-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(9rem, 1fr));
