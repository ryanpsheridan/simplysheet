---
import BaseLayout from '../layouts/BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE } from '../consts';

const colors = [
	{ token: '--color-text',           label: 'Text',           hex: '#2A2522' },
	{ token: '--color-text-secondary', label: 'Text Secondary', hex: '#6E6560' },
	{ token: '--color-text-muted',     label: 'Text Muted',     hex: '#8A817C' },
	{ token: '--color-accent',         label: 'Accent',         hex: '#196EDD' },
	{ token: '--color-accent-hover',   label: 'Accent Hover',   hex: '#1259B8' },
	{ token: '--color-accent-light',   label: 'Accent Light',   hex: '#EEF4FF' },
	{ token: '--color-btn',            label: 'Button',         hex: '#000000' },
	{ token: '--color-btn-hover',      label: 'Button Hover',   hex: '#333333' },
	{ token: '--color-bg',             label: 'Background',     hex: '#F7F6F4' },
	{ token: '--color-bg-surface',     label: 'Surface',        hex: '#FFFFFF' },
	{ token: '--color-bg-panel',       label: 'Panel',          hex: '#F2F2F2' },
	{ token: '--color-bg-emphasis',    label: 'Emphasis',       hex: '#EDEAE7' },
	{ token: '--color-bg-inverse',     label: 'Inverse',        hex: '#2A2522' },
	{ token: '--color-border',         label: 'Border',         hex: '#E8E4E0' },
	{ token: '--color-divider',        label: 'Divider',        hex: '#D9D4CF' },
];

const typeScale = [
	{ token: '--text-display', label: 'Display',  sample: 'Practical budgeting help' },
	{ token: '--text-h1',      label: 'H1',       sample: 'Page heading' },
	{ token: '--text-h2',      label: 'H2',       sample: 'Section heading' },
	{ token: '--text-h3',      label: 'H3',       sample: 'Subsection heading' },
	{ token: '--text-body-lg', label: 'Body Lg',  sample: 'Introductory paragraph text at a comfortable reading size.' },
	{ token: '--text-body',    label: 'Body',     sample: 'Standard paragraph text for articles and general content.' },
	{ token: '--text-small',   label: 'Small',    sample: 'Captions, labels, metadata' },
	{ token: '--text-xs',      label: 'XS',       sample: 'Fine print, timestamps' },
];

const spacingScale = [
	{ token: '--space-2xs', label: '2xs', px: '4' },
	{ token: '--space-xs',  label: 'xs',  px: '8' },
	{ token: '--space-sm',  label: 'sm',  px: '16' },
	{ token: '--space-md',  label: 'md',  px: '24' },
	{ token: '--space-lg',  label: 'lg',  px: '40' },
	{ token: '--space-xl',  label: 'xl',  px: '64' },
	{ token: '--space-2xl', label: '2xl', px: '96' },
];
---

<BaseLayout title={`Style Guide — ${SITE_TITLE}`} description="Living reference for Simply Sheet Design components, tokens, and patterns.">
	<div class="guide">

		<header class="guide-header">
			<h1>Style Guide</h1>
			<p class="guide-intro">Living reference for every component, token, and pattern in the design system.</p>
		</header>

		<!-- ============ COLORS ============ -->
		<section class="guide-section">
			<h2 class="section-title">Colors</h2>
			<div class="color-grid">
				{colors.map((c) => (
					<div class="color-card">
						<div class="color-swatch" style={`background-color: var(${c.token})`} />
						<div class="color-info">
							<span class="color-label">{c.label}</span>
							<code class="color-token">{c.token}</code>
							<span class="color-hex">{c.hex}</span>
						</div>
					</div>
				))}
			</div>
		</section>

		<!-- ============ TYPE SCALE ============ -->
		<section class="guide-section">
			<h2 class="section-title">Type Scale</h2>
			<div class="type-list">
				{typeScale.map((t) => (
					<div class="type-row">
						<div class="type-meta">
							<span class="type-label">{t.label}</span>
							<code class="type-token">{t.token}</code>
						</div>
						<div class="type-sample" style={`font-size: var(${t.token})`}>
							{t.sample}
						</div>
					</div>
				))}
			</div>
		</section>

		<!-- ============ FONT WEIGHTS ============ -->
		<section class="guide-section">
			<h2 class="section-title">Font Weights</h2>
			<div class="weight-list">
				<p style="font-weight: var(--weight-normal)">400 Normal — The quick brown fox jumps over the lazy dog</p>
				<p style="font-weight: var(--weight-medium)">500 Medium — The quick brown fox jumps over the lazy dog</p>
				<p style="font-weight: var(--weight-semibold)">600 Semibold — The quick brown fox jumps over the lazy dog</p>
				<p style="font-weight: var(--weight-bold)">700 Bold — The quick brown fox jumps over the lazy dog</p>
			</div>
		</section>

		<!-- ============ SPACING ============ -->
		<section class="guide-section">
			<h2 class="section-title">Spacing Scale</h2>
			<div class="spacing-list">
				{spacingScale.map((s) => (
					<div class="spacing-row">
						<code class="spacing-token">{s.token}</code>
						<span class="spacing-px">{s.px}px</span>
						<div class="spacing-bar" style={`width: var(${s.token})`} />
					</div>
				))}
			</div>
		</section>

		<!-- ============ HEADLINE TREATMENTS ============ -->
		<section class="guide-section">
			<h2 class="section-title">Headline Treatments</h2>
			<p class="section-desc">Hero headlines use the display size. Section headings use H2.</p>

			<div class="headline-demo">
				<h1 class="demo-display">Practical budgeting help for people who use <span class="accent">Google Sheets and Excel</span></h1>
			</div>

			<div class="headline-demo">
				<h2 class="demo-h2">How do you budget when your <span class="accent">income changes every month</span></h2>
			</div>
		</section>

		<!-- ============ ARTICLE LIST ============ -->
		<section class="guide-section">
			<h2 class="section-title">Article List</h2>
			<p class="section-desc">Articles are displayed as a clean list with thin dividers between items.</p>

			<ul class="article-list">
				<li>
					<a href="#" class="article-card">
						<h3 class="article-title">How to budget when your income changes every month</h3>
						<p class="article-desc">A straightforward approach to budgeting on irregular income — freelancers, gig workers, commission earners.</p>
						<p class="article-date"><FormattedDate date={new Date('2026-06-23')} /></p>
					</a>
				</li>
				<li>
					<a href="#" class="article-card">
						<h3 class="article-title">The 15-minute weekly budget check-in</h3>
						<p class="article-desc">You don't need to track every coffee. Once a week, sit down for 15 minutes, enter your totals, and move on.</p>
						<p class="article-date"><FormattedDate date={new Date('2026-06-16')} /></p>
					</a>
				</li>
			</ul>
		</section>

		<!-- ============ BUTTONS ============ -->
		<section class="guide-section">
			<h2 class="section-title">Buttons</h2>
			<p class="section-desc">Pill-shaped buttons with three variants. Used for CTAs and actions.</p>
			<div class="button-row">
				<button class="btn btn-primary">Primary button</button>
				<button class="btn btn-secondary">Secondary button</button>
				<button class="btn btn-ghost">Ghost button</button>
			</div>
			<div class="button-row" style="margin-top: var(--space-sm)">
				<button class="btn btn-primary btn-sm">Small primary</button>
				<button class="btn btn-secondary btn-sm">Small secondary</button>
				<button class="btn btn-ghost btn-sm">Small ghost</button>
			</div>
		</section>

		<!-- ============ PROSE ============ -->
		<section class="guide-section">
			<h2 class="section-title">Prose / Article Body</h2>
			<p class="section-desc">How long-form article content renders. Applied via the <code>.prose</code> class.</p>

			<div class="prose">
				<h2>How do you budget when your income changes every month</h2>
				<p>Start with your baseline — the lowest amount you've earned in the past six months. Build your budget around that number, not your average and definitely not your best month.</p>
				<h3>List your non-negotiable expenses first</h3>
				<p>Rent, utilities, groceries, insurance, minimum debt payments. These get funded before anything else. Write them down with <strong>real numbers</strong> from last month, not estimates.</p>
				<blockquote>The point isn't to predict your income. It's to stop pretending it's predictable and plan around that reality instead.</blockquote>
				<ul>
					<li>An unordered list item</li>
					<li>Another list item with enough text to wrap onto a second line so you can check the spacing</li>
					<li>A third item</li>
				</ul>
				<p>A paragraph with <code>inline code</code> and an <a href="#">inline link</a> styled naturally within the reading flow.</p>
			</div>
		</section>

		<!-- ============ BORDER RADII ============ -->
		<section class="guide-section">
			<h2 class="section-title">Border Radii</h2>
			<div class="radii-row">
				<div class="radius-demo" style="border-radius: var(--radius-sm)">
					<code>--radius-sm</code>
					<span>4px</span>
				</div>
				<div class="radius-demo" style="border-radius: var(--radius-md)">
					<code>--radius-md</code>
					<span>8px</span>
				</div>
				<div class="radius-demo" style="border-radius: var(--radius-full)">
					<code>--radius-full</code>
					<span>99px</span>
				</div>
			</div>
		</section>

		<!-- ============ DIVIDERS ============ -->
		<section class="guide-section">
			<h2 class="section-title">Dividers</h2>
			<p class="section-desc">Thin 1px lines separate content sections instead of alternating background colors.</p>
			<div class="divider-demo">
				<div class="divider-sample">
					<p>Content above divider</p>
					<hr />
					<p>Content below divider</p>
				</div>
			</div>
		</section>

		<!-- ============ NAVIGATION ============ -->
		<section class="guide-section">
			<h2 class="section-title">Navigation</h2>
			<p class="section-desc">Hamburger menu with a slide-out panel from the right. Site title on the left, menu icon on the right.</p>
		</section>

		<!-- ============ FOOTER ============ -->
		<section class="guide-section">
			<h2 class="section-title">Footer</h2>
			<p class="section-desc">Minimal footer with a top divider line and muted copyright text.</p>
		</section>

	</div>
</BaseLayout>

<style>
	/* ——— Guide layout ——— */

	.guide {
		max-width: var(--max-width);
		margin: 0 auto;
	}

	.guide-header {
		padding: var(--space-xl) var(--space-md) var(--space-lg);
	}

	.guide-header h1 {
		font-size: var(--text-h1);
		margin-bottom: var(--space-xs);
	}

	.guide-intro {
		font-size: var(--text-body);
		color: var(--color-text-secondary);
		max-width: 50ch;
	}

	.guide-section {
		padding: var(--space-xl) var(--space-md) var(--space-md);
		border-top: 1px solid var(--color-border);
	}

	.section-title {
		font-size: var(--text-h2);
		font-weight: var(--weight-semibold);
		margin-bottom: var(--space-2xs);
	}

	.section-desc {
		color: var(--color-text-secondary);
		margin-bottom: var(--space-md);
		max-width: 60ch;
	}

	.section-desc code {
		padding: 2px 6px;
		background: var(--color-bg-panel);
		border-radius: var(--radius-sm);
		font-size: 0.9em;
	}

	/* ——— Colors ——— */

	.color-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(9rem, 1fr));
		gap: var(--space-sm);
	}

	.color-card {
		border: 1px solid var(--color-divider);
		border-radius: var(--radius-md);
		overflow: hidden;
	}

	.color-swatch {
		height: 4.5rem;
	}

	.color-info {
		padding: var(--space-xs);
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.color-label {
		font-size: var(--text-small);
		font-weight: var(--weight-semibold);
	}

	.color-token {
		font-size: 0.7rem;
		color: var(--color-text-muted);
		background: none;
		padding: 0;
	}

	.color-hex {
		font-size: 0.75rem;
		color: var(--color-text-muted);
		font-family: monospace;
	}

	/* ——— Type scale ——— */

	.type-list {
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
	}

	.type-row {
		border-bottom: 1px solid var(--color-border);
		padding-bottom: var(--space-md);
	}

	.type-row:last-child {
		border-bottom: none;
	}

	.type-meta {
		display: flex;
		align-items: baseline;
		gap: var(--space-sm);
		margin-bottom: var(--space-xs);
	}

	.type-label {
		font-size: var(--text-small);
		font-weight: var(--weight-semibold);
		color: var(--color-text-secondary);
		min-width: 5rem;
	}

	.type-token {
		font-size: 0.75rem;
		color: var(--color-text-muted);
		background: none;
		padding: 0;
	}

	.type-sample {
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-tight);
		font-weight: var(--weight-semibold);
		color: var(--color-text);
	}

	/* ——— Font weights ——— */

	.weight-list {
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
	}

	.weight-list p {
		font-size: var(--text-body-lg);
		margin-bottom: 0;
	}

	/* ——— Spacing ——— */

	.spacing-list {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
	}

	.spacing-row {
		display: flex;
		align-items: center;
		gap: var(--space-sm);
	}

	.spacing-token {
		font-size: 0.75rem;
		color: var(--color-text-muted);
		min-width: 8rem;
		text-align: right;
		background: none;
		padding: 0;
	}

	.spacing-px {
		font-size: var(--text-small);
		color: var(--color-text-secondary);
		min-width: 3rem;
	}

	.spacing-bar {
		height: 0.75rem;
		background: var(--color-accent);
		border-radius: var(--radius-sm);
		opacity: 0.7;
	}

	/* ——— Headline treatments ——— */

	.headline-demo {
		padding: var(--space-lg) 0;
		border-bottom: 1px solid var(--color-border);
	}

	.headline-demo:last-child {
		border-bottom: none;
	}

	.demo-display {
		font-size: var(--text-display);
		font-weight: var(--weight-bold);
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
	}

	.demo-h2 {
		font-size: var(--text-h2);
		font-weight: var(--weight-semibold);
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
	}

	.accent {
		color: var(--color-accent);
	}

	/* ——— Article list ——— */

	.article-list {
		list-style: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		max-width: var(--max-width);
	}

	.article-list li {
		border-bottom: 1px solid var(--color-border);
	}

	.article-list li:last-child {
		border-bottom: none;
	}

	.article-card {
		display: block;
		padding: var(--space-md) 0;
		text-decoration: none;
		transition: opacity 0.15s;
	}

	.article-card:hover {
		opacity: 0.7;
	}

	.article-title {
		font-size: var(--text-h3);
		font-weight: var(--weight-semibold);
		color: var(--color-text);
		margin-bottom: var(--space-2xs);
	}

	.article-desc {
		font-size: var(--text-small);
		color: var(--color-text-secondary);
		margin-bottom: var(--space-xs);
		line-height: var(--leading-snug);
	}

	.article-date {
		font-size: var(--text-small);
		color: var(--color-text-muted);
		margin: 0;
	}

	/* ——— Divider demo ——— */

	.divider-demo {
		max-width: var(--max-width-narrow);
	}

	.divider-sample p {
		padding: var(--space-sm) 0;
		color: var(--color-text-secondary);
		margin: 0;
	}

	/* ——— Prose section ——— */

	.guide-section .prose {
		max-width: var(--max-width-narrow);
		padding: var(--space-md);
		background: var(--color-bg-panel);
		border-radius: var(--radius-md);
	}

	/* ——— Border radii ——— */

	.radii-row {
		display: flex;
		gap: var(--space-lg);
		flex-wrap: wrap;
	}

	.radius-demo {
		width: 10rem;
		height: 7rem;
		border: 1px solid var(--color-divider);
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: var(--space-2xs);
	}

	.radius-demo code {
		font-size: 0.75rem;
		color: var(--color-text-secondary);
		background: none;
		padding: 0;
	}

	.radius-demo span {
		font-size: var(--text-small);
		color: var(--color-text-muted);
	}

	/* ——— Buttons ——— */

	.button-row {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-sm);
		align-items: center;
	}

	/* ——— Responsive ——— */

	@media (max-width: 640px) {
		.color-grid {
			grid-template-columns: repeat(auto-fill, minmax(7rem, 1fr));
		}
	}
</style>
